---
import Layout from "../layouts/Layout.astro";
import { styles, categories } from "../data/styles";
---

<Layout>
  <!-- Password Gate -->
  <div id="password-gate" class="fixed inset-0 z-50 flex items-center justify-center bg-bg">
    <div class="w-full max-w-sm px-6">
      <div class="text-center mb-8">
        <h1 class="font-display text-3xl font-bold tracking-tight mb-2">Style Library</h1>
        <p class="text-text-muted text-sm">PortaWerk — Interner Zugang</p>
      </div>
      <form id="password-form" class="space-y-4">
        <input
          type="password"
          id="password-input"
          placeholder="Passwort eingeben"
          autocomplete="off"
          class="w-full bg-surface border border-border rounded-lg px-4 py-3 text-sm text-text placeholder:text-text-muted/50 outline-none focus:border-accent transition-colors"
        />
        <button
          type="submit"
          class="w-full bg-accent hover:bg-accent-light text-white font-medium rounded-lg px-4 py-3 text-sm transition-colors cursor-pointer"
        >
          Zugang
        </button>
        <p id="password-error" class="text-red-500 text-xs text-center hidden">Falsches Passwort.</p>
      </form>
    </div>
  </div>

  <!-- Main App -->
  <div id="app" class="hidden min-h-screen">
    <!-- Sidebar -->
    <aside id="sidebar" class="sidebar fixed left-0 top-0 bottom-0 z-40 overflow-x-hidden flex flex-col">
      <!-- Logo area -->
      <div class="sidebar-brand">
        <div class="sidebar-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </div>
        <div class="sidebar-brand-text">
          <span class="sidebar-title">Style Library</span>
          <span class="sidebar-sub">PortaWerk</span>
        </div>
      </div>

      <!-- Filter nav -->
      <nav class="sidebar-nav">
        <div class="sidebar-nav-label">Kategorien</div>
        <button
          class="filter-btn active"
          data-category="all"
        >
          <span class="filter-label">Alle</span>
          <span class="filter-count">{styles.length}</span>
        </button>
        {categories.map((cat) => {
          const count = styles.filter((s) => s.category === cat).length;
          return (
            <button
              class="filter-btn"
              data-category={cat}
            >
              <span class="filter-label">{cat}</span>
              <span class="filter-count">{count}</span>
            </button>
          );
        })}
      </nav>

      <!-- Bottom -->
      <div class="sidebar-footer">
        <div class="sidebar-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </div>
        <span class="sidebar-footer-text">v1.0</span>
      </div>
    </aside>

    <!-- Content -->
    <main class="main-content">
      <div class="main-inner">
        <header class="page-header">
          <div class="page-header-line"></div>
          <h2 id="category-title" class="page-header-title">Alle Stile</h2>
          <p id="category-count" class="page-header-count">{styles.length} Stile</p>
        </header>

        <!-- Grid -->
        <div id="styles-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-x-8 gap-y-12">
        {styles.map((style) => (
          <div
            class="style-card group cursor-pointer"
            data-category={style.category}
            data-slug={style.slug}
            data-ready={style.ready ? "true" : "false"}
            data-bg={style.colors.background}
            data-primary={style.colors.primary}
            data-secondary={style.colors.secondary}
            data-accent={style.colors.accent}
            data-text={style.colors.text}
            data-name={style.business.name}
            data-tagline={style.business.tagline}
          >
            <!-- Color Placeholder (no iframe, no network) -->
            <div class="card-preview relative aspect-[16/10] rounded-xl overflow-hidden border border-border mb-3 transition-all duration-300 group-hover:border-accent/40 group-hover:shadow-[0_8px_40px_rgba(14,77,82,0.1)]"
              style={`background: ${style.colors.background};`}
            >
              <!-- Top accent bar -->
              <div class="absolute top-0 left-0 right-0 h-1.5" style={`background: ${style.colors.primary};`}></div>

              <!-- Fake nav dots -->
              <div class="absolute top-3.5 left-4 flex gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full" style={`background: ${style.colors.primary}; opacity: 0.3;`}></span>
                <span class="w-1.5 h-1.5 rounded-full" style={`background: ${style.colors.primary}; opacity: 0.3;`}></span>
                <span class="w-1.5 h-1.5 rounded-full" style={`background: ${style.colors.primary}; opacity: 0.3;`}></span>
              </div>

              <!-- Business info centered -->
              <div class="absolute inset-0 flex flex-col items-center justify-center px-6 text-center">
                <div class="text-[11px] font-semibold tracking-[0.2em] uppercase mb-2 opacity-50" style={`color: ${style.colors.text};`}>
                  {style.business.type}
                </div>
                <div class="text-2xl font-bold leading-tight mb-1.5" style={`color: ${style.colors.primary};`}>
                  {style.business.name}
                </div>
                <div class="text-[11px] opacity-60 max-w-[160px] leading-relaxed" style={`color: ${style.colors.text};`}>
                  {style.business.tagline}
                </div>
              </div>

              <!-- Color palette dots bottom -->
              <div class="absolute bottom-3 left-0 right-0 flex justify-center gap-1.5">
                <span class="w-3 h-3 rounded-full border border-black/10" style={`background: ${style.colors.primary};`}></span>
                <span class="w-3 h-3 rounded-full border border-black/10" style={`background: ${style.colors.secondary};`}></span>
                <span class="w-3 h-3 rounded-full border border-black/10" style={`background: ${style.colors.accent};`}></span>
                <span class="w-3 h-3 rounded-full border border-black/10" style={`background: ${style.colors.text};`}></span>
              </div>

              <!-- Hover overlay: "Ansehen" -->
              {style.ready && (
                <div class="card-hover-overlay absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                  <div class="flex items-center gap-2 px-4 py-2 rounded-full text-xs font-semibold backdrop-blur-sm bg-black/30 text-white">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
                    Ansehen
                  </div>
                </div>
              )}

              {!style.ready && (
                <div class="absolute bottom-8 left-0 right-0 flex justify-center">
                  <span class="px-2 py-0.5 rounded text-[9px] font-medium bg-black/10" style={`color: ${style.colors.text}; opacity: 0.5;`}>Coming Soon</span>
                </div>
              )}
            </div>

            <!-- Meta -->
            <div class="card-meta">
              <div class="card-row">
                <h3 class="card-title">{style.name}</h3>
                <span class="card-category">{style.category}</span>
              </div>
            </div>
          </div>
        ))}
        </div>
      </div>
    </main>
  </div>

  <!-- Modal -->
  <div id="style-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" id="modal-backdrop"></div>
    <div class="absolute inset-4 md:inset-8 lg:inset-12 bg-surface rounded-2xl overflow-hidden border border-border flex flex-col">
      <div class="flex items-center justify-between px-6 py-4 border-b border-border shrink-0">
        <h3 id="modal-title" class="font-display font-bold"></h3>
        <button id="modal-close" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-surface-hover transition-colors cursor-pointer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div id="modal-content" class="flex-1 overflow-y-auto">
        <div class="flex items-center justify-center h-full text-text-muted text-sm">
          Stil-Preview kommt bald...
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const PASSWORD = 'portawerk2026';
    const STORAGE_KEY = 'pw-styles-auth';

    // Check auth
    if (sessionStorage.getItem(STORAGE_KEY) === 'true') {
      document.getElementById('password-gate').style.display = 'none';
      document.getElementById('app').classList.remove('hidden');
    }

    // Password form
    document.getElementById('password-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = document.getElementById('password-input');
      const errorEl = document.getElementById('password-error');
      if (input.value === PASSWORD) {
        sessionStorage.setItem(STORAGE_KEY, 'true');
        document.getElementById('password-gate').style.display = 'none';
        document.getElementById('app').classList.remove('hidden');
      } else {
        errorEl.classList.remove('hidden');
        input.value = '';
        input.focus();
      }
    });

    // Filter
    let activeCategory = 'all';
    document.querySelectorAll('.filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = btn.dataset.category;

        const title = document.getElementById('category-title');
        const count = document.getElementById('category-count');
        const cards = document.querySelectorAll('.style-card');
        let visible = 0;

        cards.forEach((card) => {
          if (activeCategory === 'all' || card.dataset.category === activeCategory) {
            card.style.display = '';
            visible++;
          } else {
            card.style.display = 'none';
          }
        });

        title.textContent = activeCategory === 'all' ? 'Alle Stile' : activeCategory;
        count.textContent = visible + (visible === 1 ? ' Stil' : ' Stile');
      });
    });

    // Modal + Hover Preload
    const modal = document.getElementById('style-modal');
    const modalTitle = document.getElementById('modal-title');
    const modalContent = document.getElementById('modal-content');

    // Hidden container — iframes preload silently here
    const preloadContainer = document.createElement('div');
    preloadContainer.style.cssText = 'position:fixed;top:-9999px;left:-9999px;width:1px;height:1px;visibility:hidden;pointer-events:none;';
    document.body.appendChild(preloadContainer);

    const preloadCache = {}; // slug → iframe

    function preloadStyle(slug) {
      if (preloadCache[slug]) return;
      const iframe = document.createElement('iframe');
      iframe.src = '/styles/' + slug;
      iframe.tabIndex = -1;
      preloadContainer.appendChild(iframe);
      preloadCache[slug] = iframe;
    }

    document.querySelectorAll('.style-card').forEach((card) => {
      const slug = card.dataset.slug;
      if (card.dataset.ready !== 'true') return;

      // Hover → preload in background
      card.addEventListener('mouseenter', () => preloadStyle(slug));

      // Click → open modal, reuse preloaded iframe if available
      card.addEventListener('click', () => {
        modalTitle.textContent = card.querySelector('h3').textContent;
        while (modalContent.firstChild) modalContent.removeChild(modalContent.firstChild);

        let iframe;
        if (preloadCache[slug]) {
          iframe = preloadCache[slug];
          delete preloadCache[slug];
        } else {
          iframe = document.createElement('iframe');
          iframe.src = '/styles/' + slug;
        }
        iframe.style.cssText = 'width:100%;height:100%;border:none;display:block;';
        modalContent.appendChild(iframe);

        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });
    });

    document.getElementById('modal-close')?.addEventListener('click', closeModal);
    document.getElementById('modal-backdrop')?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
      while (modalContent.firstChild) modalContent.removeChild(modalContent.firstChild);
    }
  </script>

  <style>
    /* ═══ SIDEBAR ═══ */
    .sidebar {
      width: 52px;
      background: var(--color-surface);
      border-right: 1px solid var(--color-border);
      transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      overflow-y: auto;
    }
    .sidebar:hover {
      width: 220px;
      box-shadow: 4px 0 24px rgba(0,0,0,0.06);
    }

    /* Brand */
    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1.25rem 0.875rem;
      border-bottom: 1px solid var(--color-border);
      min-height: 56px;
    }

    .sidebar-icon {
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-accent);
    }

    .sidebar-brand-text {
      display: flex;
      flex-direction: column;
      opacity: 0;
      transition: opacity 0.2s ease;
      white-space: nowrap;
    }
    .sidebar:hover .sidebar-brand-text {
      opacity: 1;
      transition: opacity 0.25s ease 0.08s;
    }

    .sidebar-title {
      font-family: var(--font-display);
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--color-text);
      letter-spacing: -0.01em;
    }

    .sidebar-sub {
      font-size: 0.6rem;
      color: var(--color-text-muted);
      margin-top: 1px;
    }

    /* Nav */
    .sidebar-nav {
      flex: 1;
      padding: 0.75rem 0.5rem;
      overflow-y: auto;
    }

    .sidebar-nav-label {
      font-size: 0.55rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-text-muted);
      padding: 0.5rem 0.625rem 0.5rem;
      opacity: 0;
      transition: opacity 0.2s ease;
      white-space: nowrap;
    }
    .sidebar:hover .sidebar-nav-label {
      opacity: 1;
      transition: opacity 0.25s ease 0.08s;
    }

    .filter-btn {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      text-align: left;
      padding: 0.4rem 0.625rem;
      border-radius: 6px;
      font-size: 0.75rem;
      color: var(--color-text-muted);
      cursor: pointer;
      border: none;
      background: none;
      font-family: var(--font-sans);
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
      opacity: 0;
    }
    .sidebar:hover .filter-btn {
      opacity: 1;
      transition: opacity 0.25s ease 0.08s, background 0.15s, color 0.15s;
    }

    .filter-btn:hover {
      background: var(--color-surface-hover);
      color: var(--color-text);
    }
    .filter-btn.active {
      background: var(--color-accent);
      color: white;
    }
    .filter-btn.active .filter-count {
      color: rgba(255,255,255,0.6);
    }

    .filter-label { flex: 1; }

    .filter-count {
      font-size: 0.65rem;
      color: var(--color-border);
      font-variant-numeric: tabular-nums;
    }

    /* Footer */
    .sidebar-footer {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.75rem 0.875rem;
      border-top: 1px solid var(--color-border);
      min-height: 44px;
    }

    .sidebar-footer .sidebar-icon {
      color: var(--color-text-muted);
      width: 28px;
      height: 28px;
    }

    .sidebar-footer-text {
      font-size: 0.6rem;
      color: var(--color-border);
      opacity: 0;
      white-space: nowrap;
      transition: opacity 0.2s ease;
    }
    .sidebar:hover .sidebar-footer-text {
      opacity: 1;
      transition: opacity 0.25s ease 0.08s;
    }

    /* ═══ PAGE HEADER ═══ */
    .page-header {
      margin-bottom: 3.5rem;
      padding-top: 0.5rem;
    }

    .page-header-line {
      width: 2rem;
      height: 2px;
      background: var(--color-accent);
      margin-bottom: 1.25rem;
    }

    .page-header-title {
      font-family: var(--font-display);
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.025em;
      color: var(--color-text);
      line-height: 1.1;
    }

    .page-header-count {
      font-size: 0.75rem;
      color: var(--color-text-muted);
      margin-top: 0.5rem;
      letter-spacing: 0.02em;
    }

    /* ═══ CARDS ═══ */
    .card-meta {
      padding-top: 0.125rem;
    }

    .card-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .card-category {
      flex-shrink: 0;
      font-size: 0.575rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-text-muted);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      padding: 0.15rem 0.5rem;
      border-radius: 3px;
    }

    .card-title {
      font-family: var(--font-display);
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--color-text);
      letter-spacing: -0.01em;
      line-height: 1.2;
    }


    /* ═══ MAIN CONTENT ═══ */
    .main-content {
      margin-left: 52px;
      min-height: 100vh;
      transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .main-inner {
      max-width: 1400px;
      margin: 0 auto;
      padding: 3rem clamp(2rem, 4vw, 4rem) 4rem;
    }
  </style>
</Layout>
