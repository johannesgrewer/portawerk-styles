<script>
  // --- Password Gate ---
  const PW = 'portawerk2026';
  const gate = document.getElementById('pw-gate')!;
  const app = document.getElementById('gal-app')!;
  const pwForm = document.getElementById('pw-form')!;
  const pwInput = document.getElementById('pw-input') as HTMLInputElement;
  const pwError = document.getElementById('pw-error')!;

  function unlock() {
    gate.classList.add('pw-hidden');
    app.style.display = '';
    animateCount();
  }

  // Count-up animation
  function animateCount() {
    const el = document.getElementById('hero-count');
    if (!el) return;
    const target = document.querySelectorAll('.gal-card').length;
    const duration = 1600;
    const start = performance.now();
    function tick(now: number) {
      const t = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - t, 3); // ease-out cubic
      el.textContent = Math.round(eased * target).toString();
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  if (sessionStorage.getItem('gal-unlocked') === '1') unlock();
  if (window.location.hostname === 'localhost') unlock();

  if (new URLSearchParams(window.location.search).get('token') === 'unlocked') {
    sessionStorage.setItem('gal-unlocked', '1');
    unlock();
    history.replaceState(null, '', window.location.pathname);
  }

  pwForm.addEventListener('submit', (e) => {
    e.preventDefault();
    if (pwInput.value === PW) {
      sessionStorage.setItem('gal-unlocked', '1');
      unlock();
    } else {
      pwError.classList.add('visible');
      pwInput.value = '';
      pwInput.focus();
    }
  });

  // --- Tab + Filter Logic ---
  const grid = document.getElementById('grid')!;
  const cards = Array.from(grid.querySelectorAll('.gal-card')) as HTMLElement[];
  const search = document.getElementById('search') as HTMLInputElement;
  const empty = document.getElementById('empty')!;
  const tabs = document.querySelectorAll('.gal-tab');
  const filterPanels = {
    branche: document.getElementById('filter-branche')!,
    stil: document.getElementById('filter-stil')!,
    specials: document.getElementById('filter-specials')!,
  } as Record<string, HTMLElement>;

  let activeTab = 'branche';
  let activeValue = 'all';

  // --- Favorites ---
  const FAV_KEY = 'gal-favs';
  const favs: Set<string> = new Set(JSON.parse(localStorage.getItem(FAV_KEY) || '[]'));

  function saveFavs() {
    localStorage.setItem(FAV_KEY, JSON.stringify([...favs]));
  }

  function applyFavClasses() {
    cards.forEach(card => {
      const slug = card.dataset.slug || '';
      const btn = card.querySelector('.gal-card-fav');
      btn?.classList.toggle('active', favs.has(slug));
    });
    // Update tab icon fill
    const favTab = document.querySelector('.gal-tab-fav');
    favTab?.classList.toggle('has-favs', favs.size > 0);
  }

  cards.forEach(card => {
    const btn = card.querySelector('.gal-card-fav') as HTMLButtonElement;
    btn?.addEventListener('click', (e) => {
      e.stopPropagation(); // don't open overlay
      const slug = card.dataset.slug || '';
      if (favs.has(slug)) favs.delete(slug);
      else favs.add(slug);
      saveFavs();
      applyFavClasses();
      if (activeTab === 'favoriten') filterCards();
    });
  });

  applyFavClasses();

  // Switch tabs
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const newTab = (tab as HTMLElement).dataset.tab || 'branche';
      if (newTab === activeTab) return;

      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      // Hide all filter panels
      Object.values(filterPanels).forEach(p => p.classList.add('hidden'));

      if (newTab === 'favoriten') {
        // No filter panel for favorites tab
        activeTab = newTab;
      } else {
        filterPanels[newTab].classList.remove('hidden');
        activeTab = newTab;
        activeValue = 'all';
        filterPanels[newTab].querySelectorAll('.gal-filter').forEach((f, i) => {
          f.classList.toggle('active', i === 0);
        });
      }

      filterCards();
    });
  });

  // Filter buttons within each panel
  Object.entries(filterPanels).forEach(([tabName, panel]) => {
    panel.querySelectorAll('.gal-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        panel.querySelectorAll('.gal-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeValue = (btn as HTMLElement).dataset.value || 'all';
        filterCards();
      });
    });
  });

  function filterCards() {
    const q = search.value.toLowerCase().trim();
    const terms = q.split(/\s+/).filter(Boolean);
    let visible = 0;

    cards.forEach(card => {
      const name = card.dataset.name || '';
      const slug = card.dataset.slug || '';
      const tags = card.dataset.tags || '';
      const branche = card.dataset.branche || '';
      const stil = card.dataset.stil || '';
      const specials = card.dataset.specials || '';
      const haystack = `${branche} ${stil} ${specials} ${name} ${slug} ${tags}`.toLowerCase();

      // Tab filter
      let matchFilter: boolean;
      if (activeTab === 'favoriten') {
        matchFilter = favs.has(slug);
      } else {
        matchFilter = activeValue === 'all';
        if (!matchFilter) {
          if (activeTab === 'branche') matchFilter = branche === activeValue;
          else if (activeTab === 'stil') matchFilter = stil.split(',').includes(activeValue);
          else if (activeTab === 'specials') matchFilter = specials.split(',').includes(activeValue);
        }
      }

      // Search filter
      const matchSearch = !terms.length || terms.every(t => haystack.includes(t));
      const show = matchFilter && matchSearch;
      card.classList.toggle('card-hidden', !show);
      if (show) visible++;
    });

    empty.style.display = visible === 0 ? '' : 'none';
  }

  search.addEventListener('input', filterCards);

  // --- Hover Scroll Animation (step-based: top → middle → bottom) ---
  cards.forEach(card => {
    const img = card.querySelector('img') as HTMLImageElement;
    let timer: ReturnType<typeof setTimeout> | null = null;
    let stepIdx = 0;

    // img height: 200% → translateY(-50%) = very bottom
    const steps = [0, -25, -50];
    const viewMs = 900;     // ms to view each section before sliding to next
    const slideMs = 750;    // matches CSS transition duration

    function advance() {
      stepIdx++;
      if (stepIdx >= steps.length) return;
      img.style.transform = `translateY(${steps[stepIdx]}%)`;
      timer = setTimeout(advance, viewMs + slideMs);
    }

    card.addEventListener('mouseenter', () => {
      stepIdx = 0;
      img.style.transform = 'translateY(0%)';
      const slug = card.dataset.slug;
      if (slug) { const pre = new Image(); pre.src = `/images/style-gallery/${slug}.jpg`; }
      timer = setTimeout(advance, viewMs);
    });

    card.addEventListener('mouseleave', () => {
      if (timer) { clearTimeout(timer); timer = null; }
      img.style.transform = '';
    });
  });

  // --- Overlay (dialog) ---
  const overlay = document.getElementById('pf-overlay') as HTMLDialogElement;
  const pfTitle = document.getElementById('pf-title')!;
  const pfCat = document.getElementById('pf-cat')!;
  const pfScrollImg = document.getElementById('pf-scroll-img') as HTMLImageElement;
  const pfLink = document.getElementById('pf-link') as HTMLAnchorElement;
  const pfClose = document.getElementById('pf-close')!;
  const pfPrev = document.getElementById('pf-prev')!;
  const pfNext = document.getElementById('pf-next')!;

  function visibleCards() {
    return cards.filter(c => !c.classList.contains('card-hidden'));
  }

  let currentIdx = 0;

  function openOverlay(idx: number) {
    const vis = visibleCards();
    if (idx < 0 || idx >= vis.length) return;
    currentIdx = idx;
    const card = vis[idx];
    const name = card.querySelector('.gal-card-name')?.textContent || '';
    const cat = card.querySelector('.gal-card-cat')?.textContent || '';
    const slug = card.dataset.slug || '';
    const url = card.dataset.url || '';

    pfTitle.textContent = name;
    pfCat.textContent = cat;

    const thumb = pfScrollImg.parentElement!;
    thumb.classList.remove('loaded');
    pfScrollImg.src = `/images/style-gallery/${slug}.jpg`;
    pfScrollImg.alt = `${name} — ${cat}`;
    pfScrollImg.onload = () => thumb.classList.add('loaded');
    if (pfScrollImg.complete) thumb.classList.add('loaded');

    if (url) {
      pfLink.href = url;
      pfLink.style.display = '';
    } else {
      pfLink.style.display = 'none';
    }

    if (!overlay.open) {
      overlay.showModal();
      document.body.style.overflow = 'hidden';
    }
  }

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const vis = visibleCards();
      const idx = vis.indexOf(card);
      if (idx >= 0) openOverlay(idx);
    });
  });

  pfPrev.addEventListener('click', () => {
    const vis = visibleCards();
    openOverlay((currentIdx - 1 + vis.length) % vis.length);
  });
  pfNext.addEventListener('click', () => {
    const vis = visibleCards();
    openOverlay((currentIdx + 1) % vis.length);
  });
  function closeOverlay() {
    overlay.close();
    pfIframe.src = '';
    document.body.style.overflow = '';
  }
  pfClose.addEventListener('click', closeOverlay);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeOverlay();
  });
  document.addEventListener('keydown', (e) => {
    if (!overlay.open) return;
    if (e.key === 'Escape') { closeOverlay(); e.preventDefault(); }
    if (e.key === 'ArrowLeft') pfPrev.click();
    if (e.key === 'ArrowRight') pfNext.click();
  });
</script>

</body>
</html>
