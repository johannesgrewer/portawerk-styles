---
import Layout from "../layouts/Layout.astro";
import { styles, categories } from "../data/styles";
---

<Layout>
  <!-- Password Gate -->
  <div id="password-gate" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-bg overflow-hidden">

    <!-- Background radial glow -->
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse 70% 55% at 50% 60%, rgba(14,77,82,0.06) 0%, transparent 68%);pointer-events:none;"></div>

    <!-- Card -->
    <div style="position:relative;width:100%;max-width:400px;margin:0 auto;padding:0 20px;">
      <div style="background:#FFFFFF;border:1.5px solid #DDD7CE;border-radius:20px;padding:44px 40px 36px;box-shadow:0 8px 48px rgba(0,0,0,0.07),0 1px 2px rgba(0,0,0,0.04);">

        <!-- Logo + Headline -->
        <div style="text-align:center;margin-bottom:32px;">
          <div style="display:flex;justify-content:center;margin-bottom:20px;">
            <img src="/images/portawerk-logo.svg" alt="PortaWerk" style="height:36px;width:auto;" />
          </div>
          <h1 style="font-family:var(--font-display);font-size:1.375rem;font-weight:700;letter-spacing:-0.03em;color:#1B1B1B;line-height:1.15;margin-bottom:5px;">Style Library</h1>
          <p style="color:#6B6360;font-size:0.8rem;">Interner Zugang</p>
        </div>

        <!-- Divider -->
        <div style="height:1px;background:#E8E2D8;margin-bottom:28px;"></div>

        <!-- Form -->
        <form id="password-form">
          <div style="margin-bottom:10px;">
            <input
              type="password"
              id="password-input"
              placeholder="Passwort"
              autocomplete="off"
              style="width:100%;background:#F7F3EE;border:1.5px solid #DDD7CE;border-radius:10px;padding:13px 16px;font-size:0.9375rem;color:#1B1B1B;outline:none;transition:border-color 0.15s;font-family:var(--font-sans);"
              onfocus="this.style.borderColor='#0E4D52'"
              onblur="this.style.borderColor='#DDD7CE'"
            />
          </div>
          <button
            type="submit"
            style="width:100%;background:#0E4D52;color:#FDFAF6;font-family:var(--font-sans);font-weight:600;font-size:0.9375rem;border:none;border-radius:10px;padding:13px 16px;cursor:pointer;transition:background 0.15s;letter-spacing:0.01em;"
            onmouseover="this.style.background='#1A7A82'"
            onmouseout="this.style.background='#0E4D52'"
          >
            Zugang
          </button>
          <p id="password-error" style="color:#C0392B;font-size:0.75rem;text-align:center;margin-top:10px;display:none;">Falsches Passwort — bitte nochmal versuchen.</p>
        </form>

      </div>
    </div>

    <!-- Footer -->
    <p style="position:absolute;bottom:28px;color:#6B6360;font-size:0.6875rem;letter-spacing:0.04em;text-transform:uppercase;">portawerk.de</p>

  </div>

  <!-- Main App -->
  <div id="app" class="hidden min-h-screen">

    <!-- Mobile Header -->
    <div id="mobile-header" class="md:hidden fixed top-0 left-0 right-0 z-40 h-14 flex items-center gap-3 px-4 bg-surface border-b border-border">
      <button id="hamburger-btn" class="flex items-center justify-center w-8 h-8 rounded-lg hover:bg-surface-hover transition-colors text-text-muted hover:text-text cursor-pointer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <span class="font-display font-bold text-sm tracking-tight">Style Library</span>
    </div>

    <!-- Mobile Sidebar Overlay -->
    <div id="mobile-overlay" class="hidden md:hidden fixed inset-0 z-30 bg-black/50"></div>

    <!-- Sidebar -->
    <aside id="sidebar" class="sidebar fixed left-0 top-0 bottom-0 z-40 overflow-x-hidden flex flex-col">
      <!-- Logo area -->
      <div class="sidebar-brand">
        <div class="sidebar-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </div>
        <div class="sidebar-brand-text">
          <span class="sidebar-title">Style Library</span>
          <span class="sidebar-sub">PortaWerk</span>
        </div>
      </div>

      <!-- Filter nav -->
      <nav class="sidebar-nav">
        <div class="sidebar-nav-label">Kategorien</div>
        <button class="filter-btn active" data-category="all">
          <span class="filter-label">Alle</span>
          <span class="filter-count">{styles.length}</span>
        </button>
        {categories.map((cat) => {
          const count = styles.filter((s) => s.category === cat).length;
          return (
            <button class="filter-btn" data-category={cat}>
              <span class="filter-label">{cat}</span>
              <span class="filter-count">{count}</span>
            </button>
          );
        })}

        <!-- Favoriten -->
        <div class="sidebar-nav-sep"></div>
        <div class="sidebar-nav-label">Favoriten</div>
        <button class="filter-btn" data-category="__favs__">
          <span class="filter-label">Shortlist</span>
          <span id="fav-count" class="filter-count">0</span>
        </button>
        <button id="share-favs-btn" class="filter-btn" title="Favoriten-Link kopieren">
          <span class="filter-label">Link teilen</span>
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        </button>
      </nav>

      <!-- Bottom -->
      <div class="sidebar-footer">
        <div class="sidebar-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </div>
        <span class="sidebar-footer-text">v1.0</span>
      </div>
    </aside>

    <!-- Content -->
    <main class="main-content">
      <div class="main-inner">
        <header class="page-header">
          <div class="page-header-line"></div>
          <h2 id="category-title" class="page-header-title">Alle Stile</h2>
          <p id="category-count" class="page-header-count">{styles.length} Stile</p>
        </header>

        <!-- Grid -->
        <div id="styles-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-x-8 gap-y-12">
        {styles.map((style) => (
          <div
            class="style-card group cursor-pointer"
            data-category={style.category}
            data-slug={style.slug}
            data-ready={style.ready ? "true" : "false"}
          >
            <!-- Preview -->
            <div class="card-preview relative aspect-[16/9] rounded-xl overflow-hidden border border-border mb-3 transition-all duration-300 group-hover:border-accent/40 group-hover:shadow-[0_8px_40px_rgba(14,77,82,0.1)]">

              {style.ready ? (
                <>
                  <div
                    class="card-skeleton absolute inset-0 flex flex-col items-center justify-center"
                    style={`background: ${style.colors.background};`}
                  >
                    <div class="skeleton-pulse w-16 h-1.5 rounded mb-3" style={`background: ${style.colors.primary}; opacity: 0.25;`}></div>
                    <div class="skeleton-pulse w-24 h-2.5 rounded mb-2" style={`background: ${style.colors.primary}; opacity: 0.2;`}></div>
                    <div class="skeleton-pulse w-16 h-1.5 rounded" style={`background: ${style.colors.primary}; opacity: 0.15;`}></div>
                  </div>
                  <iframe
                    class="lazy-iframe pointer-events-none absolute top-0 opacity-0 transition-opacity duration-500"
                    style="width:1536px;height:864px;left:50%;transform:translateX(-50%) scale(0.3);transform-origin:top center;"
                    data-src={`/styles/${style.slug}`}
                    tabindex="-1"
                  />
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none">
                    <div class="flex items-center gap-2 px-4 py-2 rounded-full text-xs font-semibold backdrop-blur-sm bg-black/30 text-white">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
                      Ansehen
                    </div>
                  </div>
                </>
              ) : (
                <div
                  class="w-full h-full flex items-center justify-center"
                  style={`background: ${style.colors.background};`}
                >
                  <div class="text-center px-6">
                    <div class="text-2xl font-bold mb-1.5" style={`color: ${style.colors.primary};`}>{style.business.name}</div>
                    <div class="text-xs opacity-50" style={`color: ${style.colors.text};`}>{style.business.tagline}</div>
                    <div class="mt-3 text-[9px] px-2 py-0.5 rounded bg-black/10 inline-block" style={`color: ${style.colors.text};`}>Coming Soon</div>
                  </div>
                </div>
              )}

              <!-- Fav button (always shown on card) -->
              <button class="fav-btn" data-slug={style.slug} title="Favorisieren">
                <svg class="fav-icon-empty" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                <svg class="fav-icon-filled" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              </button>

            </div>

            <!-- Meta -->
            <div class="card-meta">
              <div class="card-row">
                <h3 class="card-title">{style.name}</h3>
                <span class="card-category">{style.category}</span>
              </div>
            </div>
          </div>
        ))}
        </div>
      </div>
    </main>
  </div>

  <!-- Modal -->
  <div id="style-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" id="modal-backdrop"></div>
    <div id="modal-panel" class="absolute inset-0 md:inset-4 lg:inset-8 xl:inset-12 bg-surface rounded-none md:rounded-2xl overflow-hidden border-0 md:border border-border flex flex-col">
      <div class="flex items-center justify-between px-4 md:px-6 py-3 md:py-4 border-b border-border shrink-0 gap-3">
        <!-- Nav arrows + position -->
        <div class="flex items-center gap-1.5 shrink-0">
          <button id="modal-prev" class="modal-nav-btn" title="Vorheriger Stil (←)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button id="modal-next" class="modal-nav-btn" title="Nächster Stil (→)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
          <span id="modal-pos" class="text-xs text-text-muted font-mono tabular-nums select-none hidden sm:inline">1 / 90</span>
        </div>
        <!-- Title -->
        <h3 id="modal-title" class="font-display font-bold flex-1 text-center text-sm md:text-base truncate"></h3>
        <!-- Actions -->
        <div class="flex items-center gap-0.5 shrink-0">
          <button id="modal-fav-btn" class="modal-action-btn" title="Favorisieren">
            <svg class="modal-fav-empty" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            <svg class="modal-fav-filled" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
          <button id="modal-share-btn" class="modal-action-btn hidden sm:flex" title="Link kopieren">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </button>
          <button id="modal-close" class="modal-action-btn" title="Schließen (Esc)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </div>
      <div id="modal-content" class="flex-1 overflow-hidden">
      </div>
    </div>
  </div>

  <script is:inline>
    const PASSWORD = 'portawerk2026';
    const STORAGE_KEY = 'pw-styles-auth';
    const FAV_KEY = 'pw-styles-favs';

    // ── State ──────────────────────────────────────────────
    let currentModalSlug = null;
    let favs = new Set(JSON.parse(localStorage.getItem(FAV_KEY) || '[]'));

    // ── Init ───────────────────────────────────────────────
    function initApp() {
      updateAllFavBtns();
      updateFavCount();
      initLazyLoad();
      initCards();
      initFilter();
      initMobile();
      handleUrlParams();
    }

    if (sessionStorage.getItem(STORAGE_KEY) === 'true') {
      document.getElementById('password-gate').style.display = 'none';
      document.getElementById('app').classList.remove('hidden');
      initApp();
    }

    document.getElementById('password-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = document.getElementById('password-input');
      const errorEl = document.getElementById('password-error');
      if (input.value === PASSWORD) {
        sessionStorage.setItem(STORAGE_KEY, 'true');
        document.getElementById('password-gate').style.display = 'none';
        document.getElementById('app').classList.remove('hidden');
        initApp();
      } else {
        errorEl.style.display = 'block';
        input.value = '';
        input.focus();
      }
    });

    // ── Favs ───────────────────────────────────────────────
    function saveFavs() {
      localStorage.setItem(FAV_KEY, JSON.stringify([...favs]));
      updateFavCount();
      updateAllFavBtns();
      if (currentModalSlug) updateModalFavBtn(currentModalSlug);
    }

    function toggleFav(slug) {
      if (favs.has(slug)) favs.delete(slug);
      else favs.add(slug);
      saveFavs();
    }

    function updateFavCount() {
      const el = document.getElementById('fav-count');
      if (el) el.textContent = favs.size;
    }

    function updateAllFavBtns() {
      document.querySelectorAll('.fav-btn').forEach((btn) => {
        btn.classList.toggle('is-fav', favs.has(btn.dataset.slug));
      });
    }

    function updateModalFavBtn(slug) {
      const btn = document.getElementById('modal-fav-btn');
      if (btn) btn.classList.toggle('is-fav', favs.has(slug));
    }

    // ── Filter ─────────────────────────────────────────────
    let activeCategory = 'all';

    function initFilter() {
      document.querySelectorAll('.filter-btn[data-category]').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.filter-btn[data-category]').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          activeCategory = btn.dataset.category;
          filterCards();
        });
      });
    }

    function filterCards() {
      const title = document.getElementById('category-title');
      const count = document.getElementById('category-count');
      const cards = document.querySelectorAll('.style-card');
      let visible = 0;

      cards.forEach((card) => {
        let show = false;
        if (activeCategory === 'all') show = true;
        else if (activeCategory === '__favs__') show = favs.has(card.dataset.slug);
        else show = card.dataset.category === activeCategory;

        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (activeCategory === 'all') title.textContent = 'Alle Stile';
      else if (activeCategory === '__favs__') title.textContent = 'Favoriten';
      else title.textContent = activeCategory;

      count.textContent = visible + (visible === 1 ? ' Stil' : ' Stile');
    }

    // ── Lazy Load with concurrency queue ───────────────────
    function initLazyLoad() {
      const loadQueue = [];
      let activeLoads = 0;
      const MAX_CONCURRENT = 4;

      function revealIframe(iframe) {
        iframe.style.opacity = '1';
        const skeleton = iframe.previousElementSibling;
        if (skeleton?.classList.contains('card-skeleton')) {
          skeleton.style.opacity = '0';
          skeleton.style.transition = 'opacity 0.4s';
        }
      }

      function processQueue() {
        while (activeLoads < MAX_CONCURRENT && loadQueue.length > 0) {
          const iframe = loadQueue.shift();
          const src = iframe.dataset.src;
          if (!src || iframe.src) continue;
          activeLoads++;
          iframe.src = src;
          iframe.addEventListener('load', () => {
            revealIframe(iframe);
            activeLoads--;
            processQueue();
          }, { once: true });
          // Fallback timeout in case load event misfires
          setTimeout(() => { revealIframe(iframe); activeLoads--; processQueue(); }, 8000);
        }
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const iframe = entry.target;
          if (!iframe.dataset.src || iframe.src) return;
          observer.unobserve(iframe);
          loadQueue.push(iframe);
          processQueue();
        });
      }, { rootMargin: '800px' });

      document.querySelectorAll('.lazy-iframe').forEach((iframe) => observer.observe(iframe));
    }

    // ── Preload Cache ──────────────────────────────────────
    const preloadContainer = document.createElement('div');
    preloadContainer.style.cssText = 'position:fixed;top:-9999px;left:-9999px;width:1px;height:1px;visibility:hidden;pointer-events:none;';
    document.body.appendChild(preloadContainer);
    const preloadCache = {};

    function preloadStyle(slug) {
      if (preloadCache[slug]) return;
      const iframe = document.createElement('iframe');
      iframe.src = '/styles/' + slug;
      iframe.tabIndex = -1;
      preloadContainer.appendChild(iframe);
      preloadCache[slug] = iframe;
    }

    // ── Cards ──────────────────────────────────────────────
    function initCards() {
      document.querySelectorAll('.style-card').forEach((card) => {
        const slug = card.dataset.slug;

        // Fav button on card (works for all cards, ready or not)
        const favBtn = card.querySelector('.fav-btn');
        if (favBtn) {
          favBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            toggleFav(slug);
          });
        }

        if (card.dataset.ready !== 'true') return;

        // Hover → preload in background + replay card animations
        card.addEventListener('mouseenter', () => {
          preloadStyle(slug);
          const iframe = card.querySelector('.lazy-iframe');
          if (!iframe?.contentDocument) return;
          try {
            iframe.contentDocument.querySelectorAll('*').forEach(el => {
              el.style.animation = 'none';
              void el.offsetHeight;
              el.style.animation = '';
            });
          } catch (e) {}
        });

        // Click → open modal
        card.addEventListener('click', () => openModal(slug));
      });
    }

    // ── Modal ──────────────────────────────────────────────
    const modal = document.getElementById('style-modal');
    const modalTitle = document.getElementById('modal-title');
    const modalPos = document.getElementById('modal-pos');
    const modalContent = document.getElementById('modal-content');

    function getVisibleCards() {
      return Array.from(document.querySelectorAll('.style-card')).filter((c) => c.style.display !== 'none');
    }

    function openModal(slug) {
      const card = document.querySelector(`.style-card[data-slug="${slug}"]`);
      if (!card || card.dataset.ready !== 'true') return;

      currentModalSlug = slug;

      // Title
      const titleEl = card.querySelector('h3');
      modalTitle.textContent = titleEl ? titleEl.textContent : slug;

      // Position indicator
      const visibleCards = getVisibleCards();
      const idx = visibleCards.findIndex((c) => c.dataset.slug === slug);
      if (modalPos) modalPos.textContent = `${idx + 1} / ${visibleCards.length}`;

      // Fav state
      updateModalFavBtn(slug);

      // Load iframe (reuse preloaded if available)
      while (modalContent.firstChild) modalContent.removeChild(modalContent.firstChild);
      let iframe;
      if (preloadCache[slug]) {
        iframe = preloadCache[slug];
        delete preloadCache[slug];
      } else {
        iframe = document.createElement('iframe');
        iframe.src = '/styles/' + slug;
      }
      iframe.style.cssText = 'width:100%;height:100%;border:none;display:block;';
      modalContent.appendChild(iframe);

      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';

      // Update URL
      const url = new URL(window.location);
      url.searchParams.set('style', slug);
      history.replaceState(null, '', url);
    }

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
      while (modalContent.firstChild) modalContent.removeChild(modalContent.firstChild);
      currentModalSlug = null;

      // Remove style param from URL
      const url = new URL(window.location);
      url.searchParams.delete('style');
      history.replaceState(null, '', url);
    }

    function navigateModal(dir) {
      if (!currentModalSlug) return;
      const visibleCards = getVisibleCards();
      const idx = visibleCards.findIndex((c) => c.dataset.slug === currentModalSlug);
      if (idx === -1) return;
      const next = visibleCards[(idx + dir + visibleCards.length) % visibleCards.length];
      if (next) openModal(next.dataset.slug);
    }

    // ── Modal Event Listeners ──────────────────────────────
    document.getElementById('modal-close')?.addEventListener('click', closeModal);
    document.getElementById('modal-backdrop')?.addEventListener('click', closeModal);
    document.getElementById('modal-prev')?.addEventListener('click', () => navigateModal(-1));
    document.getElementById('modal-next')?.addEventListener('click', () => navigateModal(1));

    document.getElementById('modal-fav-btn')?.addEventListener('click', () => {
      if (currentModalSlug) toggleFav(currentModalSlug);
    });

    document.getElementById('modal-share-btn')?.addEventListener('click', () => {
      if (!currentModalSlug) return;
      const url = new URL(window.location);
      url.searchParams.set('style', currentModalSlug);
      url.searchParams.delete('favs');
      navigator.clipboard.writeText(url.toString()).then(() => {
        const btn = document.getElementById('modal-share-btn');
        const prev = btn.title;
        btn.title = '✓ Kopiert!';
        setTimeout(() => { btn.title = prev; }, 2000);
      });
    });

    document.addEventListener('keydown', (e) => {
      if (modal.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeModal();
      if (e.key === 'ArrowLeft') navigateModal(-1);
      if (e.key === 'ArrowRight') navigateModal(1);
    });

    // ── Share Favs ─────────────────────────────────────────
    document.getElementById('share-favs-btn')?.addEventListener('click', () => {
      if (favs.size === 0) {
        alert('Noch keine Favoriten gespeichert.');
        return;
      }
      const url = new URL(window.location);
      url.searchParams.set('favs', [...favs].join(','));
      url.searchParams.delete('style');
      navigator.clipboard.writeText(url.toString()).then(() => {
        const btn = document.getElementById('share-favs-btn');
        const label = btn.querySelector('.filter-label');
        const prev = label.textContent;
        label.textContent = '✓ Kopiert!';
        setTimeout(() => { label.textContent = prev; }, 2000);
      });
    });

    // ── Mobile ─────────────────────────────────────────────
    function initMobile() {
      const hamburger = document.getElementById('hamburger-btn');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('mobile-overlay');

      hamburger?.addEventListener('click', () => {
        sidebar.classList.toggle('mobile-open');
        overlay.classList.toggle('hidden');
      });

      overlay?.addEventListener('click', () => {
        sidebar.classList.remove('mobile-open');
        overlay.classList.add('hidden');
      });

      // Close sidebar when a filter is selected on mobile
      document.querySelectorAll('.filter-btn[data-category]').forEach((btn) => {
        btn.addEventListener('click', () => {
          if (window.innerWidth < 768) {
            sidebar.classList.remove('mobile-open');
            overlay.classList.add('hidden');
          }
        });
      });
    }

    // ── URL Params ─────────────────────────────────────────
    function handleUrlParams() {
      const params = new URLSearchParams(window.location.search);

      // Load favs from URL (?favs=slug1,slug2)
      const favsParam = params.get('favs');
      if (favsParam) {
        favsParam.split(',').forEach((s) => { if (s.trim()) favs.add(s.trim()); });
        saveFavs();
      }

      // Auto-open style from URL (?style=slug)
      const styleParam = params.get('style');
      if (styleParam) {
        setTimeout(() => openModal(styleParam), 150);
      }
    }
  </script>

