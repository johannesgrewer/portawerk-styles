---
import Layout from "../layouts/Layout.astro";
import { styles, categories } from "../data/styles";
---

<Layout>
  <!-- Password Gate -->
  <div id="password-gate" class="fixed inset-0 z-50 flex items-center justify-center bg-bg">
    <div class="w-full max-w-sm px-6">
      <div class="text-center mb-8">
        <h1 class="font-display text-3xl font-bold tracking-tight mb-2">Style Library</h1>
        <p class="text-text-muted text-sm">PortaWerk — Interner Zugang</p>
      </div>
      <form id="password-form" class="space-y-4">
        <input
          type="password"
          id="password-input"
          placeholder="Passwort eingeben"
          autocomplete="off"
          class="w-full bg-surface border border-border rounded-lg px-4 py-3 text-sm text-text placeholder:text-text-muted/50 outline-none focus:border-accent transition-colors"
        />
        <button
          type="submit"
          class="w-full bg-accent hover:bg-accent-light text-white font-medium rounded-lg px-4 py-3 text-sm transition-colors cursor-pointer"
        >
          Zugang
        </button>
        <p id="password-error" class="text-red-500 text-xs text-center hidden">Falsches Passwort.</p>
      </form>
    </div>
  </div>

  <!-- Main App -->
  <div id="app" class="hidden min-h-screen">
    <!-- Sidebar -->
    <aside id="sidebar" class="sidebar fixed left-0 top-0 bottom-0 bg-surface border-r border-border overflow-y-auto z-40 overflow-x-hidden">
      <div class="sidebar-header p-4 pb-3 border-b border-border">
        <h1 class="sidebar-title font-display text-sm font-bold tracking-tight whitespace-nowrap">Style Library</h1>
        <p class="sidebar-sub text-text-muted text-[10px] mt-0.5 whitespace-nowrap">PortaWerk</p>
      </div>
      <nav class="p-2">
        <button
          class="filter-btn active w-full text-left px-2 py-1.5 rounded-md text-xs font-medium transition-colors whitespace-nowrap"
          data-category="all"
        >
          Alle
          <span class="text-text-muted ml-1 text-xs">{styles.length}</span>
        </button>
        {categories.map((cat) => {
          const count = styles.filter((s) => s.category === cat).length;
          return (
            <button
              class="filter-btn w-full text-left px-2 py-1.5 rounded-md text-xs transition-colors whitespace-nowrap"
              data-category={cat}
            >
              {cat}
              <span class="text-text-muted ml-1 text-xs">{count}</span>
            </button>
          );
        })}
      </nav>
    </aside>

    <!-- Content -->
    <main class="main-content">
      <div class="main-inner">
        <div class="mb-12 pt-2">
          <h2 id="category-title" class="font-display text-2xl font-bold tracking-tight">Alle Stile</h2>
          <p id="category-count" class="text-text-muted text-sm mt-1.5">{styles.length} Stile</p>
        </div>

        <!-- Grid -->
        <div id="styles-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-x-8 gap-y-12">
        {styles.map((style) => (
          <div
            class="style-card group cursor-pointer"
            data-category={style.category}
            data-slug={style.slug}
          >
            <!-- Hero Preview -->
            <div class="relative aspect-[16/10] rounded-xl overflow-hidden border border-border bg-surface-hover mb-5 transition-all duration-300 group-hover:border-accent/40 group-hover:shadow-[0_8px_40px_rgba(14,77,82,0.1)]">
              {style.ready ? (
                <iframe
                  src={`/styles/${style.slug}`}
                  class="w-[1536px] h-[960px] origin-top-left pointer-events-none"
                  style="transform: scale(0.3); transform-origin: top left;"
                  loading="lazy"
                  tabindex="-1"
                />
              ) : (
                <div
                  class="w-full h-full flex items-center justify-center"
                  style={`background: ${style.colors.background};`}
                >
                  <div class="text-center px-6">
                    <div
                      class="text-3xl font-bold mb-2 font-display"
                      style={`color: ${style.colors.primary};`}
                    >
                      {style.business.name}
                    </div>
                    <div
                      class="text-sm opacity-60"
                      style={`color: ${style.colors.text};`}
                    >
                      {style.business.tagline}
                    </div>
                    <div class="mt-4 inline-block px-3 py-1 rounded-full text-xs bg-black/5 text-text-muted">
                      Coming Soon
                    </div>
                  </div>
                </div>
              )}
            </div>

            <!-- Info -->
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="font-display font-bold text-sm">{style.name}</h3>
                <p class="text-text-muted text-xs mt-0.5">{style.business.name} — {style.business.type}</p>
              </div>
              <span class="shrink-0 text-[10px] font-medium px-2 py-0.5 rounded-full bg-surface border border-border text-text-muted">
                {style.category}
              </span>
            </div>

            <!-- Colors + Fonts -->
            <div class="flex items-center gap-3 mt-2">
              <div class="flex gap-1">
                <span class="w-3 h-3 rounded-full border border-black/10" style={`background: ${style.colors.primary};`} />
                <span class="w-3 h-3 rounded-full border border-black/10" style={`background: ${style.colors.secondary};`} />
                <span class="w-3 h-3 rounded-full border border-black/10" style={`background: ${style.colors.accent};`} />
              </div>
              <span class="text-[10px] text-text-muted">
                {style.fonts.display}{style.fonts.display !== style.fonts.body ? ` + ${style.fonts.body}` : ""}
              </span>
            </div>
          </div>
        ))}
        </div>
      </div>
    </main>
  </div>

  <!-- Modal -->
  <div id="style-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" id="modal-backdrop"></div>
    <div class="absolute inset-4 md:inset-8 lg:inset-12 bg-surface rounded-2xl overflow-hidden border border-border flex flex-col">
      <div class="flex items-center justify-between px-6 py-4 border-b border-border shrink-0">
        <div>
          <h3 id="modal-title" class="font-display font-bold"></h3>
          <p id="modal-subtitle" class="text-text-muted text-xs mt-0.5"></p>
        </div>
        <button id="modal-close" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-surface-hover transition-colors cursor-pointer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div id="modal-content" class="flex-1 overflow-y-auto">
        <div class="flex items-center justify-center h-full text-text-muted text-sm">
          Stil-Preview kommt bald...
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const PASSWORD = 'portawerk2026';
    const STORAGE_KEY = 'pw-styles-auth';

    // Check auth
    if (sessionStorage.getItem(STORAGE_KEY) === 'true') {
      document.getElementById('password-gate').style.display = 'none';
      document.getElementById('app').classList.remove('hidden');
    }

    // Password form
    document.getElementById('password-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = document.getElementById('password-input');
      const errorEl = document.getElementById('password-error');
      if (input.value === PASSWORD) {
        sessionStorage.setItem(STORAGE_KEY, 'true');
        document.getElementById('password-gate').style.display = 'none';
        document.getElementById('app').classList.remove('hidden');
      } else {
        errorEl.classList.remove('hidden');
        input.value = '';
        input.focus();
      }
    });

    // Filter
    let activeCategory = 'all';
    document.querySelectorAll('.filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = btn.dataset.category;

        const title = document.getElementById('category-title');
        const count = document.getElementById('category-count');
        const cards = document.querySelectorAll('.style-card');
        let visible = 0;

        cards.forEach((card) => {
          if (activeCategory === 'all' || card.dataset.category === activeCategory) {
            card.style.display = '';
            visible++;
          } else {
            card.style.display = 'none';
          }
        });

        title.textContent = activeCategory === 'all' ? 'Alle Stile' : activeCategory;
        count.textContent = visible + (visible === 1 ? ' Stil' : ' Stile');
      });
    });

    // Modal
    const modal = document.getElementById('style-modal');
    const modalTitle = document.getElementById('modal-title');
    const modalSubtitle = document.getElementById('modal-subtitle');
    const modalContent = document.getElementById('modal-content');
    const modalPlaceholder = '<div class="flex items-center justify-center h-full text-text-muted text-sm">Stil-Preview kommt bald...</div>';

    document.querySelectorAll('.style-card').forEach((card) => {
      card.addEventListener('click', () => {
        modalTitle.textContent = card.querySelector('h3').textContent;
        modalSubtitle.textContent = card.querySelector('p').textContent;
        modalContent.textContent = '';
        const placeholder = document.createElement('div');
        placeholder.className = 'flex items-center justify-center h-full text-sm';
        placeholder.style.color = 'var(--color-text-muted)';
        placeholder.textContent = 'Stil-Preview kommt bald...';
        modalContent.appendChild(placeholder);
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });
    });

    document.getElementById('modal-close')?.addEventListener('click', closeModal);
    document.getElementById('modal-backdrop')?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }
  </script>

  <style>
    /* Sidebar: collapsed by default, expands on hover */
    .sidebar {
      width: 48px;
      transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .sidebar:hover {
      width: 200px;
    }

    /* Hide text when collapsed */
    .sidebar .sidebar-title,
    .sidebar .sidebar-sub,
    .sidebar .filter-btn {
      opacity: 0;
      transition: opacity 0.15s ease;
    }
    .sidebar:hover .sidebar-title,
    .sidebar:hover .sidebar-sub,
    .sidebar:hover .filter-btn {
      opacity: 1;
      transition: opacity 0.2s ease 0.1s;
    }

    /* Main content offset */
    .main-content {
      margin-left: 48px;
      min-height: 100vh;
      transition: margin-left 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .main-inner {
      max-width: 1400px;
      margin: 0 auto;
      padding: 3rem clamp(2rem, 4vw, 4rem) 4rem;
    }

    .filter-btn {
      color: var(--color-text-muted);
    }
    .filter-btn:hover {
      background: var(--color-surface-hover);
      color: var(--color-text);
    }
    .filter-btn.active {
      background: var(--color-accent);
      color: white;
    }
  </style>
</Layout>
