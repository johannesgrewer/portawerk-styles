function deriveStil(tags: string, slug: string): string[] {
  const t = `${tags} ${slug}`.toLowerCase()
  const s: string[] = []
  if (t.includes('dunkel') || t.includes('moody') || t.includes('dark') || t.includes('noir') || t.includes('schwarz')) s.push('Dunkel & Moody')
  if (t.includes('hell') || t.includes('clean') || t.includes('pastell') || t.includes('soft')) s.push('Hell & Clean')
  if (t.includes('minimal') || t.includes('swiss') || t.includes('zen')) s.push('Minimal')
  if (t.includes('bold') || t.includes('laut') || t.includes('grafik')) s.push('Bold & Grafisch')
  if (t.includes('retro') || t.includes('vintage') || t.includes('nostalgisch') || t.includes('80er')) s.push('Retro & Vintage')
  if (t.includes('editorial') || t.includes('magazin') || t.includes('typografie') || t.includes('schrift')) s.push('Editorial & Typografie')
  if (t.includes('industrial') || t.includes('roh') || t.includes('beton') || t.includes('brutal') || t.includes('fabrik')) s.push('Industrial & Roh')
  if (t.includes('verspielt') || t.includes('fröhlich') || t.includes('kinder') || t.includes('süß') || t.includes('candy') || t.includes('bunt')) s.push('Verspielt & Bunt')
  if (t.includes('luxus') || t.includes('premium') || t.includes('edel') || t.includes('elegant') || t.includes('gold') || t.includes('marmor')) s.push('Luxus & Elegant')
  if (t.includes('neon') || t.includes('tech') || t.includes('digital') || t.includes('futuristisch') || t.includes('cyber') || t.includes('synthwave') || t.includes('saas')) s.push('Neon & Tech')
  if (t.includes('warm') || t.includes('mediterran') || t.includes('gemütlich')) s.push('Warm & Gemütlich')
  if (t.includes('natur') || t.includes('bio') || t.includes('nachhaltig') || t.includes('grün') || t.includes('botanik')) s.push('Natur & Organisch')
  if (s.length === 0) s.push('Modern')
  return s
}

function deriveSpecials(tags: string, slug: string): string[] {
  const t = `${tags} ${slug}`.toLowerCase()
  const s: string[] = []
  if (t.includes('3d') || t.includes('vr') || t.includes('spatial')) s.push('3D')
  if (t.includes('gaming') || t.includes('interactive') || t.includes('spiel')) s.push('Interaktiv')
  if (t.includes('gradient') || t.includes('glassmorphism') || t.includes('glas')) s.push('Glassmorphism')
  if (t.includes('duotone') || t.includes('split')) s.push('Split-Design')
  if (t.includes('oversized') || t.includes('groß')) s.push('Oversized Typo')
  if (t.includes('maximalist') || t.includes('opulent')) s.push('Maximalistisch')
  return s
}

const enrichedStyles = styles.map(s => ({
  ...s,
  branche: brancheMap[s.category] || 'Sonstige',
  stil: deriveStil(s.tags, s.slug),
  specials: deriveSpecials(s.tags, s.slug),
}))

const allBranchen = [...new Set(enrichedStyles.map(s => s.branche))].sort()
const allStile = [...new Set(enrichedStyles.flatMap(s => s.stil))].sort()
const allSpecials = [...new Set(enrichedStyles.flatMap(s => s.specials))].filter(Boolean).sort()

