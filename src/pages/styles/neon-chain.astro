---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>CHAIN — Underground Club & Events | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --cyan:    #00E5FF;
      --magenta: #FF0066;
      --bg:      #060608;
      --mid:     #0D0D16;
      --text:    #FFFFFF;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Space Grotesk', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* CRT scanlines */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,229,255,0.012) 2px,
        rgba(0,229,255,0.012) 3px
      );
      pointer-events: none;
      z-index: 0;
    }

    /* Ambient neon glow */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 15% 80%, rgba(255,0,102,0.07) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 85% 20%, rgba(0,229,255,0.07) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 3rem;
      background: rgba(6,6,8,0.92);
      border-bottom: 1px solid rgba(0,229,255,0.1);
      backdrop-filter: blur(12px);
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      letter-spacing: 0.25em;
      color: var(--text);
    }
    .nav-logo span {
      color: var(--cyan);
      text-shadow: 0 0 20px rgba(0,229,255,0.6), 0 0 40px rgba(0,229,255,0.2);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.58rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      text-decoration: none;
      transition: color 0.2s, text-shadow 0.2s;
    }
    .nav-links a:hover {
      color: var(--cyan);
      text-shadow: 0 0 8px rgba(0,229,255,0.5);
    }
    .nav-tickets {
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--magenta);
      padding: 0.6rem 1.5rem;
      text-decoration: none;
      box-shadow: 0 0 20px rgba(255,0,102,0.35);
      transition: box-shadow 0.2s;
    }
    .nav-tickets:hover { box-shadow: 0 0 36px rgba(255,0,102,0.65); }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 420px;
      padding-top: 68px;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.1;
      filter: saturate(0.4) hue-rotate(200deg);
    }
    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(6,6,8,0.97) 35%, rgba(6,6,8,0.65) 100%);
    }

    .hero-left {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 5rem 4rem 5rem 5rem;
      gap: 2.25rem;
      border-right: 1px solid rgba(0,229,255,0.08);
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--magenta);
      text-shadow: 0 0 10px rgba(255,0,102,0.5);
    }
    .hero-badge::before {
      content: '';
      display: block;
      width: 8px;
      height: 8px;
      background: var(--magenta);
      border-radius: 50%;
      box-shadow: 0 0 10px rgba(255,0,102,0.8);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; box-shadow: 0 0 10px rgba(255,0,102,0.8); }
      50% { opacity: 0.4; box-shadow: 0 0 4px rgba(255,0,102,0.3); }
    }

    .hero-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5.5rem, 13vw, 11rem);
      line-height: 0.88;
      letter-spacing: 0.03em;
    }
    .hl-white  { color: var(--text); display: block; }
    .hl-cyan   {
      color: var(--cyan);
      display: block;
      text-shadow:
        0 0 30px rgba(0,229,255,0.75),
        0 0 60px rgba(0,229,255,0.3),
        0 0 100px rgba(0,229,255,0.12);
    }
    .hl-magenta {
      color: var(--magenta);
      display: block;
      text-shadow:
        0 0 30px rgba(255,0,102,0.75),
        0 0 60px rgba(255,0,102,0.3);
    }

    .hero-sub {
      font-size: 0.8rem;
      font-weight: 300;
      line-height: 1.85;
      color: rgba(255,255,255,0.35);
      max-width: 40ch;
      border-left: 2px solid rgba(0,229,255,0.2);
      padding-left: 1rem;
    }

    .hero-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .htag {
      font-size: 0.54rem;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 0.3rem 0.85rem;
      border: 1px solid;
    }
    .htag-c { color: var(--cyan);    border-color: rgba(0,229,255,0.25); }
    .htag-m { color: var(--magenta); border-color: rgba(255,0,102,0.25); }
    .htag-d { color: rgba(255,255,255,0.4); border-color: rgba(255,255,255,0.1); }

    .hero-cta {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .cta-main {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--cyan);
      color: var(--bg);
      text-decoration: none;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.15rem;
      letter-spacing: 0.12em;
      padding: 0.82rem 2.25rem;
      box-shadow: 0 0 28px rgba(0,229,255,0.3);
      transition: box-shadow 0.2s;
    }
    .cta-main:hover { box-shadow: 0 0 50px rgba(0,229,255,0.6); }
    .cta-ghost {
      font-size: 0.58rem;
      font-weight: 300;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
      text-decoration: none;
      transition: color 0.2s;
    }
    .cta-ghost:hover { color: var(--magenta); }

    /* Hero right panel */
    .hero-right {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
    }

    .tonight-panel {
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .tonight-photo {
      flex: 1;
      position: relative;
      overflow: hidden;
      min-height: 320px;
    }
    .tonight-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.55;
      filter: saturate(0.5) hue-rotate(200deg);
      transition: transform 0.55s ease;
    }
    .tonight-photo:hover img { transform: scale(1.04); }
    .tonight-photo::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(6,6,8,0.97) 0%, rgba(6,6,8,0.3) 60%, transparent 100%);
    }

    .tonight-info {
      padding: 2rem;
      border-top: 1px solid rgba(0,229,255,0.1);
      background: rgba(13,13,22,0.7);
      backdrop-filter: blur(4px);
    }
    .ti-label {
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--magenta);
      text-shadow: 0 0 8px rgba(255,0,102,0.4);
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .ti-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, rgba(255,0,102,0.3), transparent);
    }
    .ti-event {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.85rem;
      letter-spacing: 0.06em;
      color: var(--text);
      line-height: 1;
      margin-bottom: 0.25rem;
    }
    .ti-artist {
      font-size: 0.62rem;
      font-weight: 300;
      color: rgba(255,255,255,0.35);
      margin-bottom: 1rem;
    }
    .ti-meta {
      display: flex;
      gap: 1.5rem;
    }
    .tm-val {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1rem;
      letter-spacing: 0.08em;
      color: var(--cyan);
      text-shadow: 0 0 8px rgba(0,229,255,0.4);
      line-height: 1;
    }
    .tm-key {
      font-size: 0.44rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.2);
      margin-top: 0.2rem;
    }

    .stats-bar {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-top: 1px solid rgba(0,229,255,0.08);
    }
    .sb-item {
      padding: 1.5rem;
      border-right: 1px solid rgba(0,229,255,0.07);
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .sb-item:last-child { border-right: none; }
    .sb-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.9rem;
      letter-spacing: 0.04em;
      color: var(--text);
      line-height: 1;
    }
    .sb-label {
      font-size: 0.47rem;
      font-weight: 300;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.2);
    }

    /* ─── PHOTO HELPER ─── */
    .ph { position: relative; overflow: hidden; }
    .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
    .ph:hover img { transform: scale(1.05); }

    /* ─── SHARED SECTION STYLES ─── */
    .s-inner {
      max-width: 1600px;
      margin: 0 auto;
      padding: 0 5rem;
    }
    .s-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 3.5rem;
    }
    .s-eyebrow {
      font-size: 0.52rem;
      font-weight: 400;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--cyan);
      text-shadow: 0 0 8px rgba(0,229,255,0.4);
      margin-bottom: 0.6rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .s-eyebrow::before {
      content: '';
      display: block;
      width: 1.5rem;
      height: 1px;
      background: var(--cyan);
      box-shadow: 0 0 6px rgba(0,229,255,0.8);
    }
    .s-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      letter-spacing: 0.04em;
      line-height: 0.92;
      color: var(--text);
    }
    .s-all {
      font-size: 0.54rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
      text-decoration: none;
      transition: color 0.2s, border-color 0.2s;
      padding-bottom: 0.25rem;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      white-space: nowrap;
    }
    .s-all:hover { color: var(--cyan); border-color: rgba(0,229,255,0.4); }

    /* ─── EVENTS SECTION ─── */
    .section-events {
      padding: 7rem 0;
      background: var(--mid);
      position: relative;
      z-index: 1;
    }

    .events-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(0,229,255,0.07);
    }
    .event-card {
      background: var(--bg);
      position: relative;
      cursor: pointer;
    }
    .ec-photo {
      position: relative;
      overflow: hidden;
      height: 280px;
    }
    .ec-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(0.65);
      transition: transform 0.55s ease;
    }
    .event-card:hover .ec-photo img { transform: scale(1.05); }
    .ec-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(6,6,8,0.92) 0%, transparent 55%);
    }
    .ec-genre {
      position: absolute;
      top: 1rem;
      left: 1rem;
      font-size: 0.47rem;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 0.25rem 0.7rem;
      border: 1px solid;
      z-index: 2;
      background: rgba(6,6,8,0.75);
    }
    .genre-c { color: var(--cyan);    border-color: rgba(0,229,255,0.4); }
    .genre-m { color: var(--magenta); border-color: rgba(255,0,102,0.4); }
    .genre-d { color: rgba(255,255,255,0.6); border-color: rgba(255,255,255,0.2); }

    .ec-sold {
      position: absolute;
      top: 1rem;
      right: 1rem;
      font-size: 0.44rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--magenta);
      border: 1px solid rgba(255,0,102,0.4);
      background: rgba(6,6,8,0.8);
      padding: 0.22rem 0.6rem;
      z-index: 2;
    }

    .ec-body { padding: 1.5rem; }
    .ec-date {
      font-size: 0.54rem;
      font-weight: 300;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(0,229,255,0.5);
      margin-bottom: 0.4rem;
    }
    .ec-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      letter-spacing: 0.06em;
      color: var(--text);
      line-height: 1;
      margin-bottom: 0.3rem;
    }
    .ec-acts {
      font-size: 0.63rem;
      font-weight: 300;
      color: rgba(255,255,255,0.3);
      margin-bottom: 1rem;
      line-height: 1.5;
    }
    .ec-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .ec-time {
      font-size: 0.54rem;
      font-weight: 400;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.22);
    }
    .ec-price {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1rem;
      letter-spacing: 0.08em;
      color: var(--cyan);
      text-shadow: 0 0 8px rgba(0,229,255,0.4);
    }

    /* ─── FLOOR SECTION ─── */
    .section-floor {
      padding: 7rem 0;
      background: var(--bg);
      position: relative;
      z-index: 1;
    }
    .floor-inner {
      max-width: 1600px;
      margin: 0 auto;
      padding: 0 5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
    }
    .floor-body {
      font-size: 0.82rem;
      font-weight: 300;
      line-height: 1.9;
      color: rgba(255,255,255,0.35);
      max-width: 40ch;
      margin-bottom: 2.5rem;
    }
    .floor-features {
      display: flex;
      flex-direction: column;
      border-top: 1px solid rgba(0,229,255,0.08);
    }
    .ff-row {
      display: grid;
      grid-template-columns: 1.5rem 1fr;
      gap: 1rem;
      align-items: center;
      padding: 0.9rem 0;
      border-bottom: 1px solid rgba(0,229,255,0.06);
    }
    .ff-dot {
      width: 6px;
      height: 6px;
      background: var(--cyan);
      box-shadow: 0 0 8px rgba(0,229,255,0.7);
      justify-self: center;
    }
    .ff-text {
      font-size: 0.64rem;
      font-weight: 300;
      letter-spacing: 0.04em;
      color: rgba(255,255,255,0.38);
      line-height: 1.5;
    }
    .ff-text strong { color: rgba(255,255,255,0.75); font-weight: 500; }
    .floor-cta {
      margin-top: 2.5rem;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--magenta);
      color: var(--text);
      text-decoration: none;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      letter-spacing: 0.12em;
      padding: 0.82rem 2.25rem;
      box-shadow: 0 0 24px rgba(255,0,102,0.3);
      transition: box-shadow 0.2s;
    }
    .floor-cta:hover { box-shadow: 0 0 44px rgba(255,0,102,0.6); }

    .floor-photos {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
    }

    /* ─── LINEUP SECTION ─── */
    .section-lineup {
      padding: 7rem 0;
      background: var(--mid);
      position: relative;
      z-index: 1;
      overflow: hidden;
    }
    .section-lineup::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(0,229,255,0.3) 30%, rgba(255,0,102,0.3) 70%, transparent);
    }

    .lineup-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: rgba(0,229,255,0.06);
      margin-top: 3.5rem;
    }
    .artist-card {
      background: var(--bg);
      cursor: pointer;
    }
    .ac-photo {
      position: relative;
      overflow: hidden;
      height: 300px;
    }
    .ac-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(0.45) contrast(1.1);
      transition: transform 0.55s ease, filter 0.3s;
    }
    .artist-card:hover .ac-photo img {
      transform: scale(1.05);
      filter: saturate(0.7) contrast(1.1);
    }
    .ac-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(6,6,8,0.95) 0%, transparent 60%);
    }
    .ac-glow {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .artist-card:hover .ac-glow { opacity: 1; }
    .glow-c { background: radial-gradient(ellipse at center bottom, rgba(0,229,255,0.12) 0%, transparent 60%); }
    .glow-m { background: radial-gradient(ellipse at center bottom, rgba(255,0,102,0.12) 0%, transparent 60%); }

    .ac-body { padding: 1.25rem 1.5rem 1.5rem; }
    .ac-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      color: rgba(0,229,255,0.2);
      margin-bottom: 0.3rem;
    }
    .ac-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 0.05em;
      color: var(--text);
      line-height: 1;
      margin-bottom: 0.3rem;
    }
    .ac-genre {
      font-size: 0.6rem;
      font-weight: 300;
      color: rgba(255,255,255,0.3);
      margin-bottom: 0.6rem;
    }
    .ac-date {
      font-size: 0.52rem;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(0,229,255,0.45);
      border-top: 1px solid rgba(0,229,255,0.08);
      padding-top: 0.6rem;
    }

    /* ─── BOTTOM NEON LINE ─── */
    .neon-bar {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(
        to right,
        transparent,
        rgba(0,229,255,0.4) 20%,
        rgba(255,0,102,0.5) 50%,
        rgba(0,229,255,0.4) 80%,
        transparent
      );
      z-index: 50;
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 1100px) {
      .hero { grid-template-columns: 1fr; }
      .hero-right { display: none; }
      .hero-left { padding: 5rem 2.5rem; border-right: none; }
      .floor-inner { grid-template-columns: 1fr; gap: 3rem; padding: 0 2.5rem; }
      .floor-photos { height: 420px; grid-template-columns: 1fr 1fr; }
      .lineup-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      .s-inner { padding: 0 1.5rem; }
      .s-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
      .events-grid { grid-template-columns: 1fr; }
