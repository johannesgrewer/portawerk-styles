---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Atelier Blanc — Interior Design, Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    html { overflow-x: hidden; }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --primary: #2C2C2C;
      --secondary: #F8F6F3;
      --accent: #9C8B7A;
      --bg: #F8F6F3;
      --text: #2C2C2C;
      --font-display: "Cormorant", "Georgia", "Times New Roman", serif;
      --font-body: "Jost", system-ui, -apple-system, sans-serif;

      /* Spacing scale — 8px base */
      --space-xs: 0.5rem;    /* 8px */
      --space-sm: 1rem;      /* 16px */
      --space-md: 1.5rem;    /* 24px */
      --space-lg: 2rem;      /* 32px */
      --space-xl: 3rem;      /* 48px */
      --space-2xl: 4rem;     /* 64px */
      --space-3xl: 5rem;     /* 80px */
      --space-4xl: 8rem;     /* 128px */
    }

    html {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-weight: 300;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      scroll-behavior: smooth;
      scroll-padding-top: var(--space-4xl);
    }

    body {
      overflow-x: hidden;
      position: relative;
    }

    /* Faint linen texture — CSS noise at 2% opacity */
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9999;
      opacity: 0.02;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 256px 256px;
    }

    ::selection { background: var(--accent); color: var(--secondary); }

    img { display: block; max-width: 100%; }


    /* ═══════════════════════════════════════════
       ANIMATIONS — Subtle, barely perceptible
    ═══════════════════════════════════════════ */

    /* Ken Burns — very slow zoom on hero image */
    @keyframes kenBurns {
      0% { transform: scale(1); }
      50% { transform: scale(1.04); }
      100% { transform: scale(1); }
    }

    /* Accent line draw */
    @keyframes lineReveal {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }

    /* Word fade in */
    @keyframes wordFadeIn {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Section fade in on scroll */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Scroll-triggered reveal class */
    .reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.9s cubic-bezier(0.25, 0, 0.15, 1),
                  transform 0.9s cubic-bezier(0.25, 0, 0.15, 1);
    }

    .reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }


    /* ═══════════════════════════════════════════
       HERO
    ═══════════════════════════════════════════ */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      padding: 6rem 4rem;
      gap: 4rem;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-right: 2rem;
    }

    .hero-headline {
      font-family: var(--font-display);
      font-weight: 300;
      font-size: clamp(3rem, 5.5vw, 5.5rem);
      line-height: 1.15;
      letter-spacing: 0.04em;
      color: var(--primary);
      margin-bottom: var(--space-xl);
    }

    .hero-headline .word {
      display: inline-block;
      opacity: 0;
      animation: wordFadeIn 0.8s cubic-bezier(0.25, 0, 0.15, 1) forwards;
    }

    .hero-headline .word:nth-child(1) { animation-delay: 0.1s; }
    .hero-headline .word:nth-child(2) { animation-delay: 0.3s; }
    .hero-headline .word:nth-child(3) { animation-delay: 0.5s; }

    .hero-line {
      width: 60px;
      height: 1px;
      background: var(--accent);
      margin-bottom: var(--space-lg);
      transform-origin: left center;
      animation: lineReveal 1.6s cubic-bezier(0.25, 0, 0.15, 1) 0.4s both;
    }

    .hero-subtitle {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 3rem;
    }

    .hero-link {
      font-family: var(--font-body);
      font-weight: 400;
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      color: var(--primary);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.4em;
      transition: color 0.5s cubic-bezier(0.25, 0, 0.15, 1);
    }

    .hero-link .arrow {
      display: inline-block;
      transition: transform 0.5s cubic-bezier(0.33, 1, 0.68, 1);
    }

    .hero-link:hover {
      color: var(--accent);
    }

    .hero-link:hover .arrow {
      transform: translateX(6px);
    }

    .hero-image-wrapper {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      overflow: hidden;
    }

    .hero-image {
      width: 85%;
      max-width: 480px;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      animation: kenBurns 20s cubic-bezier(0.25, 0, 0.15, 1) infinite;
      cursor: crosshair;
    }


    /* ═══════════════════════════════════════════
       PROJEKTE
    ═══════════════════════════════════════════ */
    .projekte {
      padding: 8rem 4rem 6rem;
    }

    .section-label {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 4rem;
    }

    .projekte-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2rem;
      align-items: start;
    }

    .projekt-card {
      position: relative;
    }

    .projekt-card:nth-child(2) {
      margin-top: 4rem;
    }

    .projekt-image-wrapper {
      overflow: hidden;
      margin-bottom: var(--space-md);
      position: relative;
      cursor: crosshair;
    }

    /* Warm overlay on hover */
    .projekt-image-wrapper::after {
      content: "";
      position: absolute;
      inset: 0;
      background: rgba(156, 139, 122, 0);
      transition: background 0.7s cubic-bezier(0.25, 0, 0.15, 1);
      pointer-events: none;
      z-index: 1;
    }

    .projekt-card:hover .projekt-image-wrapper::after {
      background: rgba(156, 139, 122, 0.08);
    }

    .projekt-image {
      width: 100%;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      transition: transform 1s cubic-bezier(0.25, 0, 0.15, 1);
    }

    .projekt-card:hover .projekt-image {
      transform: scale(1.03);
    }

    .projekt-name {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 1.35rem;
      letter-spacing: 0.02em;
      margin-bottom: 0.5rem;
    }

    .projekt-description {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.8rem;
      color: var(--accent);
      line-height: 1.6;
      margin-bottom: 0.35rem;
    }

    .projekt-year {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      color: var(--accent);
      opacity: 0.7;
    }


    /* ═══════════════════════════════════════════
       PHILOSOPHIE
    ═══════════════════════════════════════════ */
    .philosophie {
      padding: 8rem 4rem 10rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .philosophie-text-column {
      max-width: 500px;
      text-align: center;
    }

    .philosophie-divider {
      width: 40px;
      height: 1px;
      background: var(--accent);
      margin: 0 auto var(--space-xl);
      transform-origin: center;
      transform: scaleX(0);
      transition: transform 1.4s cubic-bezier(0.25, 0, 0.15, 1);
    }

    /* Override generic .reveal for the divider — uses scaleX instead of translateY */
    .philosophie-divider.reveal {
      opacity: 1;
      transform: scaleX(0);
    }

    .philosophie-divider.is-visible {
      transform: scaleX(1);
    }

    .philosophie-quote {
      font-family: var(--font-display);
      font-weight: 300;
      font-style: italic;
      font-size: clamp(1.3rem, 2.2vw, 1.7rem);
      line-height: 1.7;
      letter-spacing: 0.01em;
      color: var(--primary);
      margin-bottom: var(--space-xl);
    }

    /* Elegant drop cap on first letter */
    .philosophie-quote::first-letter {
      font-family: var(--font-display);
      font-weight: 400;
      font-style: normal;
      font-size: 3.2em;
      float: left;
      line-height: 0.8;
      margin-right: 0.08em;
      margin-top: 0.05em;
      color: var(--accent);
    }

    .philosophie-attribution {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: var(--space-3xl);
    }

    .philosophie-contact {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.8rem;
      line-height: 2;
      color: var(--accent);
      text-align: center;
    }

    .philosophie-contact a {
      color: var(--accent);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .philosophie-contact a:hover {
      color: var(--primary);
    }

    .philosophie-note {
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      opacity: 0.6;
      margin-top: 2rem;
    }


    /* ═══════════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════════ */
    @media (max-width: 1024px) {
      .hero {
        grid-template-columns: 1fr;
        padding: 5rem 3rem;
        gap: 3rem;
        min-height: auto;
      }

      .hero-content {
        padding-right: 0;
        order: 2;
      }

      .hero-image-wrapper {
        order: 1;
        justify-content: center;
      }

      .hero-image {
        width: 70%;
        max-width: 400px;
      }

      .projekte {
        padding: 5rem 3rem 4rem;
      }

      .projekte-grid {
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      }

      .projekt-card:nth-child(2) {
        margin-top: 3rem;
      }

      .projekt-card:nth-child(3) {
        grid-column: 1 / -1;
        max-width: 50%;
      }

      .philosophie {
        padding: 5rem 3rem 7rem;
      }
    }

    @media (max-width: 640px) {
      .hero {
        padding: 4rem 1.5rem;
        gap: 2.5rem;
      }

      .hero-headline {
        font-size: 2.4rem;
        margin-bottom: 1.8rem;
      }

      .hero-image {
        width: 90%;
      }

      .projekte {
        padding: 4rem 1.5rem 3rem;
      }

      .projekte-grid {
        grid-template-columns: 1fr;
        gap: 3rem;
      }

      .projekt-card:nth-child(2) {
        margin-top: 0;
      }

      .projekt-card:nth-child(3) {
        max-width: 100%;
      }

      .philosophie {
        padding: 4rem 1.5rem 6rem;
      }

      .philosophie-text-column {
        max-width: 100%;
      }
    }
  </style>
</head>
<body>

  <!-- ════════════════════════════════════════════
       HERO — Negative Space Mastery
  ════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-headline"><span class="word">Raeume,</span><br /><span class="word">die</span> <span class="word">atmen.</span></h1>
      <div class="hero-line"></div>
      <p class="hero-subtitle">Atelier Blanc &middot; Interior Design &middot; Trier</p>
      <a href="#projekte" class="hero-link">Projekte ansehen <span class="arrow">&rarr;</span></a>
    </div>
    <div class="hero-image-wrapper">
      <img
        class="hero-image"
        src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=900&q=80&auto=format"
        alt="Minimalistisches Interior mit natuerlichem Licht"
        loading="eager"
      />
    </div>
  </section>


  <!-- ════════════════════════════════════════════
       PROJEKTE
  ════════════════════════════════════════════ -->
  <section class="projekte" id="projekte">
    <p class="section-label reveal">Projekte</p>
    <div class="projekte-grid">

      <div class="projekt-card reveal">
        <div class="projekt-image-wrapper">
          <img
            class="projekt-image"
            src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&q=80&auto=format"
            alt="Villa am Moselufer — helles Wohnzimmer mit Flussblick"
            loading="lazy"
          />
        </div>
        <h3 class="projekt-name">Villa am Moselufer</h3>
        <p class="projekt-description">Reduktion und Weite in 280 Quadratmetern am Wasser</p>
        <span class="projekt-year">2024</span>
      </div>

      <div class="projekt-card reveal">
        <div class="projekt-image-wrapper">
          <img
            class="projekt-image"
            src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=80&auto=format"
            alt="Loft Bahnhofsviertel — offener Grundriss mit Industriecharme"
            loading="lazy"
          />
        </div>
        <h3 class="projekt-name">Loft Bahnhofsviertel</h3>
        <p class="projekt-description">Industriegeschichte trifft auf zeitlose Eleganz</p>
        <span class="projekt-year">2023</span>
      </div>

      <div class="projekt-card reveal">
        <div class="projekt-image-wrapper">
          <img
            class="projekt-image"
            src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=800&q=80&auto=format"
            alt="Stadthaus Petrisberg — moderne Kueche mit Naturstein"
            loading="lazy"
          />
        </div>
        <h3 class="projekt-name">Stadthaus Petrisberg</h3>
        <p class="projekt-description">Drei Generationen unter einem ruhigen Dach</p>
        <span class="projekt-year">2023</span>
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════════
       PHILOSOPHIE
  ════════════════════════════════════════════ -->
  <section class="philosophie">
    <div class="philosophie-text-column">
      <div class="philosophie-divider reveal"></div>
      <p class="philosophie-quote reveal">
        Wir gestalten keine Raeume.<br />
        Wir hoeren zu, was ein Raum braucht.
      </p>
      <p class="philosophie-attribution reveal">Anna Weber, Gruenderin</p>

      <div class="philosophie-contact reveal">
        Atelier Blanc<br />
        Neustrasse 12, 54290 Trier<br />
        <a href="tel:+4965194820">+49 651 948 20</a>
      </div>
      <p class="philosophie-note reveal">Termine nach Vereinbarung</p>
    </div>
  </section>

  <!-- Scroll reveal observer -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const revealElements = document.querySelectorAll(".reveal");

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.15,
          rootMargin: "0px 0px -40px 0px",
        }
      );

      revealElements.forEach((el) => observer.observe(el));
    });
  </script>

</body>
</html>
