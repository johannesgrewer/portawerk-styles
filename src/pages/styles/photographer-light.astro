---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Weißlicht — Fotostudio & Bildgestaltung | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Figtree:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --dark:   #1A1A1A;
      --amber:  #E07A2F;
      --bg:     #FAFAFA;
      --white:  #FFFFFF;
      --muted:  rgba(26,26,26,0.4);
      --rule:   rgba(26,26,26,0.07);
    }

    body {
      background: var(--bg);
      color: var(--dark);
      font-family: 'Figtree', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 4.5rem;
      background: rgba(250,250,250,0.97);
      backdrop-filter: blur(8px);
    }
    .nav-logo {
      font-family: 'Instrument Serif', serif;
      font-size: 1.1rem;
      letter-spacing: 0.08em;
      color: var(--dark);
    }
    .nav-links {
      display: flex;
      gap: 3rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.58rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: var(--dark); }
    .nav-contact {
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--dark);
      text-decoration: none;
      border-bottom: 1px solid var(--dark);
      padding-bottom: 2px;
      transition: color 0.3s, border-color 0.3s;
    }
    .nav-contact:hover { color: var(--amber); border-color: var(--amber); }

    .hero {
      min-height: 100vh;
      padding-top: 72px;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    /* LEFT */
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 5rem 4.5rem 5rem 5rem;
      gap: 3rem;
      border-right: 1px solid var(--rule);
    }

    .eyebrow {
      font-size: 0.52rem;
      font-weight: 400;
      letter-spacing: 0.36em;
      text-transform: uppercase;
      color: var(--amber);
    }

    .hero-headline {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(2.8rem, 5vw, 4.5rem);
      line-height: 1.2;
      color: var(--dark);
      letter-spacing: 0.01em;
    }
    .hero-headline em {
      font-style: italic;
      color: var(--muted);
    }

    .amber-rule {
      width: 2rem;
      height: 2px;
      background: var(--amber);
    }

    .hero-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 2.1;
      color: var(--muted);
      max-width: 42ch;
    }

    /* Work list */
    .work-list {
      display: flex;
      flex-direction: column;
      border-top: 1px solid var(--rule);
    }
    .work-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 1rem 0;
      border-bottom: 1px solid var(--rule);
      transition: padding-left 0.3s;
      cursor: default;
    }
    .work-row:hover { padding-left: 0.35rem; }
    .wr-name {
      font-family: 'Instrument Serif', serif;
      font-size: 1rem;
      color: var(--dark);
    }
    .wr-cat {
      font-size: 0.62rem;
      font-weight: 300;
      color: var(--muted);
      letter-spacing: 0.08em;
    }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 2rem;
    }
    .cta-btn {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #fff;
      background: var(--dark);
      padding: 0.95rem 2.2rem;
      text-decoration: none;
      transition: background 0.3s;
    }
    .cta-btn:hover { background: var(--amber); }
    .cta-link {
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid rgba(26,26,26,0.12);
      padding-bottom: 1px;
    }

    /* RIGHT */
    .hero-right {
      display: flex;
      flex-direction: column;
      padding: 6rem 4.5rem 5rem 4rem;
      gap: 4rem;
    }

    /* Portrait number */
    .portrait-block {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .pb-label {
      font-size: 0.52rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.2);
    }
    .pb-num {
      font-family: 'Instrument Serif', serif;
      font-size: 5rem;
      font-weight: 400;
      line-height: 1;
      color: var(--amber);
      letter-spacing: -0.02em;
    }
    .pb-desc {
      font-size: 0.78rem;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.7;
    }

    .divider {
      width: 100%;
      height: 1px;
      background: var(--rule);
    }

    /* Process steps */
    .process-list {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .pl-label {
      font-size: 0.52rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.2);
      margin-bottom: 0.25rem;
    }
    .process-step {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
    }
    .ps-num {
      font-family: 'Instrument Serif', serif;
      font-size: 0.85rem;
      color: var(--amber);
      flex-shrink: 0;
      margin-top: 0.05rem;
    }
    .ps-info {}
    .ps-title {
      font-family: 'Instrument Serif', serif;
      font-size: 0.92rem;
      color: var(--dark);
    }
    .ps-desc {
      font-size: 0.65rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 0.1rem;
    }

    /* Awards / trust */
    .trust-row {
      display: flex;
      gap: 2.5rem;
    }
    .tr-item {}
    .tr-num {
      font-family: 'Instrument Serif', serif;
      font-size: 2rem;
      color: var(--dark);
      line-height: 1;
    }
    .tr-label {
      font-size: 0.55rem;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 0.2rem;
    }
    /* === Animations & Micro-interactions === */
    @keyframes floatNum {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(-6px); }
    }
    @keyframes ambientGlow {
      0%, 100% { text-shadow: none; }
      50%       { text-shadow: 0 0 40px rgba(224,122,47,0.18); }
    }

    .pb-num {
      animation: floatNum 5s ease-in-out infinite,
                 ambientGlow 5s ease-in-out infinite;
    }

    .work-row .wr-name { transition: color 0.3s; }
    .work-row:hover { background: rgba(224,122,47,0.03); }
    .work-row:hover .wr-name { color: var(--amber); }

    .process-step {
      transition: transform 0.2s;
      cursor: default;
    }
    .process-step:hover { transform: translateX(4px); }
    .process-step:hover .ps-title { color: var(--amber); }
    .ps-title { transition: color 0.2s; }

    .tr-item {
      cursor: default;
      transition: transform 0.2s;
    }
    .tr-item:hover { transform: translateY(-3px); }
    .tr-num { transition: color 0.2s; }
    .tr-item:hover .tr-num { color: var(--amber); }

    .cta-btn {
      position: relative;
      overflow: hidden;
    }
    .cta-btn::after {
      content: '';
      position: absolute;
      top: 0; left: -60%;
      width: 40%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
      transition: left 0.5s;
    }
    .cta-btn:hover::after { left: 150%; }

    /* Photo container */
    .ph { position: relative; overflow: hidden; }
    .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
    .ph:hover img { transform: scale(1.05); }

    /* Portfolio section */
    .section-portfolio {
      padding: 7rem 4.5rem;
      background: var(--bg);
      max-width: 1600px;
      margin: 0 auto;
    }
    .s-eyebrow {
      font-size: 0.52rem;
      font-weight: 400;
      letter-spacing: 0.36em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 0.6rem;
    }
    .s-heading {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(2rem, 4vw, 3.5rem);
      line-height: 1.15;
      color: var(--dark);
      letter-spacing: 0.01em;
      margin-bottom: 3.5rem;
    }
    .s-heading em { font-style: italic; color: var(--muted); }

    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .port-card {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .port-card-label {
      font-size: 0.52rem;
      font-weight: 400;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .port-card-title {
      font-family: 'Instrument Serif', serif;
      font-size: 1rem;
      color: var(--dark);
    }
    .port-card-sub {
      font-size: 0.68rem;
      font-weight: 300;
      color: var(--muted);
    }

    /* Packages section */
    .section-packages {
      padding: 7rem 4.5rem;
      background: var(--dark);
      max-width: 1600px;
      margin: 0 auto;
    }
    .pkg-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(255,255,255,0.08);
      margin-top: 3.5rem;
    }
    .pkg-card {
      background: #1A1A1A;
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .pkg-name {
      font-family: 'Instrument Serif', serif;
      font-size: 1.4rem;
      color: #fff;
    }
    .pkg-price {
      font-family: 'Instrument Serif', serif;
      font-size: 2.2rem;
      color: var(--amber);
      line-height: 1;
    }
    .pkg-desc {
      font-size: 0.75rem;
      font-weight: 300;
      line-height: 1.75;
      color: rgba(255,255,255,0.4);
    }
    .pkg-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: auto;
    }
    .pkg-list li {
      font-size: 0.7rem;
      font-weight: 300;
      color: rgba(255,255,255,0.5);
      padding-left: 1rem;
      position: relative;
    }
    .pkg-list li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: var(--amber);
    }
    .pkg-cta {
      display: block;
      text-align: center;
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--dark);
      background: var(--amber);
      text-decoration: none;
      padding: 0.85rem;
      margin-top: 0.5rem;
      transition: opacity 0.2s;
    }
    .pkg-cta:hover { opacity: 0.85; }

  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Weißlicht</div>
    <ul class="nav-links">
      <li><a href="#">Portrait</a></li>
      <li><a href="#">Produkt</a></li>
      <li><a href="#">Werbefotos</a></li>
      <li><a href="#">Studio</a></li>
    </ul>
    <a href="#" class="nav-contact">Anfrage stellen</a>
  </nav>

  <section class="hero">
    <div class="hero-left">
      <div class="eyebrow">Fotostudio · Trier</div>

      <h1 class="hero-headline">
        Das Licht<br>
        <em>entscheidet.</em>
      </h1>

      <div class="amber-rule"></div>

      <p class="hero-body">
        Gute Fotos entstehen nicht durch Zufall. Sie entstehen
        durch Vorbereitung, Vertrauen und das richtige Licht —
        im richtigen Moment, für den richtigen Moment.
      </p>

      <div class="work-list">
        <div class="work-row">
          <span class="wr-name">Corporate Portraits</span>
          <span class="wr-cat">Bewerbung · Team · Führungsebene</span>
        </div>
        <div class="work-row">
          <span class="wr-name">Produktfotografie</span>
          <span class="wr-cat">E-Commerce · Katalog · Lookbook</span>
        </div>
        <div class="work-row">
          <span class="wr-name">Werbefotografie</span>
          <span class="wr-cat">Kampagne · Social · Print</span>
        </div>
        <div class="work-row">
          <span class="wr-name">Reportage & Veranstaltung</span>
          <span class="wr-cat">Live · Dokumentation</span>
        </div>
      </div>

      <div class="cta-row">
        <a href="#" class="cta-btn">Projekt anfragen</a>
        <a href="#" class="cta-link">Portfolio ansehen →</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="portrait-block">
        <div class="pb-label">Erfahrung</div>
        <div class="pb-num">11</div>
        <div class="pb-desc">
          Jahre im Einsatz — für Unternehmen, Agenturen
          und Privatpersonen in der Region Trier.
        </div>
      </div>

      <div class="divider"></div>

      <div class="process-list">
        <div class="pl-label">Ablauf</div>
        <div class="process-step">
          <span class="ps-num">01</span>
          <div class="ps-info">
            <div class="ps-title">Briefing</div>
            <div class="ps-desc">Ziele, Zielgruppe, Nutzungsrechte</div>
          </div>
        </div>
        <div class="process-step">
          <span class="ps-num">02</span>
          <div class="ps-info">
            <div class="ps-title">Konzept & Vorbereitung</div>
            <div class="ps-desc">Moodboard, Lichtsetzung, Styling-Empfehlung</div>
          </div>
        </div>
        <div class="process-step">
          <span class="ps-num">03</span>
          <div class="ps-info">
            <div class="ps-title">Shooting</div>
            <div class="ps-desc">Im Studio oder on Location</div>
          </div>
        </div>
        <div class="process-step">
          <span class="ps-num">04</span>
          <div class="ps-info">
            <div class="ps-title">Bildauswahl & Retusche</div>
            <div class="ps-desc">Gemeinsame Selektion, professionelle Nachbearbeitung</div>
          </div>
        </div>
      </div>

      <div class="trust-row">
        <div class="tr-item">
          <div class="tr-num">280+</div>
          <div class="tr-label">Kunden</div>
        </div>
        <div class="tr-item">
          <div class="tr-num">3</div>
          <div class="tr-label">Auszeichnungen</div>
        </div>
        <div class="tr-item">
          <div class="tr-num">2</div>
          <div class="tr-label">Studios</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Portfolio -->
  <div style="background:var(--bg);">
    <section class="section-portfolio">
      <div class="s-eyebrow">Portfolio</div>
      <h2 class="s-heading">Bilder, die<br><em>bleiben.</em></h2>
      <div class="portfolio-grid">
        <div class="port-card">
          <div class="ph" style="height:320px; border-radius:2px;">
            <img src="https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&w=800&h=1000&q=80" alt="Portrait Fotografie" loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.35) 0%,transparent 55%);pointer-events:none;"></div>
          </div>
          <div class="port-card-label">Portrait</div>
          <div class="port-card-title">Corporate & Bewerbung</div>
          <div class="port-card-sub">Führungsebene · Team · Einzelperson</div>
        </div>
        <div class="port-card">
          <div class="ph" style="height:320px; border-radius:2px;">
            <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=800&h=1000&q=80" alt="Editorial Fotografie" loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.35) 0%,transparent 55%);pointer-events:none;"></div>
          </div>
          <div class="port-card-label">Editorial</div>
          <div class="port-card-title">Mode & Magazin</div>
          <div class="port-card-sub">Lookbook · Kampagne · Print</div>
        </div>
        <div class="port-card">
          <div class="ph" style="height:320px; border-radius:2px;">
            <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=800&h=1000&q=80" alt="Werbefotografie" loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.35) 0%,transparent 55%);pointer-events:none;"></div>
          </div>
          <div class="port-card-label">Werbung</div>
          <div class="port-card-title">Produkt & Marke</div>
          <div class="port-card-sub">E-Commerce · Social · OOH</div>
        </div>
      </div>
    </section>
  </div>

  <!-- SECTION 3: Pakete & Buchung -->
  <div style="background:var(--dark);">
    <section class="section-packages">
      <div style="font-size:0.52rem;font-weight:400;letter-spacing:0.36em;text-transform:uppercase;color:var(--amber);margin-bottom:0.6rem;">Pakete & Preise</div>
      <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(2rem,4vw,3.5rem);line-height:1.15;color:#fff;letter-spacing:0.01em;">Einfach<br><em style="font-style:italic;color:rgba(255,255,255,0.4);">transparent.</em></h2>
      <div class="pkg-grid">
        <div class="pkg-card">
          <div class="pkg-name">Essential</div>
          <div class="pkg-price">180 €</div>
          <div class="pkg-desc">Perfekt für Einzelpersonen, Bewerbungsfotos und kleine Teams bis 3 Personen.</div>
          <ul class="pkg-list">
            <li>2 Stunden Shooting</li>
            <li>15 retuschierte Aufnahmen</li>
            <li>Digitale Lieferung</li>
            <li>1 Outfit</li>
          </ul>
          <a href="#" class="pkg-cta">Buchen →</a>
        </div>
        <div class="pkg-card">
          <div class="pkg-name">Business</div>
          <div class="pkg-price">420 €</div>
          <div class="pkg-desc">Für Unternehmen, Teams und professionelle Kampagnen mit mehreren Motiven.</div>
          <ul class="pkg-list">
            <li>4 Stunden Shooting</li>
            <li>40 retuschierte Aufnahmen</li>
            <li>Moodboard & Vorbereitung</li>
            <li>Bis zu 8 Personen</li>
          </ul>
          <a href="#" class="pkg-cta">Buchen →</a>
        </div>
        <div class="pkg-card">
          <div class="pkg-name">Produktion</div>
          <div class="pkg-price">auf Anfrage</div>
          <div class="pkg-desc">Große Kampagnen, Werbeproduktionen und langfristige Kooperationen.</div>
          <ul class="pkg-list">
            <li>Ganztages-Shooting</li>
            <li>Unbegrenzte Motive</li>
            <li>Stylingsupport</li>
            <li>Nutzungsrechte inklusive</li>
          </ul>
          <a href="#" class="pkg-cta">Anfragen →</a>
        </div>
      </div>
    </section>
  </div>

</body>
</html>
