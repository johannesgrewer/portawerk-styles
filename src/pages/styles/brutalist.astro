---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>BLOC — Grafikdesign & Art Direction | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --bg: #F0EDE8;
      --ink: #1A1A1A;
      --red: #FF2D00;
      --border: 2px solid #1A1A1A;
      --border-heavy: 3px solid #1A1A1A;
    }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: 'Space Grotesk', sans-serif;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    a { text-decoration: none; color: inherit; }
    img { display: block; }

    /* ─── UTILITIES ─── */
    .mono { font-family: 'Space Mono', monospace; }
    .ph { position: relative; overflow: hidden; }
    .ph img {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; transition: transform 0.6s ease;
    }
    .ph:hover img { transform: scale(1.04); }
    .overlay-dark {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(26,26,26,0.65) 0%, transparent 55%);
      pointer-events: none;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      height: 52px;
      display: flex; align-items: stretch;
      border-bottom: var(--border-heavy);
      background: var(--bg);
    }
    .nav-logo {
      display: flex; align-items: center;
      padding: 0 1.5rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.9rem; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--bg); background: var(--ink);
      border-right: var(--border-heavy);
      white-space: nowrap;
    }
    .nav-links {
      display: flex; list-style: none; height: 100%;
    }
    .nav-links li { border-right: var(--border); }
    .nav-links a {
      display: flex; align-items: center;
      padding: 0 1.2rem; height: 100%;
      font-family: 'Space Mono', monospace;
      font-size: 0.55rem; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--ink); transition: background 0.1s, color 0.1s;
    }
    .nav-links a:hover { background: var(--red); color: var(--bg); }
    .nav-right {
      margin-left: auto; display: flex; align-items: center;
      padding: 0 1.5rem; border-left: var(--border);
      font-family: 'Space Mono', monospace;
      font-size: 0.5rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(26,26,26,0.4);
    }

    /* ─── MARQUEE ─── */
    .marquee-strip {
      margin-top: 52px;
      background: var(--ink);
      border-bottom: var(--border-heavy);
      overflow: hidden; height: 36px;
      display: flex; align-items: center;
    }
    .marquee-track {
      display: flex; gap: 0;
      animation: marquee 28s linear infinite;
      white-space: nowrap;
    }
    .marquee-track span {
      font-family: 'Space Mono', monospace;
      font-size: 0.5rem; font-weight: 700;
      letter-spacing: 0.25em; text-transform: uppercase;
      color: rgba(240,237,232,0.55);
      padding: 0 2rem;
    }
    .marquee-track span.accent { color: var(--red); }
    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    /* ─── HERO ─── */
    .hero {
      display: grid;
      grid-template-rows: auto 1fr auto;
    }
    .top-bar {
      display: flex; border-bottom: var(--border);
    }
    .top-cell {
      flex: 1; padding: 0.85rem 1.5rem;
      border-right: var(--border);
      font-family: 'Space Mono', monospace;
      font-size: 0.48rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(26,26,26,0.38);
    }
    .top-cell:last-child { border-right: none; }
    .top-cell.accent { background: var(--red); color: var(--bg); }

    .hero-main {
      display: grid;
      grid-template-columns: 1fr 420px;
      border-bottom: var(--border);
      min-height: calc(100vh - 52px - 36px - 39px - 64px);
    }

    /* Left */
    .hero-left {
      padding: 3.5rem 3rem;
      border-right: var(--border);
      display: flex; flex-direction: column;
      justify-content: space-between;
    }
    .hero-index {
      font-family: 'Space Mono', monospace;
      font-size: 0.5rem; font-weight: 700;
      letter-spacing: 0.28em; text-transform: uppercase;
      color: rgba(26,26,26,0.3);
      margin-bottom: 2.5rem;
    }
    h1.hero-headline {
      font-size: clamp(4rem, 9.5vw, 8.5rem);
      font-weight: 700;
      line-height: 0.88;
      letter-spacing: -0.04em;
      text-transform: uppercase;
    }
    .hero-headline .stroke {
      -webkit-text-stroke: 2.5px var(--ink);
      color: transparent;
    }
    .hero-headline .fill { color: var(--ink); }
    .hero-headline .red { color: var(--red); }

    .hero-foot {
      display: flex; align-items: flex-end;
      justify-content: space-between;
      margin-top: 3rem; gap: 2rem;
    }
    .hero-tagline {
      font-size: 0.875rem; font-weight: 300;
      line-height: 1.65; max-width: 30ch;
      color: rgba(26,26,26,0.6);
    }
    .cta-btn {
      display: inline-flex; align-items: center;
      background: var(--red); color: var(--bg);
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      padding: 0.9rem 1.6rem;
      border: 3px solid var(--red);
      white-space: nowrap;
      transition: background 0.1s, color 0.1s;
    }
    .cta-btn:hover { background: var(--bg); color: var(--red); }

    /* Right */
    .hero-right {
      display: flex; flex-direction: column;
    }
    .hero-photo-panel {
      flex: 1;
    }
    .hero-photo-panel .ph {
      height: 100%; min-height: 320px;
    }
    .hero-services {
      background: var(--ink);
      padding: 1.75rem 1.75rem;
      border-top: var(--border-heavy);
    }
    .services-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.45rem; font-weight: 700;
      letter-spacing: 0.25em; text-transform: uppercase;
      color: rgba(240,237,232,0.35);
      margin-bottom: 1rem;
    }
    .services-list {
      list-style: none; display: flex;
      flex-direction: column; gap: 0;
    }
    .services-list li {
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 0.6rem 0;
      border-bottom: 1px solid rgba(240,237,232,0.08);
      font-size: 0.72rem; font-weight: 500;
      letter-spacing: 0.03em; color: var(--bg);
    }
    .services-list li:last-child { border-bottom: none; }
    .svc-arrow { color: var(--red); }
    .hero-year-bar {
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 1rem 1.75rem;
      border-top: var(--border-heavy);
    }
    .year-num {
      font-family: 'Space Mono', monospace;
      font-size: 2rem; font-weight: 700;
      color: var(--red); line-height: 1;
      letter-spacing: -0.04em;
    }
    .year-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.45rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(26,26,26,0.3); text-align: right;
    }

    /* Stats bar */
    .stats-bar {
      display: grid; grid-template-columns: repeat(4, 1fr);
    }
    .stat-cell {
      padding: 1.25rem 1.5rem;
      border-right: var(--border);
    }
    .stat-cell:last-child { border-right: none; }
    .stat-num {
      font-size: 1.5rem; font-weight: 700;
      line-height: 1; margin-bottom: 0.2rem;
    }
    .stat-lbl {
      font-family: 'Space Mono', monospace;
      font-size: 0.45rem; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(26,26,26,0.38);
    }
    .stat-cell.hl { background: var(--red); }
    .stat-cell.hl .stat-num,
    .stat-cell.hl .stat-lbl { color: var(--bg); }

    /* ─── SECTION HEADER BAR ─── */
    .sec-bar {
      display: flex; align-items: stretch;
      border-top: var(--border-heavy);
      border-bottom: var(--border);
    }
    .sec-bar-num {
      background: var(--red); color: var(--bg);
      font-family: 'Space Mono', monospace;
      font-size: 0.52rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      padding: 0.9rem 1.4rem;
      border-right: var(--border);
      display: flex; align-items: center;
    }
    .sec-bar-title {
      flex: 1; padding: 0.9rem 1.4rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.5rem; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(26,26,26,0.42);
      display: flex; align-items: center;
      border-right: var(--border);
    }
    .sec-bar-tag {
      padding: 0.9rem 1.4rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.48rem; font-weight: 700;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: rgba(26,26,26,0.28);
      display: flex; align-items: center;
    }

    /* ─── SECTION 002: PORTFOLIO ─── */
    /* Featured row */
    .portfolio-featured {
      display: grid;
      grid-template-columns: 2fr 1fr;
      border-bottom: var(--border);
    }
    .featured-photo {
      height: 480px;
      border-right: var(--border);
      position: relative;
    }
    .featured-label-strip {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 1.5rem;
      background: linear-gradient(to top, rgba(26,26,26,0.88) 0%, transparent 100%);
      z-index: 2;
    }
    .featured-year {
      font-family: 'Space Mono', monospace;
      font-size: 0.45rem; font-weight: 700;
      letter-spacing: 0.25em; text-transform: uppercase;
      color: rgba(240,237,232,0.55);
      margin-bottom: 0.4rem;
    }
    .featured-title {
      font-size: 1.5rem; font-weight: 700;
      letter-spacing: -0.02em; text-transform: uppercase;
      color: var(--bg); line-height: 1.1;
    }
    .featured-tags {
      display: flex; gap: 0.4rem; flex-wrap: wrap;
      margin-top: 0.6rem;
    }
    .tag {
      font-family: 'Space Mono', monospace;
      font-size: 0.42rem; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      padding: 0.22rem 0.55rem;
      border: 1.5px solid rgba(240,237,232,0.5);
      color: var(--bg);
    }
    .tag.red { background: var(--red); border-color: var(--red); }

    .featured-side {
      display: flex; flex-direction: column;
    }
    .featured-side-card {
      flex: 1; display: flex; flex-direction: column;
      border-bottom: var(--border);
    }
    .featured-side-card:last-child { border-bottom: none; }
    .side-photo { height: 200px; }
    .side-card-body {
      padding: 1.25rem;
      border-top: var(--border);
      flex: 1;
    }
    .side-card-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.42rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(26,26,26,0.32);
      margin-bottom: 0.4rem;
    }
    .side-card-title {
      font-size: 0.875rem; font-weight: 700;
      letter-spacing: -0.01em; text-transform: uppercase;
      color: var(--ink); line-height: 1.2;
    }
    .side-card-tags {
      display: flex; gap: 0.35rem; flex-wrap: wrap;
      margin-top: 0.6rem;
    }
    .tag-dark {
      font-family: 'Space Mono', monospace;
      font-size: 0.4rem; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase;
      padding: 0.2rem 0.5rem;
      border: 1.5px solid var(--ink);
      color: var(--ink);
    }
    .tag-dark.red { background: var(--red); border-color: var(--red); color: var(--bg); }

    /* Bottom row */
    .portfolio-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-bottom: var(--border-heavy);
    }
    .portfolio-card-sm {
      border-right: var(--border);
      display: flex; flex-direction: column;
    }
    .portfolio-card-sm:last-child { border-right: none; }
    .sm-photo { height: 220px; }
    .sm-body {
      padding: 1.25rem;
      border-top: var(--border);
    }

    /* ─── SECTION 003: MANIFESTO ─── */
    .manifesto-section {
      background: var(--ink);
      border-bottom: var(--border-heavy);
    }
    .manifesto-sec-bar {
      display: flex; align-items: stretch;
      border-bottom: 2px solid rgba(240,237,232,0.12);
    }
    .manifesto-sec-bar .sec-bar-num { border-right-color: rgba(240,237,232,0.12); }
    .manifesto-sec-bar .sec-bar-title {
      color: rgba(240,237,232,0.28);
      border-right-color: rgba(240,237,232,0.12);
    }
    .manifesto-sec-bar .sec-bar-tag { color: rgba(240,237,232,0.18); }
    .manifesto-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .manifesto-left {
      padding: 4rem 3rem;
      border-right: 2px solid rgba(240,237,232,0.1);
      display: flex; flex-direction: column;
      justify-content: space-between;
    }
    .manifesto-big {
      font-size: clamp(4.5rem, 10vw, 9rem);
      font-weight: 700; line-height: 0.85;
      letter-spacing: -0.04em; text-transform: uppercase;
    }
    .manifesto-big .outline {
      -webkit-text-stroke: 2px var(--bg);
      color: transparent;
    }
    .manifesto-big .solid { color: var(--bg); }
    .manifesto-big .accent { color: var(--red); -webkit-text-stroke: 0; }
    .manifesto-text {
      margin-top: 3rem;
      font-size: 0.9rem; font-weight: 300;
      line-height: 1.75; color: rgba(240,237,232,0.55);
      max-width: 44ch;
      border-top: 1px solid rgba(240,237,232,0.15);
      padding-top: 2rem;
    }
    .manifesto-right {
      display: flex; flex-direction: column;
    }
    .manifesto-photo { flex: 1; min-height: 380px; }
    .manifesto-quote-bar {
      padding: 1.5rem 2rem;
      border-top: 2px solid rgba(240,237,232,0.12);
      display: flex; align-items: center; gap: 1.5rem;
    }
    .manifesto-quote-mark {
      font-size: 3rem; font-weight: 700; color: var(--red); line-height: 1;
      font-family: 'Space Mono', monospace;
    }
    .manifesto-quote-text {
      font-size: 0.82rem; font-style: italic;
      color: rgba(240,237,232,0.48); line-height: 1.55;
    }

    /* ─── SECTION 004: KONTAKT ─── */
    .contact-section { }
    .contact-grid {
      display: grid; grid-template-columns: 1fr 1fr;
    }
    .contact-left {
      padding: 3rem; border-right: var(--border);
      display: flex; flex-direction: column; gap: 2rem;
    }
    .contact-field-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.45rem; font-weight: 700;
      letter-spacing: 0.25em; text-transform: uppercase;
      color: rgba(26,26,26,0.35);
      margin-bottom: 0.4rem;
    }
    .contact-field-value {
      font-size: 1rem; font-weight: 700;
      letter-spacing: -0.01em; text-transform: uppercase; color: var(--ink);
    }
    .contact-field-value.light {
      font-size: 0.85rem; font-weight: 300;
      letter-spacing: 0.01em; text-transform: none;
    }
    .avail-block {
      background: var(--red); padding: 1.5rem;
      display: flex; align-items: center;
      justify-content: space-between;
    }
    .avail-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.45rem; font-weight: 700;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: rgba(240,237,232,0.7);
      margin-bottom: 0.3rem;
    }
    .avail-status {
      font-size: 1.3rem; font-weight: 700;
      color: var(--bg); letter-spacing: -0.02em;
      text-transform: uppercase;
    }
    .avail-dot {
      width: 12px; height: 12px;
      border-radius: 50%;
      background: var(--bg);
      box-shadow: 0 0 0 4px rgba(240,237,232,0.35);
    }
    .contact-right { display: flex; flex-direction: column; }
    .process-header {
      padding: 0.9rem 1.4rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.5rem; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(26,26,26,0.42);
      border-bottom: var(--border);
    }
    .process-list { list-style: none; }
    .process-item {
      display: flex; align-items: stretch;
      border-bottom: var(--border);
    }
    .process-item:last-child { border-bottom: none; }
    .process-num {
      background: var(--ink); color: var(--bg);
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.1em;
      padding: 1rem 1.25rem;
      border-right: var(--border);
      display: flex; align-items: center;
      min-width: 58px;
    }
    .process-text {
      padding: 1rem 1.25rem;
      font-size: 0.78rem; font-weight: 400;
      color: var(--ink); display: flex; align-items: center;
      line-height: 1.5;
    }

    /* ─── FOOTER ─── */
    footer {
      border-top: var(--border-heavy);
      display: flex; align-items: center;
      padding: 0;
    }
    .footer-logo {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      padding: 1.1rem 1.5rem;
      background: var(--ink); color: var(--bg);
      border-right: var(--border-heavy);
    }
    .footer-text {
      padding: 1.1rem 1.5rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.45rem; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(26,26,26,0.3);
    }
    .footer-copy {
      margin-left: auto;
      padding: 1.1rem 1.5rem;
      border-left: var(--border);
      font-family: 'Space Mono', monospace;
      font-size: 0.45rem; font-weight: 700;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: rgba(26,26,26,0.25);
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      .hero-main { grid-template-columns: 1fr; }
      .hero-photo-panel { display: none; }
      .hero-services { border-top: var(--border-heavy); }
      .portfolio-featured { grid-template-columns: 1fr; }
      .featured-side { display: none; }
      .portfolio-row { grid-template-columns: 1fr 1fr; }
      .manifesto-grid { grid-template-columns: 1fr; }
      .manifesto-right { display: none; }
      .contact-grid { grid-template-columns: 1fr; }
      .contact-left { border-right: none; border-bottom: var(--border); }
    }
    @media (max-width: 600px) {
      .nav-links { display: none; }
      .top-bar { flex-wrap: wrap; }
      .top-cell { min-width: 50%; border-bottom: var(--border); }
      .stats-bar { grid-template-columns: repeat(2, 1fr); }
      .stats-bar .stat-cell:nth-child(2) { border-right: none; }
      .stats-bar .stat-cell:nth-child(3) { border-right: var(--border); }
      .portfolio-row { grid-template-columns: 1fr; }
      .portfolio-card-sm { border-right: none; border-bottom: var(--border); }
      .portfolio-card-sm:last-child { border-bottom: none; }
      .hero-left { padding: 2rem 1.5rem; }
      .manifesto-left { padding: 2.5rem 1.5rem; }
      .contact-left { padding: 2rem 1.5rem; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">BLOC</div>
  <ul class="nav-links">
    <li><a href="#">Projekte</a></li>
    <li><a href="#">Services</a></li>
    <li><a href="#">Studio</a></li>
    <li><a href="#">Kontakt</a></li>
  </ul>
  <div class="nav-right mono">Trier · DE</div>
</nav>

<!-- MARQUEE -->
<div class="marquee-strip">
  <div class="marquee-track">
    <span>BLOC Studio</span>
    <span class="accent">✦</span>
    <span>Grafikdesign</span>
    <span class="accent">✦</span>
    <span>Art Direction</span>
    <span class="accent">✦</span>
    <span>Corporate Identity</span>
    <span class="accent">✦</span>
    <span>Editorial Design</span>
    <span class="accent">✦</span>
    <span>Trier · Rheinland-Pfalz</span>
    <span class="accent">✦</span>
    <span>Seit 2016</span>
    <span class="accent">✦</span>
    <span>Keine Kompromisse</span>
    <span class="accent">✦</span>
    <!-- duplicate for seamless loop -->
    <span>BLOC Studio</span>
    <span class="accent">✦</span>
    <span>Grafikdesign</span>
    <span class="accent">✦</span>
    <span>Art Direction</span>
    <span class="accent">✦</span>
    <span>Corporate Identity</span>
    <span class="accent">✦</span>
    <span>Editorial Design</span>
    <span class="accent">✦</span>
    <span>Trier · Rheinland-Pfalz</span>
