---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>BLOC — Grafikdesign & Art Direction | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }
    body {
      background: #F0EDE8;
      color: #1A1A1A;
      font-family: 'Space Grotesk', monospace, sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: stretch;
      height: 52px;
      border-bottom: 3px solid #1A1A1A;
      background: #F0EDE8;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      padding: 0 1.5rem;
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: #F0EDE8;
      background: #1A1A1A;
      border-right: 3px solid #1A1A1A;
      text-transform: uppercase;
    }
    .nav-links {
      display: flex;
      list-style: none;
      height: 100%;
    }
    .nav-links li {
      border-right: 2px solid #1A1A1A;
    }
    .nav-links a {
      display: flex;
      align-items: center;
      padding: 0 1.25rem;
      height: 100%;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #1A1A1A;
      text-decoration: none;
      transition: background 0.1s, color 0.1s;
    }
    .nav-links a:hover { background: #FF2D00; color: #F0EDE8; }
    .nav-right {
      margin-left: auto;
      display: flex;
      align-items: center;
      padding: 0 1.5rem;
      border-left: 2px solid #1A1A1A;
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.4);
    }

    .hero {
      min-height: 100vh;
      padding-top: 52px;
      display: grid;
      grid-template-rows: auto 1fr auto;
    }

    /* TOP BAR */
    .top-bar {
      display: flex;
      border-bottom: 2px solid #1A1A1A;
    }
    .top-cell {
      flex: 1;
      padding: 1rem 1.5rem;
      border-right: 2px solid #1A1A1A;
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.4);
    }
    .top-cell:last-child { border-right: none; }
    .top-cell.accent { background: #FF2D00; color: #F0EDE8; }

    /* MAIN */
    .hero-main {
      display: grid;
      grid-template-columns: 1fr 380px;
      border-bottom: 2px solid #1A1A1A;
    }

    .hero-left {
      padding: 3rem 3rem 3rem 3rem;
      border-right: 2px solid #1A1A1A;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .hero-num {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-bottom: 2rem;
      color: rgba(26,26,26,0.35);
    }

    .hero-headline {
      font-size: clamp(4.5rem, 10vw, 9rem);
      font-weight: 700;
      line-height: 0.88;
      letter-spacing: -0.04em;
      text-transform: uppercase;
    }
    .hero-headline .stroke {
      -webkit-text-stroke: 3px #1A1A1A;
      color: transparent;
    }
    .hero-headline .fill { color: #1A1A1A; }
    .hero-headline .red { color: #FF2D00; }

    .hero-bottom-row {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-top: 3rem;
      gap: 2rem;
    }
    .hero-tagline {
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 1.6;
      max-width: 32ch;
      color: rgba(26,26,26,0.65);
    }
    .cta-btn {
      display: inline-block;
      background: #FF2D00;
      color: #F0EDE8;
      text-decoration: none;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 1rem 1.75rem;
      white-space: nowrap;
      border: 3px solid #FF2D00;
      transition: background 0.1s, color 0.1s;
    }
    .cta-btn:hover { background: #F0EDE8; color: #FF2D00; }

    /* RIGHT COLUMN */
    .hero-right {
      display: flex;
      flex-direction: column;
    }
    .right-top {
      background: #1A1A1A;
      color: #F0EDE8;
      padding: 2.5rem 2rem;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    .right-label {
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.4);
      margin-bottom: 1.5rem;
    }
    .service-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .service-list li {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(240,237,232,0.1);
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: #F0EDE8;
    }
    .service-list li:last-child { border-bottom: none; }
    .service-arrow { color: #FF2D00; }

    .right-bottom {
      border-top: 3px solid #1A1A1A;
      padding: 1.5rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .year-badge {
      font-size: 2.5rem;
      font-weight: 700;
      color: #FF2D00;
      line-height: 1;
      letter-spacing: -0.04em;
    }
    .founded-text {
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.35);
      text-align: right;
    }

    /* BOTTOM GRID */
    .bottom-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }
    .bottom-cell {
      padding: 1.25rem 1.5rem;
      border-right: 2px solid #1A1A1A;
    }
    .bottom-cell:last-child { border-right: none; }
    .bottom-cell-num {
      font-size: 1.4rem;
      font-weight: 700;
      color: #1A1A1A;
      line-height: 1;
      margin-bottom: 0.2rem;
    }
    .bottom-cell-label {
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.4);
    }
    .bottom-cell.highlight { background: #FF2D00; }
    .bottom-cell.highlight .bottom-cell-num,
    .bottom-cell.highlight .bottom-cell-label { color: #F0EDE8; }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">BLOC</div>
    <ul class="nav-links">
      <li><a href="#">Projekte</a></li>
      <li><a href="#">Services</a></li>
      <li><a href="#">Studio</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <div class="nav-right">Trier · DE</div>
  </nav>

  <section class="hero">
    <div class="top-bar">
      <div class="top-cell">Grafikdesign & Art Direction</div>
      <div class="top-cell accent">Verfügbar — Q2 2026</div>
      <div class="top-cell">Trier, Rheinland-Pfalz</div>
      <div class="top-cell">hello@bloc-studio.de</div>
    </div>

    <div class="hero-main">
      <div class="hero-left">
        <div>
          <div class="hero-num">001 — Studio</div>
          <h1 class="hero-headline">
            <span class="stroke">De</span><span class="fill">sign</span><br>
            <span class="fill">das nicht</span><br>
            <span class="fill">um </span><span class="red">Er</span><span class="fill">laub</span><br>
            <span class="fill">nis</span> <span class="stroke">fragt.</span>
          </h1>
        </div>
        <div class="hero-bottom-row">
          <p class="hero-tagline">
            BLOC ist ein Designstudio für Marken, die auffallen wollen.
            Kein Mainstream. Keine Kompromisse.
          </p>
          <a href="#" class="cta-btn">Projekt starten →</a>
        </div>
      </div>

      <div class="hero-right">
        <div class="right-top">
          <div class="right-label">Leistungen</div>
          <ul class="service-list">
            <li>Corporate Identity <span class="service-arrow">→</span></li>
            <li>Editorial Design <span class="service-arrow">→</span></li>
            <li>Packaging & Print <span class="service-arrow">→</span></li>
            <li>Art Direction <span class="service-arrow">→</span></li>
            <li>Motion & Digital <span class="service-arrow">→</span></li>
          </ul>
        </div>
        <div class="right-bottom">
          <div class="year-badge">2016</div>
          <div class="founded-text">Studio<br>gegründet</div>
        </div>
      </div>
    </div>

    <div class="bottom-grid">
      <div class="bottom-cell">
        <div class="bottom-cell-num">80+</div>
        <div class="bottom-cell-label">Projekte</div>
      </div>
      <div class="bottom-cell highlight">
        <div class="bottom-cell-num">12</div>
        <div class="bottom-cell-label">Auszeichnungen</div>
      </div>
      <div class="bottom-cell">
        <div class="bottom-cell-num">3</div>
        <div class="bottom-cell-label">Kontinente</div>
      </div>
      <div class="bottom-cell">
        <div class="bottom-cell-num">1</div>
        <div class="bottom-cell-label">Regel: keine</div>
      </div>
    </div>
  </section>
</body>
</html>
