---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>BLOC — Grafikdesign & Art Direction | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }
    body {
      background: #F0EDE8;
      color: #1A1A1A;
      font-family: 'Space Grotesk', monospace, sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: stretch;
      height: 52px;
      border-bottom: 3px solid #1A1A1A;
      background: #F0EDE8;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      padding: 0 1.5rem;
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: #F0EDE8;
      background: #1A1A1A;
      border-right: 3px solid #1A1A1A;
      text-transform: uppercase;
    }
    .nav-links {
      display: flex;
      list-style: none;
      height: 100%;
    }
    .nav-links li {
      border-right: 2px solid #1A1A1A;
    }
    .nav-links a {
      display: flex;
      align-items: center;
      padding: 0 1.25rem;
      height: 100%;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #1A1A1A;
      text-decoration: none;
      transition: background 0.1s, color 0.1s;
    }
    .nav-links a:hover { background: #FF2D00; color: #F0EDE8; }
    .nav-right {
      margin-left: auto;
      display: flex;
      align-items: center;
      padding: 0 1.5rem;
      border-left: 2px solid #1A1A1A;
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.4);
    }

    .hero {
      min-height: 100vh;
      padding-top: 52px;
      display: grid;
      grid-template-rows: auto 1fr auto;
    }

    /* TOP BAR */
    .top-bar {
      display: flex;
      border-bottom: 2px solid #1A1A1A;
    }
    .top-cell {
      flex: 1;
      padding: 1rem 1.5rem;
      border-right: 2px solid #1A1A1A;
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.4);
    }
    .top-cell:last-child { border-right: none; }
    .top-cell.accent { background: #FF2D00; color: #F0EDE8; }

    /* MAIN */
    .hero-main {
      display: grid;
      grid-template-columns: 1fr 380px;
      border-bottom: 2px solid #1A1A1A;
    }

    .hero-left {
      padding: 3rem 3rem 3rem 3rem;
      border-right: 2px solid #1A1A1A;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .hero-num {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-bottom: 2rem;
      color: rgba(26,26,26,0.35);
    }

    .hero-headline {
      font-size: clamp(4.5rem, 10vw, 9rem);
      font-weight: 700;
      line-height: 0.88;
      letter-spacing: -0.04em;
      text-transform: uppercase;
    }
    .hero-headline .stroke {
      -webkit-text-stroke: 3px #1A1A1A;
      color: transparent;
    }
    .hero-headline .fill { color: #1A1A1A; }
    .hero-headline .red { color: #FF2D00; }

    .hero-bottom-row {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-top: 3rem;
      gap: 2rem;
    }
    .hero-tagline {
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 1.6;
      max-width: 32ch;
      color: rgba(26,26,26,0.65);
    }
    .cta-btn {
      display: inline-block;
      background: #FF2D00;
      color: #F0EDE8;
      text-decoration: none;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 1rem 1.75rem;
      white-space: nowrap;
      border: 3px solid #FF2D00;
      transition: background 0.1s, color 0.1s;
    }
    .cta-btn:hover { background: #F0EDE8; color: #FF2D00; }

    /* RIGHT COLUMN */
    .hero-right {
      display: flex;
      flex-direction: column;
    }
    .right-top {
      background: #1A1A1A;
      color: #F0EDE8;
      padding: 2.5rem 2rem;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    .right-label {
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.4);
      margin-bottom: 1.5rem;
    }
    .service-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .service-list li {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(240,237,232,0.1);
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: #F0EDE8;
    }
    .service-list li:last-child { border-bottom: none; }
    .service-arrow { color: #FF2D00; }

    .right-bottom {
      border-top: 3px solid #1A1A1A;
      padding: 1.5rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .year-badge {
      font-size: 2.5rem;
      font-weight: 700;
      color: #FF2D00;
      line-height: 1;
      letter-spacing: -0.04em;
    }
    .founded-text {
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.35);
      text-align: right;
    }

    /* BOTTOM GRID */
    .bottom-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }
    .bottom-cell {
      padding: 1.25rem 1.5rem;
      border-right: 2px solid #1A1A1A;
    }
    .bottom-cell:last-child { border-right: none; }
    .bottom-cell-num {
      font-size: 1.4rem;
      font-weight: 700;
      color: #1A1A1A;
      line-height: 1;
      margin-bottom: 0.2rem;
    }
    .bottom-cell-label {
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.4);
    }
    .bottom-cell.highlight { background: #FF2D00; }
    .bottom-cell.highlight .bottom-cell-num,
    .bottom-cell.highlight .bottom-cell-label { color: #F0EDE8; }

    /* Photo container */
    .ph { position: relative; overflow: hidden; }
    .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
    .ph:hover img { transform: scale(1.05); }

    /* Page wrap */
    .page-wrap { max-width: 1600px; margin-left: auto; margin-right: auto; }

    /* Section 2: Portfolio */
    .portfolio-section {
      border-top: 3px solid #1A1A1A;
    }
    .section-header-bar {
      display: flex;
      align-items: stretch;
      border-bottom: 2px solid #1A1A1A;
    }
    .section-header-num {
      background: #FF2D00;
      color: #F0EDE8;
      padding: 1rem 1.5rem;
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      border-right: 2px solid #1A1A1A;
      display: flex;
      align-items: center;
    }
    .section-header-title {
      padding: 1rem 1.5rem;
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.45);
      display: flex;
      align-items: center;
      border-right: 2px solid #1A1A1A;
      flex: 1;
    }
    .section-header-tag {
      margin-left: auto;
      padding: 1rem 1.5rem;
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.3);
      display: flex;
      align-items: center;
      border-left: 2px solid #1A1A1A;
    }
    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
    }
    .portfolio-card {
      border-right: 2px solid #1A1A1A;
      border-bottom: 2px solid #1A1A1A;
      display: flex;
      flex-direction: column;
    }
    .portfolio-card:nth-child(2n) { border-right: none; }
    .portfolio-card:nth-last-child(-n+2) { border-bottom: none; }
    .portfolio-card-photo {
      position: relative;
    }
    .portfolio-card-body {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      border-top: 2px solid #1A1A1A;
    }
    .portfolio-card-label {
      font-size: 0.48rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.35);
    }
    .portfolio-card-title {
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #1A1A1A;
      text-transform: uppercase;
    }
    .portfolio-card-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 0.25rem;
    }
    .p-tag {
      font-size: 0.45rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 0.25rem 0.6rem;
      border: 2px solid #1A1A1A;
      color: #1A1A1A;
    }
    .p-tag.red { background: #FF2D00; color: #F0EDE8; border-color: #FF2D00; }

    /* Section 3: Kontakt + Prozess */
    .contact-section-brut {
      border-top: 3px solid #1A1A1A;
    }
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .contact-left {
      padding: 3rem;
      border-right: 2px solid #1A1A1A;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .contact-right {
      display: flex;
      flex-direction: column;
    }
    .brut-contact-label {
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.4);
      margin-bottom: 0.75rem;
    }
    .brut-contact-value {
      font-size: 1.1rem;
      font-weight: 700;
      color: #1A1A1A;
      letter-spacing: -0.02em;
      text-transform: uppercase;
    }
    .brut-contact-value.small {
      font-size: 0.82rem;
      font-weight: 300;
      letter-spacing: 0.02em;
      text-transform: none;
    }
    .availability-block {
      background: #FF2D00;
      padding: 1.5rem;
    }
    .avail-label {
      font-size: 0.5rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.7);
      margin-bottom: 0.5rem;
    }
    .avail-status {
      font-size: 1.5rem;
      font-weight: 700;
      color: #F0EDE8;
      letter-spacing: -0.03em;
      text-transform: uppercase;
    }
    .process-list {
      list-style: none;
      display: flex;
      flex-direction: column;
    }
    .process-item {
      display: flex;
      align-items: stretch;
      border-bottom: 2px solid #1A1A1A;
    }
    .process-item:last-child { border-bottom: none; }
    .process-num {
      background: #1A1A1A;
      color: #F0EDE8;
      padding: 1rem 1.25rem;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      border-right: 2px solid #1A1A1A;
      display: flex;
      align-items: center;
      min-width: 60px;
    }
    .process-text {
      padding: 1rem 1.25rem;
      font-size: 0.75rem;
      font-weight: 500;
      color: #1A1A1A;
      display: flex;
      align-items: center;
    }
  </style>
</head>
<body>
  <div class="page-wrap">
  <nav>
    <div class="nav-logo">BLOC</div>
    <ul class="nav-links">
      <li><a href="#">Projekte</a></li>
      <li><a href="#">Services</a></li>
      <li><a href="#">Studio</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <div class="nav-right">Trier · DE</div>
  </nav>

  <section class="hero">
    <div class="top-bar">
      <div class="top-cell">Grafikdesign & Art Direction</div>
      <div class="top-cell accent">Verfügbar — Q2 2026</div>
      <div class="top-cell">Trier, Rheinland-Pfalz</div>
      <div class="top-cell">hello@bloc-studio.de</div>
    </div>

    <div class="hero-main">
      <div class="hero-left">
        <div>
          <div class="hero-num">001 — Studio</div>
          <h1 class="hero-headline">
            <span class="stroke">De</span><span class="fill">sign</span><br>
            <span class="fill">das nicht</span><br>
            <span class="fill">um </span><span class="red">Er</span><span class="fill">laub</span><br>
            <span class="fill">nis</span> <span class="stroke">fragt.</span>
          </h1>
        </div>
        <div class="hero-bottom-row">
          <p class="hero-tagline">
            BLOC ist ein Designstudio für Marken, die auffallen wollen.
            Kein Mainstream. Keine Kompromisse.
          </p>
          <a href="#" class="cta-btn">Projekt starten →</a>
        </div>
      </div>

      <div class="hero-right">
        <div class="right-top">
          <div class="right-label">Leistungen</div>
          <ul class="service-list">
            <li>Corporate Identity <span class="service-arrow">→</span></li>
            <li>Editorial Design <span class="service-arrow">→</span></li>
            <li>Packaging & Print <span class="service-arrow">→</span></li>
            <li>Art Direction <span class="service-arrow">→</span></li>
            <li>Motion & Digital <span class="service-arrow">→</span></li>
          </ul>
        </div>
        <div class="right-bottom">
          <div class="year-badge">2016</div>
          <div class="founded-text">Studio<br>gegründet</div>
        </div>
      </div>
    </div>

    <div class="bottom-grid">
      <div class="bottom-cell">
        <div class="bottom-cell-num">80+</div>
        <div class="bottom-cell-label">Projekte</div>
      </div>
      <div class="bottom-cell highlight">
        <div class="bottom-cell-num">12</div>
        <div class="bottom-cell-label">Auszeichnungen</div>
      </div>
      <div class="bottom-cell">
        <div class="bottom-cell-num">3</div>
        <div class="bottom-cell-label">Kontinente</div>
      </div>
      <div class="bottom-cell">
        <div class="bottom-cell-num">1</div>
        <div class="bottom-cell-label">Regel: keine</div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Portfolio -->
  <section class="portfolio-section">
    <div class="section-header-bar">
      <div class="section-header-num">002</div>
      <div class="section-header-title">Ausgewählte Projekte</div>
      <div class="section-header-tag">2022 – 2025</div>
    </div>
    <div class="portfolio-grid">
      <div class="portfolio-card">
        <div class="portfolio-card-photo">
          <div class="ph" style="height:280px;">
            <img src="https://images.unsplash.com/photo-1471193945509-9ad0617afabf?auto=format&fit=crop&w=1200&h=800&q=80" alt="Brand Identity Projekt" loading="lazy"/>
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,26,26,0.5) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
        </div>
        <div class="portfolio-card-body">
          <div class="portfolio-card-label">Corporate Identity · 2025</div>
          <div class="portfolio-card-title">Weingut Mertes — Brand Relaunch</div>
          <div class="portfolio-card-tags">
            <span class="p-tag red">CI</span>
            <span class="p-tag">Print</span>
            <span class="p-tag">Packaging</span>
          </div>
        </div>
      </div>
      <div class="portfolio-card">
        <div class="portfolio-card-photo">
          <div class="ph" style="height:280px;">
            <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1200&h=800&q=80" alt="Editorial Design Projekt" loading="lazy"/>
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,26,26,0.5) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
        </div>
        <div class="portfolio-card-body">
          <div class="portfolio-card-label">Editorial Design · 2024</div>
          <div class="portfolio-card-title">Trier Magazin — Jahresausgabe</div>
          <div class="portfolio-card-tags">
            <span class="p-tag red">Editorial</span>
            <span class="p-tag">Print</span>
            <span class="p-tag">Foto</span>
          </div>
        </div>
      </div>
      <div class="portfolio-card">
        <div class="portfolio-card-photo">
          <div class="ph" style="height:280px;">
            <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1200&h=800&q=80" alt="Art Direction Projekt" loading="lazy"/>
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,26,26,0.5) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
        </div>
        <div class="portfolio-card-body">
          <div class="portfolio-card-label">Art Direction · 2024</div>
          <div class="portfolio-card-title">Architekturbüro Lenz — Visual System</div>
          <div class="portfolio-card-tags">
            <span class="p-tag red">Art Direction</span>
            <span class="p-tag">Digital</span>
          </div>
        </div>
      </div>
      <div class="portfolio-card">
        <div class="portfolio-card-photo">
          <div class="ph" style="height:280px;">
            <img src="https://images.unsplash.com/photo-1521791136064-7986c2920216?auto=format&fit=crop&w=1200&h=800&q=80" alt="Motion Design Projekt" loading="lazy"/>
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,26,26,0.5) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
        </div>
        <div class="portfolio-card-body">
          <div class="portfolio-card-label">Motion & Digital · 2023</div>
          <div class="portfolio-card-title">Startup Klinix — Launch Campaign</div>
          <div class="portfolio-card-tags">
            <span class="p-tag red">Motion</span>
            <span class="p-tag">Digital</span>
            <span class="p-tag">Social</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Kontakt + Prozess -->
  <section class="contact-section-brut">
    <div class="section-header-bar">
      <div class="section-header-num">003</div>
      <div class="section-header-title">Kontakt & Prozess</div>
      <div class="section-header-tag">hello@bloc-studio.de</div>
    </div>
    <div class="contact-grid">
      <div class="contact-left">
        <div>
          <div class="brut-contact-label">Studio</div>
          <div class="brut-contact-value">BLOC</div>
        </div>
        <div>
          <div class="brut-contact-label">Standort</div>
          <div class="brut-contact-value">Trier, DE</div>
        </div>
        <div>
          <div class="brut-contact-label">Kontakt</div>
          <div class="brut-contact-value small">hello@bloc-studio.de<br>+49 651 / 456 78 90</div>
        </div>
        <div>
          <div class="brut-contact-label">Projektstart</div>
          <div class="brut-contact-value small">Anfrage → Briefing → Angebot<br>Typisch 2–3 Wochen Vorlauf</div>
        </div>
        <div class="availability-block">
          <div class="avail-label">Verfügbarkeit</div>
          <div class="avail-status">Q2 2026 frei</div>
        </div>
      </div>
      <div class="contact-right">
        <div class="section-header-bar" style="border-left:none;">
          <div class="section-header-title" style="border-right:none;">Der Prozess</div>
        </div>
        <ul class="process-list">
          <li class="process-item">
            <span class="process-num">01</span>
            <span class="process-text">Anfrage per Mail — kurze Projektbeschreibung genügt</span>
          </li>
          <li class="process-item">
            <span class="process-num">02</span>
            <span class="process-text">Briefing-Call (30 Min) — Ziele, Zielgruppe, Budget</span>
          </li>
          <li class="process-item">
            <span class="process-num">03</span>
            <span class="process-text">Konzept & Angebot innerhalb von 5 Werktagen</span>
          </li>
          <li class="process-item">
            <span class="process-num">04</span>
            <span class="process-text">Produktion mit 2 Feedback-Runden inklusive</span>
          </li>
          <li class="process-item">
            <span class="process-num">05</span>
            <span class="process-text">Übergabe aller Dateien + Nutzungsrechte</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  </div><!-- /page-wrap -->
</body>
</html>
