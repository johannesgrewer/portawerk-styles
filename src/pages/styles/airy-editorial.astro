---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>PASSAGE — Magazin für Lebensart · Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <style>
    /* ─── RESET ─── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    /* ─── TOKENS ─── */
    :root {
      --white:      #FFFFFF;
      --off-white:  #F8F7F4;
      --ink:        #151210;
      --ink-50:     rgba(21,18,16,0.50);
      --ink-20:     rgba(21,18,16,0.20);
      --ink-08:     rgba(21,18,16,0.08);
      --sage:       #4E6B5A;
      --sage-light: #EAF0EC;
      --serif:      'EB Garamond', Georgia, serif;
      --sans:       'DM Sans', system-ui, sans-serif;
    }

    body {
      background: var(--white);
      color: var(--ink);
      font-family: var(--sans);
      font-weight: 300;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    img { display: block; max-width: 100%; }
    a   { text-decoration: none; }

    /* ─── KEYFRAMES ─── */
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes reveal {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes scaleIn {
      from { transform: scale(1.08); opacity: 0; }
      to   { transform: scale(1);    opacity: 1; }
    }
    @keyframes ticker {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    .u0  { animation: slideUp 0.7s      ease both; }
    .u1  { animation: slideUp 0.7s .12s ease both; }
    .u2  { animation: slideUp 0.7s .24s ease both; }
    .u3  { animation: slideUp 0.7s .38s ease both; }
    .u4  { animation: slideUp 0.7s .52s ease both; }
    .r0  { animation: reveal  1.0s      ease both; }
    .r1  { animation: reveal  1.0s .18s ease both; }
    .sci { animation: scaleIn 1.1s      ease both; }

    /* ─── UTILITY ─── */
    .eyebrow {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      font-family: var(--sans);
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--sage);
    }
    .eyebrow::before {
      content: '';
      display: block;
      width: 1.8rem;
      height: 1px;
      background: var(--sage);
      flex-shrink: 0;
    }

    /* ─── NAVIGATION ─── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      background: rgba(255,255,255,0.96);
      backdrop-filter: blur(16px);
    }
    .nav-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.6rem 4rem;
      border-bottom: 1px solid var(--ink-08);
    }
    .nav-top-meta {
      font-size: 0.48rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-50);
    }
    .nav-top-sub {
      font-size: 0.48rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sage);
      border-bottom: 1px solid var(--sage);
      padding-bottom: 1px;
      transition: opacity 0.2s;
    }
    .nav-top-sub:hover { opacity: 0.65; }

    .nav-main {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      padding: 1.1rem 4rem;
    }
    .nav-links {
      list-style: none;
      display: flex;
      gap: 2.5rem;
    }
    .nav-links-r { justify-content: flex-end; }
    .nav-links a {
      font-size: 0.53rem;
      font-weight: 400;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink-50);
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--ink); }

    .nav-wordmark {
      text-align: center;
    }
    .nav-wordmark-main {
      font-family: var(--serif);
      font-size: 1.75rem;
      font-weight: 500;
      letter-spacing: 0.38em;
      color: var(--ink);
      line-height: 1;
    }
    .nav-wordmark-sub {
      font-size: 0.42rem;
      font-weight: 400;
      letter-spacing: 0.38em;
      text-transform: uppercase;
      color: var(--ink-50);
      margin-top: 0.22rem;
    }

    /* ─── HERO ─── */
    /* Full-bleed image + offset text block */
    .hero {
      padding-top: 100px;
      position: relative;
      display: grid;
      grid-template-columns: 60fr 40fr;
      min-height: 92vh;
    }

    .hero-img-col {
      position: relative;
      overflow: hidden;
    }
    .hero-img-col img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
      animation: scaleIn 1.4s ease both;
    }
    /* thin right border on image */
    .hero-img-col::after {
      content: '';
      position: absolute;
      inset: 0;
      border-right: 1px solid var(--ink-08);
      pointer-events: none;
    }

    .hero-text-col {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 4rem 4.5rem 4.5rem 4rem;
      border-bottom: 1px solid var(--ink-08);
    }

    /* oversized issue number in background */
    .hero-issue-bg {
      position: absolute;
      top: 96px;
      right: 0;
      font-family: var(--serif);
      font-size: 22vw;
      font-weight: 600;
      color: var(--ink);
      opacity: 0.028;
      line-height: 1;
      letter-spacing: -0.04em;
      pointer-events: none;
      user-select: none;
      z-index: 0;
    }

    .hero-content { position: relative; z-index: 1; }

    .hero-tag {
      display: inline-block;
      font-family: var(--sans);
      font-size: 0.46rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--white);
      background: var(--sage);
      padding: 0.3rem 0.75rem;
      margin-bottom: 1.5rem;
    }

    .hero-h1 {
      font-family: var(--serif);
      font-size: clamp(2.2rem, 3.5vw, 3.6rem);
      font-weight: 400;
      line-height: 1.18;
      color: var(--ink);
      margin-bottom: 1.6rem;
    }
    .hero-h1 em {
      font-style: italic;
      color: var(--ink-50);
    }

    .hero-deck {
      font-size: 0.84rem;
      font-weight: 300;
      line-height: 1.85;
      color: var(--ink-50);
      max-width: 38ch;
      margin-bottom: 2.25rem;
    }

    .hero-byline {
      display: flex;
      align-items: center;
      gap: 1.1rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--ink-08);
    }
    .hero-byline-avatar {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      overflow: hidden;
      flex-shrink: 0;
    }
    .hero-byline-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .hero-byline-name {
      font-size: 0.58rem;
      font-weight: 500;
      color: var(--ink);
    }
    .hero-byline-meta {
      font-size: 0.51rem;
      color: var(--ink-50);
      margin-top: 0.1rem;
    }
    .hero-cta {
      margin-left: auto;
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sage);
      border-bottom: 1px solid var(--sage);
      padding-bottom: 2px;
      white-space: nowrap;
      transition: opacity 0.2s;
    }
    .hero-cta:hover { opacity: 0.65; }

    /* ─── SECTION SUBTITLE STRIP ─── */
    .strip {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 4rem;
      border-bottom: 1px solid var(--ink-08);
      overflow: hidden;
    }
    .strip-ticker {
      overflow: hidden;
      flex: 1;
      mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    }
    .strip-track {
      display: flex;
      white-space: nowrap;
      animation: ticker 32s linear infinite;
    }
    .strip-item {
      font-size: 0.48rem;
      font-weight: 400;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink-50);
      padding-right: 3rem;
      flex-shrink: 0;
    }
    .strip-diamond {
      font-size: 0.36rem;
      color: var(--sage);
      opacity: 0.6;
      padding-right: 3rem;
      flex-shrink: 0;
    }
    .strip-issue {
      font-family: var(--serif);
      font-size: 0.82rem;
      font-weight: 400;
      font-style: italic;
      color: var(--ink-50);
      white-space: nowrap;
      padding-left: 2rem;
    }

    /* ─── SECTION 2 — FEATURED GRID ─── */
    .featured {
      padding: 5.5rem 4rem;
    }
    .featured-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 3.5rem;
    }
    .featured-h2 {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 2.5vw, 2.6rem);
      font-weight: 400;
      line-height: 1.15;
      color: var(--ink);
      margin-top: 0.7rem;
    }
    .featured-h2 em { font-style: italic; }
    .see-all {
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-50);
      border-bottom: 1px solid var(--ink-20);
      padding-bottom: 2px;
      white-space: nowrap;
      transition: color 0.2s, border-color 0.2s;
    }
    .see-all:hover { color: var(--ink); border-color: var(--ink-50); }

    /* 3-column + sidebar layout */
    .feat-grid {
      display: grid;
      grid-template-columns: 5fr 3fr 4fr;
      grid-template-rows: auto auto;
      gap: 0;
      border: 1px solid var(--ink-08);
    }

    .feat-main   { grid-column: 1; grid-row: 1 / 3; border-right: 1px solid var(--ink-08); }
    .feat-mid-a  { grid-column: 2; grid-row: 1;     border-right: 1px solid var(--ink-08); border-bottom: 1px solid var(--ink-08); }
    .feat-mid-b  { grid-column: 2; grid-row: 2;     border-right: 1px solid var(--ink-08); }
    .feat-side   { grid-column: 3; grid-row: 1 / 3; }

    .feat-card { overflow: hidden; }

    .feat-img {
      position: relative;
      overflow: hidden;
    }
    .feat-main .feat-img   { height: 400px; }
    .feat-mid-a .feat-img  { height: 200px; }
    .feat-mid-b .feat-img  { height: 180px; }
    .feat-side .feat-img   { height: 300px; }

    .feat-img img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }
    .feat-card:hover .feat-img img { transform: scale(1.05); }

    .feat-body { padding: 1.4rem 1.75rem 1.75rem; }
    .feat-main .feat-body  { padding: 1.6rem 2rem 2rem; }
    .feat-side .feat-body  { padding: 1.4rem 1.75rem; }

    .feat-cat {
      font-size: 0.44rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--sage);
      margin-bottom: 0.5rem;
    }
    .feat-title {
      font-family: var(--serif);
      font-weight: 500;
      font-size: 1rem;
      line-height: 1.35;
      color: var(--ink);
    }
    .feat-main .feat-title { font-size: 1.45rem; }
    .feat-title em { font-style: italic; font-weight: 400; }
    .feat-excerpt {
      font-size: 0.78rem;
      font-weight: 300;
      line-height: 1.8;
      color: var(--ink-50);
      margin-top: 0.65rem;
      max-width: 48ch;
    }
    .feat-foot {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      margin-top: 0.85rem;
    }
    .feat-author {
      font-size: 0.5rem;
      color: var(--ink-50);
    }
    .feat-dot {
      width: 3px; height: 3px;
      border-radius: 50%;
      background: var(--ink-20);
    }
    .feat-min {
      font-size: 0.5rem;
      color: var(--ink-50);
    }

    /* Column of smaller articles in sidebar */
    .feat-side-list {
      border-top: 1px solid var(--ink-08);
    }
    .feat-list-item {
      display: flex;
      gap: 0.85rem;
      padding: 1.1rem 1.75rem;
      border-bottom: 1px solid var(--ink-08);
      transition: background 0.2s;
    }
    .feat-list-item:last-child { border-bottom: none; }
    .feat-list-item:hover { background: var(--off-white); }
    .feat-list-num {
      font-family: var(--serif);
      font-size: 0.78rem;
      color: var(--sage);
      opacity: 0.5;
      flex-shrink: 0;
      padding-top: 0.05rem;
    }
    .feat-list-cat {
      font-size: 0.42rem;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--sage);
      margin-bottom: 0.28rem;
    }
    .feat-list-title {
      font-family: var(--serif);
      font-size: 0.88rem;
      font-weight: 400;
      line-height: 1.35;
      color: var(--ink);
    }
    .feat-list-title em { font-style: italic; }

    /* ─── SECTION 3 — PULL QUOTE (sage bg) ─── */
    .pullquote-band {
      background: var(--sage-light);
      border-top: 1px solid rgba(78,107,90,0.15);
      border-bottom: 1px solid rgba(78,107,90,0.15);
      padding: 5rem 4rem;
      display: grid;
      grid-template-columns: 5fr 7fr;
      gap: 5rem;
      align-items: center;
    }
    .pq-photo {
      position: relative;
      overflow: hidden;
      height: 420px;
    }
    .pq-photo img {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.9s ease;
    }
    .pq-photo:hover img { transform: scale(1.04); }
    .pq-badge {
      position: absolute;
      bottom: 1.5rem;
      left: 1.5rem;
      font-size: 0.44rem;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--white);
      background: var(--sage);
      padding: 0.28rem 0.72rem;
    }

    .pq-content {}
    .pq-opener {
      font-family: var(--serif);
      font-size: 5rem;
      font-weight: 500;
      color: var(--sage);
      opacity: 0.25;
      line-height: 0.8;
      margin-bottom: 0.5rem;
    }
    .pq-quote {
      font-family: var(--serif);
      font-style: italic;
      font-size: clamp(1.4rem, 2.2vw, 2rem);
      font-weight: 400;
      line-height: 1.52;
      color: var(--ink);
      margin-bottom: 1.25rem;
    }
    .pq-source {
      font-size: 0.52rem;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--sage);
      margin-bottom: 1.75rem;
    }
    .pq-body {
      font-size: 0.82rem;
      font-weight: 300;
      line-height: 1.88;
      color: var(--ink-50);
      max-width: 44ch;
      margin-bottom: 2rem;
    }
    .pq-link {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--sage);
      border-bottom: 1px solid rgba(78,107,90,0.35);
      padding-bottom: 3px;
      transition: gap 0.3s;
    }
    .pq-link:hover { gap: 1rem; }

    /* ─── SECTION 4 — RUBRIK NUMMER (large type) ─── */
    .rubrik-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-top: 1px solid var(--ink-08);
    }
    .rubrik-cell {
      padding: 3rem 2.5rem 2.5rem;
      border-right: 1px solid var(--ink-08);
      position: relative;
      overflow: hidden;
      transition: background 0.25s;
    }
    .rubrik-cell:last-child { border-right: none; }
    .rubrik-cell:hover { background: var(--off-white); }
    .rubrik-num {
      position: absolute;
      bottom: -1rem;
      right: -0.5rem;
      font-family: var(--serif);
      font-size: 7rem;
      font-weight: 500;
      color: var(--ink);
      opacity: 0.04;
      line-height: 1;
      pointer-events: none;
      user-select: none;
    }
    .rubrik-img {
      position: relative;
      overflow: hidden;
      height: 175px;
      margin-bottom: 1.25rem;
    }
    .rubrik-img img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .rubrik-cell:hover .rubrik-img img { transform: scale(1.06); }
    .rubrik-cat {
      font-size: 0.44rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--sage);
      margin-bottom: 0.45rem;
    }
    .rubrik-title {
      font-family: var(--serif);
      font-size: 1.05rem;
      font-weight: 400;
      line-height: 1.35;
      color: var(--ink);
      margin-bottom: 0.6rem;
      position: relative;
      z-index: 1;
    }
    .rubrik-title em { font-style: italic; }
    .rubrik-meta {
      font-size: 0.5rem;
      font-weight: 300;
      color: var(--ink-50);
      position: relative;
      z-index: 1;
    }

    /* ─── SECTION 5 — LANGER LESESTOFF ─── */
    .longread {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-top: 1px solid var(--ink-08);
      border-bottom: 1px solid var(--ink-08);
    }
    .lr-left {
      padding: 6rem 4.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 2rem;
      border-right: 1px solid var(--ink-08);
    }
    .lr-issue-no {
      font-family: var(--serif);
      font-size: 0.72rem;
      font-weight: 400;
      font-style: italic;
      color: var(--ink-50);
    }
    .lr-h2 {
      font-family: var(--serif);
      font-size: clamp(2rem, 3vw, 3rem);
      font-weight: 400;
      line-height: 1.15;
      color: var(--ink);
    }
    .lr-h2 em { font-style: italic; }
    .lr-body {
      font-size: 0.84rem;
      font-weight: 300;
      line-height: 1.9;
      color: var(--ink-50);
      max-width: 42ch;
    }

    /* pull statistic */
    .lr-stat {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      border-left: 2px solid var(--sage);
      padding-left: 1.25rem;
    }
    .lr-stat-num {
      font-family: var(--serif);
      font-size: 2.5rem;
      font-weight: 500;
      color: var(--sage);
      line-height: 1;
    }
    .lr-stat-label {
      font-size: 0.55rem;
      font-weight: 300;
      letter-spacing: 0.08em;
      color: var(--ink-50);
    }
    .lr-read {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--sage);
      border-bottom: 1px solid rgba(78,107,90,0.3);
      padding-bottom: 3px;
      align-self: flex-start;
      transition: gap 0.3s;
    }
    .lr-read:hover { gap: 1.1rem; }

    .lr-right {
      position: relative;
      overflow: hidden;
      min-height: 540px;
    }
    .lr-right img {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.9s ease;
    }
    .lr-right:hover img { transform: scale(1.04); }
    .lr-right-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent 55%, rgba(21,18,16,0.6) 100%);
    }
    .lr-right-caption {
      position: absolute;
      bottom: 2rem;
      left: 2.25rem;
      right: 2.25rem;
      font-size: 0.52rem;
      font-weight: 300;
      color: rgba(255,255,255,0.6);
      letter-spacing: 0.06em;
    }

    /* ─── FOOTER ─── */
    .footer-wrapper {
      border-top: 2px solid var(--ink);
    }
    footer {
      padding: 4.5rem 4rem 2rem;
    }
    .footer-top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 2fr;
      gap: 3rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--ink-08);
      margin-bottom: 2rem;
    }
    .f-brand-name {
      font-family: var(--serif);
      font-size: 1.4rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      color: var(--ink);
      margin-bottom: 0.65rem;
    }
    .f-brand-sub {
      font-size: 0.58rem;
      font-weight: 300;
      line-height: 1.75;
      color: var(--ink-50);
      max-width: 24ch;
    }
    .f-col-label {
      font-size: 0.44rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
