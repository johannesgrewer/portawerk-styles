---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Palais Sieben — Veranstaltungslocation & Event | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --gold:   #B8963E;
      --dark:   #0E0B06;
      --ivory:  #F5EDD0;
      --mid:    #1A1208;
    }

    body {
      background: var(--dark);
      color: var(--ivory);
      font-family: 'Playfair Display', serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Art Deco geometric border overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        repeating-linear-gradient(
          90deg,
          transparent,
          transparent calc(50% - 1px),
          rgba(184,150,62,0.04) calc(50% - 1px),
          rgba(184,150,62,0.04) calc(50% + 1px),
          transparent calc(50% + 1px)
        );
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 4rem;
      background: rgba(14,11,6,0.95);
      border-bottom: 1px solid rgba(184,150,62,0.25);
    }
    .nav-logo {
      font-family: 'Cinzel Decorative', serif;
      font-weight: 400;
      font-size: 1rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
    }
    .nav-links {
      display: flex;
      gap: 3rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Playfair Display', serif;
      font-size: 0.6rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(245,237,208,0.4);
      text-decoration: none;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: var(--gold); }
    .nav-book {
      font-family: 'Cinzel Decorative', serif;
      font-size: 0.5rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--dark);
      background: var(--gold);
      padding: 0.7rem 1.5rem;
      text-decoration: none;
      transition: background 0.3s;
    }
    .nav-book:hover { background: var(--ivory); }

    .hero {
      min-height: 100vh;
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 8rem 4rem 4rem;
      text-align: center;
      gap: 0;
    }

    /* Art Deco top ornament */
    .deco-top {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 2.5rem;
    }
    .deco-line {
      flex: 1;
      max-width: 120px;
      height: 1px;
      background: linear-gradient(to right, transparent, var(--gold));
    }
    .deco-line.right { background: linear-gradient(to left, transparent, var(--gold)); }
    .deco-diamond {
      width: 8px;
      height: 8px;
      background: var(--gold);
      transform: rotate(45deg);
    }
    .deco-dot {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--gold);
      opacity: 0.6;
    }
    .deco-label {
      font-size: 0.52rem;
      letter-spacing: 0.38em;
      text-transform: uppercase;
      color: rgba(184,150,62,0.7);
      white-space: nowrap;
    }

    .hero-headline {
      font-family: 'Cinzel Decorative', serif;
      font-weight: 700;
      font-size: clamp(3rem, 7vw, 6.5rem);
      line-height: 1.1;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ivory);
      margin-bottom: 0.5rem;
    }
    .hero-headline .gold { color: var(--gold); }

    .hero-subtitle {
      font-family: 'Cinzel Decorative', serif;
      font-weight: 400;
      font-size: clamp(0.9rem, 2vw, 1.4rem);
      letter-spacing: 0.5em;
      text-transform: uppercase;
      color: rgba(184,150,62,0.6);
      margin-bottom: 3rem;
    }

    /* Center ornament */
    .center-ornament {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 2rem;
    }
    .orn-line {
      width: 60px;
      height: 1px;
      background: var(--gold);
      opacity: 0.4;
    }
    .orn-chevron {
      font-size: 0.7rem;
      color: var(--gold);
      letter-spacing: 0.1em;
      opacity: 0.6;
    }

    .hero-body {
      font-size: 0.85rem;
      font-weight: 400;
      font-style: italic;
      line-height: 1.9;
      color: rgba(245,237,208,0.5);
      max-width: 44ch;
      margin-bottom: 3rem;
    }

    .cta-area {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      margin-bottom: 4rem;
    }
    .cta-btn {
      font-family: 'Cinzel Decorative', serif;
      font-size: 0.52rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--dark);
      background: var(--gold);
      text-decoration: none;
      padding: 1.1rem 3rem;
      border: 1px solid var(--gold);
      transition: background 0.3s, color 0.3s;
    }
    .cta-btn:hover { background: transparent; color: var(--gold); }
    .cta-link {
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(245,237,208,0.3);
      text-decoration: none;
      transition: color 0.3s;
    }
    .cta-link:hover { color: var(--gold); }

    /* Stats row Art Deco style */
    .stats-row {
      display: flex;
      gap: 0;
      border-top: 1px solid rgba(184,150,62,0.15);
      border-bottom: 1px solid rgba(184,150,62,0.15);
    }
    .stat-cell {
      flex: 1;
      padding: 1.75rem 2.5rem;
      border-right: 1px solid rgba(184,150,62,0.1);
      text-align: center;
    }
    .stat-cell:last-child { border-right: none; }
    .stat-num {
      font-family: 'Cinzel Decorative', serif;
      font-weight: 700;
      font-size: 2rem;
      color: var(--gold);
      line-height: 1;
      margin-bottom: 0.4rem;
    }
    .stat-label {
      font-size: 0.5rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(245,237,208,0.3);
    }

    /* Bottom fan ornament */
    .fan-deco {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: flex-end;
      gap: 3px;
    }
    .fan-bar {
      width: 2px;
      background: linear-gradient(to top, var(--gold), transparent);
      opacity: 0.25;
    }
    .fan-bar:nth-child(1)  { height: 16px; }
    .fan-bar:nth-child(2)  { height: 24px; }
    .fan-bar:nth-child(3)  { height: 30px; }
    .fan-bar:nth-child(4)  { height: 34px; }
    .fan-bar:nth-child(5)  { height: 36px; }
    .fan-bar:nth-child(6)  { height: 34px; }
    .fan-bar:nth-child(7)  { height: 30px; }
    .fan-bar:nth-child(8)  { height: 24px; }
    .fan-bar:nth-child(9)  { height: 16px; }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Palais Sieben</div>
    <ul class="nav-links">
      <li><a href="#">Eventräume</a></li>
      <li><a href="#">Catering</a></li>
      <li><a href="#">Referenzen</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <a href="#" class="nav-book">Anfrage</a>
  </nav>

  <section class="hero">
    <div class="deco-top">
      <div class="deco-line"></div>
      <div class="deco-dot"></div>
      <div class="deco-diamond"></div>
      <div class="deco-dot"></div>
      <span class="deco-label">Veranstaltungslocation · Trier · Est. 1924</span>
      <div class="deco-dot"></div>
      <div class="deco-diamond"></div>
      <div class="deco-dot"></div>
      <div class="deco-line right"></div>
    </div>

    <h1 class="hero-headline">
      <span class="gold">Palais</span><br>
      Sieben
    </h1>

    <div class="hero-subtitle">Grandeur · Stil · Unvergesslich</div>

    <div class="center-ornament">
      <div class="orn-line"></div>
      <span class="orn-chevron">◆ ◆ ◆</span>
      <div class="orn-line"></div>
    </div>

    <p class="hero-body">
      Ein Ort, der Geschichte atmet.<br>
      Hochzeiten, Galadiners, Firmenevents —<br>
      für Anlässe, die in Erinnerung bleiben sollen.
    </p>

    <div class="cta-area">
      <a href="#" class="cta-btn">Besichtigung vereinbaren</a>
      <a href="#" class="cta-link">Eventräume entdecken →</a>
    </div>

    <div class="stats-row">
      <div class="stat-cell">
        <div class="stat-num">7</div>
        <div class="stat-label">Eventräume</div>
      </div>
      <div class="stat-cell">
        <div class="stat-num">450</div>
        <div class="stat-label">Gäste max.</div>
      </div>
      <div class="stat-cell">
        <div class="stat-num">100</div>
        <div class="stat-label">Jahre Geschichte</div>
      </div>
      <div class="stat-cell">
        <div class="stat-num">★★★★★</div>
        <div class="stat-label">Google Bewertung</div>
      </div>
    </div>
  </section>

  <div class="fan-deco">
    <div class="fan-bar"></div>
    <div class="fan-bar"></div>
    <div class="fan-bar"></div>
    <div class="fan-bar"></div>
    <div class="fan-bar"></div>
    <div class="fan-bar"></div>
    <div class="fan-bar"></div>
    <div class="fan-bar"></div>
    <div class="fan-bar"></div>
  </div>
</body>
</html>
