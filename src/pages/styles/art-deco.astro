    .btn-res-ghost {
      font-size: 0.56rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--ivory-25); text-decoration: none; text-align: center;
      transition: color 0.25s; padding: 0.25rem 0;
    }
    .btn-res-ghost:hover { color: var(--gold); }

    /* ───── FOOTER ORNAMENT ───── */
