---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Pixelschmiede — Digitalagentur Trier</title>
  <meta name="description" content="Pixelschmiede — Digitalagentur in Trier. Branding, Webdesign, E-Commerce. Digital, aber mit Handschrift." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <style>
    html { overflow-x: hidden; }
    /* ===== RESET & BASE ===== */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Sora', 'Instrument Sans', 'Geist', system-ui, sans-serif;
      color: #0D0D0D;
      background-color: #FAFAFA;
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    img {
      max-width: 100%;
      height: auto;
      display: block;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    /* ===== CURSOR DOT ===== */
    #cursor-dot {
      position: fixed;
      top: 0;
      left: 0;
      width: 10px;
      height: 10px;
      background: #FF5722;
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%, -50%);
      transition: transform 0.15s ease, opacity 0.3s ease;
      opacity: 0;
    }

    /* ===== HERO ===== */
    .hero {
      position: relative;
      width: 100%;
      height: 100vh;
      min-height: 600px;
      overflow: hidden;
      background: #0D0D0D;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    .hero-image-wrapper {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
    }

    .hero-image {
      width: 65%;
      max-width: 800px;
      height: 60vh;
      object-fit: cover;
      border-radius: 4px;
      filter: brightness(0.85) contrast(1.05);
    }

    .hero-big-number {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: clamp(180px, 22vw, 400px);
      font-weight: 800;
      color: rgba(255, 255, 255, 0.06);
      z-index: 1;
      line-height: 1;
      letter-spacing: -0.04em;
      user-select: none;
      pointer-events: none;
    }

    .hero-content {
      position: absolute;
      inset: 0;
      z-index: 3;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      color: #F5F5F5;
      pointer-events: none;
    }

    .hero-label {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      margin-bottom: 1.2rem;
      opacity: 0.7;
    }

    .hero-tagline {
      font-size: clamp(1.4rem, 3vw, 2.4rem);
      font-weight: 300;
      letter-spacing: -0.01em;
      line-height: 1.3;
    }

    .hero-tagline .accent-dot {
      color: #FF5722;
      font-size: 1.4em;
      line-height: 0;
      vertical-align: baseline;
    }

    .hero-cta {
      position: absolute;
      bottom: 100px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 4;
      pointer-events: all;
    }

    .hero-cta a {
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #F5F5F5;
      opacity: 0.6;
      transition: opacity 0.3s ease;
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .hero-cta a:hover {
      opacity: 1;
    }

    /* ===== MARQUEE ===== */
    .marquee-wrapper {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      z-index: 5;
      background: rgba(13, 13, 13, 0.9);
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      padding: 14px 0;
      overflow: hidden;
    }

    .marquee-track {
      display: flex;
      width: max-content;
      animation: marqueeScroll 25s linear infinite;
    }

    .marquee-track span {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.35);
      white-space: nowrap;
      padding-right: 3rem;
    }

    @keyframes marqueeScroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ===== SECTION ARBEITEN ===== */
    .section {
      padding: 100px 5vw;
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: #FF5722;
      margin-bottom: 3.5rem;
    }

    .case-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .case-item {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
      padding: 3rem 0;
      border-bottom: 1px solid rgba(13, 13, 13, 0.1);
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      transition: background-color 0.3s ease;
      /* perspective for tilt effect */
      transform-style: preserve-3d;
      perspective: 800px;
    }

    .case-item:first-child {
      border-top: 1px solid rgba(13, 13, 13, 0.1);
    }

    .case-item:hover {
      background-color: rgba(13, 13, 13, 0.02);
    }

    .case-image-wrapper {
      overflow: hidden;
      border-radius: 3px;
      aspect-ratio: 16 / 10;
    }

    .case-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .case-item:hover .case-image {
      transform: scale(1.03) translateY(-4px);
    }

    .case-info {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .case-meta {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(13, 13, 13, 0.4);
    }

    .case-title {
      font-size: clamp(1.5rem, 2.5vw, 2.2rem);
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: 1.2;
      position: relative;
      display: inline-block;
    }

    .case-title::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 2px;
      background: #FF5722;
      transition: width 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .case-item:hover .case-title::after {
      width: 100%;
    }

    .case-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    .case-tag {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 4px 12px;
      border: 1px solid rgba(13, 13, 13, 0.15);
      border-radius: 100px;
      color: rgba(13, 13, 13, 0.6);
    }

    /* ===== SECTION TEAM ===== */
    .team-section {
      padding: 100px 5vw;
      max-width: 1200px;
      margin: 0 auto;
    }

    .team-intro {
      font-size: clamp(1.6rem, 3vw, 2.4rem);
      font-weight: 300;
      letter-spacing: -0.01em;
      line-height: 1.4;
      max-width: 600px;
      margin-bottom: 4rem;
      color: #0D0D0D;
    }

    .team-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
      margin-bottom: 5rem;
    }

    .team-member {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.2rem;
    }

    .team-avatar {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: #FF5722;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #FAFAFA;
      font-size: 1.4rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      flex-shrink: 0;
    }

    .team-name {
      font-size: 1.1rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .team-role {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(13, 13, 13, 0.4);
      margin-top: -0.6rem;
    }

    .team-bio {
      font-size: 0.9rem;
      line-height: 1.6;
      color: rgba(13, 13, 13, 0.65);
      max-width: 300px;
    }

    /* ===== FOOTER / CONTACT ===== */
    .contact-bar {
      border-top: 1px solid rgba(13, 13, 13, 0.1);
      padding: 2.5rem 5vw;
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .contact-bar-text {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      color: rgba(13, 13, 13, 0.4);
    }

    .contact-bar-text a {
      color: #0D0D0D;
      transition: color 0.3s ease;
    }

    .contact-bar-text a:hover {
      color: #FF5722;
    }

    .contact-motto {
      font-size: 0.8rem;
      font-weight: 400;
      color: rgba(13, 13, 13, 0.35);
      font-style: italic;
    }

    /* ===== SCROLL REVEAL ===== */
    .animate-up {
      opacity: 0;
      transform: translateY(50px);
      transition: opacity 0.65s ease, transform 0.65s ease;
    }

    .animate-up.in-view {
      opacity: 1;
      transform: translateY(0);
    }

    /* Staggered delays for case items */
    .case-item.animate-up:nth-child(1) { transition-delay: 0s; }
    .case-item.animate-up:nth-child(2) { transition-delay: 0.1s; }
    .case-item.animate-up:nth-child(3) { transition-delay: 0.2s; }

    /* Staggered delays for team members */
    .team-member.animate-up:nth-child(1) { transition-delay: 0s; }
    .team-member.animate-up:nth-child(2) { transition-delay: 0.1s; }
    .team-member.animate-up:nth-child(3) { transition-delay: 0.2s; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 900px) {
      .case-item {
        grid-template-columns: 1fr;
        gap: 1.5rem;
        padding: 2rem 0;
      }

      .team-grid {
        grid-template-columns: 1fr;
        gap: 3rem;
      }

      .hero-image {
        width: 85%;
        height: 45vh;
      }
    }

    @media (max-width: 600px) {
      .section,
      .team-section {
        padding: 60px 6vw;
      }

      .hero-image {
        width: 92%;
        height: 40vh;
      }

      .hero-tagline {
        font-size: 1.2rem;
        padding: 0 1.5rem;
      }

      .hero-cta {
        bottom: 70px;
      }

      .contact-bar {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
      }
    }

    /* Hide cursor dot on touch devices */
    @media (hover: none) {
      #cursor-dot { display: none; }
    }
  </style>
</head>
<body>

  <!-- ===== CURSOR DOT ===== -->
  <div id="cursor-dot"></div>

  <!-- ===== HERO ===== -->
  <section class="hero" id="top">
    <div class="hero-big-number">07</div>

    <div class="hero-image-wrapper">
      <img
        class="hero-image"
        src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=1200&q=80&auto=format"
        alt="Arbeitsplatz mit Laptop und Analytics-Dashboard"
        loading="eager"
      />
    </div>

    <div class="hero-content">
      <span class="hero-label">Pixelschmiede</span>
      <h1 class="hero-tagline">Digital. Aber mit Handschrift<span class="accent-dot">.</span></h1>
    </div>

    <div class="hero-cta">
      <a href="#arbeiten">Arbeiten ansehen &#8595;</a>
    </div>

    <div class="marquee-wrapper">
      <div class="marquee-track">
        <span>Weingut Becker</span>
        <span>Caf&eacute; Karls</span>
        <span>Karate-Do Trier</span>
        <span>Moselkorb</span>
        <span>Stadtwerke Trier</span>
        <span>Weingut Becker</span>
        <span>Caf&eacute; Karls</span>
        <span>Karate-Do Trier</span>
        <span>Moselkorb</span>
        <span>Stadtwerke Trier</span>
        <span>Weingut Becker</span>
        <span>Caf&eacute; Karls</span>
        <span>Karate-Do Trier</span>
        <span>Moselkorb</span>
        <span>Stadtwerke Trier</span>
        <span>Weingut Becker</span>
        <span>Caf&eacute; Karls</span>
        <span>Karate-Do Trier</span>
        <span>Moselkorb</span>
        <span>Stadtwerke Trier</span>
      </div>
    </div>
  </section>

  <!-- ===== ARBEITEN ===== -->
  <section class="section" id="arbeiten">
    <div class="section-label animate-up">Arbeiten</div>

    <div class="case-list">
      <div class="case-item animate-up">
        <div class="case-image-wrapper">
          <img
            class="case-image"
            src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=900&q=80&auto=format"
            alt="Weingut Becker — Marke und Website"
            loading="lazy"
          />
        </div>
        <div class="case-info">
          <span class="case-meta">Weingut Becker &mdash; 2025</span>
          <h3 class="case-title">Marke &amp; Website</h3>
          <div class="case-tags">
            <span class="case-tag">Branding</span>
            <span class="case-tag">Webdesign</span>
            <span class="case-tag">Fotografie</span>
          </div>
        </div>
      </div>

      <div class="case-item animate-up">
        <div class="case-image-wrapper">
          <img
            class="case-image"
            src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=900&q=80&auto=format"
            alt="Cafe Karls — Branding und Packaging"
            loading="lazy"
          />
        </div>
        <div class="case-info">
          <span class="case-meta">Caf&eacute; Karls &mdash; 2024</span>
          <h3 class="case-title">Branding &amp; Packaging</h3>
          <div class="case-tags">
            <span class="case-tag">Branding</span>
            <span class="case-tag">Packaging</span>
            <span class="case-tag">Illustration</span>
          </div>
        </div>
      </div>

      <div class="case-item animate-up">
        <div class="case-image-wrapper">
          <img
            class="case-image"
            src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=900&q=80&auto=format"
            alt="Moselkorb — E-Commerce"
            loading="lazy"
          />
        </div>
        <div class="case-info">
          <span class="case-meta">Moselkorb &mdash; 2025</span>
          <h3 class="case-title">E-Commerce</h3>
          <div class="case-tags">
            <span class="case-tag">Webdesign</span>
            <span class="case-tag">Shopify</span>
            <span class="case-tag">Branding</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TEAM ===== -->
  <section class="team-section" id="team">
    <div class="section-label animate-up">Wer wir sind</div>

    <p class="team-intro animate-up">Drei Leute, ein Raum, guter Kaffee.</p>

    <div class="team-grid">
      <div class="team-member animate-up">
        <div class="team-avatar">J</div>
        <h4 class="team-name">Jan</h4>
        <span class="team-role">Design</span>
        <p class="team-bio">Denkt in Rastern und Proportionen. Mag Weissraum mehr als die meisten Menschen. Zustaendig fuer alles, was man sieht.</p>
      </div>

      <div class="team-member animate-up">
        <div class="team-avatar">L</div>
        <h4 class="team-name">Lisa</h4>
        <span class="team-role">Entwicklung</span>
        <p class="team-bio">Baut, was Jan zeichnet. Performance-besessen. Findet, dass jede Website unter einer Sekunde laden sollte.</p>
      </div>

      <div class="team-member animate-up">
        <div class="team-avatar">T</div>
        <h4 class="team-name">Tom</h4>
        <span class="team-role">Strategie</span>
        <p class="team-bio">Stellt die unbequemen Fragen vor dem ersten Pixel. Sorgt dafuer, dass Design nicht nur gut aussieht, sondern funktioniert.</p>
      </div>
    </div>

    <div class="contact-bar animate-up">
      <span class="contact-bar-text">Trier &middot; <a href="mailto:info@pixelschmiede.de">info@pixelschmiede.de</a> &middot; Kein Formular, einfach schreiben.</span>
      <span class="contact-motto">Show, don't tell.</span>
    </div>
  </section>

  <script>
    // ===== INTERSECTION OBSERVER — animate-up =====
    const slideObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            slideObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('.animate-up').forEach((el) => {
      slideObserver.observe(el);
    });


    // ===== CURSOR DOT FOLLOWER =====
    const cursorDot = document.getElementById('cursor-dot');
    let cursorX = 0;
    let cursorY = 0;
    let dotX = 0;
    let dotY = 0;
    let cursorVisible = false;
    let rafId = null;

    document.addEventListener('mousemove', (e) => {
      cursorX = e.clientX;
      cursorY = e.clientY;

      if (!cursorVisible) {
        cursorVisible = true;
        cursorDot.style.opacity = '1';
      }

      if (!rafId) {
        rafId = requestAnimationFrame(animateCursor);
      }
    });

    document.addEventListener('mouseleave', () => {
      cursorDot.style.opacity = '0';
      cursorVisible = false;
    });

    function animateCursor() {
      // 150ms lag via lerp (lower = more lag)
      const lerpFactor = 0.12;
      dotX += (cursorX - dotX) * lerpFactor;
      dotY += (cursorY - dotY) * lerpFactor;

      cursorDot.style.left = dotX + 'px';
      cursorDot.style.top = dotY + 'px';

      const distX = Math.abs(cursorX - dotX);
      const distY = Math.abs(cursorY - dotY);

      if (distX > 0.1 || distY > 0.1) {
        rafId = requestAnimationFrame(animateCursor);
      } else {
        rafId = null;
      }
    }


    // ===== CARD TILT on hover =====
    const caseItems = document.querySelectorAll('.case-item');

    caseItems.forEach((card) => {
      card.addEventListener('mouseenter', () => {
        card.style.transition = 'transform 0.15s ease, background-color 0.3s ease';
      });

      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;
        const relX = (e.clientX - centerX) / (rect.width / 2);
        const relY = (e.clientY - centerY) / (rect.height / 2);

        // Max tilt: 2deg — subtle, not cheesy
        const tiltX = relY * -2;
        const tiltY = relX * 2;

        card.style.transform = `perspective(800px) rotateX(${tiltX}deg) rotateY(${tiltY}deg)`;
      });

      card.addEventListener('mouseleave', () => {
        card.style.transition = 'transform 0.4s ease, background-color 0.3s ease';
        card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg)';
      });
    });
  </script>

</body>
</html>
