---
export const prerender = true;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>FORM. — Digital Design Studio Trier</title>
  <meta name="description" content="FORM. ist ein Digital Design Studio aus Trier. Wir bauen Marken, die sich nicht entschuldigen." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    /* ─── RESET ─────────────────────────────────────────────────── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { overflow-x: hidden; scroll-behavior: smooth; }
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }

    /* ─── TOKENS ────────────────────────────────────────────────── */
    :root {
      --bg:       #080808;
      --bg2:      #0F0F0F;
      --fg:       #F0EDE6;
      --fg-dim:   rgba(240,237,230,0.4);
      --accent:   #C8F751;          /* electric lime */
      --border:   rgba(240,237,230,0.08);
      --font-display: 'Syne', system-ui, sans-serif;
      --font-body:    'Space Grotesk', system-ui, sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--fg);
      font-family: var(--font-body);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
      cursor: none;
    }

    ::selection { background: var(--accent); color: var(--bg); }

    /* ─── CUSTOM CURSOR ─────────────────────────────────────────── */
    #cur-ring {
      position: fixed;
      width: 36px; height: 36px;
      border: 1px solid rgba(200,247,81,0.5);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%,-50%);
      transition: width 0.25s ease, height 0.25s ease, border-color 0.25s ease, background 0.25s ease;
      mix-blend-mode: difference;
    }
    #cur-dot {
      position: fixed;
      width: 5px; height: 5px;
      background: var(--accent);
      border-radius: 50%;
      pointer-events: none;
      z-index: 10000;
      transform: translate(-50%,-50%);
    }
    body.cursor-hover #cur-ring {
      width: 64px; height: 64px;
      border-color: var(--accent);
      background: rgba(200,247,81,0.06);
    }
    @media (hover: none) { #cur-ring, #cur-dot { display: none; } body { cursor: auto; } }

    /* ─── NAV ───────────────────────────────────────────────────── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 2rem clamp(1.5rem,5vw,4rem);
    }
    .nav::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(8,8,8,0.9) 0%, transparent 100%);
      z-index: -1;
      pointer-events: none;
    }
    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.4rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--fg);
    }
    .nav-logo span { color: var(--accent); }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--fg-dim);
      transition: color 0.3s;
    }
    .nav-links a:hover { color: var(--accent); }
    .nav-cta {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--accent);
      padding: 0.6rem 1.4rem;
      border-radius: 100px;
      transition: opacity 0.25s;
    }
    .nav-cta:hover { opacity: 0.85; }

    /* ─── HERO ──────────────────────────────────────────────────── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 clamp(1.5rem,5vw,4rem) 6rem;
      overflow: hidden;
    }

    /* Background image with parallax-like treatment */
    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .hero-bg img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: brightness(0.28) saturate(0.7);
      transform: scale(1.04);
      animation: heroZoom 14s ease-out forwards;
    }
    @keyframes heroZoom {
      from { transform: scale(1.08); }
      to   { transform: scale(1.0); }
    }
    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to top, rgba(8,8,8,1) 0%, rgba(8,8,8,0.3) 45%, transparent 100%),
        linear-gradient(to right, rgba(8,8,8,0.5) 0%, transparent 60%);
    }

    /* Oversized wordmark watermark */
    .hero-wordmark {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-family: var(--font-display);
      font-size: clamp(120px, 20vw, 320px);
      font-weight: 800;
      letter-spacing: -0.05em;
      color: transparent;
      -webkit-text-stroke: 1px rgba(240,237,230,0.05);
      z-index: 1;
      user-select: none;
      pointer-events: none;
      white-space: nowrap;
      animation: fadeIn 2s ease 0.5s both;
    }

    .hero-content {
      position: relative;
      z-index: 2;
    }

    .hero-eyebrow {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
      animation: slideUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.2s both;
    }

    .hero-h1 {
      font-family: var(--font-display);
      font-size: clamp(3.2rem, 8.5vw, 10rem);
      font-weight: 800;
      line-height: 0.92;
      letter-spacing: -0.04em;
      color: var(--fg);
      max-width: 14ch;
      animation: slideUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.35s both;
    }
    .hero-h1 em {
      font-style: italic;
      color: var(--accent);
    }

    .hero-sub {
      margin-top: 2.5rem;
      font-size: clamp(0.95rem, 1.4vw, 1.2rem);
      font-weight: 300;
      color: var(--fg-dim);
      max-width: 42ch;
      line-height: 1.6;
      animation: slideUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.5s both;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      margin-top: 3rem;
      animation: slideUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.65s both;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--accent);
      padding: 1rem 2rem;
      border-radius: 100px;
      transition: transform 0.25s, opacity 0.25s;
    }
    .btn-primary:hover { transform: translateY(-2px); opacity: 0.9; }
    .btn-ghost {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--fg-dim);
      border-bottom: 1px solid var(--border);
      padding-bottom: 2px;
      transition: color 0.3s, border-color 0.3s;
    }
    .btn-ghost:hover { color: var(--fg); border-color: var(--fg-dim); }

    /* Hero stats */
    .hero-stats {
      position: absolute;
      right: clamp(1.5rem,5vw,4rem);
      bottom: 6rem;
      z-index: 2;
      display: flex;
      flex-direction: column;
      gap: 2rem;
      text-align: right;
      animation: fadeIn 1s ease 1s both;
    }
    .hero-stat-num {
      font-family: var(--font-display);
      font-size: 2.2rem;
      font-weight: 800;
      line-height: 1;
      color: var(--fg);
    }
    .hero-stat-label {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--fg-dim);
      margin-top: 0.3rem;
    }

    /* Scroll indicator */
    .hero-scroll {
      position: absolute;
      left: clamp(1.5rem,5vw,4rem);
      bottom: 2.5rem;
      z-index: 2;
      display: flex;
      align-items: center;
      gap: 1rem;
      animation: fadeIn 1s ease 1.2s both;
    }
    .scroll-line {
      width: 40px;
      height: 1px;
      background: var(--fg-dim);
      position: relative;
      overflow: hidden;
    }
    .scroll-line::after {
      content: '';
      position: absolute;
      top: 0; left: -100%;
      width: 100%; height: 100%;
      background: var(--accent);
      animation: scrollSlide 2s ease-in-out 1.5s infinite;
    }
    @keyframes scrollSlide {
      0%   { left: -100%; }
      50%  { left: 0; }
      100% { left: 100%; }
    }
    .scroll-text {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--fg-dim);
    }

    /* ─── MARQUEE ───────────────────────────────────────────────── */
    .marquee {
      background: var(--accent);
      padding: 0.85rem 0;
      overflow: hidden;
    }
    .marquee-track {
      display: flex;
      width: max-content;
      animation: marquee 22s linear infinite;
    }
    .marquee-item {
      font-family: var(--font-display);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--bg);
      white-space: nowrap;
      padding-right: 3.5rem;
    }
    .marquee-sep {
      color: rgba(8,8,8,0.35);
      padding-right: 3.5rem;
    }
    @keyframes marquee {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* ─── SECTION SHELL ─────────────────────────────────────────── */
    .section {
      padding: clamp(5rem,10vh,9rem) clamp(1.5rem,5vw,4rem);
    }
    .section-label {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 4rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .section-label::before {
      content: '';
      display: block;
      width: 24px;
      height: 1px;
      background: var(--accent);
    }

    /* ─── WORK ──────────────────────────────────────────────────── */
    .work { background: var(--bg); }

    .work-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 5rem;
      gap: 2rem;
    }
    .work-title {
      font-family: var(--font-display);
      font-size: clamp(2.8rem, 6vw, 6rem);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 0.95;
    }
    .work-count {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fg-dim);
      margin-bottom: 0.5rem;
    }

    .cases { display: flex; flex-direction: column; }

    .case {
      display: grid;
      grid-template-columns: 60px 1fr 1fr;
      gap: 3rem;
      align-items: center;
      padding: 3rem 0;
      border-top: 1px solid var(--border);
      transition: background 0.3s;
      position: relative;
    }
    .case:last-child { border-bottom: 1px solid var(--border); }
    .case:hover { background: rgba(240,237,230,0.02); }

    .case-num {
      font-family: var(--font-display);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--fg-dim);
      align-self: flex-start;
      padding-top: 0.4rem;
    }

    .case-img-wrap {
      overflow: hidden;
      border-radius: 6px;
      aspect-ratio: 4/3;
      position: relative;
    }
    .case-img-wrap img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.7s cubic-bezier(0.25,0.46,0.45,0.94), filter 0.4s;
      filter: saturate(0.85);
    }
    .case:hover .case-img-wrap img {
      transform: scale(1.06);
      filter: saturate(1.1);
    }
    .case-img-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(200,247,81,0.12) 0%, transparent 60%);
      opacity: 0;
      transition: opacity 0.4s;
    }
    .case:hover .case-img-overlay { opacity: 1; }

    .case-info { display: flex; flex-direction: column; gap: 1.2rem; }

    .case-client {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--fg-dim);
    }

    .case-title {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 2.8vw, 2.8rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.05;
      position: relative;
    }
    .case-title::after {
      content: '';
      position: absolute;
      bottom: -6px; left: 0;
      width: 0; height: 2px;
      background: var(--accent);
      transition: width 0.45s cubic-bezier(0.25,0.46,0.45,0.94);
    }
    .case:hover .case-title::after { width: 48px; }

    .case-desc {
      font-size: 0.9rem;
      font-weight: 300;
      color: var(--fg-dim);
      line-height: 1.65;
      max-width: 36ch;
    }

    .case-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }
    .tag {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 4px 10px;
      border: 1px solid var(--border);
      border-radius: 100px;
      color: var(--fg-dim);
      transition: border-color 0.25s, color 0.25s;
    }
    .case:hover .tag { border-color: rgba(200,247,81,0.25); color: var(--accent); }

    .case-arrow {
      position: absolute;
      right: 0; top: 50%;
      transform: translateY(-50%) translateX(8px);
      opacity: 0;
      transition: opacity 0.3s, transform 0.3s;
      font-size: 1.4rem;
      color: var(--accent);
    }
    .case:hover .case-arrow { opacity: 1; transform: translateY(-50%) translateX(0); }

    /* ─── STATEMENT ─────────────────────────────────────────────── */
    .statement {
      background: var(--accent);
      padding: clamp(4rem,8vw,8rem) clamp(1.5rem,5vw,4rem);
    }
    .statement-text {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 5.5rem);
      font-weight: 800;
      line-height: 1.0;
      letter-spacing: -0.04em;
      color: var(--bg);
      max-width: 18ch;
    }
    .statement-text em {
      font-style: italic;
      font-weight: 400;
    }
    .statement-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 3.5rem;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .statement-sub {
      font-size: 0.95rem;
      font-weight: 400;
      color: rgba(8,8,8,0.65);
      max-width: 42ch;
      line-height: 1.6;
    }
    .btn-dark {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      background: var(--bg);
      padding: 1rem 2rem;
      border-radius: 100px;
      transition: transform 0.25s;
      white-space: nowrap;
    }
    .btn-dark:hover { transform: translateY(-2px); }

    /* ─── ABOUT ─────────────────────────────────────────────────── */
    .about { background: var(--bg2); }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }
    .about-left {}
    .about-headline {
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 5vw, 5rem);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 0.96;
      margin-bottom: 2.5rem;
    }
    .about-headline em {
      font-style: italic;
      color: var(--accent);
    }
    .about-body {
      font-size: 1rem;
      font-weight: 300;
      color: var(--fg-dim);
      line-height: 1.75;
      max-width: 44ch;
    }
    .about-body + .about-body { margin-top: 1.2rem; }

    .about-right {}
    .about-photo {
      position: relative;
      border-radius: 8px;
      overflow: hidden;
      aspect-ratio: 4/5;
    }
    .about-photo img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: saturate(0.7);
    }
    .about-photo-label {
      position: absolute;
      bottom: 1.5rem; left: 1.5rem;
      background: var(--accent);
      color: var(--bg);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 0.5rem 1rem;
      border-radius: 100px;
    }

    /* Team */
    .team-grid {
      display: grid;
      grid-template-columns: repeat(3,1fr);
      gap: 2rem;
      margin-top: 5rem;
    }
    .team-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
      transition: border-color 0.3s, transform 0.3s;
    }
    .team-card:hover { border-color: rgba(200,247,81,0.25); transform: translateY(-4px); }
    .team-avatar {
      width: 56px; height: 56px;
      border-radius: 50%;
      background: var(--bg2);
      border: 1px solid var(--border);
      overflow: hidden;
      margin-bottom: 1.5rem;
    }
    .team-avatar img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: saturate(0.6);
    }
    .team-name {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.3rem;
    }
    .team-role {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1rem;
    }
    .team-bio {
      font-size: 0.85rem;
      font-weight: 300;
      color: var(--fg-dim);
      line-height: 1.65;
    }

    /* ─── SERVICES ──────────────────────────────────────────────── */
    .services { background: var(--bg); }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3,1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      margin-top: 0;
    }
    .service-item {
      background: var(--bg);
      padding: 2.5rem 2rem;
      transition: background 0.3s;
    }
    .service-item:hover { background: var(--bg2); }
    .service-icon {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      display: block;
    }
    .service-name {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.8rem;
    }
    .service-desc {
      font-size: 0.85rem;
      font-weight: 300;
      color: var(--fg-dim);
      line-height: 1.6;
    }

    /* ─── CONTACT ───────────────────────────────────────────────── */
    .contact {
      background: var(--bg);
      border-top: 1px solid var(--border);
    }
    .contact-inner {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 4rem;
      align-items: end;
    }
    .contact-headline {
      font-family: var(--font-display);
      font-size: clamp(2.8rem, 6vw, 7rem);
      font-weight: 800;
      letter-spacing: -0.05em;
      line-height: 0.92;
    }
    .contact-headline em { color: var(--accent); font-style: italic; }
    .contact-info {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.8rem;
      flex-shrink: 0;
    }
    .contact-link {
      font-size: 0.85rem;
      font-weight: 400;
      color: var(--fg-dim);
      transition: color 0.25s;
    }
    .contact-link:hover { color: var(--accent); }

    /* ─── FOOTER BAR ─────────────────────────────────────────────── */
    .footer-bar {
      border-top: 1px solid var(--border);
      padding: 1.75rem clamp(1.5rem,5vw,4rem);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .footer-copy {
      font-size: 0.65rem;
      font-weight: 400;
      letter-spacing: 0.08em;
      color: var(--fg-dim);
    }
    .footer-tagline {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(200,247,81,0.4);
    }

    /* ─── REVEAL ANIMATIONS ─────────────────────────────────────── */
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
