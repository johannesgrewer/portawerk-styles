---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nadelwerk — Tattoo & Illustration Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      overflow-x: hidden;
      height: 100%;
    }

    body {
      overflow-x: hidden;
      height: 100%;
      background: #0A0A0A;
      color: #F0EDE8;
      font-family: 'DM Mono', monospace;
    }

    /* ---- Film grain overlay ---- */
    .hero {
      position: relative;
      width: 100vw;
      height: 100vh;
      overflow: hidden;
    }

    .hero::after {
      content: '';
      position: absolute;
      inset: -50%;
      width: 200%;
      height: 200%;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E");
      opacity: 0.12;
      pointer-events: none;
      z-index: 20;
      animation: grainShift 0.12s steps(1) infinite;
    }

    @keyframes grainShift {
      0%   { transform: translate(0, 0); }
      25%  { transform: translate(-2%, 1%); }
      50%  { transform: translate(1%, -2%); }
      75%  { transform: translate(2%, 2%); }
      100% { transform: translate(-1%, 0%); }
    }

    /* ---- Background image ---- */
    .hero__bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.unsplash.com/photo-1567324216289-5b5b8c4f5e45?w=1400&q=80&auto=format');
      background-size: cover;
      background-position: center;
      z-index: 0;
      transition: filter 0.6s ease;
    }

    .hero:hover .hero__bg {
      filter: saturate(1.6) hue-rotate(340deg) brightness(0.9);
    }

    /* Gradient overlay */
    .hero__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(10,10,10,0.2) 0%,
        rgba(10,10,10,0.45) 50%,
        rgba(10,10,10,0.85) 100%
      );
      z-index: 1;
    }

    /* ---- Red diagonal line ---- */
    .hero__diagonal {
      position: absolute;
      z-index: 5;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      overflow: hidden;
    }

    .hero__diagonal::after {
      content: '';
      position: absolute;
      width: 2px;
      height: 180%;
      background: #E63946;
      top: -40%;
      left: 52%;
      transform: rotate(22deg);
      transform-origin: top center;
      opacity: 0;
      animation: fadeIn 0.6s ease forwards 2.4s;
    }

    /* ---- Content layout ---- */
    .hero__content {
      position: relative;
      z-index: 10;
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 3.5rem 3.5rem 3rem;
    }

    /* Top section — brand name */
    .hero__top {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }

    .hero__name-top {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5rem, 14vw, 13rem);
      line-height: 0.88;
      color: #F0EDE8;
      letter-spacing: 0.02em;
      opacity: 0;
      transform: translateX(-40px);
      animation: slideRight 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.3s;
    }

    .hero__red-rule {
      width: clamp(5rem, 14vw, 13rem);
      height: 3px;
      background: #E63946;
      margin: 0.3rem 0;
      opacity: 0;
      transform: scaleX(0);
      transform-origin: left;
      animation: expandLine 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.85s;
    }

    .hero__name-bottom {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5rem, 14vw, 13rem);
      line-height: 0.88;
      color: #F0EDE8;
      letter-spacing: 0.02em;
      opacity: 0;
      transform: translateX(-40px);
      animation: slideRight 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.5s;
    }

    /* Bottom section */
    .hero__bottom {
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
    }

    .hero__sub {
      font-family: 'DM Mono', monospace;
      font-weight: 300;
      font-size: clamp(0.55rem, 1vw, 0.72rem);
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(240, 237, 232, 0.65);
      opacity: 0;
      transform: translateY(12px);
      animation: riseIn 0.7s ease forwards 1.3s;
    }

    .hero__tagline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2rem, 5vw, 4rem);
      color: #F0EDE8;
      letter-spacing: 0.04em;
      opacity: 0;
      transform: translateY(12px);
      animation: riseIn 0.7s ease forwards 1.6s;
    }

    /* ---- Scroll indicator ---- */
    .hero__scroll {
      position: absolute;
      bottom: 2.5rem;
      right: 3.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      z-index: 10;
      opacity: 0;
      animation: fadeIn 0.8s ease forwards 2.8s;
    }

    .hero__scroll-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.4);
      writing-mode: vertical-rl;
    }

    .hero__scroll-line {
      width: 1px;
      height: 60px;
      background: #E63946;
      position: relative;
      overflow: hidden;
    }

    .hero__scroll-line::after {
      content: '';
      position: absolute;
      top: -100%;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(240,237,232,0.2);
      animation: scrollPulse 1.8s ease-in-out infinite;
    }

    @keyframes scrollPulse {
      0%   { top: -100%; opacity: 1; }
      100% { top: 100%;  opacity: 0; }
    }

    /* ---- Keyframes ---- */

    @keyframes riseIn {
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeIn {
      to { opacity: 1; }
    }

    @keyframes slideRight {
      to { opacity: 1; transform: translateX(0); }
    }

    @keyframes expandLine {
      to { opacity: 1; transform: scaleX(1); }
    }

    /* === PHOTO CONTAINER === */
    .ph { position: relative; overflow: hidden; }
    .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
    .ph:hover img { transform: scale(1.05); }

    /* === PORTFOLIO SECTION === */
    .portfolio {
      background: #0A0A0A;
      padding: 6rem 3.5rem;
      max-width: 1600px;
      margin-left: auto;
      margin-right: auto;
    }
    .port-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.35);
      margin-bottom: 0.75rem;
    }
    .port-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 5vw, 4rem);
      color: #F0EDE8;
      letter-spacing: 0.04em;
      margin-bottom: 3rem;
    }
    .port-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3px;
    }
    .port-card {
      position: relative;
      overflow: hidden;
    }
    .port-card-inner {
      height: 380px;
    }
    .port-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(10,10,10,0.85) 0%, transparent 55%);
      pointer-events: none;
      transition: background 0.4s ease;
    }
    .port-card:hover .port-card-overlay {
      background: linear-gradient(to top, rgba(230,57,70,0.6) 0%, transparent 70%);
    }
    .port-card-info {
      position: absolute;
      bottom: 1.25rem;
      left: 1.25rem;
      z-index: 2;
    }
    .port-card-tag {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #E63946;
      display: block;
      margin-bottom: 0.25rem;
    }
    .port-card-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      color: #F0EDE8;
      letter-spacing: 0.06em;
    }

    /* === ARTISTS SECTION === */
    .artists {
      background: #111111;
      padding: 6rem 3.5rem;
      max-width: 1600px;
      margin-left: auto;
      margin-right: auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .artists-photo {
      height: 520px;
      border: 1px solid rgba(240,237,232,0.08);
    }
    .artists-content {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .artists-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.35);
    }
    .artists-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 4vw, 3.8rem);
      color: #F0EDE8;
      letter-spacing: 0.04em;
      line-height: 1.0;
    }
    .artists-title .red { color: #E63946; }
    .artists-body {
      font-family: 'DM Mono', monospace;
      font-weight: 300;
      font-size: 0.78rem;
      line-height: 1.9;
      color: rgba(240,237,232,0.55);
    }
    .artists-list {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }
    .artist-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(240,237,232,0.08);
    }
    .artist-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #E63946;
      flex-shrink: 0;
    }
    .artist-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      color: #F0EDE8;
      letter-spacing: 0.06em;
      flex: 1;
    }
    .artist-spec {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.35);
    }
    .artists-cta {
      font-family: 'DM Mono', monospace;
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #F0EDE8;
      background: #E63946;
      padding: 1rem 2rem;
      text-decoration: none;
      width: fit-content;
      transition: background 0.2s;
    }
    .artists-cta:hover { background: #c42d3a; }
  </style>
</head>
<body>
  <section class="hero">

    <div class="hero__bg"></div>
    <div class="hero__overlay"></div>
    <div class="hero__diagonal"></div>

    <div class="hero__content">

      <div class="hero__top">
        <div class="hero__name-top">NADEL</div>
        <div class="hero__red-rule"></div>
        <div class="hero__name-bottom">WERK</div>
      </div>

      <div class="hero__bottom">
        <p class="hero__sub">Tattoo &amp; Illustration &nbsp;·&nbsp; Trier</p>
        <p class="hero__tagline">Haut als Leinwand.</p>
      </div>

    </div>

    <!-- Scroll indicator -->
    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-label">Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>

  </section>

  <!-- PORTFOLIO -->
  <section class="portfolio">
    <p class="port-label">02 / Arbeiten</p>
    <h2 class="port-title">Portfolio.</h2>
    <div class="port-grid">

      <div class="port-card">
        <div class="ph port-card-inner">
          <img src="https://images.unsplash.com/photo-1542736667-069246bdbc6d?auto=format&fit=crop&w=1200&h=800&q=80" alt="Blackwork Tattoo" loading="lazy"/>
        </div>
        <div class="port-card-overlay"></div>
        <div class="port-card-info">
          <span class="port-card-tag">Blackwork</span>
          <div class="port-card-name">Geometrie & Linie</div>
        </div>
      </div>

      <div class="port-card">
        <div class="ph port-card-inner">
          <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?auto=format&fit=crop&w=1200&h=800&q=80" alt="Fine Line Tattoo" loading="lazy"/>
        </div>
        <div class="port-card-overlay"></div>
        <div class="port-card-info">
          <span class="port-card-tag">Fine Line</span>
          <div class="port-card-name">Botanik & Flora</div>
        </div>
      </div>

      <div class="port-card">
        <div class="ph port-card-inner">
          <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=1200&h=800&q=80" alt="Traditional Tattoo" loading="lazy"/>
        </div>
        <div class="port-card-overlay"></div>
        <div class="port-card-info">
          <span class="port-card-tag">Traditional</span>
          <div class="port-card-name">Flash & Klassik</div>
        </div>
      </div>

    </div>
  </section>

  <!-- ARTISTS + BOOKING -->
  <section class="artists">
    <div class="ph artists-photo">
      <img src="https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=1200&h=800&q=80" alt="Nadelwerk Studio Trier" loading="lazy"/>
      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.45) 0%,transparent 60%);pointer-events:none;"></div>
    </div>
    <div class="artists-content">
      <p class="artists-label">03 / Das Team</p>
      <h2 class="artists-title">Unsere <span class="red">Artists.</span></h2>
      <p class="artists-body">
        Drei Charaktere, drei Handschriften —
        ein gemeinsamer Anspruch: jedes Motiv
        sitzt für immer. Termine nach Absprache,
        Custom-Anfragen willkommen.
      </p>
      <div class="artists-list">
        <div class="artist-item">
          <span class="artist-dot"></span>
          <span class="artist-name">Jana Krause</span>
          <span class="artist-spec">Fine Line · Botanical</span>
        </div>
        <div class="artist-item">
          <span class="artist-dot"></span>
          <span class="artist-name">Marc Thiel</span>
          <span class="artist-spec">Blackwork · Geometric</span>
        </div>
        <div class="artist-item">
          <span class="artist-dot"></span>
          <span class="artist-name">Sari Nowak</span>
          <span class="artist-spec">Traditional · Illustrative</span>
        </div>
      </div>
      <a href="#" class="artists-cta">Termin anfragen →</a>
    </div>
  </section>

</body>
</html>
