---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nadelwerk — Tattoo & Illustration Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Caveat:wght@700&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { overflow-x: hidden; }

    body {
      overflow-x: hidden;
      background: #0A0A0A;
      color: #F0EDE8;
      font-family: 'DM Mono', monospace;
    }

    /* ─── Photo container helper ─── */
    .ph { position: relative; overflow: hidden; }
    .ph img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.65s cubic-bezier(0.22,1,0.36,1);
    }
    .ph:hover img { transform: scale(1.05); }

    /* ─── Utility ─── */
    .label {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.35);
      display: block;
    }

    /* ══════════════════════════════════════
       HERO
    ══════════════════════════════════════ */
    .hero {
      position: relative;
      width: 100vw;
      height: 100vh;
      min-height: 600px;
      overflow: hidden;
    }

    /* film grain */
    .hero::after {
      content: '';
      position: absolute;
      inset: -50%;
      width: 200%; height: 200%;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.08'/%3E%3C/svg%3E");
      opacity: 0.13;
      pointer-events: none;
      z-index: 20;
      animation: grainShift 0.12s steps(1) infinite;
    }

    @keyframes grainShift {
      0%   { transform: translate(0,0); }
      25%  { transform: translate(-2%,1%); }
      50%  { transform: translate(1%,-2%); }
      75%  { transform: translate(2%,2%); }
      100% { transform: translate(-1%,0%); }
    }

    .hero__bg {
      position: absolute; inset: 0;
      background-image: url('https://images.unsplash.com/photo-1605106702842-01a887a31122?auto=format&fit=crop&w=1600&q=80');
      background-size: cover;
      background-position: center 35%;
      z-index: 0;
      transition: transform 8s ease;
    }
    .hero:hover .hero__bg { transform: scale(1.03); }

    .hero__overlay {
      position: absolute; inset: 0;
      background: linear-gradient(
        135deg,
        rgba(10,10,10,0.72) 0%,
        rgba(10,10,10,0.35) 45%,
        rgba(10,10,10,0.78) 100%
      );
      z-index: 1;
    }

    /* diagonal red line */
    .hero__slash {
      position: absolute; inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 5;
    }
    .hero__slash::after {
      content: '';
      position: absolute;
      width: 1px; height: 180%;
      background: #E63946;
      top: -40%; left: 55%;
      transform: rotate(18deg);
      transform-origin: top;
      opacity: 0;
      animation: fadeIn 0.5s ease forwards 2.6s;
    }

    .hero__content {
      position: relative; z-index: 10;
      width: 100%; height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: clamp(2rem, 5vw, 3.5rem);
    }

    /* nav bar */
    .hero__nav {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }
    .hero__nav-brand {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.45);
      opacity: 0;
      animation: fadeIn 0.6s ease forwards 0.1s;
    }
    .hero__nav-links {
      display: flex; gap: 2rem;
      opacity: 0;
      animation: fadeIn 0.6s ease forwards 0.2s;
    }
    .hero__nav-link {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.4);
      text-decoration: none;
      transition: color 0.2s;
    }
    .hero__nav-link:hover { color: #E63946; }

    /* headline */
    .hero__headline {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }
    .hero__word {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5.5rem, 16vw, 14rem);
      line-height: 0.86;
      color: #F0EDE8;
      letter-spacing: 0.01em;
      opacity: 0;
      transform: translateX(-50px);
    }
    .hero__word--1 { animation: slideRight 0.75s cubic-bezier(0.22,1,0.36,1) forwards 0.35s; }
    .hero__word--2 { animation: slideRight 0.75s cubic-bezier(0.22,1,0.36,1) forwards 0.55s; }

    .hero__rule {
      width: clamp(5.5rem, 16vw, 14rem);
      height: 3px;
      background: #E63946;
      margin: 0.25rem 0;
      opacity: 0;
      transform: scaleX(0);
      transform-origin: left;
      animation: expandLine 0.6s cubic-bezier(0.22,1,0.36,1) forwards 0.95s;
    }

    /* bottom info row */
    .hero__bottom {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }
    .hero__meta {
      display: flex; flex-direction: column; gap: 0.7rem;
    }
    .hero__location {
      font-family: 'DM Mono', monospace;
      font-size: 0.52rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.5);
      opacity: 0;
      animation: riseIn 0.7s ease forwards 1.4s;
    }
    .hero__tagline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(1.8rem, 4.5vw, 3.8rem);
      color: #F0EDE8;
      letter-spacing: 0.04em;
      opacity: 0;
      animation: riseIn 0.7s ease forwards 1.65s;
    }
    .hero__caveat {
      font-family: 'Caveat', cursive;
      font-size: clamp(1.2rem, 2.5vw, 1.7rem);
      color: #E63946;
      opacity: 0;
      animation: riseIn 0.7s ease forwards 1.9s;
    }

    /* scroll indicator */
    .hero__scroll {
      display: flex; flex-direction: column;
      align-items: center; gap: 0.5rem;
      opacity: 0;
      animation: fadeIn 0.8s ease forwards 3s;
    }
    .hero__scroll-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.48rem; letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.3);
      writing-mode: vertical-rl;
    }
    .hero__scroll-line {
      width: 1px; height: 56px;
      background: rgba(240,237,232,0.12);
      position: relative; overflow: hidden;
    }
    .hero__scroll-line::after {
      content: '';
      position: absolute; top: -100%; left: 0;
      width: 100%; height: 50%;
      background: #E63946;
      animation: scrollPulse 1.8s ease-in-out infinite;
    }
    @keyframes scrollPulse {
      0%   { top: -50%; opacity: 1; }
      100% { top: 110%; opacity: 0; }
    }

    /* ─── Keyframes ─── */
    @keyframes riseIn   { to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeIn   { to { opacity: 1; } }
    @keyframes slideRight { to { opacity: 1; transform: translateX(0); } }
    @keyframes expandLine { to { opacity: 1; transform: scaleX(1); } }

    /* ══════════════════════════════════════
       INTRO STRIP
    ══════════════════════════════════════ */
    .intro-strip {
      background: #E63946;
      padding: 1rem clamp(2rem, 5vw, 3.5rem);
      display: flex;
      gap: 3rem;
      overflow: hidden;
    }
    .intro-strip__item {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(10,10,10,0.8);
      white-space: nowrap;
    }
    .intro-strip__sep {
      color: rgba(10,10,10,0.4);
    }

    /* ══════════════════════════════════════
       PORTFOLIO
    ══════════════════════════════════════ */
    .portfolio {
      padding: 6rem clamp(2rem, 5vw, 3.5rem);
      max-width: 1600px;
      margin: 0 auto;
    }
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 3rem;
    }
    .section-header__left { display: flex; flex-direction: column; gap: 0.6rem; }
    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 5vw, 4rem);
      color: #F0EDE8;
      letter-spacing: 0.04em;
      line-height: 1;
    }
    .section-caveat {
      font-family: 'Caveat', cursive;
      font-size: clamp(1rem, 2vw, 1.35rem);
      color: rgba(240,237,232,0.3);
    }
    .section-header__link {
      font-family: 'DM Mono', monospace;
      font-size: 0.52rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.35);
      text-decoration: none;
      border-bottom: 1px solid rgba(240,237,232,0.15);
      padding-bottom: 0.15rem;
      transition: color 0.2s, border-color 0.2s;
    }
    .section-header__link:hover { color: #E63946; border-color: #E63946; }

    /* Featured row */
    .port-featured {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: 3px;
      margin-bottom: 3px;
    }
    .port-featured__main { height: 520px; }
    .port-featured__stack {
      display: grid;
      grid-template-rows: 1fr 1fr;
      gap: 3px;
    }
    .port-featured__stack .ph { height: 100%; }

    /* Regular grid */
    .port-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3px;
    }
    .port-grid .ph { height: 320px; }

    /* Card overlay + info */
    .port-card {
      position: relative;
    }
    .port-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(10,10,10,0.85) 0%, transparent 55%);
      transition: background 0.4s ease;
      pointer-events: none;
    }
    .port-card:hover .port-overlay {
      background: linear-gradient(to top, rgba(230,57,70,0.65) 0%, transparent 65%);
    }
    .port-info {
      position: absolute;
      bottom: 1.25rem; left: 1.25rem;
      z-index: 2;
    }
    .port-tag {
      font-family: 'DM Mono', monospace;
      font-size: 0.48rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #E63946;
      display: block;
      margin-bottom: 0.2rem;
    }
    .port-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      color: #F0EDE8;
      letter-spacing: 0.06em;
    }

    /* ══════════════════════════════════════
       ARTISTS
    ══════════════════════════════════════ */
    .artists {
      background: #0F0F0F;
      padding: 6rem clamp(2rem, 5vw, 3.5rem);
    }
    .artists__inner {
      max-width: 1600px;
      margin: 0 auto;
    }
    .artists__header {
      display: flex;
      flex-direction: column; gap: 0.6rem;
      margin-bottom: 3.5rem;
    }
    .artists__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    .artist-card {
      position: relative;
      overflow: hidden;
    }
    .artist-card__photo { height: 480px; }
    .artist-card__overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0.2) 50%, transparent 75%);
      pointer-events: none;
    }
    .artist-card:hover .artist-card__overlay {
      background: linear-gradient(to top, rgba(10,10,10,0.95) 0%, rgba(230,57,70,0.15) 60%, transparent 85%);
    }
    .artist-card__content {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 1.75rem 1.5rem;
      z-index: 2;
    }
    .artist-card__number {
      font-family: 'DM Mono', monospace;
      font-size: 0.45rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #E63946;
      display: block;
      margin-bottom: 0.4rem;
    }
    .artist-card__name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      color: #F0EDE8;
      letter-spacing: 0.06em;
      display: block;
      margin-bottom: 0.3rem;
    }
    .artist-card__spec {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.45);
      display: block;
      margin-bottom: 0.9rem;
    }
    .artist-card__tags {
      display: flex; flex-wrap: wrap; gap: 0.4rem;
    }
    .artist-tag {
      font-family: 'DM Mono', monospace;
      font-size: 0.45rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.55);
      border: 1px solid rgba(240,237,232,0.12);
      padding: 0.2rem 0.5rem;
    }
    .artist-card:hover .artist-tag {
      border-color: rgba(230,57,70,0.4);
      color: rgba(240,237,232,0.75);
    }

    /* ══════════════════════════════════════
       ATMOSPHERE STRIP
    ══════════════════════════════════════ */
    .atmo-strip {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 3px;
      height: 380px;
    }

    /* ══════════════════════════════════════
       BOOKING
    ══════════════════════════════════════ */
    .booking {
      padding: 6rem clamp(2rem, 5vw, 3.5rem);
      max-width: 1600px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }
    .booking__left {
      display: flex; flex-direction: column; gap: 2rem;
    }
    .booking__eyebrow {
      display: flex; flex-direction: column; gap: 0.6rem;
    }
    .booking__title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      color: #F0EDE8;
      letter-spacing: 0.04em;
      line-height: 1.0;
    }
    .booking__title .red { color: #E63946; }
    .booking__body {
      font-family: 'DM Mono', monospace;
      font-weight: 300;
      font-size: 0.75rem;
      line-height: 2;
      color: rgba(240,237,232,0.5);
      max-width: 38ch;
    }
    .booking__info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      padding-top: 1rem;
      border-top: 1px solid rgba(240,237,232,0.07);
    }
    .booking__info-item { display: flex; flex-direction: column; gap: 0.35rem; }
    .booking__info-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.45rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.3);
    }
    .booking__info-value {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      color: rgba(240,237,232,0.7);
      line-height: 1.6;
    }
    .booking__caveat {
      font-family: 'Caveat', cursive;
      font-size: 1.5rem;
      color: rgba(240,237,232,0.2);
      font-style: normal;
    }

    /* Right: CTA panel */
    .booking__right {
      background: #111111;
      border: 1px solid rgba(240,237,232,0.06);
      padding: 3rem;
      display: flex; flex-direction: column; gap: 2rem;
    }
    .booking__cta-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      color: #F0EDE8;
      letter-spacing: 0.04em;
      line-height: 1.1;
    }
    .booking__steps {
      display: flex; flex-direction: column; gap: 1rem;
      padding: 1.5rem 0;
      border-top: 1px solid rgba(240,237,232,0.06);
      border-bottom: 1px solid rgba(240,237,232,0.06);
    }
    .booking__step {
      display: flex; gap: 1rem; align-items: flex-start;
    }
    .booking__step-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      color: #E63946;
      line-height: 1;
      min-width: 1.5rem;
    }
    .booking__step-text {
      font-family: 'DM Mono', monospace;
      font-size: 0.62rem;
      line-height: 1.7;
      color: rgba(240,237,232,0.5);
    }
    .booking__step-text strong {
      color: rgba(240,237,232,0.8);
      font-weight: 500;
    }
    .booking__btn {
      display: block;
      font-family: 'DM Mono', monospace;
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #0A0A0A;
      background: #E63946;
      padding: 1.1rem 2rem;
      text-align: center;
      text-decoration: none;
      transition: background 0.2s;
    }
    .booking__btn:hover { background: #c42d3a; }
    .booking__btn-sub {
      font-family: 'DM Mono', monospace;
      font-size: 0.48rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.25);
      text-align: center;
    }

    /* ══════════════════════════════════════
       FOOTER
    ══════════════════════════════════════ */
    .footer {
      background: #080808;
      border-top: 1px solid rgba(240,237,232,0.06);
      padding: 2.5rem clamp(2rem, 5vw, 3.5rem);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .footer__brand {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 0.08em;
      color: rgba(240,237,232,0.2);
    }
    .footer__brand span { color: #E63946; }
    .footer__copy {
      font-family: 'DM Mono', monospace;
      font-size: 0.45rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.15);
    }
    .footer__address {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.1em;
      color: rgba(240,237,232,0.2);
      text-align: right;
      line-height: 1.8;
    }
  </style>
</head>
<body>

  <!-- ══ HERO ══ -->
  <section class="hero">
    <div class="hero__bg"></div>
    <div class="hero__overlay"></div>
    <div class="hero__slash"></div>

    <div class="hero__content">

      <nav class="hero__nav">
        <span class="hero__nav-brand">Nadelwerk Studio · Trier</span>
        <div class="hero__nav-links">
          <a href="#portfolio" class="hero__nav-link">Portfolio</a>
          <a href="#artists" class="hero__nav-link">Artists</a>
          <a href="#booking" class="hero__nav-link">Booking</a>
        </div>
      </nav>

      <div class="hero__headline">
        <div class="hero__word hero__word--1">NADEL</div>
        <div class="hero__rule"></div>
        <div class="hero__word hero__word--2">WERK</div>
      </div>

      <div class="hero__bottom">
        <div class="hero__meta">
          <span class="hero__location">Tattoo &amp; Illustration &nbsp;·&nbsp; Trier, Moselstraße 14</span>
          <div class="hero__tagline">Haut als Leinwand.</div>
          <div class="hero__caveat">— seit 2016 in Trier</div>
        </div>
        <div class="hero__scroll" aria-hidden="true">
          <span class="hero__scroll-label">Scroll</span>
          <div class="hero__scroll-line"></div>
        </div>
      </div>

    </div>
  </section>

  <!-- ══ INTRO STRIP ══ -->
  <div class="intro-strip">
    <span class="intro-strip__item">Custom Tattoos</span>
    <span class="intro-strip__sep">·</span>
    <span class="intro-strip__item">Blackwork</span>
    <span class="intro-strip__sep">·</span>
    <span class="intro-strip__item">Fine Line</span>
    <span class="intro-strip__sep">·</span>
    <span class="intro-strip__item">Traditional</span>
    <span class="intro-strip__sep">·</span>
    <span class="intro-strip__item">Neo-Traditional</span>
    <span class="intro-strip__sep">·</span>
    <span class="intro-strip__item">Geometric</span>
    <span class="intro-strip__sep">·</span>
    <span class="intro-strip__item">Illustrative</span>
    <span class="intro-strip__sep">·</span>
    <span class="intro-strip__item">Cover-Up</span>
    <span class="intro-strip__sep">·</span>
    <span class="intro-strip__item">Walk-In möglich</span>
  </div>

  <!-- ══ PORTFOLIO ══ -->
  <section class="portfolio" id="portfolio">
    <div class="section-header">
      <div class="section-header__left">
        <span class="label">02 / Arbeiten</span>
        <h2 class="section-title">Portfolio.</h2>
        <span class="section-caveat">handgemacht. für immer.</span>
      </div>
      <a href="#" class="section-header__link">Alle Arbeiten →</a>
    </div>

    <!-- Featured row (large + 2 stacked) -->
    <div class="port-featured">
      <div class="port-card ph port-featured__main">
        <img src="https://images.unsplash.com/photo-1542736667-069246bdbc6d?auto=format&fit=crop&w=1200&h=800&q=80" alt="Geometric Blackwork" loading="lazy" />
        <div class="port-overlay"></div>
        <div class="port-info">
          <span class="port-tag">Blackwork · Geometric</span>
