---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nadelwerk — Tattoo & Illustration Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      overflow-x: hidden;
      height: 100%;
    }

    body {
      overflow-x: hidden;
      height: 100%;
      background: #0A0A0A;
      color: #F0EDE8;
      font-family: 'DM Mono', monospace;
    }

    /* ---- Film grain overlay ---- */
    .hero {
      position: relative;
      width: 100vw;
      height: 100vh;
      overflow: hidden;
    }

    .hero::after {
      content: '';
      position: absolute;
      inset: -50%;
      width: 200%;
      height: 200%;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E");
      opacity: 0.12;
      pointer-events: none;
      z-index: 20;
      animation: grainShift 0.12s steps(1) infinite;
    }

    @keyframes grainShift {
      0%   { transform: translate(0, 0); }
      25%  { transform: translate(-2%, 1%); }
      50%  { transform: translate(1%, -2%); }
      75%  { transform: translate(2%, 2%); }
      100% { transform: translate(-1%, 0%); }
    }

    /* ---- Background image ---- */
    .hero__bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.unsplash.com/photo-1567324216289-5b5b8c4f5e45?w=1400&q=80&auto=format');
      background-size: cover;
      background-position: center;
      z-index: 0;
      transition: filter 0.6s ease;
    }

    .hero:hover .hero__bg {
      filter: saturate(1.6) hue-rotate(340deg) brightness(0.9);
    }

    /* Gradient overlay */
    .hero__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(10,10,10,0.2) 0%,
        rgba(10,10,10,0.45) 50%,
        rgba(10,10,10,0.85) 100%
      );
      z-index: 1;
    }

    /* ---- Red diagonal line ---- */
    .hero__diagonal {
      position: absolute;
      z-index: 5;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      overflow: hidden;
    }

    .hero__diagonal::after {
      content: '';
      position: absolute;
      width: 2px;
      height: 180%;
      background: #E63946;
      top: -40%;
      left: 52%;
      transform: rotate(22deg);
      transform-origin: top center;
      opacity: 0;
      animation: fadeIn 0.6s ease forwards 2.4s;
    }

    /* ---- Content layout ---- */
    .hero__content {
      position: relative;
      z-index: 10;
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 3.5rem 3.5rem 3rem;
    }

    /* Top section — brand name */
    .hero__top {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }

    .hero__name-top {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5rem, 14vw, 13rem);
      line-height: 0.88;
      color: #F0EDE8;
      letter-spacing: 0.02em;
      opacity: 0;
      transform: translateX(-40px);
      animation: slideRight 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.3s;
    }

    .hero__red-rule {
      width: clamp(5rem, 14vw, 13rem);
      height: 3px;
      background: #E63946;
      margin: 0.3rem 0;
      opacity: 0;
      transform: scaleX(0);
      transform-origin: left;
      animation: expandLine 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.85s;
    }

    .hero__name-bottom {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5rem, 14vw, 13rem);
      line-height: 0.88;
      color: #F0EDE8;
      letter-spacing: 0.02em;
      opacity: 0;
      transform: translateX(-40px);
      animation: slideRight 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.5s;
    }

    /* Bottom section */
    .hero__bottom {
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
    }

    .hero__sub {
      font-family: 'DM Mono', monospace;
      font-weight: 300;
      font-size: clamp(0.55rem, 1vw, 0.72rem);
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(240, 237, 232, 0.65);
      opacity: 0;
      transform: translateY(12px);
      animation: riseIn 0.7s ease forwards 1.3s;
    }

    .hero__tagline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2rem, 5vw, 4rem);
      color: #F0EDE8;
      letter-spacing: 0.04em;
      opacity: 0;
      transform: translateY(12px);
      animation: riseIn 0.7s ease forwards 1.6s;
    }

    /* ---- Scroll indicator ---- */
    .hero__scroll {
      position: absolute;
      bottom: 2.5rem;
      right: 3.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      z-index: 10;
      opacity: 0;
      animation: fadeIn 0.8s ease forwards 2.8s;
    }

    .hero__scroll-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(240,237,232,0.4);
      writing-mode: vertical-rl;
    }

    .hero__scroll-line {
      width: 1px;
      height: 60px;
      background: #E63946;
      position: relative;
      overflow: hidden;
    }

    .hero__scroll-line::after {
      content: '';
      position: absolute;
      top: -100%;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(240,237,232,0.2);
      animation: scrollPulse 1.8s ease-in-out infinite;
    }

    @keyframes scrollPulse {
      0%   { top: -100%; opacity: 1; }
      100% { top: 100%;  opacity: 0; }
    }

    /* ---- Keyframes ---- */

    @keyframes riseIn {
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeIn {
      to { opacity: 1; }
    }

    @keyframes slideRight {
      to { opacity: 1; transform: translateX(0); }
    }

    @keyframes expandLine {
      to { opacity: 1; transform: scaleX(1); }
    }
  </style>
</head>
<body>
  <section class="hero">

    <div class="hero__bg"></div>
    <div class="hero__overlay"></div>
    <div class="hero__diagonal"></div>

    <div class="hero__content">

      <div class="hero__top">
        <div class="hero__name-top">NADEL</div>
        <div class="hero__red-rule"></div>
        <div class="hero__name-bottom">WERK</div>
      </div>

      <div class="hero__bottom">
        <p class="hero__sub">Tattoo &amp; Illustration &nbsp;·&nbsp; Trier</p>
        <p class="hero__tagline">Haut als Leinwand.</p>
      </div>

    </div>

    <!-- Scroll indicator -->
    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-label">Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>

  </section>
</body>
</html>
