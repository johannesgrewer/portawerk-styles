    .footer-copy {
      font-family: 'Courier Prime', monospace;
      font-size: 0.58rem;
      color: rgba(255,255,255,0.18);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .footer-err {
      font-family: 'Courier Prime', monospace;
      font-size: 0.58rem;
      color: var(--red);
      letter-spacing: 0.08em;
      opacity: 0.7;
    }

    /* ── RESPONSIVE ──────────────────────────────────────── */
    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; }
      .hero-right { display: none; }
      .hero-hl-wrap { right: 0; }
      .manifest-inner { grid-template-columns: 1fr; gap: 3.5rem; }
      .bento { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
      .bento-card:nth-child(1),
      .bento-card:nth-child(4) { grid-column: 1 / 3; }
      .kollektiv-inner { grid-template-columns: 1fr; }
      .kollektiv-photo { aspect-ratio: 3/2; }
      .kontakt-inner { grid-template-columns: 1fr; }
      .nav-bl, .nav-br { display: none; }
      .arbeiten-ghost { display: none; }
    }
    @media (max-width: 600px) {
      .hero-hl { font-size: clamp(4.5rem, 18vw, 7rem); }
