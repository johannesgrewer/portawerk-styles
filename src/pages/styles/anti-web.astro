---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>fehler_ — Anti-Design Kollektiv für Subkultur & radikale Marken | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,700;0,900;1,400;1,900&family=Courier+Prime:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; cursor: crosshair; }

    :root {
      --cream:  #E8E3DA;
      --black:  #0C0C0C;
      --yellow: #E8FF00;
      --red:    #FF2600;
      --white:  #F5F4F0;
    }

    body {
      background: var(--cream);
      color: var(--black);
      font-family: 'Courier Prime', monospace;
      overflow-x: hidden;
    }

    ::selection { background: var(--yellow); color: var(--black); }

    /* ── CORNER NAVIGATION ─────────────────────────────── */
    .nav-corner {
      position: fixed;
      z-index: 200;
      font-family: 'Courier Prime', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .nav-tl { top: 1.5rem; left: 2rem; }
    .nav-tr { top: 1.5rem; right: 2rem; text-align: right; }
    .nav-bl { bottom: 1.5rem; left: 2rem; }
    .nav-br { bottom: 1.5rem; right: 2rem; text-align: right; }

    .nav-logo {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1.4rem;
      color: var(--black);
      text-decoration: none;
      letter-spacing: -0.01em;
      line-height: 1;
      display: block;
    }
    .nav-logo .logo-err { color: var(--red); }

    .nav-link {
      color: var(--black);
      text-decoration: none;
      display: block;
      padding: 0.15rem 0;
      opacity: 0.45;
      transition: opacity 0.18s;
    }
    .nav-link:hover { opacity: 1; }

    .nav-meta {
      color: var(--black);
      opacity: 0.3;
      font-size: 0.56rem;
    }

    /* glitch effect on logo */
    @keyframes glitch {
      0%, 88%, 100% { transform: translate(0, 0); clip-path: none; }
      90% { transform: translate(-3px, 0); }
      92% { transform: translate(3px, 0); }
      94% { transform: translate(-2px, 1px); clip-path: inset(10% 0 60% 0); }
      96% { transform: translate(2px, -1px); clip-path: inset(60% 0 10% 0); }
      98% { transform: translate(0, 0); clip-path: none; }
    }
    .nav-logo { animation: glitch 9s step-end infinite; }

    /* ── HERO ──────────────────────────────────────────── */
    .hero {
      height: 100vh;
      min-height: 620px;
      display: grid;
      grid-template-columns: 52% 48%;
      position: relative;
      overflow: hidden;
    }

    /* Left — cream background */
    .hero-left {
      background: var(--cream);
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 2.5rem 2.5rem 4.5rem 3rem;
      border-right: 3px solid var(--black);
    }

    /* Massive headline — positioned absolute, spans out of left column */
    .hero-hl-wrap {
      position: absolute;
      top: 50%;
      left: 0;
      right: -15%;
      transform: translateY(-52%);
      z-index: 5;
      pointer-events: none;
      padding-left: 3rem;
    }
    .hero-hl {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(6rem, 17vw, 13.5rem);
      line-height: 0.85;
      letter-spacing: -0.02em;
      color: var(--black);
    }
    .hero-hl .hl-row2 {
      display: block;
      color: var(--cream);
      -webkit-text-stroke: 3px var(--black);
    }
    .hero-hl .hl-row3 {
      display: block;
      color: var(--red);
    }

    /* Bottom-left content */
    .hero-sub {
      font-size: 0.78rem;
      line-height: 1.75;
      color: rgba(12,12,12,0.55);
      max-width: 30ch;
      margin-bottom: 2rem;
      padding-left: 1rem;
      border-left: 2px solid var(--black);
    }
    .hero-actions { display: flex; gap: 1rem; align-items: center; }
    .hero-cta {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--white);
      background: var(--black);
      padding: 0.75rem 1.75rem;
      text-decoration: none;
      display: inline-block;
      transition: background 0.15s;
    }
    .hero-cta:hover { background: var(--red); }
    .hero-cta-ghost {
      font-family: 'Courier Prime', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: underline;
      text-underline-offset: 3px;
      opacity: 0.5;
    }
    .hero-cta-ghost:hover { opacity: 1; }

    /* Right — dark concert photo */
    .hero-right {
      position: relative;
      overflow: hidden;
    }
    .hero-photo {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(25%) brightness(0.7);
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(12,12,12,0.55) 0%, rgba(12,12,12,0.1) 70%);
    }

    /* Big 404 ghost number on photo */
    .hero-404 {
      position: absolute;
      bottom: -2.5rem;
      right: -1rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(10rem, 22vw, 18rem);
      color: rgba(232,255,0,0.1);
      line-height: 1;
      letter-spacing: -0.04em;
      pointer-events: none;
      user-select: none;
      z-index: 1;
    }

    /* Yellow rotated tag at boundary */
    .hero-tag {
      position: absolute;
      top: 50%;
      left: 0;
      transform: translateY(-50%) rotate(-2deg) translateX(-50%);
      z-index: 15;
      background: var(--yellow);
      padding: 0.65rem 1rem;
      border: 2px solid var(--black);
    }
    .hero-tag-text {
      font-family: 'Courier Prime', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--black);
      line-height: 1.7;
    }

    /* Small status badge — top-right of photo */
    .hero-status {
      position: absolute;
      top: 2rem;
      right: 2rem;
      z-index: 10;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      align-items: flex-end;
    }
    .hero-status-dot {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-family: 'Courier Prime', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }
    .status-led {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--yellow);
      animation: ledPulse 2s ease-in-out infinite;
    }
    @keyframes ledPulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    /* ── TICKER ──────────────────────────────────────────── */
    .ticker {
      background: var(--black);
      padding: 0.55rem 0;
      overflow: hidden;
      border-top: 3px solid var(--yellow);
      border-bottom: 3px solid var(--yellow);
    }
    .ticker-track {
      display: flex;
      gap: 0;
      white-space: nowrap;
      animation: ticker 28s linear infinite;
    }
    .ticker-track:hover { animation-play-state: paused; }
    .t-item {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.95rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--yellow);
      padding: 0 2.5rem;
      flex-shrink: 0;
    }
    .t-item.crossed {
      color: rgba(232,255,0,0.3);
      text-decoration: line-through;
      text-decoration-color: var(--red);
    }
    .t-sep {
      color: var(--red);
      padding: 0 0.5rem;
      flex-shrink: 0;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 0.95rem;
    }
    @keyframes ticker {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ── MANIFEST ─────────────────────────────────────────── */
    .manifest {
      background: var(--black);
      color: var(--white);
      padding: 7rem 3rem 7rem;
      position: relative;
      overflow: hidden;
    }

    /* Big ghost number */
    .manifest-bgnum {
      position: absolute;
      top: -3rem;
      right: -2rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(14rem, 32vw, 24rem);
      color: rgba(232,255,0,0.03);
      line-height: 1;
      letter-spacing: -0.05em;
      pointer-events: none;
      user-select: none;
    }

    .manifest-inner {
      max-width: 1240px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }

    .section-label {
      font-size: 0.58rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--yellow);
      margin-bottom: 1.5rem;
      display: block;
    }

    .manifest-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(2.5rem, 5.5vw, 4.5rem);
      line-height: 0.9;
      letter-spacing: -0.02em;
      margin-bottom: 3rem;
    }
    .manifest-title .t-stroke {
      -webkit-text-stroke: 2px var(--yellow);
      color: transparent;
    }

    .rules-list {
      display: flex;
      flex-direction: column;
    }
    .rule {
      display: grid;
      grid-template-columns: 3rem 1fr;
      gap: 1rem;
      align-items: start;
      padding: 1.1rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .rule:first-child { border-top: 1px solid rgba(255,255,255,0.07); }
    .rule-n {
      font-family: 'Courier Prime', monospace;
      font-size: 0.58rem;
      color: var(--yellow);
      opacity: 0.6;
      padding-top: 0.2rem;
    }
    .rule-t {
      font-family: 'Courier Prime', monospace;
      font-size: 0.88rem;
      line-height: 1.6;
      color: rgba(255,255,255,0.7);
    }
    .rule-t s {
      color: rgba(255,255,255,0.2);
      text-decoration-color: var(--red);
    }
    .rule-t em {
      font-style: normal;
      color: var(--yellow);
    }

    /* Manifest right: photo + overlay badge */
    .manifest-right {
      position: relative;
    }
    .manifest-photo-wrap {
      transform: rotate(1.8deg);
      position: relative;
    }
    .manifest-photo {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
      filter: grayscale(15%);
    }
    .manifest-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(12,12,12,0.5) 0%, transparent 50%);
    }
    .manifest-photo-label {
      position: absolute;
      bottom: -1.8rem;
      left: 0;
      font-family: 'Courier Prime', monospace;
      font-size: 0.56rem;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.2);
      text-transform: uppercase;
    }

    /* Vertical TRIER ghost text */
    .manifest-trier {
      position: absolute;
      top: 2rem;
      right: -3rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 7rem;
      color: rgba(232,255,0,0.05);
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      letter-spacing: 0.1em;
      pointer-events: none;
      user-select: none;
    }

    /* stat strip below manifest photo */
    .manifest-stats {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 0;
      margin-top: 3rem;
      border: 1px solid rgba(255,255,255,0.08);
    }
    .stat {
      padding: 1rem;
      border-right: 1px solid rgba(255,255,255,0.08);
      text-align: center;
    }
    .stat:last-child { border-right: none; }
    .stat-val {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 2.2rem;
      color: var(--yellow);
      letter-spacing: -0.02em;
      line-height: 1;
      display: block;
    }
    .stat-label {
      font-size: 0.56rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
      margin-top: 0.3rem;
      display: block;
    }

    /* ── ARBEITEN ─────────────────────────────────────────── */
    .arbeiten {
      background: var(--cream);
      padding: 7rem 3rem;
      position: relative;
    }

    .arbeiten-hdr {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 3rem;
      gap: 2rem;
    }
    .arbeiten-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(2.8rem, 6.5vw, 5.5rem);
      line-height: 0.88;
      letter-spacing: -0.03em;
      color: var(--black);
    }
    .arbeiten-title .t-outline {
      -webkit-text-stroke: 2px var(--black);
      color: transparent;
    }
    .arbeiten-count {
      font-family: 'Courier Prime', monospace;
      font-size: 0.65rem;
      color: rgba(12,12,12,0.35);
      white-space: nowrap;
      padding-bottom: 0.5rem;
    }

    /* Asymmetric bento grid */
    .bento {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: 320px 260px;
      gap: 1.25rem;
    }
    .bento-card {
      position: relative;
      overflow: hidden;
      background: var(--black);
      cursor: crosshair;
    }
    .bento-card:nth-child(1) { grid-column: 1 / 3; } /* wide */
    .bento-card:nth-child(4) { grid-column: 2 / 4; } /* wide, offset */

    .bento-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(20%);
      transition: transform 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  filter 0.45s ease;
    }
    .bento-card:hover .bento-img {
      transform: scale(1.05);
      filter: grayscale(0%);
    }

    .bento-grad {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(12,12,12,0.92) 0%, rgba(12,12,12,0.2) 55%, transparent 100%);
    }

    .bento-info {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1.5rem;
    }
    .bento-tag {
      display: inline-block;
      font-family: 'Courier Prime', monospace;
      font-size: 0.52rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--yellow);
      border: 1px solid rgba(232,255,0,0.35);
      padding: 0.15rem 0.55rem;
      margin-bottom: 0.6rem;
    }
    .bento-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(1.3rem, 2.8vw, 2rem);
      color: var(--white);
      line-height: 0.95;
      letter-spacing: -0.01em;
      display: block;
    }
    .bento-year {
      font-family: 'Courier Prime', monospace;
      font-size: 0.6rem;
      color: rgba(255,255,255,0.3);
      margin-top: 0.3rem;
      display: block;
    }

    /* Decoration: rotated "FEHLER" ghost behind grid */
    .arbeiten-ghost {
      position: absolute;
      bottom: 3rem;
      right: -3rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(7rem, 16vw, 12rem);
      color: rgba(12,12,12,0.04);
      letter-spacing: -0.03em;
      pointer-events: none;
      user-select: none;
      line-height: 1;
      transform: rotate(-3deg);
    }

    /* ── KOLLEKTIV ───────────────────────────────────────── */
    .kollektiv {
      background: var(--yellow);
      padding: 6rem 3rem;
      position: relative;
      overflow: hidden;
    }

    /* Big ghost text behind */
    .kollektiv-bg {
      position: absolute;
      bottom: -4rem;
      left: -2rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(8rem, 22vw, 17rem);
      color: rgba(12,12,12,0.06);
      letter-spacing: -0.04em;
      white-space: nowrap;
      pointer-events: none;
      user-select: none;
      line-height: 1;
    }

    .kollektiv-inner {
      max-width: 1240px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .kollektiv-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(2.8rem, 5.5vw, 4.5rem);
      line-height: 0.88;
      letter-spacing: -0.03em;
      color: var(--black);
      margin-bottom: 1.25rem;
    }
    .kollektiv-desc {
      font-family: 'Courier Prime', monospace;
      font-size: 0.82rem;
      line-height: 1.75;
      color: rgba(12,12,12,0.6);
      max-width: 36ch;
      margin-bottom: 2.5rem;
    }

    .members {
      border-top: 2px solid var(--black);
    }
    .member {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.8rem 0;
      border-bottom: 1px solid rgba(12,12,12,0.15);
      gap: 1rem;
    }
    .member-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 1.15rem;
      letter-spacing: -0.01em;
      color: var(--black);
    }
    .member-role {
      font-family: 'Courier Prime', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(12,12,12,0.45);
    }

    /* Right: rotated photo */
    .kollektiv-photo-wrap {
      position: relative;
    }
    .kollektiv-photo-num {
      position: absolute;
      top: -2rem;
      right: 1.5rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 7rem;
      color: rgba(12,12,12,0.08);
      line-height: 1;
      pointer-events: none;
      user-select: none;
    }
    .kollektiv-photo {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      display: block;
      transform: rotate(-1.5deg);
      border: 4px solid var(--black);
      filter: grayscale(10%);
    }

    /* ── KONTAKT ─────────────────────────────────────────── */
    .kontakt {
      background: var(--black);
      color: var(--white);
      padding: 7rem 3rem;
      position: relative;
      overflow: hidden;
    }

    .kontakt-inner {
      max-width: 1240px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }

    .error-badge {
      display: inline-block;
      background: var(--red);
      color: var(--white);
      font-family: 'Courier Prime', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.35rem 0.8rem;
      margin-bottom: 2rem;
    }

    .kontakt-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(3rem, 6.5vw, 5.5rem);
      line-height: 0.88;
      letter-spacing: -0.03em;
      margin-bottom: 1.5rem;
    }
    .kontakt-title .k-cross { color: var(--red); }
    .kontakt-title .k-strike {
      text-decoration: line-through;
      text-decoration-color: rgba(255,255,255,0.25);
      color: rgba(255,255,255,0.2);
    }

    .kontakt-sub {
      font-family: 'Courier Prime', monospace;
      font-size: 0.82rem;
      line-height: 1.75;
      color: rgba(255,255,255,0.45);
      max-width: 34ch;
      margin-bottom: 3rem;
    }

    .kontakt-items {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .k-item {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 1.25rem 0;
    }
    .k-item:last-child { border-bottom: 1px solid rgba(255,255,255,0.08); }
    .k-label {
      font-family: 'Courier Prime', monospace;
      font-size: 0.54rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--yellow);
      margin-bottom: 0.4rem;
    }
    .k-val {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 400;
      font-size: 1.35rem;
      color: var(--white);
    }
    .k-val a { color: var(--white); text-decoration: none; transition: color 0.15s; }
    .k-val a:hover { color: var(--yellow); }

    /* Terminal block */
    .terminal {
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.025);
      padding: 1.5rem;
    }
    .term-header {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding-bottom: 1rem;
      margin-bottom: 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .td { width: 10px; height: 10px; border-radius: 50%; }
    .td-r { background: #FF5F57; }
    .td-y { background: #FFBD2E; }
    .td-g { background: #28C840; }
    .term-name {
      font-family: 'Courier Prime', monospace;
      font-size: 0.58rem;
      color: rgba(255,255,255,0.2);
      margin-left: auto;
      letter-spacing: 0.08em;
    }

    .tl {
      font-family: 'Courier Prime', monospace;
      font-size: 0.8rem;
      line-height: 1.95;
      color: rgba(255,255,255,0.45);
    }
    .tl .p { color: var(--yellow); }
    .tl .c { color: rgba(255,255,255,0.9); }
    .tl .o { color: rgba(255,255,255,0.3); }
    .tl .e { color: var(--red); }
    .tl .s { color: #28C840; }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
    .cursor {
      display: inline-block;
      width: 0.5rem;
      height: 0.9rem;
      background: var(--yellow);
      animation: blink 1.1s step-end infinite;
      vertical-align: text-bottom;
      margin-left: 1px;
    }

    /* ── FOOTER ──────────────────────────────────────────── */
    .site-footer {
      background: var(--black);
      border-top: 1px solid rgba(255,255,255,0.07);
      padding: 1.5rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }
    .footer-logo {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1.2rem;
      color: rgba(255,255,255,0.15);
      letter-spacing: -0.01em;
