---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Pfötchen — Tierarztpraxis & Tierpflege | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Source+Serif+4:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }
    body {
      overflow-x: hidden;
      background: #F7FAF8;
      color: #1A3D35;
      font-family: 'Nunito', sans-serif;
      min-height: 100vh;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.4rem 3rem;
      background: rgba(247, 250, 248, 0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid rgba(45, 106, 90, 0.08);
    }
    .nav-logo-wrap {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .paw-icon {
      width: 28px; height: 28px;
      fill: #2D6A5A;
    }
    .nav-logo {
      font-family: 'Nunito', sans-serif;
      font-weight: 800;
      font-size: 1.3rem;
      letter-spacing: -0.01em;
      color: #1A3D35;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: #2D6A5A;
      text-decoration: none;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: #E07A5F; }
    .nav-cta {
      background: #2D6A5A;
      color: #F7FAF8 !important;
      padding: 0.5rem 1.2rem;
      border-radius: 100px;
      transition: background 0.3s !important;
    }
    .nav-cta:hover { background: #1A3D35 !important; color: #F7FAF8 !important; }

    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 55% 45%;
      position: relative;
    }

    /* LEFT — photo */
    .hero-visual {
      position: relative;
      padding: 5.5rem 3rem 3rem 4rem;
      display: flex;
      align-items: center;
    }

    .photo-wrap {
      position: relative;
      width: 100%;
      max-width: 520px;
    }
    .photo-frame {
      width: 100%;
      aspect-ratio: 4/5;
      border-radius: 48% 52% 40% 60% / 55% 45% 55% 45%;
      overflow: hidden;
      box-shadow: 0 30px 80px rgba(26, 61, 53, 0.12);
      animation: gentleMorph 8s ease-in-out infinite;
    }
    @keyframes gentleMorph {
      0%, 100% { border-radius: 48% 52% 40% 60% / 55% 45% 55% 45%; }
      50%       { border-radius: 55% 45% 55% 45% / 40% 60% 42% 58%; }
    }
    .photo-frame img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center top;
    }

    /* Floating info card */
    .info-card {
      position: absolute;
      bottom: 16%;
      right: -20px;
      background: #fff;
      border-radius: 16px;
      padding: 1.2rem 1.4rem;
      box-shadow: 0 16px 48px rgba(26, 61, 53, 0.1);
      min-width: 200px;
      opacity: 0;
      animation: floatIn 0.8s ease 1.3s forwards;
    }
    @keyframes floatIn {
      from { opacity: 0; transform: translateX(16px) translateY(8px); }
      to   { opacity: 1; transform: translateX(0) translateY(0); }
    }
    .card-row {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      margin-bottom: 0.6rem;
    }
    .card-row:last-child { margin-bottom: 0; }
    .card-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #E07A5F;
      flex-shrink: 0;
    }
    .card-dot.green { background: #2D6A5A; }
    .card-text {
      font-size: 0.75rem;
      font-weight: 600;
      color: #1A3D35;
    }
    .card-sub {
      font-size: 0.65rem;
      color: #7A9E95;
    }

    /* Floating paw decorations */
    .paw-float {
      position: absolute;
      opacity: 0.06;
      animation: floatPaw 5s ease-in-out infinite;
    }
    .paw-float svg { fill: #2D6A5A; }
    .paw-float-1 { top: 10%; right: 15%; width: 60px; animation-delay: 0s; }
    .paw-float-2 { bottom: 25%; left: 5%; width: 40px; animation-delay: 1.5s; }
    @keyframes floatPaw {
      0%, 100% { transform: translateY(0) rotate(-10deg); }
      50%       { transform: translateY(-10px) rotate(5deg); }
    }

    /* RIGHT — text */
    .hero-text {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 6rem 4rem 4rem 3rem;
    }

    .eyebrow {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #E07A5F;
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: up 0.7s ease 0.2s forwards;
    }

    .headline {
      font-family: 'Nunito', sans-serif;
      font-weight: 800;
      font-size: clamp(2.8rem, 4vw, 4.5rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: #1A3D35;
      margin-bottom: 1.4rem;
    }
    .headline .accent { color: #2D6A5A; }
    .headline .ln {
      display: block;
      opacity: 0;
      animation: up 0.7s ease forwards;
    }
    .headline .ln:nth-child(1) { animation-delay: 0.3s; }
    .headline .ln:nth-child(2) { animation-delay: 0.48s; }
    .headline .ln:nth-child(3) { animation-delay: 0.62s; }

    .tagline-serif {
      font-family: 'Source Serif 4', serif;
      font-style: italic;
      font-size: 1.05rem;
      color: #4A7A70;
      margin-bottom: 1.4rem;
      opacity: 0;
      animation: up 0.7s ease 0.8s forwards;
    }

    .desc {
      font-family: 'Source Serif 4', serif;
      font-size: 0.92rem;
      line-height: 1.8;
      color: #4A6B62;
      max-width: 360px;
      margin-bottom: 2.5rem;
      opacity: 0;
      animation: up 0.7s ease 0.95s forwards;
    }

    .services {
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
      margin-bottom: 2.5rem;
      opacity: 0;
      animation: up 0.7s ease 1.1s forwards;
    }
    .service-item {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      font-size: 0.82rem;
      font-weight: 600;
      color: #2D6A5A;
    }
    .service-check {
      width: 20px; height: 20px;
      border-radius: 50%;
      background: rgba(45, 106, 90, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .service-check::after {
      content: '✓';
      font-size: 0.6rem;
      color: #2D6A5A;
    }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      opacity: 0;
      animation: up 0.7s ease 1.25s forwards;
    }
    .btn-main {
      background: #2D6A5A;
      color: #F7FAF8;
      border: none;
      padding: 0.9rem 2rem;
      border-radius: 100px;
      font-family: 'Nunito', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      text-decoration: none;
      transition: all 0.3s;
      box-shadow: 0 4px 20px rgba(45, 106, 90, 0.25);
    }
    .btn-main:hover {
      background: #1A3D35;
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(45, 106, 90, 0.3);
    }
    .phone {
      font-size: 0.82rem;
      font-weight: 600;
      color: #4A7A70;
      text-decoration: none;
    }
    .phone:hover { color: #2D6A5A; }

    @keyframes up {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* Large screen constraint */
    .sec-wrap { max-width: 1600px; margin: 0 auto; }

    /* Animal cards */
    .animal-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    @media (max-width: 768px) {
      .animal-grid { grid-template-columns: 1fr; }
    }

    .animal-card {
      border-radius: 16px;
      overflow: hidden;
      background: #fff;
      box-shadow: 0 4px 24px rgba(26,61,53,0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .animal-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(26,61,53,0.14);
    }
    .animal-img-wrap {
      position: relative; overflow: hidden; height: 220px;
    }
    .animal-img-wrap img {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; transition: transform 0.55s ease;
    }
    .animal-card:hover .animal-img-wrap img { transform: scale(1.05); }
    .animal-img-wrap .img-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(26,61,53,0.4) 0%, transparent 55%);
      pointer-events: none;
    }
    .animal-card-body {
      padding: 1.4rem 1.6rem 1.6rem;
    }
    .animal-card-body h3 {
      font-family: 'Nunito', sans-serif;
      font-weight: 800; font-size: 1.1rem;
      color: #1A3D35; margin-bottom: 0.4rem;
    }
    .animal-card-body p {
      font-family: 'Source Serif 4', serif;
      font-size: 0.85rem; color: #4A6B62; line-height: 1.7;
    }
    .animal-tag {
      display: inline-block; margin-top: 0.75rem;
      font-family: 'Nunito', sans-serif;
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.06em; text-transform: uppercase;
      color: #2D6A5A;
      background: rgba(45,106,90,0.1);
      padding: 0.3rem 0.8rem; border-radius: 100px;
    }

    /* Opening hours section */
    .hours-section {
      background: #1A3D35;
      padding: 5rem 2rem;
    }
    .hours-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
      max-width: 1000px;
      margin: 0 auto;
    }
    @media (max-width: 768px) {
      .hours-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    }
    .hours-label {
      font-family: 'Nunito', sans-serif;
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: #E07A5F; margin-bottom: 1rem;
    }
    .hours-title {
      font-family: 'Nunito', sans-serif;
      font-weight: 800; font-size: clamp(1.8rem,3.5vw,2.8rem);
      color: #F7FAF8; line-height: 1.15; margin-bottom: 1.25rem;
    }
    .hours-title .accent { color: #7EC8B8; }
    .hours-desc {
      font-family: 'Source Serif 4', serif;
      font-size: 0.9rem; line-height: 1.8;
      color: rgba(247,250,248,0.65); margin-bottom: 2rem;
    }
    .hours-list {
      display: flex; flex-direction: column; gap: 0;
      border-top: 1px solid rgba(247,250,248,0.1);
    }
    .hours-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.85rem 0;
      border-bottom: 1px solid rgba(247,250,248,0.08);
    }
    .hours-day {
      font-family: 'Nunito', sans-serif;
      font-size: 0.82rem; font-weight: 600; color: rgba(247,250,248,0.7);
    }
    .hours-time {
      font-family: 'Nunito', sans-serif;
      font-size: 0.82rem; font-weight: 700; color: #F7FAF8;
    }
    .hours-time.closed { color: rgba(247,250,248,0.3); }
    .emergency-box {
      margin-top: 1.75rem; padding: 1.25rem 1.5rem;
      background: rgba(224,122,95,0.15);
      border: 1px solid rgba(224,122,95,0.3);
      border-radius: 12px;
    }
    .emergency-box p {
      font-family: 'Nunito', sans-serif;
      font-size: 0.82rem; font-weight: 700;
      color: #E07A5F; margin-bottom: 0.25rem;
    }
    .emergency-box span {
      font-family: 'Nunito', sans-serif;
      font-size: 0.95rem; font-weight: 800; color: #F7FAF8;
    }
    .hours-photo-wrap {
      position: relative; overflow: hidden;
      border-radius: 20px; height: 420px;
    }
    .hours-photo-wrap img {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; transition: transform 0.55s ease;
    }
    .hours-photo-wrap:hover img { transform: scale(1.04); }
    .hours-photo-wrap .img-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(26,61,53,0.35) 0%, transparent 60%);
      pointer-events: none;
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo-wrap">
      <svg class="paw-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="5" cy="8" rx="2.2" ry="3"/>
        <ellipse cx="9.5" cy="5.5" rx="2" ry="2.8"/>
        <ellipse cx="14.5" cy="5.5" rx="2" ry="2.8"/>
        <ellipse cx="19" cy="8" rx="2.2" ry="3"/>
        <path d="M12 22c-4 0-7-2.8-7-7 0-2.5 1.5-4.2 3.5-5 1-.4 2.3-.5 3.5-.5s2.5.1 3.5.5c2 .8 3.5 2.5 3.5 5 0 4.2-3 7-7 7z"/>
      </svg>
      <span class="nav-logo">Pfötchen</span>
    </div>
    <ul class="nav-links">
      <li><a href="#">Leistungen</a></li>
      <li><a href="#">Team</a></li>
      <li><a href="#">Notfall</a></li>
      <li><a href="#" class="nav-cta">Termin buchen</a></li>
    </ul>
  </nav>

  <section class="hero">
    <!-- LEFT -->
    <div class="hero-visual">
      <div class="paw-float paw-float-1">
        <svg viewBox="0 0 24 24"><ellipse cx="5" cy="8" rx="2.2" ry="3"/><ellipse cx="9.5" cy="5.5" rx="2" ry="2.8"/><ellipse cx="14.5" cy="5.5" rx="2" ry="2.8"/><ellipse cx="19" cy="8" rx="2.2" ry="3"/><path d="M12 22c-4 0-7-2.8-7-7 0-2.5 1.5-4.2 3.5-5 1-.4 2.3-.5 3.5-.5s2.5.1 3.5.5c2 .8 3.5 2.5 3.5 5 0 4.2-3 7-7 7z"/></svg>
      </div>
      <div class="paw-float paw-float-2">
        <svg viewBox="0 0 24 24"><ellipse cx="5" cy="8" rx="2.2" ry="3"/><ellipse cx="9.5" cy="5.5" rx="2" ry="2.8"/><ellipse cx="14.5" cy="5.5" rx="2" ry="2.8"/><ellipse cx="19" cy="8" rx="2.2" ry="3"/><path d="M12 22c-4 0-7-2.8-7-7 0-2.5 1.5-4.2 3.5-5 1-.4 2.3-.5 3.5-.5s2.5.1 3.5.5c2 .8 3.5 2.5 3.5 5 0 4.2-3 7-7 7z"/></svg>
      </div>

      <div class="photo-wrap">
        <div class="photo-frame">
          <img
            src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=900&q=80&auto=format"
            alt="Hund bei der Tierarztpraxis Pfötchen Trier"
            loading="eager"
          />
        </div>
        <div class="info-card">
          <div class="card-row">
            <div class="card-dot green"></div>
            <div>
              <div class="card-text">Heute verfügbar</div>
              <div class="card-sub">Kurztermine frei</div>
            </div>
          </div>
          <div class="card-row">
            <div class="card-dot"></div>
            <div>
              <div class="card-text">24h Notfalldienst</div>
              <div class="card-sub">0651 / 123 45 67</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="hero-text">
      <p class="eyebrow">Tierarztpraxis · Trier</p>

      <h1 class="headline">
        <span class="ln">Mit Liebe.</span>
        <span class="ln">Mit <span class="accent">Kompetenz.</span></span>
      </h1>

      <p class="tagline-serif">Veterinärmedizin, die Tiere spüren.</p>

      <p class="desc">
        In der Pfötchen-Praxis behandeln wir jeden Patienten
        wie unser eigenes Tier — mit Ruhe, Fachwissen und echter
        Fürsorge.
      </p>

      <div class="services">
        <div class="service-item">
          <div class="service-check"></div>
          Vorsorge & Impfungen
        </div>
        <div class="service-item">
          <div class="service-check"></div>
          Zahnpflege & Chirurgie
        </div>
        <div class="service-item">
          <div class="service-check"></div>
          Ernährungsberatung
        </div>
        <div class="service-item">
          <div class="service-check"></div>
          Notfallversorgung 24/7
        </div>
      </div>

      <div class="cta-row">
        <a href="#" class="btn-main">Termin buchen</a>
        <a href="tel:+4965112345" class="phone">0651 / 123 45 67</a>
      </div>
    </div>
  </section>

  <!-- SECTION 2 — Leistungen nach Tierart -->
  <section style="padding: 5rem 2rem; background: #F7FAF8;">
    <div class="sec-wrap">
      <div style="text-align:center; margin-bottom:3rem;">
        <p style="font-family:'Nunito',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#E07A5F;margin-bottom:0.75rem;">Für jeden Patienten</p>
        <h2 style="font-family:'Nunito',sans-serif;font-weight:800;font-size:clamp(1.8rem,4vw,2.8rem);color:#1A3D35;letter-spacing:-0.02em;">Rundum versorgt.</h2>
        <p style="font-family:'Source Serif 4',serif;font-style:italic;font-size:1rem;color:#4A7A70;margin-top:0.5rem;">Ob Hund, Katze oder Kleintier — wir sind für alle da.</p>
      </div>

      <div class="animal-grid">

        <div class="animal-card">
          <div class="animal-img-wrap">
            <img src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=800&h=500&q=80"
                 alt="Hund Tierarzt Behandlung" loading="lazy" />
            <div class="img-overlay"></div>
          </div>
          <div class="animal-card-body">
            <h3>Hunde</h3>
            <p>Vorsorge, Impfungen, Zahnpflege und Chirurgie — wir begleiten deinen Hund von Welpe bis Senior mit Fachwissen und Herz.</p>
            <span class="animal-tag">Alle Rassen</span>
          </div>
        </div>

        <div class="animal-card">
          <div class="animal-img-wrap">
            <img src="https://images.unsplash.com/photo-1583939003579-730e3918a45a?auto=format&fit=crop&w=800&h=500&q=80"
                 alt="Katze Tierarztpraxis" loading="lazy" />
            <div class="img-overlay"></div>
          </div>
          <div class="animal-card-body">
            <h3>Katzen</h3>
            <p>Kastration, Impfschutz, Ernährungsberatung und stressfreie Behandlung in einer ruhigen, katzenfreundlichen Umgebung.</p>
            <span class="animal-tag">Innen- & Freigänger</span>
          </div>
        </div>

        <div class="animal-card">
          <div class="animal-img-wrap">
            <img src="https://images.unsplash.com/photo-1548839140-29a749e1cf4d?auto=format&fit=crop&w=800&h=500&q=80"
                 alt="Kleintiere Kaninchen Hamster" loading="lazy" />
            <div class="img-overlay"></div>
          </div>
          <div class="animal-card-body">
            <h3>Kleintiere</h3>
            <p>Kaninchen, Meerschweinchen, Hamster & Co. — auch die kleinen Patienten verdienen professionelle Versorgung und echte Fürsorge.</p>
            <span class="animal-tag">Nager & Exoten</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SECTION 3 — Öffnungszeiten & Kontakt -->
  <section class="hours-section">
    <div class="sec-wrap">
      <div class="hours-grid">

        <div>
          <p class="hours-label">Praxiszeiten</p>
          <h2 class="hours-title">Wir sind <span class="accent">für euch</span> da.</h2>
          <p class="hours-desc">Kurztermine sind oft noch am selben Tag möglich. Für Notfälle sind wir rund um die Uhr erreichbar.</p>

          <div class="hours-list">
            <div class="hours-row">
              <span class="hours-day">Montag – Freitag</span>
              <span class="hours-time">08:00 – 18:00 Uhr</span>
            </div>
            <div class="hours-row">
              <span class="hours-day">Samstag</span>
              <span class="hours-time">09:00 – 13:00 Uhr</span>
            </div>
            <div class="hours-row">
              <span class="hours-day">Sonntag</span>
              <span class="hours-time closed">Geschlossen</span>
            </div>
          </div>

          <div class="emergency-box">
            <p>24h Notfalldienst</p>
            <span>0651 / 123 45 67</span>
          </div>
        </div>

        <div class="hours-photo-wrap">
          <img src="https://images.unsplash.com/photo-1545389336-cf090694435e?auto=format&fit=crop&w=800&h=900&q=80"
               alt="Tierarzt mit Tier Praxis" loading="lazy" />
          <div class="img-overlay"></div>
        </div>

      </div>
    </div>
  </section>

</body>
</html>
