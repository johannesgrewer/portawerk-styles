  </div>

  <!-- ── SECTION 3: PHILOSOPHY ── -->
  <div class="philosophy-section">
    <div class="philosophy-inner">
      <div class="philosophy-photo">
        <img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&w=900&h=700&q=80" alt="Küchenchef Marcus Stein bei der Arbeit" loading="lazy" />
        <div class="philosophy-photo-overlay"></div>
      </div>
      <div class="philosophy-content">
        <p class="philosophy-eyebrow">Küche &amp; Philosophie</p>
        <blockquote class="philosophy-quote">
          „Ein Gericht ist fertig, wenn nichts mehr <em>weggelassen</em> werden kann."
        </blockquote>
        <div class="philosophy-separator">
          <div class="phil-line"></div>
          <div class="phil-diamond"></div>
        </div>
        <div>
          <div class="philosophy-chef-name">Marcus Stein</div>
          <div class="philosophy-chef-role">Küchenchef &amp; Gastgeber</div>
        </div>
        <p class="philosophy-text">
          Seit 2018 koche ich in der Grotte für Gäste, die essen wollen — nicht konsumieren.
          Jedes Produkt hat eine Herkunft, die ich kenne. Jedes Gericht hat eine Absicht,
          die ich erklären kann. Die Weinbegleitung wähle ich selbst aus — ausschließlich
          Erzeuger von der Mosel und aus dem Burgund.
        </p>
      </div>
    </div>
  </div>

  <script>
    // Entrance animations
    const elements = document.querySelectorAll('.animate-el');
    requestAnimationFrame(() => {
      elements.forEach((el, i) => {
        setTimeout(() => {
          el.classList.add('visible');
        }, i * 120);
      });
    });

    // Gold particles
    const container = document.getElementById('particlesContainer');
    const PARTICLE_COUNT = 15;

    for (let i = 0; i < PARTICLE_COUNT; i++) {
      const particle = document.createElement('div');
      particle.classList.add('particle');

      const leftPct = 15 + Math.random() * 70;
      const duration = 12 + Math.random() * 18;
      const delay = Math.random() * 20;
      const drift = (Math.random() - 0.5) * 80;
      const size = 1 + Math.random() * 2.5;

      particle.style.cssText = `
        left: ${leftPct}%;
        width: ${size}px;
        height: ${size}px;
        animation-duration: ${duration}s;
        animation-delay: ${delay}s;
        --drift: ${drift}px;
      `;

      container.appendChild(particle);
    }
  </script>
</body>
</html>
