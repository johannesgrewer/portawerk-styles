        <div class="menu-banner-separator fade-up delay-2">
          <div class="mbs-line"></div>
          <div class="mbs-diamond"></div>
          <div class="mbs-line r"></div>
        </div>
      </div>
    </div>

    <!-- Menu grid -->
    <div class="menu-section">
      <div class="menu-section-inner">
        <div class="menu-grid">

          <!-- Vorspeise -->
          <div class="fade-up">
            <div class="menu-col-label">Vorspeise</div>
            <div class="menu-dish">
              <div class="menu-dish-photo">
                <img src="https://images.unsplash.com/photo-1476224203421-9ac39bcb3327?auto=format&fit=crop&w=800&h=500&q=80" alt="Tatar vom Mosel-Rind" loading="lazy" />
                <div class="menu-dish-photo-overlay"></div>
              </div>
              <div class="menu-dish-name">Tatar vom Mosel-Rind</div>
