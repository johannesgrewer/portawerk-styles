---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>ZUCKERWATTE — Bubble Tea & Süßigkeiten · Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300;400;500;600;700&family=Nunito:wght@300;400;600;700&display=swap" rel="stylesheet" />

  <style>
    /* ─── RESET ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }

    /* ─── TOKENS ─────────────────────────────────────────── */
    :root {
      --hot:      #FF2D78;
      --mint:     #00CEB8;
      --lemon:    #FFE234;
      --lavender: #C77DFF;
      --sky:      #7EC8E3;
      --bg:       #FFF0F8;
      --bg-alt:   #FFFFFF;
      --dark:     #1A0A12;
      --dark-dim: rgba(26,10,18,0.55);
      --ff-disp:  'Fredoka', system-ui, sans-serif;
      --ff-body:  'Nunito', system-ui, sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--dark);
      font-family: var(--ff-body);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── PHOTO HELPER ───────────────────────────────────── */
    .ph { position: relative; overflow: hidden; }
    .ph img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .ph:hover img { transform: scale(1.05); }

    /* ─── NAV ────────────────────────────────────────────── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.1rem clamp(1.5rem, 5vw, 3.5rem);
      background: rgba(255,240,248,0.88);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1.5px solid rgba(255,45,120,0.12);
    }

    .nav-logo {
      font-family: var(--ff-disp);
      font-size: 1.45rem;
      font-weight: 700;
      color: var(--dark);
      letter-spacing: -0.01em;
    }
    .nav-logo em {
      font-style: normal;
      color: var(--hot);
    }

    .nav-links {
      display: flex;
      gap: 0.25rem;
      list-style: none;
    }
    .nav-links a {
      font-family: var(--ff-body);
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--dark-dim);
      padding: 0.45rem 1rem;
      border-radius: 50px;
      transition: background 0.2s, color 0.2s;
    }
    .nav-links a:hover {
      background: rgba(255,45,120,0.1);
      color: var(--hot);
    }

    .nav-cta {
      font-family: var(--ff-disp);
      font-size: 0.85rem;
      font-weight: 600;
      color: #fff;
      background: var(--hot);
      padding: 0.55rem 1.4rem;
      border-radius: 50px;
      box-shadow: 0 4px 16px rgba(255,45,120,0.3);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .nav-cta:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(255,45,120,0.4);
    }

    /* ─── HERO ───────────────────────────────────────────── */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 55fr 45fr;
    }

    /* LEFT: big text */
    .hero-left {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 8rem clamp(2rem,5vw,4.5rem) 5.5rem;
      background: var(--bg);
      z-index: 1;
    }

    /* Polka dots on hero-left */
    .hero-left::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle, rgba(255,45,120,0.1) 1.5px, transparent 1.5px);
      background-size: 28px 28px;
      pointer-events: none;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--lemon);
      color: var(--dark);
      font-family: var(--ff-body);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 0.4rem 1rem;
      border-radius: 50px;
      width: fit-content;
      margin-bottom: 1.75rem;
      animation: slideUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.1s both;
    }
    .hero-eyebrow::before { content: '✦'; font-size: 0.7rem; }

    .hero-h1 {
      font-family: var(--ff-disp);
      font-weight: 700;
      font-size: clamp(3.8rem, 8vw, 7.5rem);
      line-height: 0.95;
      letter-spacing: -0.03em;
      color: var(--dark);
      margin-bottom: 2rem;
      animation: slideUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.2s both;
    }
    .hero-h1 .line-hot    { color: var(--hot); display: block; }
    .hero-h1 .line-mint   { color: var(--mint); display: block; }
    .hero-h1 .line-lav    {
      display: block;
      background: linear-gradient(90deg, var(--lavender), var(--hot));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: 0.95rem;
      font-weight: 400;
      line-height: 1.75;
      color: var(--dark-dim);
      max-width: 36ch;
      margin-bottom: 2.25rem;
      animation: slideUp 1s cubic-bezier(0.16,1,0.3,1) 0.3s both;
    }

    .flavor-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 2.5rem;
      animation: slideUp 1s cubic-bezier(0.16,1,0.3,1) 0.4s both;
    }
    .fpill {
      font-family: var(--ff-body);
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.4rem 1rem;
      border-radius: 50px;
      border: 2px solid;
      transition: transform 0.2s;
    }
    .fpill:hover { transform: scale(1.04); }
    .fp-a { color: var(--hot);     border-color: rgba(255,45,120,0.3);   background: rgba(255,45,120,0.07); }
    .fp-b { color: #009E8C;        border-color: rgba(0,206,184,0.35);   background: rgba(0,206,184,0.08);  }
    .fp-c { color: #7B40CC;        border-color: rgba(199,125,255,0.35); background: rgba(199,125,255,0.08); }
    .fp-d { color: #A0760A;        border-color: rgba(255,226,52,0.5);   background: rgba(255,226,52,0.12); }
    .fp-e { color: #1A7A9A;        border-color: rgba(126,200,227,0.4);  background: rgba(126,200,227,0.1); }

    .hero-cta-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
      animation: slideUp 1.1s cubic-bezier(0.16,1,0.3,1) 0.5s both;
    }
    .btn-main {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--hot);
      color: #fff;
      font-family: var(--ff-disp);
      font-size: 1rem;
      font-weight: 600;
      padding: 0.95rem 2.25rem;
      border-radius: 50px;
      box-shadow: 0 8px 28px rgba(255,45,120,0.35);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-main:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 36px rgba(255,45,120,0.45);
    }
    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--dark);
      font-family: var(--ff-body);
      font-size: 0.85rem;
      font-weight: 600;
      opacity: 0.6;
      transition: opacity 0.2s;
    }
    .btn-ghost:hover { opacity: 1; }

    /* RIGHT: photo column */
    .hero-right {
      position: relative;
      overflow: hidden;
    }
    .hero-right img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transform: scale(1.03);
      animation: heroZoom 16s ease-out forwards;
    }
    @keyframes heroZoom {
      from { transform: scale(1.06); }
      to   { transform: scale(1.0); }
    }
    .hero-right::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, var(--bg) 0%, transparent 18%);
      pointer-events: none;
    }

    /* Sticker badge on hero-right */
    .sticker {
      position: absolute;
      z-index: 10;
      background: var(--lemon);
      color: var(--dark);
      font-family: var(--ff-disp);
      font-size: 0.75rem;
      font-weight: 700;
      line-height: 1.1;
      text-align: center;
      padding: 1rem;
      width: 90px;
      height: 90px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: stickSpin 12s linear infinite;
      box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    }
    .sticker-1 { bottom: 3rem; left: -1.5rem; }
    .sticker-2 {
      top: 7rem;
      right: 2rem;
      background: var(--lavender);
      color: #fff;
      animation-direction: reverse;
      animation-duration: 16s;
      font-size: 0.7rem;
      width: 78px;
      height: 78px;
    }
    @keyframes stickSpin {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }

    /* Rating badge on hero */
    .hero-rating {
      position: absolute;
      bottom: 2.5rem;
      right: 2rem;
      z-index: 10;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(8px);
      border-radius: 16px;
      padding: 0.9rem 1.2rem;
      box-shadow: 0 8px 24px rgba(0,0,0,0.1);
      border: 1px solid rgba(255,45,120,0.1);
    }
    .hero-rating-stars { color: var(--lemon); font-size: 0.85rem; margin-bottom: 0.2rem; }
    .hero-rating-num {
      font-family: var(--ff-disp);
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--dark);
      line-height: 1;
    }
    .hero-rating-sub {
      font-size: 0.6rem;
      color: var(--dark-dim);
    }

    /* ─── ANIMATIONS ─────────────────────────────────────── */
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes floatY {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(-10px); }
    }
    @keyframes marquee {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* ─── TICKER ─────────────────────────────────────────── */
    .ticker-strip {
      background: var(--hot);
      padding: 0.9rem 0;
      overflow: hidden;
      position: relative;
      z-index: 1;
    }
    .ticker-track {
      display: flex;
      gap: 0;
      white-space: nowrap;
      animation: marquee 28s linear infinite;
    }
    .ticker-item {
      display: inline-flex;
      align-items: center;
      gap: 1.25rem;
      font-family: var(--ff-disp);
      font-size: 0.85rem;
      font-weight: 600;
      color: rgba(255,255,255,0.92);
      padding: 0 2rem;
      flex-shrink: 0;
    }
    .ticker-dot {
      display: inline-block;
      width: 5px;
      height: 5px;
      background: rgba(255,255,255,0.5);
      border-radius: 50%;
    }

    /* ─── PRODUCTS SECTION ───────────────────────────────── */
    .products {
      position: relative;
      z-index: 1;
      padding: 6rem clamp(1.5rem,5vw,4.5rem);
      background: var(--bg-alt);
    }
    .products-inner {
      max-width: 1400px;
      margin: 0 auto;
    }

    .sec-eyebrow {
      font-family: var(--ff-body);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--hot);
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 0.6rem;
    }
    .sec-eyebrow::before {
      content: '';
      display: block;
      width: 1.5rem;
      height: 2px;
      background: var(--hot);
      border-radius: 2px;
    }

    .sec-h2 {
      font-family: var(--ff-disp);
      font-size: clamp(2.2rem, 4.5vw, 3.5rem);
      font-weight: 700;
      color: var(--dark);
      letter-spacing: -0.025em;
      margin-bottom: 3rem;
    }
    .sec-h2 em {
      font-style: normal;
      color: var(--hot);
    }

    /* Asymmetric product layout */
    .product-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 1.25rem;
    }

    .pcard {
      background: var(--bg);
      border-radius: 20px;
      overflow: hidden;
      border: 1.5px solid rgba(255,45,120,0.08);
      transition: transform 0.28s ease, box-shadow 0.28s ease;
    }
    .pcard:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 48px rgba(255,45,120,0.12);
    }

    /* Large hero card spans 2 rows */
    .pcard-large {
      grid-column: 1;
      grid-row: 1 / 3;
    }
    .pcard-large .ph { height: 100%; min-height: 480px; }

    .pcard-sm .ph { height: 200px; }

    .pcard-info {
      padding: 1.1rem 1.25rem 1.4rem;
    }

    .pcard-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 0.45rem;
    }
    .tag-hot   { color: var(--hot); }
    .tag-mint  { color: #009E8C; }
    .tag-lav   { color: #7B40CC; }
    .tag-lemon { color: #A0760A; }

    .pcard-name {
      font-family: var(--ff-disp);
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--dark);
      margin-bottom: 0.3rem;
    }
    .pcard-desc {
      font-size: 0.75rem;
      line-height: 1.6;
      color: var(--dark-dim);
      margin-bottom: 1rem;
    }
    .pcard-foot {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .pcard-price {
      font-family: var(--ff-disp);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--hot);
    }
    .pcard-btn {
      font-family: var(--ff-body);
      font-size: 0.68rem;
      font-weight: 700;
      color: #fff;
      background: var(--hot);
      border: none;
      padding: 0.45rem 1.1rem;
      border-radius: 50px;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
    }
    .pcard-btn:hover {
      background: var(--lavender);
      transform: scale(1.03);
    }

    /* Badge overlay on product photos */
    .badge-overlay {
      position: absolute;
      top: 0.9rem;
      left: 0.9rem;
      z-index: 5;
      background: var(--lemon);
      color: var(--dark);
      font-family: var(--ff-body);
      font-size: 0.58rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.3rem 0.75rem;
      border-radius: 50px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    }
    .badge-hot  { background: var(--hot); color: #fff; }
    .badge-mint { background: var(--mint); color: #fff; }
    .badge-lav  { background: var(--lavender); color: #fff; }

    /* ─── ATMOSPHERE STRIP ───────────────────────────────── */
    .atmo {
      position: relative;
      height: 560px;
      overflow: hidden;
    }
    .atmo-bg {
      position: absolute;
      inset: 0;
    }
    .atmo-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(1.1) brightness(0.55);
    }
    .atmo-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to right, rgba(26,10,18,0.75) 0%, rgba(26,10,18,0.2) 65%, transparent 100%),
        linear-gradient(to top, rgba(26,10,18,0.6) 0%, transparent 50%);
    }

    .atmo-content {
      position: relative;
      z-index: 2;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 clamp(2rem,6vw,5rem) 4.5rem;
      max-width: 640px;
    }

    .atmo-label {
      font-family: var(--ff-body);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--lemon);
      margin-bottom: 1.2rem;
    }

    .atmo-h2 {
      font-family: var(--ff-disp);
      font-size: clamp(2.4rem, 5vw, 4rem);
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.025em;
      line-height: 1.05;
      margin-bottom: 1.5rem;
    }

    .atmo-stats {
      display: flex;
      gap: 2.5rem;
    }
    .atmo-stat-num {
      font-family: var(--ff-disp);
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--lemon);
      line-height: 1;
      margin-bottom: 0.2rem;
    }
    .atmo-stat-label {
      font-size: 0.68rem;
      color: rgba(255,255,255,0.6);
      font-weight: 400;
    }

    /* Floating candies over atmosphere */
    .candy-float {
      position: absolute;
      right: clamp(4rem, 10vw, 9rem);
      top: 50%;
      transform: translateY(-50%);
      z-index: 5;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .candy-chip {
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 16px;
      padding: 1.25rem 1.4rem;
      text-align: center;
      animation: floatY 5s ease-in-out infinite;
    }
    .candy-chip:nth-child(2) { animation-delay: 1.2s; }
    .candy-chip:nth-child(3) { animation-delay: 2.4s; }
    .candy-chip:nth-child(4) { animation-delay: 0.6s; }
    .chip-icon { font-size: 1.75rem; margin-bottom: 0.4rem; }
    .chip-label {
      font-family: var(--ff-disp);
      font-size: 0.75rem;
      font-weight: 600;
      color: #fff;
    }

    /* ─── STORY + HOURS ──────────────────────────────────── */
    .story {
      position: relative;
      z-index: 1;
      padding: 6.5rem clamp(1.5rem,5vw,4.5rem);
      background: var(--bg);
    }
    .story::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle, rgba(255,45,120,0.07) 1.5px, transparent 1.5px);
      background-size: 28px 28px;
      pointer-events: none;
    }

    .story-inner {
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      gap: 5rem;
      align-items: center;
      position: relative;
    }

    /* Photo stack */
    .story-photos {
      position: relative;
    }
    .story-photo-main {
      border-radius: 24px;
      overflow: hidden;
    }
    .story-photo-main .ph { height: 460px; border-radius: 24px; }

    .story-photo-sm {
      position: absolute;
      bottom: -2rem;
      right: -2rem;
      width: 44%;
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 16px 48px rgba(26,10,18,0.18);
      border: 4px solid var(--bg-alt);
    }
    .story-photo-sm .ph { height: 180px; border-radius: 14px; }

    /* Floating tag on story */
    .story-tag {
      position: absolute;
      top: -1.5rem;
      left: -1.5rem;
      background: var(--hot);
      color: #fff;
      font-family: var(--ff-disp);
      font-size: 0.8rem;
      font-weight: 700;
      padding: 0.8rem 1.2rem;
      border-radius: 16px;
      box-shadow: 0 8px 24px rgba(255,45,120,0.3);
      z-index: 2;
      line-height: 1.3;
    }

    /* Right: text */
    .story-content {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .story-text {
      font-size: 0.95rem;
      line-height: 1.85;
      color: var(--dark-dim);
    }

    /* Feature chips */
    .features-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .feature-chip {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--bg-alt);
      border: 1.5px solid rgba(255,45,120,0.12);
      border-radius: 12px;
      padding: 0.6rem 1rem;
    }
    .feature-chip-icon { font-size: 1rem; }
    .feature-chip-label {
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--dark);
    }

    /* Hours card */
    .hours-card {
      background: var(--bg-alt);
      border: 1.5px solid rgba(255,45,120,0.1);
      border-radius: 20px;
      padding: 1.75rem;
    }
    .hours-title {
      font-family: var(--ff-disp);
      font-size: 1rem;
      font-weight: 600;
      color: var(--dark);
      margin-bottom: 1.2rem;
      display: flex;
      align-items: center;
      gap: 0.45rem;
    }
    .hours-row {
      display: flex;
