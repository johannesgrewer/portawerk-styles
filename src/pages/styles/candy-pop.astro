    /* ─── PHOTO GRID STRIP ───────────────────────────────── */
    .photo-grid-strip {
      position: relative;
      z-index: 1;
      background: var(--bg-alt);
      padding: 0 clamp(1.5rem,5vw,4.5rem) 6rem;
    }
    .photo-grid-inner {
      max-width: 1400px;
      margin: 0 auto;
    }
    .pgrid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
    .pgrid-item {
      border-radius: 16px;
      overflow: hidden;
    }
    .pgrid-item .ph { height: 280px; border-radius: 16px; }

    /* ─── FOOTER ─────────────────────────────────────────── */
    .footer {
      background: var(--dark);
      padding: 4rem clamp(2rem,5vw,5rem) 3rem;
    }
    .footer-inner {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 2rem;
    }
    .footer-logo {
      font-family: var(--ff-disp);
      font-size: 1.6rem;
      font-weight: 700;
      color: #fff;
    }
    .footer-logo em { font-style: normal; color: var(--hot); }
    .footer-tagline {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.35);
      margin-top: 0.3rem;
    }
    .footer-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .footer-links a {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.45);
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--hot); }
    .footer-copy {
      font-size: 0.65rem;
      color: rgba(255,255,255,0.2);
      margin-top: 2.5rem;
      text-align: center;
      max-width: 1400px;
      margin-left: auto;
      margin-right: auto;
      padding-top: 2rem;
      border-top: 1px solid rgba(255,255,255,0.06);
