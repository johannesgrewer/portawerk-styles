    .hr-time { font-weight: 700; color: var(--dark); }
    .hr-badge {
      font-size: 0.55rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: rgba(0,206,184,0.12);
