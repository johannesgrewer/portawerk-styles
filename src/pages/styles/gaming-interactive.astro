  <script>
    // ─── Mobile Nav ───
    document.getElementById('navToggle')?.addEventListener('click', () => {
      document.getElementById('navLinks')?.classList.toggle('open');
    });
    document.querySelectorAll('.nav-links a').forEach(link => {
      link.addEventListener('click', () => {
        document.getElementById('navLinks')?.classList.remove('open');
      });
    });

    // ─── Score Counter (counts up on scroll into view) ───
    const scoreEl = document.getElementById('scoreCount');
    let scoreStarted = false;
    const scoreObserver = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting && !scoreStarted) {
        scoreStarted = true;
        let val = 0;
        const target = 12400;
        const step = Math.ceil(target / 60);
        const interval = setInterval(() => {
          val = Math.min(val + step, target);
          scoreEl.textContent = String(val).padStart(8, '0');
          if (val >= target) clearInterval(interval);
        }, 16);
      }
    }, { threshold: 0.3 });
    if (scoreEl) scoreObserver.observe(scoreEl);

    // ─── Konami Code Easter Egg ───
    const KONAMI = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
    let konamiIdx = 0;
    document.addEventListener('keydown', e => {
      if (e.key === KONAMI[konamiIdx]) {
        konamiIdx++;
        if (konamiIdx === KONAMI.length) {
          document.body.classList.toggle('konami');
          konamiIdx = 0;
          if (document.body.classList.contains('konami')) {
            // Flash message
            const msg = document.createElement('div');
            msg.textContent = '★ CHEAT ACTIVATED ★';
            msg.style.cssText = 'position:fixed;top:80px;left:50%;transform:translateX(-50%);font-family:"Press Start 2P",cursive;font-size:12px;color:#FFD700;z-index:10000;text-shadow:0 0 10px #FFD700;animation:blink 0.5s steps(1) 4;pointer-events:none;';
            document.body.appendChild(msg);
            setTimeout(() => msg.remove(), 2000);
          }
        }
      } else {
        konamiIdx = e.key === KONAMI[0] ? 1 : 0;
      }
    });

    // ─── Click-to-zap monsters ───
    document.querySelectorAll('.px-invader, .px-ghost, .px-alien, .px-skull').forEach(sprite => {
      sprite.style.cursor = 'pointer';
      sprite.style.transition = 'transform 0.15s, opacity 0.15s';
      sprite.addEventListener('click', function(e) {
        e.stopPropagation();
        this.style.transform = 'scale(0)';
        this.style.opacity = '0';
        setTimeout(() => {
          this.style.transition = 'transform 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.4s';
          this.style.transform = 'scale(1)';
          this.style.opacity = '1';
        }, 300);
      });
    });

    // ─── Parallax on hero bg photo ───
    const heroBg = document.querySelector('.hero-bg-photo img');
    if (heroBg) {
      window.addEventListener('scroll', () => {
        const scrolled = window.scrollY;
        if (scrolled < window.innerHeight) {
          heroBg.style.transform = `translateY(${scrolled * 0.15}px)`;
        }
      }, { passive: true });
    }
  </script>
</body>
</html>
