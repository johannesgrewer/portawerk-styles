---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Respawn — Gaming Cafe & Bar | Trier</title>
  <meta name="description" content="Respawn — Gaming Cafe & Bar in Trier. Konsolen, High-End PCs, Brettspiele und Turniere. Di-So 14-01 Uhr." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet" />

  <style>
    html { overflow-x: hidden; }
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'VT323', monospace;
      color: #E0E0E0;
      background-color: #0D0D0D;
      line-height: 1.6;
      overflow-x: hidden;
      font-size: 20px;
    }
    img { max-width: 100%; height: auto; display: block; }
    a { text-decoration: none; color: inherit; }
    h1, h2, h3, h4 {
      font-family: 'Press Start 2P', cursive;
      line-height: 1.4;
    }

    /* ===== CRT SCANLINE OVERLAY ===== */
    body::before {
      content: '';
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: repeating-linear-gradient(
        0deg,
        transparent, transparent 2px,
        rgba(0, 0, 0, 0.15) 2px, rgba(0, 0, 0, 0.15) 4px
      );
      pointer-events: none;
      z-index: 9999;
    }

    /* ===== CRT VIGNETTE ===== */
    body::after {
      content: '';
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: radial-gradient(ellipse at center, transparent 60%, rgba(0,0,0,0.6) 100%);
      pointer-events: none;
      z-index: 9998;
    }

    /* ===== NEON GLOW UTILITIES ===== */
    .glow-green {
      text-shadow: 0 0 7px #39FF14, 0 0 10px #39FF14, 0 0 21px #39FF14, 0 0 42px #39FF14;
    }
    .glow-pink {
      text-shadow: 0 0 7px #FF1493, 0 0 10px #FF1493, 0 0 21px #FF1493, 0 0 42px #FF1493;
    }
    .glow-green-subtle {
      text-shadow: 0 0 4px #39FF14, 0 0 8px #39FF14;
    }

    /* ===== PIXEL BORDER ===== */
    .pixel-border {
      border: 4px solid #39FF14;
      box-shadow: 4px 4px 0 #39FF14, -4px -4px 0 #0D0D0D, inset 0 0 20px rgba(57,255,20,0.05);
      position: relative;
    }
    .pixel-border::before {
      content: '';
      position: absolute;
      top: -8px; left: -8px; right: -8px; bottom: -8px;
      border: 2px solid rgba(57,255,20,0.3);
      pointer-events: none;
    }

    /* ===== KEYFRAMES ===== */
    @keyframes blink {
      0%, 49% { opacity: 1; }
      50%, 100% { opacity: 0; }
    }
    @keyframes typeLine1 {
      0% { width: 0; }
      100% { width: 100%; }
    }
    @keyframes typeLine2 {
      0%, 33% { width: 0; opacity: 0; }
      34% { opacity: 1; }
      100% { width: 100%; opacity: 1; }
    }
    @keyframes typeLine3 {
      0%, 60% { width: 0; opacity: 0; }
      61% { opacity: 1; }
      100% { width: 100%; opacity: 1; }
    }
    @keyframes fadeInUp {
      0% { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    @keyframes glitch {
      0%, 100% {
        text-shadow: 0 0 7px #39FF14, 0 0 10px #39FF14, 0 0 21px #39FF14, 0 0 42px #39FF14;
        transform: translate(0);
      }
      20% { text-shadow: -3px 0 #FF1493, 3px 0 #39FF14; transform: translate(-2px, 1px); }
      40% { text-shadow: 3px 0 #FF1493, -3px 0 #39FF14; transform: translate(2px, -1px); }
      60% { text-shadow: -1px 0 #FF1493, 1px 0 #39FF14, 0 0 21px #39FF14; transform: translate(1px, 1px); }
      80% { text-shadow: 2px 0 #FF1493, -2px 0 #39FF14; transform: translate(-1px, -1px); }
    }
    @keyframes flicker {
      0%, 19.999%, 22%, 62.999%, 64%, 64.999%, 70%, 100% { opacity: 1; }
      20%, 21.999%, 63%, 63.999%, 65%, 69.999% { opacity: 0.4; }
    }
    @keyframes neonPulse {
      0%, 100% {
        box-shadow: 0 0 5px #39FF14, 0 0 10px #39FF14, 0 0 20px #39FF14, inset 0 0 5px rgba(57,255,20,0.1);
      }
      50% {
        box-shadow: 0 0 10px #39FF14, 0 0 20px #39FF14, 0 0 40px #39FF14, 0 0 60px #39FF14, inset 0 0 10px rgba(57,255,20,0.2);
      }
    }

    /* ===== NEW ANIMATIONS ===== */
    @keyframes floatPixel {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-10px); }
    }
    @keyframes floatPixelSlow {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      33% { transform: translateY(-8px) rotate(2deg); }
      66% { transform: translateY(-4px) rotate(-2deg); }
    }
    @keyframes ghostBob {
      0%, 100% { transform: translateY(0px) scaleX(1); }
      50% { transform: translateY(-8px) scaleX(-1); }
    }
    @keyframes invaderWalk {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-4px); }
    }
    @keyframes rgbGlitch {
      0%, 88%, 100% { filter: none; clip-path: none; }
      89% {
        filter: drop-shadow(3px 0 0 #FF1493) drop-shadow(-3px 0 0 #00FFFF);
        transform: skewX(2deg);
      }
      90% { filter: none; transform: skewX(0); }
      92% {
        filter: drop-shadow(-4px 0 0 #FF1493) drop-shadow(4px 0 0 #00FFFF);
        transform: skewX(-1deg) translateX(2px);
      }
      94% { filter: none; transform: skewX(0) translateX(0); }
      96% {
        filter: drop-shadow(2px 2px 0 #FF1493) drop-shadow(-2px -2px 0 #39FF14);
      }
      98% { filter: none; }
    }
    @keyframes walkAcross {
      0% { left: -80px; transform: scaleX(1); }
      49.9% { transform: scaleX(1); }
      50% { left: calc(100% + 80px); transform: scaleX(-1); }
      99.9% { transform: scaleX(-1); }
      100% { left: -80px; transform: scaleX(1); }
    }
    @keyframes hpDrain {
      0% { width: 100%; background: #39FF14; }
      60% { background: #FFD700; }
      100% { width: 34%; background: #FF1493; }
    }
    @keyframes hpDrainLoop {
      0% { width: 100%; }
      100% { width: 34%; }
    }
    @keyframes rainbowColor {
      0% { color: #FF1493; }
      17% { color: #FF6600; }
      33% { color: #FFD700; }
      50% { color: #39FF14; }
      67% { color: #00FFFF; }
      83% { color: #AA00FF; }
      100% { color: #FF1493; }
    }
    @keyframes scanSweep {
      0% { left: -110%; }
      100% { left: 110%; }
    }
    @keyframes monsterPop {
      0% { transform: scale(0) translateY(12px); opacity: 0; }
      60% { transform: scale(1.3) translateY(-3px); opacity: 1; }
      100% { transform: scale(1) translateY(0); opacity: 1; }
    }
    @keyframes coinBlink {
      0%, 45% { opacity: 1; color: #FFD700; }
      46%, 54% { opacity: 0; }
      55%, 100% { opacity: 1; color: #FF1493; }
    }

    /* ===== PIXEL ART SPRITES via box-shadow ===== */
    /*
      Each .px-* sprite uses a 6×6px element (background=pixel at 0,0 if filled, else transparent).
      box-shadow draws the remaining pixels: (col*6)px (row*6)px 0 0 currentColor
      Color is inherited via `color` property on parent or the element itself.
    */

    /* Invader — 7 cols × 5 rows (42×30px)
       .X...X.
       ..XXX..
       .XXXXX.
       XX.X.XX
       X.....X  */
    .px-invader {
      width: 6px; height: 6px;
      background: transparent;
      box-shadow:
        6px 0 0 0 currentColor, 30px 0 0 0 currentColor,
        12px 6px 0 0 currentColor, 18px 6px 0 0 currentColor, 24px 6px 0 0 currentColor,
        6px 12px 0 0 currentColor, 12px 12px 0 0 currentColor, 18px 12px 0 0 currentColor, 24px 12px 0 0 currentColor, 30px 12px 0 0 currentColor,
        0 18px 0 0 currentColor, 6px 18px 0 0 currentColor, 18px 18px 0 0 currentColor, 30px 18px 0 0 currentColor, 36px 18px 0 0 currentColor,
        0 24px 0 0 currentColor, 36px 24px 0 0 currentColor;
    }

    /* Ghost — 5 cols × 7 rows (30×42px)
       .XXX.
       XXXXX
       XXXXX
       XXXXX
       XXXXX
       X.X.X
       .X.X.  */
    .px-ghost {
      width: 6px; height: 6px;
      background: transparent;
      box-shadow:
        6px 0 0 0 currentColor, 12px 0 0 0 currentColor, 18px 0 0 0 currentColor,
        0 6px 0 0 currentColor, 6px 6px 0 0 currentColor, 12px 6px 0 0 currentColor, 18px 6px 0 0 currentColor, 24px 6px 0 0 currentColor,
        0 12px 0 0 currentColor, 6px 12px 0 0 currentColor, 12px 12px 0 0 currentColor, 18px 12px 0 0 currentColor, 24px 12px 0 0 currentColor,
        0 18px 0 0 currentColor, 6px 18px 0 0 currentColor, 12px 18px 0 0 currentColor, 18px 18px 0 0 currentColor, 24px 18px 0 0 currentColor,
        0 24px 0 0 currentColor, 6px 24px 0 0 currentColor, 12px 24px 0 0 currentColor, 18px 24px 0 0 currentColor, 24px 24px 0 0 currentColor,
        0 30px 0 0 currentColor, 12px 30px 0 0 currentColor, 24px 30px 0 0 currentColor,
        6px 36px 0 0 currentColor, 18px 36px 0 0 currentColor;
    }

    /* Alien — 5 cols × 5 rows (30×30px)
       X.X.X
       XXXXX
       .XXX.
       X.X.X
       .X.X.  */
    .px-alien {
      width: 6px; height: 6px;
      background: currentColor;
      box-shadow:
        12px 0 0 0 currentColor, 24px 0 0 0 currentColor,
        0 6px 0 0 currentColor, 6px 6px 0 0 currentColor, 12px 6px 0 0 currentColor, 18px 6px 0 0 currentColor, 24px 6px 0 0 currentColor,
        6px 12px 0 0 currentColor, 12px 12px 0 0 currentColor, 18px 12px 0 0 currentColor,
        0 18px 0 0 currentColor, 12px 18px 0 0 currentColor, 24px 18px 0 0 currentColor,
        6px 24px 0 0 currentColor, 18px 24px 0 0 currentColor;
    }

    /* Skull — 7 cols × 7 rows (42×42px)
       .XXXXX.
       XXXXXXX
       X.X.X.X
       XXXXXXX
       .XXXXX.
       .X...X.
       .XX.XX.  */
    .px-skull {
      width: 6px; height: 6px;
      background: transparent;
      box-shadow:
        6px 0 0 0 currentColor, 12px 0 0 0 currentColor, 18px 0 0 0 currentColor, 24px 0 0 0 currentColor, 30px 0 0 0 currentColor,
        0 6px 0 0 currentColor, 6px 6px 0 0 currentColor, 12px 6px 0 0 currentColor, 18px 6px 0 0 currentColor, 24px 6px 0 0 currentColor, 30px 6px 0 0 currentColor, 36px 6px 0 0 currentColor,
        0 12px 0 0 currentColor, 12px 12px 0 0 currentColor, 24px 12px 0 0 currentColor, 36px 12px 0 0 currentColor,
        0 18px 0 0 currentColor, 6px 18px 0 0 currentColor, 12px 18px 0 0 currentColor, 18px 18px 0 0 currentColor, 24px 18px 0 0 currentColor, 30px 18px 0 0 currentColor, 36px 18px 0 0 currentColor,
        6px 24px 0 0 currentColor, 12px 24px 0 0 currentColor, 18px 24px 0 0 currentColor, 24px 24px 0 0 currentColor, 30px 24px 0 0 currentColor,
        6px 30px 0 0 currentColor, 30px 30px 0 0 currentColor,
        6px 36px 0 0 currentColor, 12px 36px 0 0 currentColor, 24px 36px 0 0 currentColor, 30px 36px 0 0 currentColor;
    }

    /* Color classes */
    .c-green { color: #39FF14; }
    .c-pink   { color: #FF1493; }
    .c-cyan   { color: #00FFFF; }
    .c-gold   { color: #FFD700; }
    .c-purple { color: #AA00FF; }

    /* Sprite wrapper — handles the overflow from box-shadow */
    .px-sprite-wrap {
      display: inline-block;
      overflow: visible;
      line-height: 0;
    }

    /* ===== MONSTER DECORATIONS ===== */
    .hero-monsters {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    /* Override the hero > *:not(.hero-bg-photo) { z-index:1 } */
    .hero .hero-monsters {
      z-index: 0 !important;
    }

    .hero-monster {
      position: absolute;
    }
    .hero-monster--tl {
      top: 80px; left: 40px;
      animation: floatPixel 3.2s ease-in-out infinite;
    }
    .hero-monster--tr {
      top: 90px; right: 70px;
      animation: floatPixelSlow 4s ease-in-out infinite 0.8s;
    }
    .hero-monster--bl {
      bottom: 140px; left: 50px;
      animation: ghostBob 3.5s ease-in-out infinite 1.2s;
    }
    .hero-monster--br {
      bottom: 140px; right: 50px;
      animation: floatPixel 2.8s ease-in-out infinite 0.4s;
    }
    .hero-monster--mid-l {
      top: 50%; left: 20px;
      transform: translateY(-50%);
      animation: invaderWalk 1.5s steps(2) infinite;
    }
    .hero-monster--mid-r {
      top: 50%; right: 20px;
      transform: translateY(-50%);
      animation: invaderWalk 1.5s steps(2) infinite 0.75s;
    }

    /* Walking invader across the hero bottom */
    .walking-invader {
      position: absolute;
      bottom: 48px;
      animation: walkAcross 14s linear infinite;
    }

    /* INSERT COIN blinking in corner */
    .insert-coin {
      position: absolute;
      bottom: 100px;
      right: 24px;
      font-family: 'Press Start 2P', cursive;
      font-size: 9px;
      letter-spacing: 1px;
      animation: coinBlink 1.4s steps(1) infinite;
      opacity: 0;
      animation-delay: 4s;
      animation-fill-mode: both;
      pointer-events: none;
    }

    /* ===== HP BAR ===== */
    .hp-bar-wrap {
      margin-top: 36px;
      text-align: center;
      opacity: 0;
      animation: fadeInUp 0.6s 4s both;
    }
    .hp-bar-label {
      font-family: 'Press Start 2P', cursive;
      font-size: 9px;
      color: rgba(57,255,20,0.55);
      letter-spacing: 1px;
      margin-bottom: 8px;
    }
    .hp-bar-track {
      display: inline-block;
      width: 180px;
      height: 10px;
      border: 2px solid rgba(57,255,20,0.4);
      background: rgba(0,0,0,0.4);
      position: relative;
      overflow: hidden;
    }
    .hp-bar-fill {
      position: absolute;
      left: 0; top: 0;
      height: 100%;
      width: 100%;
      background: #39FF14;
      animation: hpDrain 6s 4.5s both;
    }

    /* ===== NAV ===== */
    .nav {
      position: fixed;
      top: 0; left: 0;
      width: 100%;
      z-index: 1000;
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(13,13,13,0.92);
      border-bottom: 2px solid rgba(57,255,20,0.3);
      backdrop-filter: blur(8px);
    }
    .nav-logo {
      font-family: 'Press Start 2P', cursive;
      font-size: 14px;
      color: #39FF14;
      letter-spacing: 2px;
      position: relative;
    }
    /* Easter egg: hover nav logo shows tiny invader */
    .nav-logo-monster {
      position: absolute;
      top: -28px;
      left: 50%;
      transform: translateX(-50%) scale(0);
      transform-origin: bottom center;
      transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
      pointer-events: none;
    }
    .nav-logo:hover .nav-logo-monster {
      transform: translateX(-50%) scale(1);
    }

    .nav-links {
      display: flex;
      gap: 32px;
      list-style: none;
    }
    .nav-links a {
      font-family: 'VT323', monospace;
      font-size: 22px;
      color: #E0E0E0;
      transition: color 0.2s, text-shadow 0.2s;
      letter-spacing: 1px;
    }
    .nav-links a:hover {
      color: #39FF14;
      text-shadow: 0 0 8px #39FF14;
    }
    .nav-toggle {
      display: none;
      background: none;
      border: 2px solid #39FF14;
      color: #39FF14;
      font-family: 'Press Start 2P', cursive;
      font-size: 10px;
      padding: 8px 12px;
      cursor: pointer;
    }

    /* ===== HERO — BOOT SCREEN ===== */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 120px 24px 80px;
      text-align: center;
      position: relative;
      overflow: hidden;
      background: #0D0D0D;
    }
    .hero-bg-photo {
      position: absolute; inset: 0; z-index: 0;
    }
    .hero-bg-photo img {
      width: 100%; height: 100%;
      object-fit: cover;
      opacity: 0.25;
      display: block;
    }
    .hero-bg-photo::after {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 50% 0%, rgba(57,255,20,0.08) 0%, transparent 60%);
    }
    .hero > *:not(.hero-bg-photo):not(.hero-monsters) {
      position: relative;
      z-index: 1;
    }

    .boot-terminal {
      width: 100%;
      max-width: 700px;
      text-align: left;
      margin-bottom: 48px;
    }
    .boot-line {
      font-family: 'VT323', monospace;
      font-size: 24px;
      color: #39FF14;
      white-space: nowrap;
      overflow: hidden;
      display: block;
      margin-bottom: 8px;
    }
    .boot-line-1 { animation: typeLine1 1.2s steps(28) 0.5s both; }
    .boot-line-2 { animation: typeLine2 1.8s steps(20) 0.5s both; }
    .boot-line-3 { animation: typeLine3 2.5s steps(16) 0.5s both; }

    .hero-title {
      font-size: clamp(28px, 6vw, 64px);
      color: #39FF14;
      letter-spacing: 4px;
      margin-bottom: 24px;
      opacity: 0;
      animation: glitch 3s infinite, fadeInUp 0.8s 2.8s both, rgbGlitch 7s infinite 5s;
      animation-delay: 2.8s, 2.8s, 5s;
    }
    .hero-title-wrapper {
      animation: flicker 8s infinite;
    }
    .hero-subtitle {
      font-family: 'VT323', monospace;
      font-size: clamp(20px, 3vw, 28px);
      color: #E0E0E0;
      letter-spacing: 2px;
      margin-bottom: 40px;
      opacity: 0;
      animation: fadeInUp 0.8s 3.2s both;
    }
    .hero-subtitle span { color: #FF1493; }

    .pixel-decoration {
      display: flex;
      justify-content: center;
      gap: 6px;
      margin-bottom: 40px;
      opacity: 0;
      animation: fadeInUp 0.6s 3s both;
    }
    .pixel-dot {
      width: 8px; height: 8px;
      background: #39FF14;
    }
    .pixel-dot:nth-child(even) { background: #FF1493; }
    .pixel-dot:nth-child(3n) { background: transparent; border: 2px solid #39FF14; }

    .cta-button {
      display: inline-block;
      font-family: 'Press Start 2P', cursive;
      font-size: clamp(14px, 2.5vw, 20px);
      color: #0D0D0D;
      background: #39FF14;
      padding: 20px 48px;
      border: none;
      cursor: pointer;
      letter-spacing: 2px;
      position: relative;
      transition: all 0.2s;
      opacity: 0;
      animation: fadeInUp 0.8s 3.5s both, neonPulse 2s infinite 4s;
      text-transform: uppercase;
    }
    .cta-button::before {
      content: '';
      position: absolute;
      top: 4px; left: 4px; right: -4px; bottom: -4px;
      background: #FF1493;
      z-index: -1;
      transition: all 0.2s;
    }
    .cta-button:hover {
      transform: translate(2px, 2px);
      background: #FF1493;
      color: #0D0D0D;
      box-shadow: 0 0 10px #FF1493, 0 0 20px #FF1493, 0 0 40px #FF1493;
    }
    .cta-button:hover::before {
      transform: translate(-4px, -4px);
      background: #39FF14;
    }

    /* ===== SECTION 2 — SELECT MODE ===== */
    .select-mode {
      padding: 100px 24px;
      max-width: 900px;
      margin: 0 auto;
      position: relative;
    }
    .section-header {
      text-align: center;
      margin-bottom: 64px;
    }
    .section-tag {
      font-family: 'VT323', monospace;
      font-size: 22px;
      color: #FF1493;
      letter-spacing: 4px;
      margin-bottom: 16px;
      display: block;
    }
    .section-title {
      font-size: clamp(20px, 4vw, 36px);
      color: #39FF14;
      letter-spacing: 3px;
    }

    /* Pixel row separator decoration */
    .pixel-row-deco {
      display: flex;
      justify-content: center;
      gap: 3px;
      margin-top: 20px;
      opacity: 0.45;
    }
    .prd { width: 6px; height: 6px; background: #39FF14; }
    .prd:nth-child(even) { background: #FF1493; }
    .prd:nth-child(4n) { background: transparent; border: 1px solid rgba(57,255,20,0.5); }

    /* Section corner monster decorations */
    .section-corner-monster {
      position: absolute;
      opacity: 0.2;
      transition: opacity 0.5s, transform 0.5s;
      pointer-events: none;
    }
    .section-corner-monster--tr {
      top: 24px; right: -8px;
      animation: floatPixel 4s ease-in-out infinite;
    }
    .section-corner-monster--bl {
      bottom: 40px; left: -8px;
      animation: ghostBob 5s ease-in-out infinite 1s;
    }
    .select-mode:hover .section-corner-monster {
      opacity: 0.5;
    }

    .menu-list {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .menu-item {
      border: 2px solid rgba(57,255,20,0.3);
      padding: 32px;
      position: relative;
      cursor: pointer;
      transition: all 0.3s;
      background: rgba(57,255,20,0.02);
      overflow: hidden;
    }
    /* Scan-sweep effect on hover */
    .menu-item::after {
      content: '';
      position: absolute;
      top: 0; left: -110%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(57,255,20,0.05), transparent);
      transition: none;
    }
    .menu-item:hover::after {
      left: 110%;
      transition: left 0.45s ease;
    }
    .menu-item::before {
      content: '>';
      position: absolute;
      left: -24px; top: 50%;
      transform: translateY(-50%);
      font-family: 'Press Start 2P', cursive;
      font-size: 16px;
      color: #39FF14;
      opacity: 0;
      animation: blink 0.8s steps(1) infinite;
      transition: opacity 0.3s;
    }
    .menu-item:hover::before { opacity: 1; }
