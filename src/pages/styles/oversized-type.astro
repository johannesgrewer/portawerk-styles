---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Laut — Podcaststudio & Sprachcoaching | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --yellow: #FFD000;
      --dark:   #0A0A0A;
      --white:  #FFFFFF;
    }

    body {
      background: var(--dark);
      color: var(--white);
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 3rem;
      background: var(--dark);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .nav-logo {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1.5rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--yellow);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--yellow); }
    .nav-cta {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--dark);
      background: var(--yellow);
      padding: 0.6rem 1.4rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .nav-cta:hover { background: var(--white); }

    .hero {
      min-height: 100vh;
      padding-top: 57px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-left: 4rem;
      padding-right: 4rem;
      gap: 0;
      overflow: hidden;
    }

    /* The giant headline */
    .big-line {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      text-transform: uppercase;
      line-height: 0.85;
      letter-spacing: -0.01em;
      display: flex;
      align-items: baseline;
      gap: 0.2em;
      white-space: nowrap;
    }
    .bl-1 { font-size: clamp(5rem, 16vw, 14rem); color: var(--white); }
    .bl-2 { font-size: clamp(5rem, 16vw, 14rem); color: var(--yellow); }
    .bl-3 {
      font-size: clamp(5rem, 16vw, 14rem);
      -webkit-text-stroke: 2px rgba(255,255,255,0.2);
      color: transparent;
    }
    .bl-4 { font-size: clamp(5rem, 16vw, 14rem); color: var(--white); }

    /* Inline content rows between headline lines */
    .meta-row {
      display: flex;
      align-items: center;
      gap: 2rem;
      padding: 0.75rem 0;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .meta-row:first-of-type { border-top: none; margin-top: 1.5rem; }

    .meta-tag {
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
    }
    .meta-tag.yellow { color: var(--yellow); }
    .meta-dot {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: rgba(255,255,255,0.15);
      flex-shrink: 0;
    }
    .meta-body {
      font-size: 0.82rem;
      font-weight: 300;
      color: rgba(255,255,255,0.4);
      max-width: 48ch;
      line-height: 1.7;
    }
    .meta-spacer { flex: 1; }
    .meta-cta {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--dark);
      background: var(--yellow);
      text-decoration: none;
      padding: 0.65rem 1.75rem;
      white-space: nowrap;
      transition: background 0.2s;
    }
    .meta-cta:hover { background: var(--white); }
    .meta-link {
      font-size: 0.58rem;
      font-weight: 300;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.2);
      text-decoration: none;
      white-space: nowrap;
    }

    /* Service pills */
    .pill-row {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .pill {
      font-size: 0.58rem;
      font-weight: 300;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.28rem 0.8rem;
      border: 1px solid rgba(255,208,0,0.2);
      color: rgba(255,208,0,0.6);
    }

    /* Ticker at bottom */
    .ticker {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--yellow);
      overflow: hidden;
      height: 32px;
      display: flex;
      align-items: center;
      z-index: 50;
    }
    .ticker-inner {
      display: flex;
      gap: 4rem;
      animation: ticker 25s linear infinite;
      white-space: nowrap;
    }
    @keyframes ticker {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .tick-item {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.68rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--dark);
    }
    .tick-sep {
      color: rgba(10,10,10,0.3);
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Laut.</div>
    <ul class="nav-links">
      <li><a href="#">Studio</a></li>
      <li><a href="#">Coaching</a></li>
      <li><a href="#">Preise</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <a href="#" class="nav-cta">Session buchen</a>
  </nav>

  <section class="hero">
    <div class="big-line">
      <span class="bl-1">DEINE</span>
      <span class="bl-2">STIMME.</span>
    </div>
    <div class="big-line">
      <span class="bl-3">DEIN</span>
      <span class="bl-4">RAUM.</span>
    </div>

    <div class="meta-row">
      <span class="meta-tag yellow">Podcaststudio · Trier</span>
      <div class="meta-dot"></div>
      <p class="meta-body">
        Professionelle Aufnahmen, Sprachcoaching und alles,
        was du brauchst, um gehört zu werden.
      </p>
      <div class="meta-spacer"></div>
      <div class="pill-row">
        <span class="pill">Podcast</span>
        <span class="pill">Voice-Over</span>
        <span class="pill">Coaching</span>
        <span class="pill">Hörbuch</span>
      </div>
    </div>

    <div class="meta-row">
      <a href="#" class="meta-cta">Studio buchen →</a>
      <a href="#" class="meta-link">Preisliste ansehen</a>
      <div class="meta-spacer"></div>
      <span class="meta-tag">Mo – Fr · 9 – 20 Uhr</span>
      <div class="meta-dot"></div>
      <span class="meta-tag">ab 60 € / Stunde</span>
    </div>
  </section>

  <div class="ticker">
    <div class="ticker-inner">
      <span class="tick-item">Podcaststudio Trier</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Sprachcoaching</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Voice-Over & Synchron</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Hörbuchproduktion</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Professionelle Aufnahmen</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Podcaststudio Trier</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Sprachcoaching</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Voice-Over & Synchron</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Hörbuchproduktion</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Professionelle Aufnahmen</span>
      <span class="tick-sep">✦</span>
    </div>
  </div>
</body>
</html>
