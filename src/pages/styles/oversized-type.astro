---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Laut — Podcaststudio & Sprachcoaching | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --yellow: #FFD000;
      --dark:   #0A0A0A;
      --white:  #FFFFFF;
    }

    body {
      background: var(--dark);
      color: var(--white);
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 3rem;
      background: var(--dark);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .nav-logo {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1.5rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--yellow);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--yellow); }
    .nav-cta {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--dark);
      background: var(--yellow);
      padding: 0.6rem 1.4rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .nav-cta:hover { background: var(--white); }

    .hero {
      min-height: 100vh;
      padding-top: 57px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-left: 4rem;
      padding-right: 4rem;
      gap: 0;
      overflow: hidden;
    }

    /* The giant headline */
    .big-line {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      text-transform: uppercase;
      line-height: 0.85;
      letter-spacing: -0.01em;
      display: flex;
      align-items: baseline;
      gap: 0.2em;
      white-space: nowrap;
    }
    .bl-1 { font-size: clamp(5rem, 16vw, 14rem); color: var(--white); }
    .bl-2 { font-size: clamp(5rem, 16vw, 14rem); color: var(--yellow); }
    .bl-3 {
      font-size: clamp(5rem, 16vw, 14rem);
      -webkit-text-stroke: 2px rgba(255,255,255,0.2);
      color: transparent;
    }
    .bl-4 { font-size: clamp(5rem, 16vw, 14rem); color: var(--white); }

    /* Inline content rows between headline lines */
    .meta-row {
      display: flex;
      align-items: center;
      gap: 2rem;
      padding: 0.75rem 0;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .meta-row:first-of-type { border-top: none; margin-top: 1.5rem; }

    .meta-tag {
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
    }
    .meta-tag.yellow { color: var(--yellow); }
    .meta-dot {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: rgba(255,255,255,0.15);
      flex-shrink: 0;
    }
    .meta-body {
      font-size: 0.82rem;
      font-weight: 300;
      color: rgba(255,255,255,0.4);
      max-width: 48ch;
      line-height: 1.7;
    }
    .meta-spacer { flex: 1; }
    .meta-cta {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--dark);
      background: var(--yellow);
      text-decoration: none;
      padding: 0.65rem 1.75rem;
      white-space: nowrap;
      transition: background 0.2s;
    }
    .meta-cta:hover { background: var(--white); }
    .meta-link {
      font-size: 0.58rem;
      font-weight: 300;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.2);
      text-decoration: none;
      white-space: nowrap;
    }

    /* Service pills */
    .pill-row {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .pill {
      font-size: 0.58rem;
      font-weight: 300;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.28rem 0.8rem;
      border: 1px solid rgba(255,208,0,0.2);
      color: rgba(255,208,0,0.6);
    }

    /* Ticker at bottom */
    .ticker {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--yellow);
      overflow: hidden;
      height: 32px;
      display: flex;
      align-items: center;
      z-index: 50;
    }
    .ticker-inner {
      display: flex;
      gap: 4rem;
      animation: ticker 25s linear infinite;
      white-space: nowrap;
    }
    @keyframes ticker {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .tick-item {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.68rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--dark);
    }
    .tick-sep {
      color: rgba(10,10,10,0.3);
    }

    /* Photo container */
    .ph { position: relative; overflow: hidden; }
    .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
    .ph:hover img { transform: scale(1.05); }

    /* Sections */
    .section-services {
      padding: 7rem 4rem;
      background: var(--dark);
      max-width: 1600px;
      margin: 0 auto;
    }
    .section-label {
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,208,0,0.5);
      margin-bottom: 0.75rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
    }
    .section-heading {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(2rem, 5vw, 4rem);
      text-transform: uppercase;
      line-height: 0.9;
      letter-spacing: -0.01em;
      color: var(--white);
      margin-bottom: 3.5rem;
    }
    .section-heading span { color: var(--yellow); }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(255,255,255,0.05);
    }
    .svc-card {
      background: var(--dark);
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      transition: background 0.2s;
    }
    .svc-card:hover { background: #111; }
    .svc-card-ph {
      height: 220px;
      border-radius: 0;
    }
    .svc-card-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1.5rem;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      color: var(--white);
    }
    .svc-card-desc {
      font-size: 0.75rem;
      font-weight: 300;
      color: rgba(255,255,255,0.35);
      line-height: 1.7;
    }
    .svc-card-price {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--yellow);
      margin-top: auto;
    }

    /* Contact section */
    .section-contact {
      background: var(--yellow);
      padding: 7rem 4rem;
      max-width: 1600px;
      margin: 0 auto;
    }
    .contact-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
    }
    .contact-left {}
    .contact-heading {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      text-transform: uppercase;
      line-height: 0.88;
      letter-spacing: -0.01em;
      color: var(--dark);
      margin-bottom: 1.5rem;
    }
    .contact-body {
      font-size: 0.88rem;
      font-weight: 300;
      color: rgba(10,10,10,0.65);
      line-height: 1.8;
      max-width: 38ch;
      margin-bottom: 2rem;
    }
    .contact-cta {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--yellow);
      background: var(--dark);
      text-decoration: none;
      padding: 0.8rem 2rem;
      display: inline-block;
      transition: background 0.2s;
    }
    .contact-cta:hover { background: #222; }
    .contact-right {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .contact-info-row {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      border-bottom: 1px solid rgba(10,10,10,0.12);
      padding-bottom: 1.25rem;
    }
    .contact-info-row:last-child { border-bottom: none; }
    .ci-label {
      font-size: 0.52rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 700;
      color: rgba(10,10,10,0.35);
      font-family: 'Barlow Condensed', sans-serif;
    }
    .ci-val {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 1.25rem;
      color: var(--dark);
      letter-spacing: 0.01em;
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Laut.</div>
    <ul class="nav-links">
      <li><a href="#">Studio</a></li>
      <li><a href="#">Coaching</a></li>
      <li><a href="#">Preise</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <a href="#" class="nav-cta">Session buchen</a>
  </nav>

  <section class="hero">
    <div class="big-line">
      <span class="bl-1">DEINE</span>
      <span class="bl-2">STIMME.</span>
    </div>
    <div class="big-line">
      <span class="bl-3">DEIN</span>
      <span class="bl-4">RAUM.</span>
    </div>

    <div class="meta-row">
      <span class="meta-tag yellow">Podcaststudio · Trier</span>
      <div class="meta-dot"></div>
      <p class="meta-body">
        Professionelle Aufnahmen, Sprachcoaching und alles,
        was du brauchst, um gehört zu werden.
      </p>
      <div class="meta-spacer"></div>
      <div class="pill-row">
        <span class="pill">Podcast</span>
        <span class="pill">Voice-Over</span>
        <span class="pill">Coaching</span>
        <span class="pill">Hörbuch</span>
      </div>
    </div>

    <div class="meta-row">
      <a href="#" class="meta-cta">Studio buchen →</a>
      <a href="#" class="meta-link">Preisliste ansehen</a>
      <div class="meta-spacer"></div>
      <span class="meta-tag">Mo – Fr · 9 – 20 Uhr</span>
      <div class="meta-dot"></div>
      <span class="meta-tag">ab 60 € / Stunde</span>
    </div>
  </section>

  <div class="ticker">
    <div class="ticker-inner">
      <span class="tick-item">Podcaststudio Trier</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Sprachcoaching</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Voice-Over & Synchron</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Hörbuchproduktion</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Professionelle Aufnahmen</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Podcaststudio Trier</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Sprachcoaching</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Voice-Over & Synchron</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Hörbuchproduktion</span>
      <span class="tick-sep">✦</span>
      <span class="tick-item">Professionelle Aufnahmen</span>
      <span class="tick-sep">✦</span>
    </div>
  </div>

  <!-- SECTION 2: Leistungen mit Fotos -->
  <div style="background:var(--dark); padding-bottom: 32px;">
    <section class="section-services">
      <div class="section-label">Leistungen</div>
      <h2 class="section-heading">Was wir<br><span>produzieren.</span></h2>
      <div class="services-grid">
        <div class="svc-card">
          <div class="ph svc-card-ph" style="height:220px;">
            <img src="https://images.unsplash.com/photo-1519671482749-fd09be7ccebf?auto=format&fit=crop&w=800&h=500&q=80" alt="Podcast Aufnahme" loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.55) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
          <div class="svc-card-name">Podcast</div>
          <div class="svc-card-desc">Professionelle Mehrspur-Aufnahmen, Schnitt, Mastering und Veröffentlichung auf allen Plattformen. Einzelfolge oder Staffel.</div>
          <div class="svc-card-price">ab 120 € / Folge</div>
        </div>
        <div class="svc-card">
          <div class="ph svc-card-ph" style="height:220px;">
            <img src="https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&fit=crop&w=800&h=500&q=80" alt="Voice-Over Studio" loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.55) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
          <div class="svc-card-name">Voice-Over</div>
          <div class="svc-card-desc">Werbespots, Erklärvideos, Telefonansagen, Hörbücher. Studioqualität für Film, Funk und digitale Medien.</div>
          <div class="svc-card-price">ab 60 € / Stunde</div>
        </div>
        <div class="svc-card">
          <div class="ph svc-card-ph" style="height:220px;">
            <img src="https://images.unsplash.com/photo-1571771894821-ce9b6c11b08e?auto=format&fit=crop&w=800&h=500&q=80" alt="Sprachcoaching" loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.55) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
          <div class="svc-card-name">Coaching</div>
          <div class="svc-card-desc">Stimm- und Sprachcoaching für Unternehmer, Speaker und Moderatoren. Einzelstunden oder Intensiv-Pakete.</div>
          <div class="svc-card-price">ab 80 € / Einheit</div>
        </div>
      </div>
    </section>
  </div>

  <!-- SECTION 3: Kontakt -->
  <div style="background:var(--yellow);">
    <section class="section-contact">
      <div class="contact-inner">
        <div class="contact-left">
          <div class="contact-heading">Studio<br>buchen.</div>
          <p class="contact-body">
            Kein langes Briefing. Einfach anrufen oder schreiben —
            wir finden gemeinsam die passende Session für dein Projekt.
          </p>
          <a href="#" class="contact-cta">Jetzt anfragen →</a>
        </div>
        <div class="contact-right">
          <div class="contact-info-row">
            <span class="ci-label">Adresse</span>
            <span class="ci-val">Fleischstraße 12, 54290 Trier</span>
          </div>
          <div class="contact-info-row">
            <span class="ci-label">Telefon</span>
            <span class="ci-val">0651 / 492 38 70</span>
          </div>
          <div class="contact-info-row">
            <span class="ci-label">E-Mail</span>
            <span class="ci-val">studio@laut-trier.de</span>
          </div>
          <div class="contact-info-row">
            <span class="ci-label">Öffnungszeiten</span>
            <span class="ci-val">Mo – Fr · 9 – 20 Uhr</span>
          </div>
        </div>
      </div>
    </section>
  </div>

</body>
</html>
