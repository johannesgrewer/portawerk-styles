---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>BLEI — Schriftgießerei | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --ink:   #0A0A0A;
      --paper: #F2ECE3;
      --red:   #D80018;
    }

    body {
      background: var(--ink);
      color: var(--paper);
      font-family: 'DM Sans', sans-serif;
      overflow-x: hidden;
    }

    /* Subtle grain */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)' opacity='0.022'/%3E%3C/svg%3E");
      background-size: 200px;
      pointer-events: none;
      z-index: 9999;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2.5rem;
      background: var(--ink);
      border-bottom: 1px solid rgba(242,236,227,0.07);
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      letter-spacing: 0.16em;
      color: var(--paper);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(242,236,227,0.28);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--paper); }
    .nav-cta {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--paper);
      padding: 0.5rem 1.3rem;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .nav-cta:hover { opacity: 0.8; }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      padding-top: 56px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .hero-type-block {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 2rem 2.5rem 0;
      gap: 0;
    }

    .display-solid {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(6rem, 44vw, 42rem);
      line-height: 0.82;
      letter-spacing: -0.01em;
      color: var(--paper);
      white-space: nowrap;
    }

    .display-solid .accent { color: var(--red); }

    .display-outline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(4rem, 22vw, 22rem);
      line-height: 0.85;
      letter-spacing: -0.01em;
      -webkit-text-stroke: 1.5px rgba(242,236,227,0.16);
      color: transparent;
      white-space: nowrap;
      margin-left: 18vw;
    }

    .hero-rule {
      height: 1px;
      background: rgba(242,236,227,0.08);
      margin: 1.75rem 2.5rem 0;
    }

    .hero-bar {
      display: flex;
      align-items: center;
      gap: 1.75rem;
      padding: 1.4rem 2.5rem 1.8rem;
    }

    .hero-tag {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(242,236,227,0.28);
      white-space: nowrap;
    }

    .hero-dot {
      width: 3px; height: 3px;
      border-radius: 50%;
      background: rgba(242,236,227,0.18);
      flex-shrink: 0;
    }

    .hero-desc {
      font-size: 0.72rem;
      font-weight: 300;
      line-height: 1.75;
      color: rgba(242,236,227,0.38);
      max-width: 40ch;
    }

    .hero-spacer { flex: 1; }

    .hero-cta {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--paper);
      text-decoration: none;
      padding: 0.62rem 1.4rem;
      white-space: nowrap;
      transition: opacity 0.2s;
    }
    .hero-cta:hover { opacity: 0.8; }

    .hero-ghost {
      font-family: 'DM Mono', monospace;
      font-size: 0.48rem;
      font-weight: 300;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(242,236,227,0.22);
      text-decoration: none;
      white-space: nowrap;
      transition: color 0.2s;
    }
    .hero-ghost:hover { color: var(--paper); }

    /* ─── SHOWCASE ─── */
    .showcase {
      background: var(--paper);
      color: var(--ink);
    }

    .showcase-grid {
      display: grid;
      grid-template-columns: 55% 1fr;
      min-height: 560px;
    }

    .showcase-photo {
      position: relative;
      overflow: hidden;
    }
    .showcase-photo img {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .showcase-photo:hover img { transform: scale(1.04); }

    .showcase-text {
      padding: 5rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.75rem;
    }

    .s-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.46rem;
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(10,10,10,0.32);
    }

    .s-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 5.5vw, 5.5rem);
      line-height: 0.88;
      color: var(--ink);
    }

    .s-headline .outline {
      -webkit-text-stroke: 1.5px var(--ink);
      color: transparent;
    }

    .s-body {
      font-size: 0.76rem;
      font-weight: 300;
      line-height: 1.88;
      color: rgba(10,10,10,0.52);
      max-width: 38ch;
    }

    .stat-row {
      display: flex;
      gap: 2.5rem;
      padding-top: 1.25rem;
      border-top: 1px solid rgba(10,10,10,0.1);
    }

    .stat-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.8rem;
      line-height: 1;
      color: var(--ink);
    }

    .stat-lbl {
      font-family: 'DM Mono', monospace;
      font-size: 0.42rem;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(10,10,10,0.32);
      margin-top: 0.25rem;
    }

    /* ─── ALPHABET BAND ─── */
    .alpha-band {
      background: var(--ink);
      padding: 3rem 0;
      overflow: hidden;
      border-top: 1px solid rgba(242,236,227,0.05);
    }

    .alpha-inner {
      display: flex;
      gap: 0.8rem;
      animation: scroll-alpha 35s linear infinite;
      white-space: nowrap;
      width: max-content;
    }

    @keyframes scroll-alpha {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    .al {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(4rem, 10vw, 10rem);
      line-height: 0.85;
      color: rgba(242,236,227,0.055);
      letter-spacing: 0.02em;
      user-select: none;
    }
    .al.out {
      -webkit-text-stroke: 1px rgba(242,236,227,0.14);
      color: transparent;
    }
    .al.red { color: rgba(216,0,24,0.65); }

    /* ─── FONT CATALOG ─── */
    .catalog {
      background: var(--paper);
      color: var(--ink);
      padding: 6rem 2.5rem;
    }

    .catalog-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 3.5rem;
    }

    .catalog-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2rem, 4.5vw, 4.5rem);
      line-height: 0.88;
      color: var(--ink);
    }

    .catalog-link {
      font-family: 'DM Mono', monospace;
      font-size: 0.48rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(10,10,10,0.38);
      text-decoration: none;
      transition: color 0.2s;
    }
    .catalog-link:hover { color: var(--ink); }

    .font-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(10,10,10,0.1);
    }

    .font-card {
      background: var(--paper);
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      overflow: hidden;
      transition: background 0.2s;
    }
    .font-card:hover { background: rgba(10,10,10,0.03); }

    .fc-photo {
      height: 200px;
      position: relative;
      overflow: hidden;
    }
    .fc-photo img {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.55s ease;
    }
    .font-card:hover .fc-photo img { transform: scale(1.05); }

    .fc-specimen {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3.5rem;
      line-height: 0.88;
      color: var(--ink);
    }

    .fc-name {
      font-family: 'DM Mono', monospace;
      font-size: 0.48rem;
      font-weight: 400;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(10,10,10,0.45);
    }

    .fc-desc {
      font-size: 0.7rem;
      font-weight: 300;
      color: rgba(10,10,10,0.4);
      line-height: 1.7;
    }

    .fc-price {
      font-family: 'DM Mono', monospace;
      font-size: 0.48rem;
      font-weight: 300;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--red);
      margin-top: auto;
    }

    /* ─── WORKSHOP ─── */
    .workshop {
      background: var(--ink);
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .ws-photo {
      position: relative;
      overflow: hidden;
      min-height: 520px;
    }
    .ws-photo img {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      filter: brightness(0.72);
    }
    .ws-photo::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, transparent 55%, var(--ink) 100%);
      pointer-events: none;
    }

    .ws-text {
      padding: 6rem 4.5rem 6rem 5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.75rem;
    }

    .ws-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.46rem;
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(242,236,227,0.22);
    }

    .ws-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 5vw, 5rem);
      line-height: 0.88;
      color: rgba(242,236,227,0.9);
    }
    .ws-headline .red { color: var(--red); }
    .ws-headline .out {
      -webkit-text-stroke: 1px rgba(242,236,227,0.28);
      color: transparent;
    }

    .ws-body {
      font-size: 0.75rem;
      font-weight: 300;
      line-height: 1.88;
      color: rgba(242,236,227,0.32);
      max-width: 40ch;
    }

    .ws-list {
      display: flex;
      flex-direction: column;
      border-top: 1px solid rgba(242,236,227,0.07);
    }

    .ws-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(242,236,227,0.05);
    }

    .wi-name {
      font-size: 0.75rem;
      font-weight: 300;
      color: rgba(242,236,227,0.58);
    }

    .wi-price {
      font-family: 'DM Mono', monospace;
      font-size: 0.44rem;
      font-weight: 300;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(242,236,227,0.22);
    }

    .btn-paper {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--paper);
      text-decoration: none;
      padding: 0.68rem 1.5rem;
      width: fit-content;
      transition: opacity 0.2s;
    }
    .btn-paper:hover { opacity: 0.8; }

    /* ─── CONTACT ─── */
    .contact {
      background: var(--red);
      padding: 7rem 2.5rem;
    }

    .contact-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .contact-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(4.5rem, 13vw, 13rem);
      line-height: 0.83;
      color: var(--paper);
    }

    .contact-headline .out {
      -webkit-text-stroke: 2px rgba(242,236,227,0.55);
      color: transparent;
    }

    .contact-right {
      display: flex;
      flex-direction: column;
      gap: 1.6rem;
    }

    .ci {
      display: flex;
      flex-direction: column;
      gap: 0.22rem;
      border-bottom: 1px solid rgba(242,236,227,0.2);
      padding-bottom: 1.2rem;
    }
    .ci:last-of-type { border-bottom: none; }

    .ci-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.42rem;
      font-weight: 300;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(242,236,227,0.45);
    }

    .ci-value {
      font-size: 0.85rem;
      font-weight: 300;
      color: rgba(242,236,227,0.88);
      line-height: 1.5;
    }

    .btn-dark {
      font-family: 'DM Mono', monospace;
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--red);
      background: var(--ink);
      text-decoration: none;
      padding: 0.68rem 1.5rem;
      width: fit-content;
      transition: opacity 0.2s;
    }
    .btn-dark:hover { opacity: 0.85; }

    /* ─── FOOTER ─── */
    footer {
      background: var(--ink);
      padding: 1.4rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid rgba(242,236,227,0.05);
    }

    .footer-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1rem;
      letter-spacing: 0.25em;
      color: rgba(242,236,227,0.3);
    }

    .footer-meta {
      font-family: 'DM Mono', monospace;
      font-size: 0.38rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(242,236,227,0.14);
    }

    /* Corner marks */
    .corner {
      position: fixed;
      font-family: 'DM Mono', monospace;
      font-size: 0.35rem;
      font-weight: 300;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(242,236,227,0.1);
      z-index: 50;
      pointer-events: none;
    }
    .corner.bl { bottom: 1.5rem; left: 1.5rem; }
    .corner.br { bottom: 1.5rem; right: 1.5rem; }
  </style>
</head>
<body>

  <div class="corner bl">49°45'N · 06°38'E</div>
  <div class="corner br">BLEI · Est. 2016</div>

  <nav>
    <div class="nav-logo">BLEI</div>
    <ul class="nav-links">
      <li><a href="#">Schriften</a></li>
      <li><a href="#">Specimen</a></li>
      <li><a href="#">Workshop</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <a href="#" class="nav-cta">Katalog bestellen</a>
  </nav>

  <!-- ── HERO: Pure Typography ── -->
  <section class="hero">
    <div class="hero-type-block">
      <div class="display-solid">BLE<span class="accent">I</span></div>
      <div class="display-outline">GUSS</div>
    </div>

    <div class="hero-rule"></div>

    <div class="hero-bar">
      <span class="hero-tag">Schriftgießerei · Trier</span>
      <div class="hero-dot"></div>
      <span class="hero-tag">Est. 2016</span>
      <div class="hero-dot"></div>
      <p class="hero-desc">14 Schriftfamilien. 89 Schnitte. Handgemacht in Trier — für Designer, Typografen und alle, denen Zeichen etwas bedeuten.</p>
      <div class="hero-spacer"></div>
      <a href="#" class="hero-cta">Schriften entdecken →</a>
      <a href="#" class="hero-ghost">Specimen ansehen</a>
    </div>
  </section>

  <!-- ── SHOWCASE: Photo + Text ── -->
  <section class="showcase">
    <div class="showcase-grid">
      <div class="showcase-photo">
        <img
          src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=1400&h=1100&q=85"
          alt="Letterpress Druckwerkstatt"
        />
      </div>
      <div class="showcase-text">
        <div class="s-label">001 — Über die Gießerei</div>
        <h2 class="s-headline">
          Jeder<br>
          Punkt.<br>
          <span class="outline">Gesetzt.</span>
        </h2>
        <p class="s-body">
          BLEI ist eine unabhängige Schriftgießerei aus Trier. Wir entwerfen, produzieren und vertreiben Schriften — für Druckmaschine und Bildschirm. Keine Massenware. Kein Kompromiss.
        </p>
        <div class="stat-row">
          <div>
            <div class="stat-num">14</div>
            <div class="stat-lbl">Familien</div>
          </div>
          <div>
            <div class="stat-num">89</div>
            <div class="stat-lbl">Schnitte</div>
          </div>
          <div>
            <div class="stat-num">10</div>
            <div class="stat-lbl">Jahre</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ALPHABET BAND ── -->
  <div class="alpha-band">
    <div class="alpha-inner">
      <span class="al">A</span><span class="al out">B</span><span class="al">C</span><span class="al red">D</span><span class="al out">E</span><span class="al">F</span><span class="al">G</span><span class="al out">H</span><span class="al">I</span><span class="al">J</span><span class="al red out">K</span><span class="al">L</span><span class="al out">M</span><span class="al">N</span><span class="al">O</span><span class="al red">P</span><span class="al out">Q</span><span class="al">R</span><span class="al">S</span><span class="al out">T</span><span class="al">U</span><span class="al red">V</span><span class="al out">W</span><span class="al">X</span><span class="al">Y</span><span class="al out">Z</span>
      <span class="al">A</span><span class="al out">B</span><span class="al">C</span><span class="al red">D</span><span class="al out">E</span><span class="al">F</span><span class="al">G</span><span class="al out">H</span><span class="al">I</span><span class="al">J</span><span class="al red out">K</span><span class="al">L</span><span class="al out">M</span><span class="al">N</span><span class="al">O</span><span class="al red">P</span><span class="al out">Q</span><span class="al">R</span><span class="al">S</span><span class="al out">T</span><span class="al">U</span><span class="al red">V</span><span class="al out">W</span><span class="al">X</span><span class="al">Y</span><span class="al out">Z</span>
    </div>
  </div>

  <!-- ── FONT CATALOG ── -->
  <section class="catalog">
    <div class="catalog-header">
      <h2 class="catalog-title">Schriften<br>im Katalog.</h2>
      <a href="#" class="catalog-link">Alle 14 Familien ansehen →</a>
    </div>
    <div class="font-grid">
      <div class="font-card">
        <div class="fc-photo">
          <img src="https://images.unsplash.com/photo-1586281380349-632531db7ed4?auto=format&fit=crop&w=800&h=500&q=80" alt="Druckwerkstatt" loading="lazy" />
        </div>
        <div class="fc-name">Mosel Grotesk</div>
        <div class="fc-specimen">Gg Aa</div>
        <div class="fc-desc">Geometrische Grotesk · 6 Schnitte · OTF + WOFF2</div>
        <div class="fc-price">ab 49 € · Drucklizenz</div>
      </div>
      <div class="font-card">
        <div class="fc-photo">
          <img src="https://images.unsplash.com/photo-1544716278-ca5e3f4abd8c?auto=format&fit=crop&w=800&h=500&q=80" alt="Typografie Layout" loading="lazy" />
        </div>
        <div class="fc-name">Porta Antiqua</div>
        <div class="fc-specimen" style="-webkit-text-stroke:1.5px var(--ink);color:transparent;">Kk Tt</div>
        <div class="fc-desc">Humanistische Antiqua · 8 Schnitte · Variable Font</div>
        <div class="fc-price">ab 89 € · Webfont-Lizenz</div>
      </div>
