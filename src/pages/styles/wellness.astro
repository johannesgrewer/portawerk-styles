---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Quellstein — Naturheilpraxis in Trier</title>
  <meta name="description" content="Quellstein ist eine Naturheilpraxis in Trier. Akupunktur, Phytotherapie, Manuelle Therapie und Ernaehrungsberatung. Dr. Lena Wirth." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible+Next:ital,wght@0,400;0,500;0,700;1,400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400&display=swap" rel="stylesheet" />

  <style>
    html { overflow-x: hidden; }
    /* ===== RESET & BASE ===== */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #4A7C6F;
      --secondary: #F5F0E8;
      --accent: #C4956A;
      --bg: #FAFAF5;
      --text: #2D3B35;
      --font-display: "Fraunces", "Georgia", serif;
      --font-body: "Atkinson Hyperlegible Next", system-ui, sans-serif;
    }

    html {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-weight: 400;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      scroll-behavior: smooth;
    }

    body {
      overflow-x: hidden;
      line-height: 1.7;
    }

    ::selection {
      background: var(--primary);
      color: var(--secondary);
    }

    img {
      display: block;
      max-width: 100%;
    }

    a {
      color: inherit;
      text-decoration: none;
    }


    /* ===================================================
       HERO — "Breathing Space"
    =================================================== */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 6rem 2rem;
      position: relative;
    }

    .hero-brand {
      font-family: var(--font-display);
      font-weight: 300;
      font-size: clamp(1.1rem, 2vw, 1.4rem);
      letter-spacing: 0.15em;
      color: var(--primary);
      margin-bottom: 3rem;
      text-transform: uppercase;
    }

    .hero-circle-wrap {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
    }

    .hero-circle {
      width: clamp(180px, 22vw, 260px);
      height: clamp(180px, 22vw, 260px);
      border-radius: 50%;
      object-fit: cover;
      box-shadow: 0 20px 60px rgba(74, 124, 111, 0.12), 0 8px 24px rgba(0, 0, 0, 0.04);
    }

    .hero-arc {
      position: absolute;
      bottom: -40px;
      left: 50%;
      transform: translateX(-50%);
      width: 120px;
      height: 50px;
    }

    .hero-headline {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(2rem, 4vw, 3.2rem);
      line-height: 1.3;
      color: var(--text);
      margin-top: 3rem;
      margin-bottom: 0.5rem;
    }

    .hero-subline {
      font-family: var(--font-display);
      font-weight: 300;
      font-style: italic;
      font-size: clamp(1.2rem, 2.2vw, 1.6rem);
      color: var(--accent);
      margin-bottom: 3rem;
      line-height: 1.5;
    }

    .hero-meta {
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      color: var(--primary);
      opacity: 0.7;
      margin-bottom: 2rem;
    }

    .hero-meta span {
      margin: 0 0.6rem;
    }

    .hero-link {
      display: inline-block;
      font-family: var(--font-body);
      font-weight: 500;
      font-size: 0.95rem;
      color: var(--primary);
      border-bottom: 1.5px solid var(--accent);
      padding-bottom: 2px;
      transition: color 0.3s ease, border-color 0.3s ease;
      letter-spacing: 0.02em;
    }

    .hero-link:hover {
      color: var(--accent);
      border-color: var(--primary);
    }

    /* ===================================================
       HERO DIVIDER LINE — grows left to right on load
    =================================================== */
    .hero-divider {
      width: 0;
      height: 1px;
      background: linear-gradient(to right, transparent, var(--accent), transparent);
      margin: 2.5rem auto 0;
      animation: lineGrow 1.8s cubic-bezier(0.4, 0, 0.2, 1) 1.3s both;
    }

    @keyframes lineGrow {
      from { width: 0; opacity: 0; }
      to   { width: clamp(120px, 30vw, 280px); opacity: 1; }
    }


    /* ===================================================
       SECTION 2 — "Wie ich arbeite"
    =================================================== */
    .treatments {
      padding: 6rem 2rem 7rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .section-label {
      font-family: var(--font-body);
      font-weight: 500;
      font-size: 0.8rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      text-align: center;
      margin-bottom: 1rem;
    }

    .section-title {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      text-align: center;
      color: var(--text);
      margin-bottom: 4rem;
      line-height: 1.3;
    }

    .treatments-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .treatment-card {
      background: var(--secondary);
      border-radius: 24px;
      padding: 2.5rem 2rem;
      transition: transform 0.4s ease, box-shadow 0.4s ease;
    }

    .treatment-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(74, 124, 111, 0.08);
    }

    /* Asymmetric offsets */
    .treatment-card:nth-child(1) { margin-top: 0; }
    .treatment-card:nth-child(2) { margin-top: 3rem; }
    .treatment-card:nth-child(3) { margin-top: -1rem; }
    .treatment-card:nth-child(4) { margin-top: 2rem; }

    .treatment-icon {
      width: 44px;
      height: 44px;
      margin-bottom: 1.5rem;
    }

    .treatment-icon svg {
      width: 100%;
      height: 100%;
    }

    /* Alternating accent colors */
    .treatment-card:nth-child(odd) .treatment-icon svg {
      stroke: var(--primary);
    }

    .treatment-card:nth-child(even) .treatment-icon svg {
      stroke: var(--accent);
    }

    .treatment-title {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: 1.3rem;
      color: var(--text);
      margin-bottom: 0.4rem;
    }

    .treatment-desc {
      font-size: 0.92rem;
      color: var(--text);
      opacity: 0.7;
      line-height: 1.6;
    }


    /* ===================================================
       SECTION 3 — "Ueber mich"
    =================================================== */
    .about {
      padding: 5rem 2rem 6rem;
      background: var(--secondary);
    }

    .about-inner {
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 4rem;
      align-items: center;
    }

    .about-portrait-wrap {
      position: relative;
    }

    .about-portrait {
      width: 220px;
      height: 220px;
      border-radius: 50%;
      object-fit: cover;
      box-shadow: 0 16px 48px rgba(74, 124, 111, 0.1);
    }

    .about-portrait-ring {
      position: absolute;
      top: -10px;
      left: -10px;
      width: 240px;
      height: 240px;
      border-radius: 50%;
      border: 1px solid var(--accent);
      opacity: 0.4;
    }

    .about-content {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .about-name {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: 1.6rem;
      color: var(--text);
    }

    .about-quote {
      font-family: var(--font-display);
      font-weight: 300;
      font-style: italic;
      font-size: 1.15rem;
      line-height: 1.7;
      color: var(--primary);
      border-left: 2px solid var(--accent);
      padding-left: 1.5rem;
    }

    .about-bio {
      font-size: 0.95rem;
      line-height: 1.8;
      color: var(--text);
      opacity: 0.8;
    }

    .about-contact {
      font-size: 0.9rem;
      color: var(--text);
      opacity: 0.65;
      padding-top: 0.5rem;
      border-top: 1px solid rgba(74, 124, 111, 0.15);
      line-height: 1.8;
    }


    /* ===================================================
       SCROLL REVEAL
    =================================================== */
    .scroll-reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .scroll-reveal.in-view {
      opacity: 1;
      transform: translateY(0);
    }

    /* Staggered treatment cards */
    .treatment-card.scroll-reveal:nth-child(1) { transition-delay: 0s; }
    .treatment-card.scroll-reveal:nth-child(2) { transition-delay: 0.1s; }
    .treatment-card.scroll-reveal:nth-child(3) { transition-delay: 0.2s; }
    .treatment-card.scroll-reveal:nth-child(4) { transition-delay: 0.3s; }


    /* ===================================================
       ANIMATIONS
    =================================================== */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Breathing animation on hero headline — very subtle */
    @keyframes breatheHeadline {
      0%, 100% { transform: scale(1); }
      50%       { transform: scale(1.002); }
    }

    @keyframes breathe {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.03); }
    }

    .hero-brand {
      animation: fadeInUp 1s ease both;
    }

    .hero-circle-wrap {
      animation: fadeInUp 1.2s ease 0.2s both;
    }

    .hero-circle {
      animation: breathe 6s ease-in-out infinite;
    }

    .hero-headline {
      animation: fadeInUp 1s ease 0.5s both, breatheHeadline 4s ease-in-out 1.5s infinite;
    }

    .hero-subline {
      animation: fadeInUp 1s ease 0.7s both;
    }

    .hero-meta {
      animation: fadeInUp 1s ease 0.9s both;
    }

    .hero-link {
      animation: fadeInUp 1s ease 1.1s both;
    }


    /* ===================================================
       RESPONSIVE
    =================================================== */
    @media (max-width: 768px) {
      .hero {
        padding: 4rem 1.5rem;
        min-height: auto;
        padding-top: 5rem;
        padding-bottom: 5rem;
      }

      .hero-circle {
        width: 160px;
        height: 160px;
      }

      .hero-arc {
        width: 80px;
        height: 35px;
        bottom: -30px;
      }

      .treatments {
        padding: 4rem 1.5rem 5rem;
      }

      .treatments-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .treatment-card:nth-child(n) {
        margin-top: 0;
      }

      .about-inner {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 2.5rem;
      }

      .about-portrait-wrap {
        display: flex;
        justify-content: center;
      }

      .about-portrait {
        width: 180px;
        height: 180px;
      }

      .about-portrait-ring {
        width: 200px;
        height: 200px;
      }

      .about-quote {
        border-left: none;
        padding-left: 0;
        border-top: 2px solid var(--accent);
        padding-top: 1.2rem;
      }
    }

    @media (max-width: 480px) {
      .hero-headline {
        font-size: 1.7rem;
      }

      .hero-subline {
        font-size: 1.05rem;
      }

      .treatment-card {
        padding: 2rem 1.5rem;
      }
    }
  </style>
</head>

<body>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <p class="hero-brand">Quellstein</p>

    <div class="hero-circle-wrap">
      <img
        class="hero-circle"
        src="https://images.unsplash.com/photo-1600618528240-fb9fc964b853?w=600&q=80&auto=format"
        alt="Naturheilpraxis Quellstein — Behandlungsraum"
        loading="eager"
      />
      <svg class="hero-arc" viewBox="0 0 120 50" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 5 Q60 55 110 5" stroke="#C4956A" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.6" />
      </svg>
    </div>

    <h1 class="hero-headline">Heilung braucht Zeit.</h1>
    <p class="hero-subline">Und die richtigen Haende.</p>

    <p class="hero-meta">
      Naturheilpraxis<span>&middot;</span>Trier<span>&middot;</span>Termine nach Vereinbarung
    </p>

    <a href="#leistungen" class="hero-link">Leistungen ansehen &rarr;</a>

    <div class="hero-divider"></div>
  </section>


  <!-- ===== SECTION 2 — Wie ich arbeite ===== -->
  <section class="treatments" id="leistungen">
    <p class="section-label scroll-reveal">Leistungen</p>
    <h2 class="section-title scroll-reveal">Wie ich arbeite</h2>

    <div class="treatments-grid">

      <div class="treatment-card scroll-reveal">
        <div class="treatment-icon">
          <svg viewBox="0 0 44 44" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <circle cx="22" cy="14" r="4" />
            <path d="M22 18v10" />
            <path d="M16 22h12" />
            <path d="M18 28c0 4 2 6 4 6s4-2 4-6" />
            <path d="M14 10c-2 2-3 5-3 8 0 8 5 14 11 16 6-2 11-8 11-16 0-3-1-6-3-8" />
          </svg>
        </div>
        <h3 class="treatment-title">Akupunktur</h3>
        <p class="treatment-desc">Traditionelle Chinesische Medizin</p>
      </div>

      <div class="treatment-card scroll-reveal">
        <div class="treatment-icon">
          <svg viewBox="0 0 44 44" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <path d="M22 36V20" />
            <path d="M22 20c-3-4-8-5-8 0s5 4 8 0z" />
            <path d="M22 20c3-4 8-5 8 0s-5 4-8 0z" />
            <path d="M22 28c-4 0-7-1-7 2s3 4 7 2" />
            <path d="M22 28c4 0 7-1 7 2s-3 4-7 2" />
            <path d="M18 36h8" />
            <circle cx="22" cy="12" r="3" />
          </svg>
        </div>
        <h3 class="treatment-title">Phytotherapie</h3>
        <p class="treatment-desc">Heilpflanzen & Tinkturen</p>
      </div>

      <div class="treatment-card scroll-reveal">
        <div class="treatment-icon">
          <svg viewBox="0 0 44 44" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 28c0-6 4-10 10-14" />
            <path d="M32 28c0-6-4-10-10-14" />
            <circle cx="22" cy="10" r="3" />
            <path d="M16 32c0-2 3-4 6-4s6 2 6 4" />
            <path d="M14 36h16" />
            <path d="M18 32v4" />
            <path d="M26 32v4" />
          </svg>
        </div>
        <h3 class="treatment-title">Manuelle Therapie</h3>
        <p class="treatment-desc">Faszienarbeit & Mobilisation</p>
      </div>

      <div class="treatment-card scroll-reveal">
        <div class="treatment-icon">
          <svg viewBox="0 0 44 44" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="22" cy="18" rx="10" ry="7" />
            <path d="M16 23c-2 2-3 5-3 8h18c0-3-1-6-3-8" />
            <path d="M19 14v-2a3 3 0 0 1 6 0v2" />
            <path d="M22 18v6" />
            <path d="M18 21l4 3 4-3" />
          </svg>
        </div>
        <h3 class="treatment-title">Ernaehrungsberatung</h3>
        <p class="treatment-desc">Ganzheitlich, individuell</p>
      </div>

    </div>
  </section>


  <!-- ===== SECTION 3 — Ueber mich ===== -->
  <section class="about">
    <div class="about-inner scroll-reveal">

      <div class="about-portrait-wrap">
        <div class="about-portrait-ring"></div>
        <img
          class="about-portrait"
          src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=500&q=80&auto=format"
          alt="Dr. Lena Wirth, Naturheilpraktikerin"
          loading="lazy"
        />
      </div>

      <div class="about-content">
        <h2 class="about-name">Dr. Lena Wirth</h2>

        <blockquote class="about-quote">
          Schulmedizin hat mir gezeigt, was moeglich ist.<br />
          Die Naturheilkunde hat mir gezeigt, was noetig ist.
        </blockquote>

        <p class="about-bio">
          15 Jahre Erfahrung in der Naturheilkunde. Studium der Medizin in Freiburg, Fortbildung in Traditioneller Chinesischer Medizin in Beijing. Seit 2012 eigene Praxis in Trier.
        </p>

        <p class="about-contact">
          Termine: 0651 &mdash; 445 22 10<br />
          Sprechzeiten: Mo, Mi, Fr 9&ndash;17 Uhr
        </p>
      </div>

    </div>
  </section>

  <script>
    // ===== INTERSECTION OBSERVER — scroll reveal =====
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.scroll-reveal').forEach((el) => {
      revealObserver.observe(el);
    });
  </script>

</body>
</html>
