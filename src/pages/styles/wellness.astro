---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Sanara — Yoga & Meditation in Trier</title>
  <meta name="description" content="Sanara ist ein Yoga- und Meditationsstudio in Trier-Altstadt. Hatha, Vinyasa, Yin Yoga, Meditation. Wo du wirklich ankommst." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible+Next:ital,wght@0,400;0,500;0,700;1,400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400;1,9..144,500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --sage:       #4A7C6F;
      --sage-dark:  #2D4A41;
      --sage-deep:  #1E3530;
      --sage-light: #EBF0EC;
      --cream:      #F5F0E8;
      --terra:      #C4956A;
      --terra-pale: #E8D5C0;
      --bg:         #FAFAF5;
      --ink:        #2D3B35;
      --muted:      #6B7D76;
      --font-d: "Fraunces", Georgia, serif;
      --font-b: "Atkinson Hyperlegible Next", system-ui, sans-serif;
    }

    html {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--font-b);
      -webkit-font-smoothing: antialiased;
      scroll-behavior: smooth;
      overflow-x: hidden;
    }

    body { overflow-x: hidden; line-height: 1.7; }
    img  { display: block; max-width: 100%; }
    a    { color: inherit; text-decoration: none; }
    ::selection { background: var(--sage); color: var(--cream); }


    /* ─── HERO ─────────────────────────────────────────── */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
    }

    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(4rem, 7vw, 7rem) clamp(2.5rem, 5vw, 5rem);
      position: relative;
      z-index: 2;
    }

    .hero-overline {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--terra);
      margin-bottom: 2.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      animation: fadeUp 1s ease both;
    }
    .hero-overline::before {
      content: '';
      width: 32px; height: 1px;
      background: var(--terra);
      opacity: 0.6;
    }

    .hero-headline {
      font-family: var(--font-d);
      font-weight: 300;
      font-size: clamp(3rem, 5.5vw, 5.2rem);
      line-height: 1.08;
      color: var(--ink);
      margin-bottom: 0.15em;
      animation: fadeUp 1s ease 0.2s both;
    }
    .hero-headline em {
      font-style: italic;
      color: var(--sage);
    }

    .hero-sub {
      font-family: var(--font-d);
      font-style: italic;
      font-weight: 300;
      font-size: clamp(1.05rem, 1.8vw, 1.3rem);
      color: var(--muted);
      line-height: 1.65;
      max-width: 38ch;
      margin-top: 1.75rem;
      margin-bottom: 3rem;
      animation: fadeUp 1s ease 0.4s both;
    }

    .hero-ctas {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      align-items: center;
      animation: fadeUp 1s ease 0.6s both;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: var(--sage);
      color: var(--cream);
      font-size: 0.88rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      padding: 0.85rem 2rem;
      border-radius: 100px;
      transition: background 0.3s, transform 0.3s;
    }
    .btn-primary:hover { background: var(--sage-dark); transform: translateY(-2px); }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--sage);
      font-size: 0.88rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      padding-bottom: 2px;
      border-bottom: 1px solid var(--terra);
      transition: color 0.3s;
    }
    .btn-ghost:hover { color: var(--terra); }

    .hero-stats {
      margin-top: 4.5rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(74,124,111,0.15);
      display: flex;
      gap: 2.5rem;
      animation: fadeUp 1s ease 0.8s both;
    }
    .stat-num {
      font-family: var(--font-d);
      font-size: 1.6rem;
      color: var(--sage);
      display: block;
    }
    .stat-label {
      font-size: 0.72rem;
      color: var(--muted);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .hero-right {
      position: relative;
      overflow: hidden;
    }
    .hero-img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
    }
    .hero-fade {
      position: absolute; inset: 0;
      background: linear-gradient(to right, var(--bg) 0%, transparent 28%);
      z-index: 1;
    }

    .scroll-hint {
      position: absolute;
      bottom: 2rem;
      left: calc(50% - 12px);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      z-index: 3;
    }
    .scroll-hint-line {
      width: 1px; height: 40px;
      background: linear-gradient(to bottom, var(--terra), transparent);
      animation: linePulse 2s ease-in-out infinite;
    }
    @keyframes linePulse {
      0%,100% { opacity: 0.5; transform: scaleY(1); }
      50%      { opacity: 1;   transform: scaleY(0.6); }
    }


    /* ─── PHILOSOPHIE ───────────────────────────────────── */
    .philosophy {
      background: var(--sage-deep);
      padding: clamp(5rem, 10vw, 10rem) clamp(2rem, 6vw, 6rem);
      position: relative;
      overflow: hidden;
    }
    .philosophy::after {
      content: '';
      position: absolute;
      bottom: -200px; right: -200px;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(74,124,111,0.18) 0%, transparent 70%);
    }

    .phil-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 5rem;
      align-items: start;
    }

    .aside-num {
      font-family: var(--font-d);
      font-size: 0.88rem;
      color: var(--terra);
      margin-bottom: 0.6rem;
    }
    .aside-label {
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(245,240,232,0.4);
    }

    .phil-quote {
      font-family: var(--font-d);
      font-style: italic;
      font-weight: 300;
      font-size: clamp(1.9rem, 4vw, 3.6rem);
      line-height: 1.28;
      color: var(--cream);
      margin-bottom: 2.5rem;
    }
    .phil-quote strong {
      font-weight: 500;
      font-style: normal;
      color: var(--terra);
    }

    .phil-body {
      font-size: 0.98rem;
      line-height: 1.85;
      color: rgba(245,240,232,0.6);
      max-width: 58ch;
      margin-bottom: 3rem;
    }

    .phil-pillars {
      display: flex;
      gap: 2.5rem;
      flex-wrap: wrap;
    }
    .pillar-name {
      font-family: var(--font-d);
      font-style: italic;
      font-size: 1.05rem;
      color: var(--cream);
    }
    .pillar-sep {
      font-size: 0.78rem;
      color: var(--terra);
      opacity: 0.6;
      display: block;
      margin-bottom: 0.25rem;
    }


    /* ─── KURSPLAN ──────────────────────────────────────── */
    .kursplan {
      padding: clamp(5rem, 8vw, 8rem) clamp(2rem, 5vw, 5rem);
    }
    .kursplan-inner { max-width: 1200px; margin: 0 auto; }

    .sec-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 3.5rem;
      gap: 2rem;
    }
    .sec-num {
      font-family: var(--font-d);
      font-size: 0.82rem;
      color: var(--terra);
      margin-bottom: 0.4rem;
    }
    .sec-title {
      font-family: var(--font-d);
      font-weight: 400;
      font-size: clamp(1.9rem, 3.5vw, 2.8rem);
      color: var(--ink);
      line-height: 1.15;
    }
    .sec-title em { font-style: italic; color: var(--sage); }
    .sec-link {
      font-size: 0.84rem;
      font-weight: 500;
      color: var(--sage);
      border-bottom: 1px solid var(--terra);
      padding-bottom: 2px;
      white-space: nowrap;
      transition: color 0.3s;
    }
    .sec-link:hover { color: var(--terra); }

    .kurs-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .kurs-card {
      background: var(--cream);
      border-radius: 20px;
      padding: 2rem 1.75rem;
      position: relative;
      overflow: hidden;
      transition: transform 0.4s ease, box-shadow 0.4s ease;
    }
    .kurs-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(to right, var(--sage), var(--terra));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.4s ease;
    }
    .kurs-card:hover { transform: translateY(-6px); box-shadow: 0 20px 60px rgba(45,74,65,0.08); }
    .kurs-card:hover::before { transform: scaleX(1); }

    .kurs-tag {
      display: block;
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--terra);
      margin-bottom: 0.75rem;
    }
    .kurs-name {
      font-family: var(--font-d);
      font-weight: 400;
      font-size: 1.35rem;
      color: var(--ink);
      margin-bottom: 0.5rem;
    }
    .kurs-desc {
      font-size: 0.87rem;
      color: var(--muted);
      line-height: 1.65;
      margin-bottom: 1.5rem;
    }
    .kurs-meta {
      display: flex;
      gap: 1.25rem;
      flex-wrap: wrap;
      margin-bottom: 1rem;
    }
    .kurs-meta-item {
      display: flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.78rem;
      color: var(--muted);
    }
    .kurs-meta-item svg {
      width: 13px; height: 13px;
      stroke: var(--sage);
      flex-shrink: 0;
      fill: none;
      stroke-width: 1.5;
      stroke-linecap: round;
    }
    .kurs-dots {
      display: flex;
      gap: 4px;
      padding-top: 1rem;
      border-top: 1px solid rgba(74,124,111,0.1);
    }
    .dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--sage-light);
    }
    .dot.on { background: var(--sage); }


    /* ─── LEHRER ────────────────────────────────────────── */
    .lehrer {
      background: var(--cream);
      padding: clamp(5rem, 8vw, 8rem) clamp(2rem, 5vw, 5rem);
    }
    .lehrer-inner { max-width: 1200px; margin: 0 auto; }

    .lehrer-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-top: 3.5rem;
    }
    .lehrer-card:nth-child(2) { margin-top: 3rem; }

    .lehrer-img-wrap {
      position: relative;
      overflow: hidden;
      border-radius: 16px;
      aspect-ratio: 3/4;
      margin-bottom: 1.5rem;
    }
    .lehrer-img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .lehrer-img-wrap:hover .lehrer-img { transform: scale(1.05); }
    .lehrer-img-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(30,53,48,0.5) 0%, transparent 50%);
    }
    .lehrer-badge {
      position: absolute;
      bottom: 1rem; left: 1rem;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--cream);
      background: rgba(74,124,111,0.75);
      backdrop-filter: blur(8px);
      padding: 0.3rem 0.75rem;
      border-radius: 100px;
    }
    .lehrer-name {
      font-family: var(--font-d);
      font-weight: 400;
      font-size: 1.35rem;
      color: var(--ink);
      margin-bottom: 0.2rem;
    }
    .lehrer-spec {
      font-family: var(--font-d);
      font-style: italic;
      font-weight: 300;
      font-size: 0.95rem;
      color: var(--sage);
      margin-bottom: 0.75rem;
    }
    .lehrer-bio {
      font-size: 0.87rem;
      color: var(--muted);
      line-height: 1.7;
    }


    /* ─── RÄUME ─────────────────────────────────────────── */
    .raeume {
      padding: clamp(5rem, 8vw, 8rem) clamp(2rem, 5vw, 5rem);
    }
    .raeume-inner { max-width: 1200px; margin: 0 auto; }

    .raeume-grid {
      display: grid;
      grid-template-columns: 1.35fr 1fr;
      gap: 1.5rem;
      margin-top: 3.5rem;
    }

    .raum-card {
      position: relative;
      border-radius: 20px;
      overflow: hidden;
    }
    .raum-tall { aspect-ratio: 4/5; }
    .raum-stack {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .raum-stack .raum-card { min-height: 220px; flex: 1; }

    .raum-img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .raum-card:hover .raum-img { transform: scale(1.04); }
    .raum-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(30,53,48,0.75) 0%, transparent 55%);
    }
    .raum-info {
      position: absolute;
      bottom: 1.5rem; left: 1.5rem; right: 1.5rem;
      z-index: 2;
    }
    .raum-title {
      font-family: var(--font-d);
      font-size: 1.15rem;
      color: var(--cream);
      margin-bottom: 0.2rem;
    }
    .raum-sub {
      font-size: 0.78rem;
      color: rgba(245,240,232,0.7);
    }


    /* ─── BOOKING ───────────────────────────────────────── */
    .booking {
      background: var(--sage);
      padding: clamp(5rem, 8vw, 8rem) clamp(2rem, 5vw, 5rem);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .booking::before {
      content: '';
      position: absolute;
      top: -180px; left: 50%; transform: translateX(-50%);
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(245,240,232,0.07) 0%, transparent 70%);
    }
    .booking-overline {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--terra-pale);
      margin-bottom: 1.5rem;
    }
    .booking-headline {
      font-family: var(--font-d);
      font-style: italic;
      font-weight: 300;
      font-size: clamp(2.2rem, 4.5vw, 3.8rem);
      color: var(--cream);
      line-height: 1.2;
      margin-bottom: 1.5rem;
    }
    .booking-sub {
      font-size: 0.97rem;
      color: rgba(245,240,232,0.65);
      max-width: 48ch;
      margin: 0 auto 3rem;
      line-height: 1.75;
    }
    .booking-btns {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn-cream {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: var(--cream);
      color: var(--sage-dark);
      font-size: 0.88rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      padding: 0.9rem 2.2rem;
      border-radius: 100px;
      transition: background 0.3s, transform 0.3s;
    }
    .btn-cream:hover { background: var(--bg); transform: translateY(-2px); }

    .btn-outline {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: transparent;
      color: var(--cream);
      font-size: 0.88rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      padding: 0.9rem 2.2rem;
      border-radius: 100px;
      border: 1px solid rgba(245,240,232,0.35);
      transition: border-color 0.3s, background 0.3s;
    }
    .btn-outline:hover { border-color: var(--cream); background: rgba(245,240,232,0.08); }

    .booking-contact {
      margin-top: 3rem;
      font-size: 0.84rem;
      color: rgba(245,240,232,0.45);
    }
    .booking-contact a {
      color: rgba(245,240,232,0.7);
      border-bottom: 1px solid rgba(245,240,232,0.2);
      transition: color 0.3s;
    }
    .booking-contact a:hover { color: var(--cream); }


    /* ─── REVEAL ────────────────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .reveal.in { opacity: 1; transform: translateY(0); }
    .d1 { transition-delay: 0.1s; }
    .d2 { transition-delay: 0.2s; }
    .d3 { transition-delay: 0.3s; }
    .d4 { transition-delay: 0.4s; }
    .d5 { transition-delay: 0.5s; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }


    /* ─── RESPONSIVE ────────────────────────────────────── */
    @media (max-width: 1024px) {
      .hero {
        grid-template-columns: 1fr;
        min-height: auto;
      }
      .hero-right { height: 55vw; position: relative; }
      .hero-fade { background: linear-gradient(to top, var(--bg) 0%, transparent 30%); }
      .hero-left { padding-top: 4rem; padding-bottom: 2rem; }
      .scroll-hint { display: none; }
      .phil-inner { grid-template-columns: 1fr; gap: 1.5rem; }
      .kurs-grid { grid-template-columns: 1fr 1fr; }
      .lehrer-grid { grid-template-columns: 1fr 1fr; }
      .lehrer-card:nth-child(3) { display: none; }
      .lehrer-card:nth-child(2) { margin-top: 0; }
      .raeume-grid { grid-template-columns: 1fr; }
      .raum-tall { aspect-ratio: 16/9; }
      .raum-stack { flex-direction: row; }
    }

    @media (max-width: 768px) {
      .kurs-grid { grid-template-columns: 1fr; }
      .lehrer-grid { grid-template-columns: 1fr; }
      .lehrer-card:nth-child(2) { margin-top: 0; }
      .lehrer-card:nth-child(3) { display: flex; }
      .sec-header { flex-direction: column; align-items: flex-start; }
      .hero-stats { gap: 1.5rem; }
      .raum-stack { flex-direction: column; }
    }

    @media (max-width: 480px) {
      .hero-ctas { flex-direction: column; align-items: flex-start; }
      .booking-btns { flex-direction: column; align-items: center; }
    }
  </style>
</head>

<body>

  <!-- ═══ HERO ═══════════════════════════════════════════ -->
  <section class="hero">

    <div class="hero-left">
      <p class="hero-overline">Sanara &mdash; Trier, Altstadt</p>

      <h1 class="hero-headline">
        Finde dein<br/>
        <em>Gleichgewicht.</em>
      </h1>

      <p class="hero-sub">
        Ein Studio für Menschen, die ankommen möchten. Ohne Lärm, ohne Druck &mdash; nur du, dein Atem und die Stille.
      </p>

      <div class="hero-ctas">
        <a href="#kursplan" class="btn-primary">Kursplan entdecken</a>
        <a href="#buchung" class="btn-ghost">Probeklasse buchen &rarr;</a>
      </div>

      <div class="hero-stats">
        <div>
          <span class="stat-num">12</span>
          <span class="stat-label">Kurse wöchentlich</span>
        </div>
        <div>
          <span class="stat-num">3</span>
          <span class="stat-label">Unterrichtsräume</span>
        </div>
        <div>
          <span class="stat-num">seit 2014</span>
          <span class="stat-label">In Trier verwurzelt</span>
        </div>
      </div>
    </div>

    <div class="hero-right">
      <img
        class="hero-img"
        src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=900&h=1200&q=85"
        alt="Yoga in der Natur"
        loading="eager"
      />
      <div class="hero-fade"></div>
    </div>

    <div class="scroll-hint">
      <div class="scroll-hint-line"></div>
      <span>Scroll</span>
    </div>

  </section>


  <!-- ═══ PHILOSOPHIE ════════════════════════════════════ -->
  <section class="philosophy">
    <div class="phil-inner">

      <div>
        <p class="aside-num">01</p>
        <p class="aside-label">Philosophie</p>
      </div>

      <div>
        <blockquote class="phil-quote reveal">
          &bdquo;Yoga ist nicht das Ziel &mdash;<br/>
          es ist der <strong>Weg zurück</strong><br/>
          zu dir selbst.&ldquo;
        </blockquote>

        <p class="phil-body reveal d1">
