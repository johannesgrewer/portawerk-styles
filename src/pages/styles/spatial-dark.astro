---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Aura — Sound Healing & Meditationsstudio | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;600&family=Plus+Jakarta+Sans:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --violet: #A78BFA;
      --sky:    #38BDF8;
      --bg:     #0A0A12;
      --mid:    #0D0D18;
      --text:   #E2E0F0;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Plus Jakarta Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Deep ambient orbs */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 60% at 30% 20%, rgba(167,139,250,0.09) 0%, transparent 60%),
        radial-gradient(ellipse 50% 70% at 75% 70%, rgba(56,189,248,0.07) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 3rem;
      background: rgba(10,10,18,0.7);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(167,139,250,0.1);
    }
    .nav-logo {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 1.15rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      background: linear-gradient(90deg, var(--violet), var(--sky));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.62rem;
      font-weight: 300;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(226,224,240,0.35);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--violet); }
    .nav-book {
      font-size: 0.6rem;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--violet);
      padding: 0.6rem 1.4rem;
      border-radius: 100px;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .nav-book:hover { opacity: 0.85; }

    .hero {
      min-height: 100vh;
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 8rem 3rem 4rem;
      gap: 3rem;
      text-align: center;
    }

    .eyebrow {
      font-size: 0.58rem;
      font-weight: 300;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(226,224,240,0.35);
    }

    .hero-headline {
      font-family: 'Outfit', sans-serif;
      font-weight: 300;
      font-size: clamp(2.8rem, 6vw, 5.5rem);
      line-height: 1.15;
      letter-spacing: -0.02em;
      max-width: 16ch;
    }
    .hero-headline strong {
      font-weight: 600;
      background: linear-gradient(90deg, var(--violet), var(--sky));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.9;
      color: rgba(226,224,240,0.45);
      max-width: 48ch;
    }

    /* Floating glass cards */
    .cards-row {
      display: flex;
      gap: 1rem;
      width: 100%;
      max-width: 820px;
    }
    .glass-card {
      flex: 1;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 1.5rem;
      backdrop-filter: blur(10px);
      text-align: left;
      transition: background 0.3s, border-color 0.3s;
    }
    .glass-card:hover {
      background: rgba(167,139,250,0.07);
      border-color: rgba(167,139,250,0.2);
    }
    .gc-icon {
      font-size: 1.4rem;
      margin-bottom: 0.75rem;
    }
    .gc-title {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--text);
      margin-bottom: 0.35rem;
    }
    .gc-desc {
      font-size: 0.68rem;
      font-weight: 300;
      line-height: 1.6;
      color: rgba(226,224,240,0.4);
    }
    .gc-badge {
      display: inline-block;
      font-size: 0.5rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.2rem 0.6rem;
      border-radius: 100px;
      margin-top: 0.75rem;
    }
    .badge-violet { color: var(--violet); background: rgba(167,139,250,0.12); border: 1px solid rgba(167,139,250,0.2); }
    .badge-sky    { color: var(--sky);    background: rgba(56,189,248,0.1);   border: 1px solid rgba(56,189,248,0.2); }
    .badge-dim    { color: rgba(226,224,240,0.4); background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 2rem;
    }
    .cta-btn {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--bg);
      background: linear-gradient(90deg, var(--violet), var(--sky));
      text-decoration: none;
      padding: 0.9rem 2.25rem;
      border-radius: 100px;
      box-shadow: 0 4px 20px rgba(167,139,250,0.25);
      transition: opacity 0.2s, box-shadow 0.2s;
    }
    .cta-btn:hover { opacity: 0.9; box-shadow: 0 8px 28px rgba(167,139,250,0.35); }
    .cta-link {
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(226,224,240,0.3);
      text-decoration: none;
    }

    /* Stats glass bar */
    .stats-bar {
      display: flex;
      gap: 0;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 12px;
      overflow: hidden;
      width: 100%;
      max-width: 580px;
    }
    .stat-item {
      flex: 1;
      padding: 1.2rem 1.5rem;
      border-right: 1px solid rgba(255,255,255,0.06);
      text-align: center;
    }
    .stat-item:last-child { border-right: none; }
    .stat-num {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 1.4rem;
      line-height: 1;
      background: linear-gradient(90deg, var(--violet), var(--sky));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .stat-label {
      font-size: 0.52rem;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(226,224,240,0.3);
      margin-top: 0.2rem;
    }

    /* Photo container */
    .ph { position: relative; overflow: hidden; }
    .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
    .ph:hover img { transform: scale(1.05); }

    /* Angebote section */
    .section-angebote {
      padding: 7rem 3rem;
      background: var(--mid);
      max-width: 1600px;
      margin: 0 auto;
    }
    .s-label {
      font-size: 0.58rem;
      font-weight: 300;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(226,224,240,0.3);
      margin-bottom: 0.75rem;
    }
    .s-heading {
      font-family: 'Outfit', sans-serif;
      font-weight: 300;
      font-size: clamp(2rem, 4vw, 3.5rem);
      line-height: 1.15;
      letter-spacing: -0.02em;
      color: var(--text);
      margin-bottom: 3.5rem;
    }
    .s-heading strong {
      font-weight: 600;
      background: linear-gradient(90deg, var(--violet), var(--sky));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .angebote-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    .angebot-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px;
      overflow: hidden;
      transition: border-color 0.3s;
    }
    .angebot-card:hover { border-color: rgba(167,139,250,0.2); }
    .angebot-body {
      padding: 1.75rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .angebot-title {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 1.1rem;
      color: var(--text);
    }
    .angebot-desc {
      font-size: 0.75rem;
      font-weight: 300;
      line-height: 1.7;
      color: rgba(226,224,240,0.45);
    }
    .angebot-price {
      display: inline-block;
      font-size: 0.55rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.25rem 0.75rem;
      border-radius: 100px;
      color: var(--violet);
      background: rgba(167,139,250,0.12);
      border: 1px solid rgba(167,139,250,0.2);
      margin-top: 0.25rem;
      width: fit-content;
    }

    /* Retreat section */
    .section-retreat {
      padding: 7rem 3rem;
      background: var(--bg);
      max-width: 1600px;
      margin: 0 auto;
    }
    .retreat-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .retreat-text {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .retreat-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.9;
      color: rgba(226,224,240,0.5);
      max-width: 44ch;
    }
    .retreat-details {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .rd-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.65rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      font-size: 0.78rem;
    }
    .rd-key { font-weight: 300; color: rgba(226,224,240,0.35); }
    .rd-val { font-weight: 400; color: var(--text); }
    .retreat-cta {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--bg);
      background: linear-gradient(90deg, var(--violet), var(--sky));
      text-decoration: none;
      padding: 0.9rem 2.25rem;
      border-radius: 100px;
      box-shadow: 0 4px 20px rgba(167,139,250,0.25);
      display: inline-block;
      transition: opacity 0.2s;
    }
    .retreat-cta:hover { opacity: 0.9; }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Aura</div>
    <ul class="nav-links">
      <li><a href="#">Angebote</a></li>
      <li><a href="#">Klangbäder</a></li>
      <li><a href="#">Retreat</a></li>
      <li><a href="#">Über uns</a></li>
    </ul>
    <a href="#" class="nav-book">Session buchen</a>
  </nav>

  <section class="hero">
    <div class="eyebrow">Sound Healing & Meditation · Trier</div>

    <h1 class="hero-headline">
      Klang, der<br>
      <strong>Räume öffnet.</strong>
    </h1>

    <p class="hero-body">
      Klangbäder, geführte Meditationen, Atemarbeit —
      für Menschen, die ihren Körper wieder spüren wollen.
      Kein Esoterik-Kitsch. Nur Wirkung.
    </p>

    <div class="cards-row">
      <div class="glass-card">
        <div class="gc-icon">🔔</div>
        <div class="gc-title">Klangbad</div>
        <div class="gc-desc">Tibetische Klangschalen & Gongs. 60 Minuten tiefe Entspannung.</div>
        <div class="gc-badge badge-violet">75 €</div>
      </div>
      <div class="glass-card">
        <div class="gc-icon">🌬️</div>
        <div class="gc-title">Atemarbeit</div>
        <div class="gc-desc">Breathwork-Session für Stressabbau und Klarheit.</div>
        <div class="gc-badge badge-sky">90 €</div>
      </div>
      <div class="glass-card">
        <div class="gc-icon">🧘</div>
        <div class="gc-title">Meditation</div>
        <div class="gc-desc">Geführte Einzel- oder Gruppenmeditation, 45–90 Min.</div>
        <div class="gc-badge badge-dim">ab 45 €</div>
      </div>
    </div>

    <div class="cta-row">
      <a href="#" class="cta-btn">Session buchen →</a>
      <a href="#" class="cta-link">Alle Angebote →</a>
    </div>

    <div class="stats-bar">
      <div class="stat-item">
        <div class="stat-num">400+</div>
        <div class="stat-label">Teilnehmer</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">5 Jahre</div>
        <div class="stat-label">Erfahrung</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">4.9 ★</div>
        <div class="stat-label">Bewertung</div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Angebote -->
  <div style="background:var(--mid); position:relative; z-index:1;">
    <section class="section-angebote">
      <div class="s-label">Angebote</div>
      <h2 class="s-heading">Wähle deinen<br><strong>Weg nach innen.</strong></h2>
      <div class="angebote-grid">
        <div class="angebot-card">
          <div class="ph" style="height:240px;">
            <img src="https://images.unsplash.com/photo-1545389336-cf090694435e?auto=format&fit=crop&w=800&h=600&q=80" alt="Klangbad Session" loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,18,0.7) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
          <div class="angebot-body">
            <div class="angebot-title">Klangbad</div>
            <div class="angebot-desc">Tibetische Klangschalen, Gongs und Stimmgabeln. 60 Minuten tiefe Entspannung im Gruppenrahmen — maximal 12 Personen.</div>
            <div class="angebot-price">75 € / Person</div>
          </div>
        </div>
        <div class="angebot-card">
          <div class="ph" style="height:240px;">
            <img src="https://images.unsplash.com/photo-1506277886164-e25aa3f4ef7f?auto=format&fit=crop&w=800&h=600&q=80" alt="Atemarbeit" loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,18,0.7) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
          <div class="angebot-body">
            <div class="angebot-title">Atemarbeit</div>
            <div class="angebot-desc">Transformative Breathwork-Sessions für Stressabbau, mentale Klarheit und emotionale Verarbeitung. Einzel oder Gruppe.</div>
            <div class="angebot-price">90 € / Session</div>
          </div>
        </div>
        <div class="angebot-card">
          <div class="ph" style="height:240px;">
            <img src="https://images.unsplash.com/photo-1512621776951-a57141f2eefd?auto=format&fit=crop&w=800&h=600&q=80" alt="Meditation" loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,18,0.7) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
          <div class="angebot-body">
            <div class="angebot-title">Meditation</div>
            <div class="angebot-desc">Geführte Einzel- und Gruppenmeditationen, 45–90 Min. Verschiedene Techniken: Vipassana, Body Scan, Visualisierung.</div>
            <div class="angebot-price">ab 45 € / Person</div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- SECTION 3: Retreat & Kontakt -->
  <div style="background:var(--bg); position:relative; z-index:1;">
    <section class="section-retreat">
      <div class="retreat-inner">
        <div class="retreat-text">
          <div class="s-label">Wochenend-Retreat</div>
          <h2 class="s-heading" style="margin-bottom:0;">Zwei Tage.<br><strong>Echter Wandel.</strong></h2>
          <p class="retreat-body">
            Unser Retreat-Format verbindet Klangarbeit, Atemübungen und stille Meditation
            zu einem intensiven Wochenende. Kleine Gruppen, persönliche Begleitung,
            tief in der Eifel.
          </p>
          <div class="retreat-details">
            <div class="rd-row">
              <span class="rd-key">Nächster Termin</span>
              <span class="rd-val">12.–13. April 2026</span>
            </div>
            <div class="rd-row">
              <span class="rd-key">Ort</span>
              <span class="rd-val">Landhaus Steinborn, Eifel</span>
            </div>
            <div class="rd-row">
              <span class="rd-key">Teilnehmer</span>
              <span class="rd-val">Max. 10 Personen</span>
            </div>
            <div class="rd-row">
              <span class="rd-key">Preis</span>
              <span class="rd-val">320 € inkl. Unterkunft & Verpflegung</span>
            </div>
          </div>
          <a href="#" class="retreat-cta">Platz reservieren →</a>
        </div>
        <div class="ph" style="height:520px; border-radius:20px;">
          <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?auto=format&fit=crop&w=800&h=1000&q=80" alt="Retreat in der Natur" loading="lazy" />
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,18,0.45) 0%,transparent 60%);pointer-events:none;"></div>
        </div>
      </div>
    </section>
  </div>

</body>
</html>
