---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Aura — Sound Healing & Meditationsstudio | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;600&family=Plus+Jakarta+Sans:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --violet: #A78BFA;
      --sky:    #38BDF8;
      --bg:     #0A0A12;
      --mid:    #0D0D18;
      --text:   #E2E0F0;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Plus Jakarta Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Deep ambient orbs */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 60% at 30% 20%, rgba(167,139,250,0.09) 0%, transparent 60%),
        radial-gradient(ellipse 50% 70% at 75% 70%, rgba(56,189,248,0.07) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 3rem;
      background: rgba(10,10,18,0.7);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(167,139,250,0.1);
    }
    .nav-logo {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 1.15rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      background: linear-gradient(90deg, var(--violet), var(--sky));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.62rem;
      font-weight: 300;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(226,224,240,0.35);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--violet); }
    .nav-book {
      font-size: 0.6rem;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--violet);
      padding: 0.6rem 1.4rem;
      border-radius: 100px;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .nav-book:hover { opacity: 0.85; }

    .hero {
      min-height: 100vh;
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 8rem 3rem 4rem;
      gap: 3rem;
      text-align: center;
    }

    .eyebrow {
      font-size: 0.58rem;
      font-weight: 300;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(226,224,240,0.35);
    }

    .hero-headline {
      font-family: 'Outfit', sans-serif;
      font-weight: 300;
      font-size: clamp(2.8rem, 6vw, 5.5rem);
      line-height: 1.15;
      letter-spacing: -0.02em;
      max-width: 16ch;
    }
    .hero-headline strong {
      font-weight: 600;
      background: linear-gradient(90deg, var(--violet), var(--sky));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.9;
      color: rgba(226,224,240,0.45);
      max-width: 48ch;
    }

    /* Floating glass cards */
    .cards-row {
      display: flex;
      gap: 1rem;
      width: 100%;
      max-width: 820px;
    }
    .glass-card {
      flex: 1;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 1.5rem;
      backdrop-filter: blur(10px);
      text-align: left;
      transition: background 0.3s, border-color 0.3s;
    }
    .glass-card:hover {
      background: rgba(167,139,250,0.07);
      border-color: rgba(167,139,250,0.2);
    }
    .gc-icon {
      font-size: 1.4rem;
      margin-bottom: 0.75rem;
    }
    .gc-title {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--text);
      margin-bottom: 0.35rem;
    }
    .gc-desc {
      font-size: 0.68rem;
      font-weight: 300;
      line-height: 1.6;
      color: rgba(226,224,240,0.4);
    }
    .gc-badge {
      display: inline-block;
      font-size: 0.5rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.2rem 0.6rem;
      border-radius: 100px;
      margin-top: 0.75rem;
    }
    .badge-violet { color: var(--violet); background: rgba(167,139,250,0.12); border: 1px solid rgba(167,139,250,0.2); }
    .badge-sky    { color: var(--sky);    background: rgba(56,189,248,0.1);   border: 1px solid rgba(56,189,248,0.2); }
    .badge-dim    { color: rgba(226,224,240,0.4); background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 2rem;
    }
    .cta-btn {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--bg);
      background: linear-gradient(90deg, var(--violet), var(--sky));
      text-decoration: none;
      padding: 0.9rem 2.25rem;
      border-radius: 100px;
      box-shadow: 0 4px 20px rgba(167,139,250,0.25);
      transition: opacity 0.2s, box-shadow 0.2s;
    }
    .cta-btn:hover { opacity: 0.9; box-shadow: 0 8px 28px rgba(167,139,250,0.35); }
    .cta-link {
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(226,224,240,0.3);
      text-decoration: none;
    }

    /* Stats glass bar */
    .stats-bar {
      display: flex;
      gap: 0;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 12px;
      overflow: hidden;
      width: 100%;
      max-width: 580px;
    }
    .stat-item {
      flex: 1;
      padding: 1.2rem 1.5rem;
      border-right: 1px solid rgba(255,255,255,0.06);
      text-align: center;
    }
    .stat-item:last-child { border-right: none; }
    .stat-num {
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 1.4rem;
      line-height: 1;
      background: linear-gradient(90deg, var(--violet), var(--sky));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .stat-label {
      font-size: 0.52rem;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(226,224,240,0.3);
      margin-top: 0.2rem;
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Aura</div>
    <ul class="nav-links">
      <li><a href="#">Angebote</a></li>
      <li><a href="#">Klangbäder</a></li>
      <li><a href="#">Retreat</a></li>
      <li><a href="#">Über uns</a></li>
    </ul>
    <a href="#" class="nav-book">Session buchen</a>
  </nav>

  <section class="hero">
    <div class="eyebrow">Sound Healing & Meditation · Trier</div>

    <h1 class="hero-headline">
      Klang, der<br>
      <strong>Räume öffnet.</strong>
    </h1>

    <p class="hero-body">
      Klangbäder, geführte Meditationen, Atemarbeit —
      für Menschen, die ihren Körper wieder spüren wollen.
      Kein Esoterik-Kitsch. Nur Wirkung.
    </p>

    <div class="cards-row">
      <div class="glass-card">
        <div class="gc-icon">🔔</div>
        <div class="gc-title">Klangbad</div>
        <div class="gc-desc">Tibetische Klangschalen & Gongs. 60 Minuten tiefe Entspannung.</div>
        <div class="gc-badge badge-violet">75 €</div>
      </div>
      <div class="glass-card">
        <div class="gc-icon">🌬️</div>
        <div class="gc-title">Atemarbeit</div>
        <div class="gc-desc">Breathwork-Session für Stressabbau und Klarheit.</div>
        <div class="gc-badge badge-sky">90 €</div>
      </div>
      <div class="glass-card">
        <div class="gc-icon">🧘</div>
        <div class="gc-title">Meditation</div>
        <div class="gc-desc">Geführte Einzel- oder Gruppenmeditation, 45–90 Min.</div>
        <div class="gc-badge badge-dim">ab 45 €</div>
      </div>
    </div>

    <div class="cta-row">
      <a href="#" class="cta-btn">Session buchen →</a>
      <a href="#" class="cta-link">Alle Angebote →</a>
    </div>

    <div class="stats-bar">
      <div class="stat-item">
        <div class="stat-num">400+</div>
        <div class="stat-label">Teilnehmer</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">5 Jahre</div>
        <div class="stat-label">Erfahrung</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">4.9 ★</div>
        <div class="stat-label">Bewertung</div>
      </div>
    </div>
  </section>
</body>
</html>
