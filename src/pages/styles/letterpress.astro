---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Drucksatz — Letterpress Atelier | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { background: #F7F3EC; overflow-x: hidden; }

    :root {
      --ink:     #1C1A17;
      --red:     #8B1A1A;
      --gold:    #B8860B;
      --paper:   #F7F3EC;
      --aged:    #EDE7D9;
      --warm:    #C4A882;
      --muted:   rgba(28,26,23,0.45);
      --rule:    rgba(28,26,23,0.12);
    }

    body {
      background: var(--paper);
      color: var(--ink);
      font-family: 'EB Garamond', serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: repeating-linear-gradient(
        0deg,
        transparent, transparent 27px,
        rgba(28,26,23,0.025) 27px, rgba(28,26,23,0.025) 28px
      );
      pointer-events: none;
      z-index: 0;
    }

    /* ─── Nav ─────────────────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.25rem 4rem;
      background: var(--paper);
      border-bottom: 2px solid var(--ink);
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-weight: 700; font-size: 1.2rem;
      letter-spacing: 0.06em; color: var(--ink);
    }
    .nav-links { display: flex; gap: 3rem; list-style: none; }
    .nav-links a {
      font-family: 'EB Garamond', serif;
      font-size: 0.85rem; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--muted);
      text-decoration: none; transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--red); }
    .nav-cta {
      font-size: 0.8rem; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--paper);
      background: var(--ink); padding: 0.6rem 1.6rem;
      text-decoration: none; transition: background 0.2s;
    }
    .nav-cta:hover { background: var(--red); }

    /* ─── Hero ────────────────────────────────────────────── */
    .hero {
      min-height: 100vh;
      padding-top: 64px;
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .hero-left {
      display: flex; flex-direction: column;
      justify-content: center;
      padding: 5rem 4rem 5rem 4.5rem;
      gap: 2.5rem;
      border-right: 2px solid var(--ink);
    }

    .eyebrow {
      font-size: 0.75rem; font-weight: 500;
      letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--red);
    }

    .hero-headline {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-size: clamp(2.8rem, 4.5vw, 4.5rem);
      line-height: 1.15; letter-spacing: 0.01em;
    }
    .hero-headline em {
      font-style: italic; color: var(--red); font-weight: 400;
    }

    .hero-rule { width: 3rem; height: 2px; background: var(--ink); }

    .hero-body {
      font-size: 1.05rem; line-height: 1.85;
      color: var(--muted); max-width: 42ch;
    }

    .service-list { display: flex; flex-direction: column; border-top: 1px solid var(--rule); }
    .service-row {
      display: flex; align-items: baseline;
      justify-content: space-between;
      padding: 0.85rem 0; border-bottom: 1px solid var(--rule);
    }
    .sr-name {
      font-family: 'Playfair Display', serif;
      font-size: 1rem; font-style: italic;
    }
    .sr-detail { font-size: 0.78rem; letter-spacing: 0.08em; color: var(--muted); }

    .cta-row { display: flex; align-items: center; gap: 2rem; }
    .cta-btn {
      font-size: 0.82rem; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--paper);
      background: var(--ink); text-decoration: none;
      padding: 0.9rem 2.2rem; transition: background 0.2s;
    }
    .cta-btn:hover { background: var(--red); }
    .cta-link {
      font-size: 0.85rem; font-style: italic;
      color: var(--muted); text-decoration: none;
      border-bottom: 1px solid var(--rule);
    }

    .hero-right {
      background: var(--aged);
      display: flex; flex-direction: column;
      padding: 5rem 4rem; gap: 3rem;
    }

    .specimen { display: flex; flex-direction: column; gap: 0.5rem; }
    .specimen-label {
      font-size: 0.65rem; letter-spacing: 0.3em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 0.25rem;
    }
    .specimen-line {
      font-family: 'Playfair Display', serif;
      line-height: 1; letter-spacing: -0.01em;
    }
    .sl-xl { font-size: 5rem; font-weight: 700; }
    .sl-lg { font-size: 3rem; font-weight: 400; font-style: italic; }
    .sl-md { font-size: 1.8rem; font-weight: 700; }
    .sl-sm { font-size: 1.1rem; font-weight: 400; letter-spacing: 0.05em; }

    .divider { width: 100%; height: 1px; background: rgba(28,26,23,0.15); }

    .swatch-row { display: flex; gap: 0.75rem; }
    .swatch-label {
      font-size: 0.65rem; letter-spacing: 0.25em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 0.6rem;
    }
    .swatch {
      flex: 1; height: 60px; border-radius: 2px;
      border: 1px solid rgba(28,26,23,0.12);
      display: flex; align-items: flex-end; padding: 0.3rem 0.4rem;
    }
    .swatch span { font-size: 0.5rem; letter-spacing: 0.1em; text-transform: uppercase; }
    .sw-cotton { background: #fff; }
    .sw-cotton span { color: var(--muted); }
    .sw-natural { background: #F7F3EC; }
    .sw-natural span { color: var(--muted); }
    .sw-aged { background: #EDE7D9; }
    .sw-aged span { color: var(--muted); }
    .sw-kraft { background: #C4A882; }
    .sw-kraft span { color: rgba(255,255,255,0.7); }

    .info-block { background: var(--ink); padding: 1.75rem; }
    .ib-label {
      font-size: 0.6rem; letter-spacing: 0.25em;
      text-transform: uppercase; color: rgba(247,243,236,0.4);
      margin-bottom: 0.5rem;
    }
    .ib-value {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem; color: var(--paper); line-height: 1.5;
    }
    .ib-sub { font-size: 0.78rem; color: rgba(247,243,236,0.5); margin-top: 0.3rem; }

    /* ─── Section 2: Editionen ───────────────────────────── */
    .editionen {
      background: var(--ink);
      padding: 7rem 4.5rem;
      position: relative; z-index: 1;
      border-top: 2px solid var(--ink);
    }

    .sec-header {
      display: flex; align-items: baseline;
      justify-content: space-between; margin-bottom: 4rem;
    }
    .sec-eyebrow {
      font-size: 0.65rem; letter-spacing: 0.3em;
      text-transform: uppercase; color: var(--red); margin-bottom: 0.4rem;
    }
    .sec-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 3.5vw, 3rem);
      font-weight: 700; color: var(--paper);
      line-height: 1.1;
    }
    .sec-title em { font-style: italic; font-weight: 400; color: var(--warm); }
    .sec-count {
      font-family: 'Playfair Display', serif;
      font-size: 4rem; font-weight: 900; line-height: 1;
      color: rgba(247,243,236,0.06); letter-spacing: -0.04em;
      user-select: none;
    }

    .edition-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }

    .edition-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(247,243,236,0.07);
      overflow: hidden;
      transition: border-color 0.3s;
    }
    .edition-card:hover { border-color: rgba(247,243,236,0.2); }

    /* CSS Art area */
    .edition-art {
      height: 280px;
      position: relative;
      overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }

    /* Card 1: Hochzeitskarte */
    .art-wedding { background: #1a1714; }
    .wedding-paper {
      width: 220px; height: 160px;
      background: var(--aged);
      position: relative;
      box-shadow:
        0 0 0 1px rgba(139,26,26,0.25),
        0 2px 0 1px rgba(139,26,26,0.12),
        0 20px 50px rgba(0,0,0,0.6),
        inset 0 1px 0 rgba(255,255,255,0.4);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 0.35rem;
    }
    .wedding-paper::before {
      content: '';
      position: absolute; inset: 10px;
      border: 1px solid rgba(139,26,26,0.3);
    }
    .wedding-paper::after {
      content: '';
      position: absolute; inset: 14px;
      border: 1px solid rgba(139,26,26,0.15);
    }
    .wp-year {
      font-family: 'EB Garamond', serif;
      font-size: 0.5rem; letter-spacing: 0.35em;
      text-transform: uppercase; color: rgba(139,26,26,0.6);
      position: relative; z-index: 1;
    }
    .wp-names {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem; font-style: italic; font-weight: 400;
      color: var(--ink); line-height: 1.2; text-align: center;
      position: relative; z-index: 1;
    }
    .wp-rule {
      width: 40px; height: 1px;
      background: var(--red); position: relative; z-index: 1;
    }
    .wp-date {
      font-family: 'EB Garamond', serif;
      font-size: 0.55rem; letter-spacing: 0.2em;
      color: rgba(28,26,23,0.55); position: relative; z-index: 1;
    }
    /* Floating card behind */
    .wedding-back {
      position: absolute;
      width: 220px; height: 160px;
      background: #F7F3EC;
      transform: rotate(-6deg) translateY(8px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

    /* Card 2: Visitenkarten-Stack */
    .art-bizcard { background: #141210; }
    .biz-stack {
      position: relative;
      width: 200px; height: 115px;
    }
    .biz-card {
      position: absolute;
      width: 200px; height: 115px;
      background: var(--paper);
      box-shadow: 0 4px 20px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.5);
      display: flex; flex-direction: column;
      justify-content: space-between;
      padding: 14px 16px;
    }
    .biz-card:nth-child(1) {
      transform: rotate(-5deg) translateY(12px) translateX(-6px);
      background: var(--aged); z-index: 1;
    }
    .biz-card:nth-child(2) {
      transform: rotate(-2deg) translateY(5px) translateX(-2px);
      background: var(--paper); z-index: 2;
    }
    .biz-card:nth-child(3) {
      transform: rotate(0deg);
      background: #fff; z-index: 3;
      box-shadow: 0 8px 30px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.6);
    }
    .bc-name {
      font-family: 'Playfair Display', serif;
      font-size: 0.8rem; font-weight: 700; letter-spacing: 0.04em;
      color: var(--ink);
    }
    .bc-title {
      font-size: 0.5rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--muted);
    }
    .bc-bottom { display: flex; justify-content: space-between; align-items: flex-end; }
    .bc-mark {
      font-family: 'Playfair Display', serif;
      font-size: 1rem; font-style: italic; color: var(--red); opacity: 0.4;
    }
    .bc-contact {
      font-size: 0.4rem; letter-spacing: 0.1em;
      color: rgba(28,26,23,0.35); text-align: right; line-height: 1.6;
    }

    /* Card 3: Kunstdruck */
    .art-poster { background: var(--red); }
    .poster-inner {
      width: 180px; height: 240px;
      background: var(--paper);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 0; padding: 1.5rem 1rem;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      position: relative;
    }
    .poster-inner::before {
      content: '';
      position: absolute; inset: 8px;
      border: 1px solid rgba(28,26,23,0.12);
    }
    .poster-letter {
      font-family: 'Playfair Display', serif;
      font-size: 7rem; font-weight: 900;
      line-height: 0.85; color: var(--ink);
      letter-spacing: -0.04em;
    }
    .poster-rule {
      width: 60%; height: 2px;
      background: var(--red); margin: 0.75rem 0;
    }
    .poster-sub {
      font-size: 0.45rem; letter-spacing: 0.4em;
      text-transform: uppercase; color: var(--muted); text-align: center;
    }
    .poster-num {
      position: absolute; bottom: 1.2rem; right: 1.2rem;
      font-size: 0.45rem; letter-spacing: 0.15em; color: var(--muted);
    }

    .edition-info { padding: 1.75rem 2rem 2rem; }
    .ei-cat {
      font-size: 0.6rem; letter-spacing: 0.28em;
      text-transform: uppercase; color: var(--warm);
      margin-bottom: 0.5rem;
    }
    .ei-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem; font-style: italic;
      color: var(--paper); margin-bottom: 0.4rem;
    }
    .ei-desc {
      font-size: 0.78rem; line-height: 1.7;
      color: rgba(247,243,236,0.4);
    }
    .ei-tag {
      display: inline-block; margin-top: 1rem;
      font-size: 0.58rem; letter-spacing: 0.18em;
      text-transform: uppercase; color: rgba(247,243,236,0.3);
      border: 1px solid rgba(247,243,236,0.1);
      padding: 0.3rem 0.7rem;
    }

    /* Bottom band */
    .editionen-band {
      display: grid; grid-template-columns: repeat(4, 1fr);
      margin-top: 4rem;
      border-top: 1px solid rgba(247,243,236,0.08);
    }
    .band-item {
      padding: 2rem 0 0;
      border-right: 1px solid rgba(247,243,236,0.06);
    }
    .band-item:last-child { border-right: none; padding-right: 0; }
    .band-label {
      font-size: 0.58rem; letter-spacing: 0.25em;
      text-transform: uppercase; color: rgba(247,243,236,0.3);
      margin-bottom: 0.35rem;
    }
    .band-value {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem; font-style: italic;
      color: rgba(247,243,236,0.7);
    }

    /* ─── Section 3: Werkstatt & Weg ───────────────────────── */
    .werkstatt {
      background: var(--aged);
      padding: 7rem 4.5rem;
      position: relative; z-index: 1;
      border-top: 2px solid var(--ink);
    }

    .ws-inner {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }

    /* Left: Process steps */
    .ws-left {}
    .ws-eyebrow {
      font-size: 0.65rem; letter-spacing: 0.3em;
      text-transform: uppercase; color: var(--red); margin-bottom: 0.5rem;
    }
    .ws-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      font-weight: 700; line-height: 1.15; margin-bottom: 3rem;
    }
    .ws-title em { font-style: italic; color: var(--red); font-weight: 400; }

    .process-steps {
      display: flex; flex-direction: column;
      gap: 0; position: relative;
    }
    .process-steps::before {
      content: '';
      position: absolute; left: 20px; top: 0; bottom: 0;
      width: 1px; background: var(--rule);
    }
    .step {
      display: flex; gap: 1.75rem; align-items: flex-start;
      padding: 1.5rem 0 1.5rem 0;
      border-bottom: 1px solid var(--rule);
      position: relative;
    }
    .step:last-child { border-bottom: none; }
    .step-num {
      flex-shrink: 0;
      width: 40px; height: 40px;
      background: var(--paper);
      border: 1px solid var(--ink);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Playfair Display', serif;
      font-size: 1rem; font-weight: 700; color: var(--ink);
      position: relative; z-index: 1;
    }
    .step-body {}
    .step-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem; font-weight: 700; margin-bottom: 0.35rem;
    }
    .step-desc {
      font-size: 0.85rem; line-height: 1.7; color: var(--muted);
    }

    /* Right: Materials + Press info */
    .ws-right {
      display: flex; flex-direction: column; gap: 3rem; padding-top: 4.5rem;
    }

    .material-block {}
    .mat-head {
      font-size: 0.65rem; letter-spacing: 0.28em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 1.2rem;
    }
    .mat-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1px; background: var(--rule);
      border: 1px solid var(--rule);
    }
    .mat-cell {
      background: var(--paper); padding: 1.1rem 1.25rem;
      display: flex; gap: 1rem; align-items: center;
    }
    .mat-swatch {
      width: 36px; height: 36px; flex-shrink: 0;
      border: 1px solid rgba(28,26,23,0.12);
    }
    .mat-info {}
    .mat-name {
      font-family: 'Playfair Display', serif;
      font-size: 0.85rem; font-style: italic; margin-bottom: 0.15rem;
    }
    .mat-detail { font-size: 0.68rem; color: var(--muted); letter-spacing: 0.04em; }

    /* Press manifesto block */
    .press-block {
      background: var(--ink); padding: 2.5rem;
      position: relative; overflow: hidden;
    }
    .press-block::before {
      content: '"';
      position: absolute; top: -1rem; left: 1.5rem;
      font-family: 'Playfair Display', serif;
      font-size: 8rem; font-style: italic; font-weight: 900;
      color: rgba(247,243,236,0.05); line-height: 1;
      user-select: none;
    }
    .pb-quote {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem; font-style: italic;
      color: var(--paper); line-height: 1.65;
      margin-bottom: 1.5rem; position: relative; z-index: 1;
    }
    .pb-author {
      display: flex; align-items: center; gap: 1rem;
      position: relative; z-index: 1;
    }
    .pb-rule { width: 24px; height: 1px; background: var(--red); }
    .pb-name {
      font-size: 0.72rem; letter-spacing: 0.12em;
      color: rgba(247,243,236,0.5); text-transform: uppercase;
    }

    /* Hours / Contact strip */
    .contact-strip {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1px; background: rgba(28,26,23,0.12);
      border: 1px solid var(--rule);
    }
    .cs-cell {
      background: var(--aged); padding: 1.25rem 1.5rem;
    }
    .cs-label {
      font-size: 0.58rem; letter-spacing: 0.25em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 0.4rem;
    }
    .cs-value {
      font-family: 'Playfair Display', serif;
      font-size: 0.95rem; color: var(--ink); line-height: 1.5;
    }

    /* ─── Animations ──────────────────────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-left > * {
      animation: fadeUp 0.7s ease both;
    }
    .hero-left > *:nth-child(1) { animation-delay: 0.1s; }
    .hero-left > *:nth-child(2) { animation-delay: 0.2s; }
    .hero-left > *:nth-child(3) { animation-delay: 0.3s; }
    .hero-left > *:nth-child(4) { animation-delay: 0.4s; }
    .hero-left > *:nth-child(5) { animation-delay: 0.5s; }
    .hero-left > *:nth-child(6) { animation-delay: 0.6s; }

    @keyframes slideIn {
      from { opacity: 0; transform: translateX(20px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    .hero-right > * {
      animation: slideIn 0.8s ease both;
    }
    .hero-right > *:nth-child(1) { animation-delay: 0.3s; }
    .hero-right > *:nth-child(2) { animation-delay: 0.45s; }
    .hero-right > *:nth-child(3) { animation-delay: 0.6s; }
    .hero-right > *:nth-child(4) { animation-delay: 0.75s; }
    .hero-right > *:nth-child(5) { animation-delay: 0.9s; }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Drucksatz</div>
    <ul class="nav-links">
      <li><a href="#">Arbeiten</a></li>
      <li><a href="#">Drucke</a></li>
      <li><a href="#">Papier</a></li>
      <li><a href="#">Atelier</a></li>
    </ul>
    <a href="#" class="nav-cta">Projekt anfragen</a>
  </nav>

  <!-- ── Section 1: Hero ─────────────────────────────────── -->
  <section class="hero">
    <div class="hero-left">
      <div class="eyebrow">Letterpress Atelier · Trier</div>

      <h1 class="hero-headline">
        Gedruckt.<br>
        Gepresst.<br>
        <em>Unverwechselbar.</em>
      </h1>

      <div class="hero-rule"></div>

      <p class="hero-body">
        Jeder Druck hinterlässt eine Spur im Papier —
        buchstäblich. Wir arbeiten mit historischen Pressen
        und modernem Anspruch für Projekte, die man anfassen will.
      </p>

      <div class="service-list">
        <div class="service-row">
          <span class="sr-name">Visitenkarten & Kurzwaren</span>
          <span class="sr-detail">ab 150 Stück</span>
        </div>
