      opacity: 0;
      transform: translateY(32px);
      transition: opacity 0.75s ease, transform 0.75s ease;
    }
    .fade-up.in { opacity: 1; transform: translateY(0); }
    .d1 { transition-delay: 0.1s; }
    .d2 { transition-delay: 0.2s; }
    .d3 { transition-delay: 0.3s; }
  </style>
</head>
