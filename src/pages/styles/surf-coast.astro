---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Wellenritt — Surfschule & Stand-up-Paddle | Mosel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cabin+Condensed:wght@400;700&family=Work+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --ocean: #0891B2;
      --sand:  #F59E0B;
      --teal:  #0E7490;
      --bg:    #F0F9FF;
      --dark:  #0C2D48;
      --muted: rgba(12,45,72,0.5);
    }

    body {
      background: var(--bg);
      color: var(--dark);
      font-family: 'Work Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Wave decoration at bottom */
    body::after {
      content: '';
      position: fixed;
      bottom: 0; left: 0; right: 0;
      height: 6px;
      background: linear-gradient(90deg,
        var(--ocean) 0%, var(--teal) 33%, var(--ocean) 66%, var(--sand) 100%);
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 3rem;
      background: rgba(240,249,255,0.95);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid rgba(8,145,178,0.15);
    }
    .nav-logo {
      font-family: 'Cabin Condensed', sans-serif;
      font-weight: 700;
      font-size: 1.3rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--ocean);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--ocean); }
    .nav-book {
      font-family: 'Cabin Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #fff;
      background: var(--ocean);
      padding: 0.65rem 1.5rem;
      text-decoration: none;
      border-radius: 4px;
      transition: background 0.2s;
    }
    .nav-book:hover { background: var(--teal); }

    .hero {
      min-height: 100vh;
      padding-top: 60px;
      display: grid;
      grid-template-columns: 1fr 400px;
    }

    /* LEFT */
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 4rem 4rem 4.5rem;
      gap: 2.5rem;
    }

    .eyebrow {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--ocean);
    }
    .eyebrow-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--sand);
    }

    .hero-headline {
      font-family: 'Cabin Condensed', sans-serif;
      font-weight: 700;
      font-size: clamp(3rem, 7vw, 6rem);
      line-height: 0.95;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      color: var(--dark);
    }
    .hero-headline .ocean { color: var(--ocean); }
    .hero-headline .sand { color: var(--sand); }

    .hero-body {
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 1.9;
      color: var(--muted);
      max-width: 44ch;
    }

    /* Course grid */
    .course-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.6rem;
    }
    .course-card {
      background: #fff;
      border: 1px solid rgba(8,145,178,0.12);
      border-radius: 10px;
      padding: 1.1rem;
      border-top: 3px solid var(--ocean);
      transition: border-top-color 0.2s, box-shadow 0.2s;
    }
    .course-card:hover {
      border-top-color: var(--sand);
      box-shadow: 0 4px 16px rgba(8,145,178,0.1);
    }
    .cc-name {
      font-family: 'Cabin Condensed', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--dark);
    }
    .cc-desc {
      font-size: 0.68rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 0.2rem;
      line-height: 1.5;
    }
    .cc-price {
      font-family: 'Cabin Condensed', sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--ocean);
      margin-top: 0.6rem;
    }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .cta-btn {
      font-family: 'Cabin Condensed', sans-serif;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #fff;
      background: var(--ocean);
      padding: 0.9rem 2rem;
      border-radius: 4px;
      text-decoration: none;
      transition: background 0.2s;
    }
    .cta-btn:hover { background: var(--teal); }
    .cta-link {
      font-size: 0.65rem;
      font-weight: 400;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid rgba(12,45,72,0.2);
      padding-bottom: 1px;
    }

    /* RIGHT — ocean panel */
    .hero-right {
      background: var(--ocean);
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .right-header {
      padding: 3rem 2.5rem 1.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .rh-label {
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      margin-bottom: 0.4rem;
    }
    .rh-value {
      font-family: 'Cabin Condensed', sans-serif;
      font-size: 1.8rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #fff;
      line-height: 1;
    }

    /* Conditions list */
    .conditions-list {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .cond-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.1rem 2.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .cond-icon { font-size: 1.2rem; flex-shrink: 0; }
    .cond-info { flex: 1; }
    .cond-name {
      font-size: 0.82rem;
      font-weight: 500;
      color: rgba(255,255,255,0.85);
    }
    .cond-val {
      font-size: 0.65rem;
      font-weight: 300;
      color: rgba(255,255,255,0.45);
      margin-top: 0.1rem;
    }
    .cond-status {
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.2rem 0.55rem;
      border-radius: 100px;
    }
    .status-green { background: rgba(16,185,129,0.2); color: #34d399; }
    .status-yellow { background: rgba(245,158,11,0.2); color: #fbbf24; }

    /* Seasonal schedule */
    .schedule-block {
      padding: 1.5rem 2.5rem;
      background: rgba(0,0,0,0.15);
      border-top: 1px solid rgba(255,255,255,0.1);
    }
    .sb-label {
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 0.75rem;
    }
    .sb-months {
      display: flex;
      gap: 0.3rem;
    }
    .sb-month {
      flex: 1;
      text-align: center;
      font-size: 0.5rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 0.3rem 0;
      border-radius: 3px;
      color: rgba(255,255,255,0.35);
      background: rgba(255,255,255,0.06);
    }
    .sb-month.active {
      background: var(--sand);
      color: var(--dark);
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Wellenritt</div>
    <ul class="nav-links">
      <li><a href="#">Kurse</a></li>
      <li><a href="#">Verleih</a></li>
      <li><a href="#">Touren</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <a href="#" class="nav-book">Kurs buchen</a>
  </nav>

  <section class="hero">
    <div class="hero-left">
      <div class="eyebrow">
        <span class="eyebrow-dot"></span>
        Surfschule & SUP · Mosel / Trier
      </div>

      <h1 class="hero-headline">
        <span class="ocean">Wellen</span><br>
        findest<br>
        du<br>
        <span class="sand">überall.</span>
      </h1>

      <p class="hero-body">
        Surfstunden auf der Mosel? Klingt verrückt.
        Ist es auch. Genau deshalb lieben wir es.
        Von Anfänger bis Fortgeschrittener — wir bringen
        dich aufs Brett.
      </p>

      <div class="course-grid">
        <div class="course-card">
          <div class="cc-name">Surfen Beginner</div>
          <div class="cc-desc">2 Stunden Einführung, Leihboard</div>
          <div class="cc-price">ab 49 €</div>
        </div>
        <div class="course-card">
          <div class="cc-name">SUP Basics</div>
          <div class="cc-desc">Stand-up-Paddle, Einzel oder Gruppe</div>
          <div class="cc-price">ab 35 €</div>
        </div>
        <div class="course-card">
          <div class="cc-name">Mosel-Tour</div>
          <div class="cc-desc">Geführte Paddel-Tour, 3 Stunden</div>
          <div class="cc-price">ab 65 €</div>
        </div>
        <div class="course-card">
          <div class="cc-name">Board Verleih</div>
          <div class="cc-desc">Tagesmiete, alle Größen</div>
          <div class="cc-price">ab 25 €</div>
        </div>
      </div>

      <div class="cta-row">
        <a href="#" class="cta-btn">Kurs buchen →</a>
        <a href="#" class="cta-link">Alle Kurse ansehen</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="right-header">
        <div class="rh-label">Aktuelle Bedingungen</div>
        <div class="rh-value">Mosel · Trier</div>
      </div>

      <div class="conditions-list">
        <div class="cond-row">
          <span class="cond-icon">🌊</span>
          <div class="cond-info">
            <div class="cond-name">Wellenhöhe</div>
            <div class="cond-val">0,4 – 0,6 m · ideal für Anfänger</div>
          </div>
          <span class="cond-status status-green">Gut</span>
        </div>
        <div class="cond-row">
          <span class="cond-icon">💨</span>
          <div class="cond-info">
            <div class="cond-name">Wind</div>
            <div class="cond-val">14 km/h · SW</div>
          </div>
          <span class="cond-status status-green">Ideal</span>
        </div>
        <div class="cond-row">
          <span class="cond-icon">🌡</span>
          <div class="cond-info">
            <div class="cond-name">Wassertemperatur</div>
            <div class="cond-val">16 °C · Neopren empfohlen</div>
          </div>
          <span class="cond-status status-yellow">OK</span>
        </div>
        <div class="cond-row">
          <span class="cond-icon">☀️</span>
          <div class="cond-info">
            <div class="cond-name">Wetter heute</div>
            <div class="cond-val">22 °C · sonnig</div>
          </div>
          <span class="cond-status status-green">Top</span>
        </div>
      </div>

      <div class="schedule-block">
        <div class="sb-label">Saison</div>
        <div class="sb-months">
          <div class="sb-month">Jan</div>
          <div class="sb-month">Feb</div>
          <div class="sb-month">Mär</div>
          <div class="sb-month active">Apr</div>
          <div class="sb-month active">Mai</div>
          <div class="sb-month active">Jun</div>
          <div class="sb-month active">Jul</div>
          <div class="sb-month active">Aug</div>
          <div class="sb-month active">Sep</div>
          <div class="sb-month active">Okt</div>
          <div class="sb-month">Nov</div>
          <div class="sb-month">Dez</div>
        </div>
      </div>
    </div>
  </section>
</body>
</html>
