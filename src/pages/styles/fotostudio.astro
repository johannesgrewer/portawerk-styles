---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Frame — Portrait & Kommerzielle Fotografie | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,300;0,700;0,900;1,300&family=Spectral:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }
    body {
      overflow-x: hidden;
      background: #FAFAF9;
      color: #0A0A0A;
      font-family: 'Spectral', serif;
      min-height: 100vh;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.6rem 3rem;
      mix-blend-mode: normal;
    }
    .nav-logo {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1.6rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #0A0A0A;
    }
    .nav-logo span { color: #B8860B; }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 300;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(10, 10, 10, 0.5);
      text-decoration: none;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: #0A0A0A; }

    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 52% 48%;
    }

    /* LEFT — photo with aperture reveal */
    .hero-photo {
      position: relative;
      background: #0A0A0A;
      overflow: hidden;
    }

    .photo-reveal {
      position: absolute;
      inset: 0;
      clip-path: inset(100% 0 0 0);
      animation: revealPhoto 1.2s cubic-bezier(0.76, 0, 0.24, 1) 0.3s forwards;
    }
    @keyframes revealPhoto {
      from { clip-path: inset(100% 0 0 0); }
      to   { clip-path: inset(0% 0 0 0); }
    }
    .photo-reveal img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
    }

    /* Gold frame accent lines */
    .photo-line-h {
      position: absolute;
      left: 2rem; right: 2rem;
      height: 1px;
      background: #B8860B;
      opacity: 0;
      animation: growH 0.8s ease 1.4s forwards;
    }
    .photo-line-h.top { top: 2rem; }
    .photo-line-h.bottom { bottom: 2rem; }
    @keyframes growH {
      from { width: 0; opacity: 0; margin: 0 auto; }
      to   { opacity: 0.6; }
    }

    /* Photo caption */
    .photo-caption {
      position: absolute;
      bottom: 3rem;
      left: 2rem;
      right: 2rem;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      opacity: 0;
      animation: fadeIn 0.8s ease 1.5s forwards;
    }
    .caption-title {
      font-family: 'Spectral', serif;
      font-style: italic;
      font-size: 0.78rem;
      color: rgba(250, 250, 249, 0.65);
      letter-spacing: 0.04em;
    }
    .caption-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 300;
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      color: #B8860B;
    }

    /* Aperture circle decorations */
    .aperture-ring {
      position: absolute;
      border-radius: 50%;
      border: 1px solid rgba(184, 134, 11, 0.25);
      pointer-events: none;
    }
    .ap-1 { width: 80px; height: 80px; top: 3rem; left: 3rem; }
    .ap-2 { width: 40px; height: 40px; top: 4.5rem; left: 4.5rem; border-color: rgba(184, 134, 11, 0.4); }

    /* RIGHT — text */
    .hero-text {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 7rem 5rem 5rem 5rem;
      position: relative;
      border-left: 1px solid rgba(10, 10, 10, 0.06);
    }

    .eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 300;
      font-size: 0.68rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: #B8860B;
      margin-bottom: 2rem;
      opacity: 0;
      animation: up 0.7s ease 0.5s forwards;
    }

    .headline {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(5rem, 9vw, 11rem);
      line-height: 0.88;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      color: #0A0A0A;
      margin-bottom: 2.5rem;
    }
    .headline .ln {
      display: block;
      overflow: hidden;
    }
    .headline .ln span {
      display: block;
      opacity: 0;
      animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .headline .ln:nth-child(1) span { animation-delay: 0.6s; }
    .headline .ln:nth-child(2) span {
      animation-delay: 0.78s;
      color: #B8860B;
    }

    .meta-line {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 2.5rem;
      opacity: 0;
      animation: up 0.7s ease 1.1s forwards;
    }
    .meta-dash { width: 24px; height: 1px; background: rgba(10, 10, 10, 0.2); }
    .meta-text {
      font-family: 'Spectral', serif;
      font-style: italic;
      font-size: 0.9rem;
      color: rgba(10, 10, 10, 0.5);
      letter-spacing: 0.02em;
    }

    .desc {
      font-family: 'Spectral', serif;
      font-size: 0.95rem;
      line-height: 1.85;
      color: rgba(10, 10, 10, 0.6);
      max-width: 360px;
      margin-bottom: 3rem;
      opacity: 0;
      animation: up 0.7s ease 1.25s forwards;
    }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      margin-bottom: 4rem;
      opacity: 0;
      animation: up 0.7s ease 1.4s forwards;
    }
    .btn-main {
      background: #0A0A0A;
      color: #FAFAF9;
      border: none;
      padding: 0.9rem 2.2rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      transition: background 0.3s;
    }
    .btn-main:hover { background: #B8860B; }
    .btn-link {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 300;
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(10, 10, 10, 0.4);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      padding-bottom: 2px;
      transition: all 0.3s;
    }
    .btn-link:hover {
      color: #0A0A0A;
      border-color: rgba(10, 10, 10, 0.2);
    }

    /* Specialty tags */
    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      opacity: 0;
      animation: up 0.7s ease 1.55s forwards;
    }
    .tag {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 300;
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(10, 10, 10, 0.4);
      border: 1px solid rgba(10, 10, 10, 0.12);
      padding: 0.3rem 0.8rem;
      transition: all 0.3s;
    }
    .tag:hover {
      color: #0A0A0A;
      border-color: rgba(10, 10, 10, 0.3);
    }

    /* Bottom right counter */
    .counter {
      position: absolute;
      bottom: 3rem;
      right: 3rem;
      text-align: right;
      opacity: 0;
      animation: fadeIn 0.8s ease 1.7s forwards;
    }
    .counter-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 3.5rem;
      line-height: 1;
      color: rgba(10, 10, 10, 0.06);
    }
    .counter-label {
      font-family: 'Spectral', serif;
      font-style: italic;
      font-size: 0.7rem;
      color: rgba(10, 10, 10, 0.3);
      letter-spacing: 0.04em;
    }

    @keyframes up {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(100%); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <nav>
    <span class="nav-logo">FR<span>.</span>AME</span>
    <ul class="nav-links">
      <li><a href="#">Portrait</a></li>
      <li><a href="#">Editorial</a></li>
      <li><a href="#">Werbung</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
  </nav>

  <section class="hero">
    <!-- LEFT: Photo -->
    <div class="hero-photo">
      <div class="photo-reveal">
        <img
          src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=1000&q=85&auto=format"
          alt="Portrait-Fotografie — Frame Studio Trier"
          loading="eager"
        />
      </div>

      <div class="photo-line-h top"></div>
      <div class="photo-line-h bottom"></div>

      <div class="aperture-ring ap-1"></div>
      <div class="aperture-ring ap-2"></div>

      <div class="photo-caption">
        <span class="caption-title">Luisa M. — Editorial, 2024</span>
        <span class="caption-num">f/1.8 · 85mm</span>
      </div>
    </div>

    <!-- RIGHT: Text -->
    <div class="hero-text">
      <p class="eyebrow">Portrait & Kommerz · Trier</p>

      <h1 class="headline">
        <div class="ln"><span>Jedes</span></div>
        <div class="ln"><span>Bild.</span></div>
      </h1>

      <div class="meta-line">
        <div class="meta-dash"></div>
        <span class="meta-text">erzählt, was Worte nicht können.</span>
      </div>

      <p class="desc">
        Frame ist ein Fotostudio für Portrait, Editorial
        und kommerzielle Fotografie. Wir schaffen Bilder,
        die bleiben.
      </p>

      <div class="cta-row">
        <a href="#" class="btn-main">Projekt anfragen</a>
        <a href="#" class="btn-link">Portfolio ansehen →</a>
      </div>

      <div class="tags">
        <span class="tag">Portrait</span>
        <span class="tag">Editorial</span>
        <span class="tag">Werbung</span>
        <span class="tag">Menschen</span>
        <span class="tag">Produkt</span>
      </div>

      <div class="counter">
        <div class="counter-num">840</div>
        <div class="counter-label">Shootings seit 2017</div>
      </div>
    </div>
  </section>
</body>
</html>
