---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Rebstock — Straußwirtschaft in Longuich an der Mosel</title>
  <meta name="description" content="Rebstock — Straußwirtschaft der Familie Schommer in Longuich an der Mosel. Wein vom eigenen Weingut, hausgemachte Speisen. Geöffnet März bis Oktober." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet" />

  <style>
    html { overflow-x: hidden; }
    body { overflow-x: hidden; max-width: 100%; }
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #722F37;
      --secondary: #F5EDE0;
      --accent: #8B6914;
      --background: #FBF7F0;
      --text: #2C1810;
      --primary-light: #8a3a44;
      --primary-dark: #5a252c;
      --accent-light: #a47d1a;
      --border-subtle: #e2d5c3;
      --warm-shadow: rgba(44, 24, 16, 0.08);
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Lora', Georgia, serif;
      color: var(--text);
      background-color: var(--background);
      line-height: 1.7;
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
    }

    /* ============ NAVIGATION ============ */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: background-color 0.4s ease, box-shadow 0.4s ease;
    }

    .nav.scrolled {
      background-color: rgba(251, 247, 240, 0.97);
      box-shadow: 0 2px 20px var(--warm-shadow);
    }

    .nav-logo {
      text-decoration: none;
      display: flex;
      flex-direction: column;
      line-height: 1.1;
      transition: color 0.4s ease;
    }

    .nav-logo-name {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.6rem;
      font-weight: 600;
      color: var(--text);
      letter-spacing: 0.02em;
    }

    .nav-logo-sub {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 0.65rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      opacity: 0.7;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-family: 'Lora', Georgia, serif;
      font-size: 0.9rem;
      color: var(--text);
      text-decoration: none;
      letter-spacing: 0.04em;
      transition: color 0.3s ease;
    }

    .nav-links a:hover {
      color: var(--primary);
    }

    .nav-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 4px;
    }

    .nav-toggle span {
      width: 24px;
      height: 2px;
      background-color: var(--text);
      transition: background-color 0.4s ease;
    }

    /* ============ HERO — EDITORIAL MAGAZINE SPREAD ============ */
    .hero {
      position: relative;
      min-height: 100vh;
      display: grid;
      grid-template-columns: 40% 60%;
      background-color: var(--background);
      overflow: hidden;
    }

    /* Left column — text */
    .hero-text {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 8rem 4rem 6rem 4rem;
      z-index: 2;
    }

    /* Watermark "1968" behind text */
    .hero-watermark {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 18rem;
      font-weight: 700;
      color: var(--primary);
      opacity: 0.04;
      pointer-events: none;
      z-index: 0;
      line-height: 1;
      letter-spacing: -0.03em;
      user-select: none;
    }

    .hero-label {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--primary);
      font-weight: 600;
      margin-bottom: 2rem;
      position: relative;
      z-index: 1;
    }

    .hero-title {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: clamp(2.4rem, 4.5vw, 3.8rem);
      font-weight: 400;
      color: var(--text);
      line-height: 1.15;
      margin-bottom: 2rem;
      letter-spacing: -0.01em;
      position: relative;
      z-index: 1;
    }

    .hero-title em {
      font-style: italic;
      font-size: 1.08em;
    }

    /* Ornamental divider */
    .hero-divider {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      margin-bottom: 2rem;
      position: relative;
      z-index: 1;
    }

    .hero-divider::before,
    .hero-divider::after {
      content: '';
      flex: 0 0 40px;
      height: 1px;
      background-color: var(--accent);
      opacity: 0.5;
    }

    .hero-divider::after {
      flex: 1;
    }

    .hero-divider-ornament {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--accent);
      opacity: 0.6;
    }

    .hero-divider-ornament svg {
      width: 18px;
      height: 18px;
      fill: currentColor;
    }

    .hero-divider-diamond {
      width: 6px;
      height: 6px;
      background-color: var(--accent);
      transform: rotate(45deg);
      flex-shrink: 0;
      opacity: 0.6;
    }

    .hero-meta {
      font-family: 'Lora', Georgia, serif;
      font-size: 0.9rem;
      color: var(--text);
      opacity: 0.6;
      line-height: 1.8;
      margin-bottom: 2.5rem;
      position: relative;
      z-index: 1;
    }

    .hero-meta span {
      opacity: 0.4;
      margin: 0 0.3em;
    }

    .hero-links {
      display: flex;
      gap: 2rem;
      position: relative;
      z-index: 1;
    }

    .hero-link {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--primary);
      text-decoration: none;
      position: relative;
      padding-bottom: 2px;
    }

    .hero-link::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: 0;
      width: 0;
      height: 1px;
      background-color: var(--primary);
      transition: width 0.35s ease;
    }

    .hero-link:hover::after {
      width: 100%;
    }

    .hero-link-arrow {
      display: inline-block;
      transition: transform 0.3s ease;
      margin-left: 0.3em;
    }

    .hero-link:hover .hero-link-arrow {
      transform: translateX(3px);
    }

    /* Right column — photo */
    .hero-photo {
      position: relative;
      padding: 3rem 3rem 3rem 0;
      display: flex;
      align-items: stretch;
    }

    .hero-photo-frame {
      position: relative;
      flex: 1;
      border: 6px solid var(--secondary);
      box-shadow: 0 8px 40px rgba(44, 24, 16, 0.12);
      overflow: hidden;
    }

    .hero-photo-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
      display: block;
      filter: sepia(0.12) saturate(1.05) brightness(0.97);
    }

    /* Warm color overlay on photo */
    .hero-photo-frame::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(139, 105, 20, 0.04) 0%,
        rgba(44, 24, 16, 0.08) 100%
      );
      pointer-events: none;
    }

    /* Overlaid season card on photo */
    .hero-season-card {
      position: absolute;
      bottom: 4.5rem;
      right: 1.5rem;
      background-color: rgba(245, 237, 224, 0.94);
      backdrop-filter: blur(6px);
      padding: 0.7rem 1.2rem;
      z-index: 3;
      box-shadow: 0 4px 16px rgba(44, 24, 16, 0.12);
    }

    .hero-season-card p {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--primary);
      font-weight: 600;
    }

    /* ============ SECTIONS GENERAL ============ */
    .section {
      padding: 6rem 2rem;
    }

    .section-header {
      text-align: center;
      margin-bottom: 4rem;
    }

    .section-label {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 0.85rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.8rem;
      font-weight: 600;
    }

    .section-title {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 500;
      color: var(--primary);
      line-height: 1.2;
      margin-bottom: 1rem;
    }

    .section-divider {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-top: 1.2rem;
      color: var(--accent);
      opacity: 0.5;
      font-size: 0.9rem;
    }

    .section-divider::before,
    .section-divider::after {
      content: '';
      width: 60px;
      height: 1px;
      background-color: var(--accent);
    }

    .container {
      max-width: 1100px;
      margin: 0 auto;
    }

    /* ============ KARTE (WEINE + SPEISEN) ============ */
    .karte {
      background-color: var(--secondary);
    }

    .karte-columns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    .karte-column-title {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.6rem;
      font-weight: 600;
      color: var(--primary);
      margin-bottom: 0.3rem;
      letter-spacing: 0.02em;
    }

    .karte-column-subtitle {
      font-family: 'Lora', Georgia, serif;
      font-size: 0.82rem;
      font-style: italic;
      color: var(--accent);
      margin-bottom: 2rem;
    }

    .karte-item {
      padding: 1.2rem 0;
      border-bottom: 1px solid var(--border-subtle);
    }

    .karte-item:last-child {
      border-bottom: none;
    }

    .karte-item-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: 0.2rem;
    }

    .karte-item-name {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--text);
      line-height: 1.3;
    }

    .karte-item-price {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--primary);
      white-space: nowrap;
      flex-shrink: 0;
    }

    .karte-item-grape {
      font-family: 'Lora', Georgia, serif;
      font-size: 0.82rem;
      font-style: italic;
      color: var(--accent);
      margin-bottom: 0.3rem;
    }

    .karte-item-desc {
      font-family: 'Lora', Georgia, serif;
      font-size: 0.88rem;
      color: var(--text);
      opacity: 0.7;
      line-height: 1.6;
    }

    .karte-item-badge {
      display: inline-block;
      background-color: var(--primary);
      color: #fff;
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.15rem 0.5rem;
      font-weight: 600;
      margin-left: 0.5rem;
      vertical-align: middle;
      position: relative;
      top: -1px;
    }

    .karte-note {
      text-align: center;
      margin-top: 3.5rem;
      font-style: italic;
      font-size: 0.92rem;
      color: var(--text);
      opacity: 0.6;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.7;
    }

    /* ============ FAMILIE ============ */
    .familie {
      background-color: var(--background);
    }

    .familie-content {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 4rem;
      align-items: start;
    }

    .familie-image-wrapper {
      position: relative;
    }

    .familie-image-wrapper img {
      width: 100%;
      height: auto;
      display: block;
      filter: sepia(0.15) saturate(0.9);
    }

    .familie-image-border {
      position: absolute;
      inset: -8px;
      border: 1px solid var(--accent);
      opacity: 0.3;
      pointer-events: none;
    }

    .familie-story {
      padding-top: 0.5rem;
    }

    .timeline {
      margin-top: 2.5rem;
      margin-bottom: 2.5rem;
      position: relative;
      padding-left: 2rem;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.4rem;
      bottom: 0.4rem;
      width: 1px;
      background: linear-gradient(to bottom, var(--accent), var(--border-subtle));
    }

    .timeline-entry {
      position: relative;
      margin-bottom: 1.8rem;
    }

    .timeline-entry:last-child {
      margin-bottom: 0;
    }

    .timeline-entry::before {
      content: '';
      position: absolute;
      left: -2rem;
      top: 0.55rem;
      width: 7px;
      height: 7px;
      background-color: var(--accent);
      border-radius: 50%;
      transform: translateX(-3px);
    }

    .timeline-year {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--primary);
      margin-bottom: 0.15rem;
    }

    .timeline-text {
      font-family: 'Lora', Georgia, serif;
      font-size: 0.92rem;
      color: var(--text);
      opacity: 0.8;
      line-height: 1.6;
    }

    .familie-quote {
      background-color: var(--secondary);
      padding: 2rem 2.2rem;
      border-left: 3px solid var(--accent);
      margin-top: 2.5rem;
      margin-bottom: 2.5rem;
      position: relative;
    }

    .familie-quote::before {
      content: '\201E';
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 4rem;
      color: var(--accent);
      opacity: 0.3;
      position: absolute;
      top: -0.5rem;
      left: 1rem;
      line-height: 1;
    }

    .familie-quote p {
      font-family: 'Lora', Georgia, serif;
      font-style: italic;
      font-size: 1.02rem;
      line-height: 1.8;
      color: var(--text);
      opacity: 0.85;
      position: relative;
      z-index: 1;
    }

    .familie-quote-author {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 0.85rem;
      color: var(--accent);
      font-weight: 600;
      letter-spacing: 0.08em;
      margin-top: 0.8rem;
      font-style: normal;
      display: block;
    }

    .familie-kontakt {
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border-subtle);
    }

    .familie-kontakt h3 {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--primary);
      margin-bottom: 1rem;
    }

    .kontakt-details {
      font-size: 0.92rem;
      line-height: 2;
      opacity: 0.8;
    }

    .kontakt-details strong {
      color: var(--primary);
      font-weight: 600;
    }

    .kontakt-details a {
      color: var(--primary);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.3s ease;
    }

    .kontakt-details a:hover {
      border-bottom-color: var(--primary);
    }

    .anfahrt-hint {
      font-family: 'Lora', Georgia, serif;
      font-style: italic;
      font-size: 0.85rem;
      color: var(--text);
      opacity: 0.55;
      margin-top: 1rem;
      line-height: 1.6;
    }

    /* ============ FOOTER ============ */
    .footer {
      background-color: var(--primary-dark);
      color: rgba(245, 237, 224, 0.7);
      padding: 3rem 2rem;
      text-align: center;
    }

    .footer-logo {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.8rem;
      font-weight: 600;
      color: var(--secondary);
      margin-bottom: 0.3rem;
    }

    .footer-tagline {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-style: italic;
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
      opacity: 0.6;
    }

    .footer-divider {
      width: 60px;
      height: 1px;
      background-color: var(--accent);
      margin: 1.5rem auto;
      opacity: 0.4;
    }

    .footer-legal {
      font-size: 0.8rem;
      opacity: 0.5;
    }

    .footer-legal a {
      color: rgba(245, 237, 224, 0.7);
      text-decoration: none;
    }

    .footer-legal a:hover {
      color: var(--secondary);
    }

    /* ============ DEMO BANNER ============ */
    .demo-banner {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 200;
      background-color: var(--primary-dark);
      color: var(--secondary);
      text-align: center;
      padding: 0.7rem 1rem;
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 0.85rem;
      letter-spacing: 0.08em;
    }

    .demo-banner a {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
      margin-left: 0.5rem;
    }

    .demo-banner a:hover {
      text-decoration: underline;
    }

    /* ============ RESPONSIVE ============ */
    @media (max-width: 900px) {
      .karte-columns {
        grid-template-columns: 1fr;
        gap: 3rem;
      }

      .familie-content {
        grid-template-columns: 1fr;
        gap: 2.5rem;
      }

      .familie-image-wrapper {
        max-width: 500px;
      }
    }

    @media (max-width: 768px) {
      .nav-links {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        flex-direction: column;
        background-color: rgba(251, 247, 240, 0.98);
        padding: 1.5rem 2rem;
        gap: 1rem;
        box-shadow: 0 4px 20px var(--warm-shadow);
      }

      .nav-links.open {
        display: flex;
      }

      .nav-links a {
        color: var(--text);
        font-size: 1rem;
      }

      .nav-toggle {
        display: flex;
      }

      .section {
        padding: 4rem 1.5rem;
      }

      .hero {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .hero-photo {
        order: -1;
        padding: 1rem 1rem 0 1rem;
        max-height: 55vh;
      }

      .hero-photo-frame {
        border-width: 4px;
      }

      .hero-text {
        padding: 2.5rem 1.5rem 3rem 1.5rem;
        text-align: center;
        align-items: center;
      }

      .hero-watermark {
        font-size: 10rem;
      }

      .hero-title {
        font-size: clamp(2rem, 7vw, 2.8rem);
      }

      .hero-divider {
        justify-content: center;
      }

      .hero-divider::before {
        flex: 0 0 30px;
      }

      .hero-divider::after {
        flex: 0 0 30px;
      }

      .hero-meta {
        text-align: center;
      }

      .hero-links {
        justify-content: center;
      }

      .hero-season-card {
        bottom: 1.5rem;
        right: 0.5rem;
      }

      .familie-quote {
        padding: 1.5rem 1.5rem;
      }

      .timeline {
        padding-left: 1.5rem;
      }
    }
  </style>
</head>

<body>
  <!-- Navigation -->
  <nav class="nav scrolled" id="mainNav">
    <a href="#" class="nav-logo">
      <span class="nav-logo-name">Rebstock</span>
      <span class="nav-logo-sub">Strau&szlig;wirtschaft</span>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="#karte">Karte</a></li>
      <li><a href="#familie">Die Familie</a></li>
    </ul>
    <button class="nav-toggle" id="navToggle" aria-label="Navigation umschalten">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- Hero — Editorial Magazine Spread -->
  <section class="hero">
    <!-- Left: Text Column -->
    <div class="hero-text">
      <div class="hero-watermark">1968</div>
      <p class="hero-label">Strau&szlig;wirtschaft &middot; Longuich an der Mosel</p>
      <h1 class="hero-title">Wo die Mosel<br />den Wein <em>k&uuml;sst.</em></h1>
      <div class="hero-divider">
        <span class="hero-divider-ornament">
          <svg viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg"><path d="M9 2C9 2 7 5.5 4.5 7C2 8.5 1 9 1 9s1 .5 3.5 2C7 12.5 9 16 9 16s2-3.5 4.5-5C16 9.5 17 9 17 9s-1-.5-3.5-2C11 5.5 9 2 9 2z" fill-opacity="0.5"/></svg>
        </span>
        <span class="hero-divider-diamond"></span>
        <span class="hero-divider-ornament">
