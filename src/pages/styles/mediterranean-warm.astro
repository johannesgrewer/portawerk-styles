---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Olivia — Feinkost & Olivenoel | Trier Altstadt</title>
  <meta name="description" content="Olivia — Feinkost & Olivenoel in der Trierer Altstadt. Handverlesene Spezialitaeten aus dem Mittelmeerraum. Seit 2018." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:ital,wght@0,300;0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />

  <style>
    html { overflow-x: hidden; }
    /* ===== RESET & BASE ===== */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #B5651D;
      --secondary: #F5EDD6;
      --accent: #6B7F3B;
      --bg: #FAF6EE;
      --text: #3D2B1F;
      --primary-light: #c97a2e;
      --primary-dark: #8f4f15;
      --accent-light: #8a9e52;
      --accent-dark: #4f5e2b;
      --warm-shadow: rgba(61, 43, 31, 0.1);
      --warm-shadow-lg: rgba(61, 43, 31, 0.15);
      --border-subtle: #e6dcc8;
      --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
      --ease-in-out-smooth: cubic-bezier(0.4, 0, 0.2, 1);
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
      color: var(--text);
      background-color: var(--bg);
      line-height: 1.75;
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    img {
      max-width: 100%;
      height: auto;
      display: block;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    h1, h2, h3, h4 {
      font-family: 'Libre Baskerville', Georgia, serif;
      line-height: 1.3;
      color: var(--text);
    }

    /* ===== ANIMATION KEYFRAMES ===== */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(32px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeInLeft {
      from {
        opacity: 0;
        transform: translateX(-40px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes fadeInRight {
      from {
        opacity: 0;
        transform: translateX(40px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes fadeInScale {
      from {
        opacity: 0;
        transform: scale(0.92);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    @keyframes drawLine {
      from {
        stroke-dashoffset: var(--line-length, 1000);
      }
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes dotPulse {
      0%, 100% { box-shadow: 0 0 0 4px var(--bg), 0 0 0 6px rgba(181, 101, 29, 0.2); }
      50% { box-shadow: 0 0 0 6px var(--bg), 0 0 0 10px rgba(181, 101, 29, 0.15); }
    }

    @keyframes subtleFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }

    /* ===== SCROLL-TRIGGERED REVEAL ===== */
    .reveal {
      opacity: 1;
      transform: none;
      transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
    }

    .reveal.visible {
      opacity: 1;
      transform: none;
    }

    .reveal-left {
      opacity: 1;
      transform: none;
      transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
    }

    .reveal-left.visible {
      opacity: 1;
      transform: none;
    }

    .reveal-right {
      opacity: 1;
      transform: none;
      transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
    }

    .reveal-right.visible {
      opacity: 1;
      transform: none;
    }

    .reveal-scale {
      opacity: 1;
      transform: none;
      transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
    }

    .reveal-scale.visible {
      opacity: 1;
      transform: none;
    }

    /* Stagger delays for children */
    .stagger-1 { transition-delay: 0.08s; }
    .stagger-2 { transition-delay: 0.16s; }
    .stagger-3 { transition-delay: 0.24s; }
    .stagger-4 { transition-delay: 0.32s; }
    .stagger-5 { transition-delay: 0.4s; }
    .stagger-6 { transition-delay: 0.48s; }

    /* ===== SVG GRAIN FILTER (referenced in hero) ===== */
    .svg-filters {
      position: absolute;
      width: 0;
      height: 0;
      overflow: hidden;
    }

    /* ===== NAVBAR ===== */
    .navbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.25rem 2.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: background-color 0.5s var(--ease-in-out-smooth), box-shadow 0.5s var(--ease-in-out-smooth), padding 0.5s var(--ease-in-out-smooth);
    }

    .navbar.scrolled {
      background-color: rgba(250, 246, 238, 0.96);
      box-shadow: 0 2px 24px var(--warm-shadow);
      padding-top: 0.85rem;
      padding-bottom: 0.85rem;
    }

    .navbar-logo {
      text-decoration: none;
      display: flex;
      flex-direction: column;
      line-height: 1.15;
    }

    .navbar-logo-name {
      font-family: 'Libre Baskerville', Georgia, serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text);
      letter-spacing: 0.01em;
    }

    .navbar-logo-sub {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.65rem;
      font-weight: 400;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--primary);
      opacity: 0.8;
    }

    .navbar-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .navbar-links a {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.92rem;
      font-weight: 600;
      color: var(--text);
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: color 0.35s var(--ease-in-out-smooth);
      position: relative;
    }

    .navbar-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 1.5px;
      background-color: var(--primary);
      transition: width 0.4s var(--ease-out-expo);
    }

    .navbar-links a:hover {
      color: var(--primary);
    }

    .navbar-links a:hover::after {
      width: 100%;
    }

    .navbar-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 4px;
    }

    .navbar-toggle span {
      width: 24px;
      height: 2px;
      background-color: var(--text);
      transition: all 0.35s var(--ease-out-expo);
    }

    /* ===== HERO — INGREDIENT STILL LIFE ===== */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 55% 45%;
      align-items: center;
      padding: 7rem 0 4rem 0;
      background-color: var(--bg);
      position: relative;
      overflow: hidden;
      max-width: 1600px;
      margin-left: auto;
      margin-right: auto;
    }

    /* Subtle texture background */
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 80% 20%, rgba(181, 101, 29, 0.04) 0%, transparent 60%),
                  radial-gradient(ellipse at 20% 80%, rgba(107, 127, 59, 0.03) 0%, transparent 50%);
      pointer-events: none;
    }

    /* Warm grain/paper texture overlay */
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0.28;
      pointer-events: none;
      z-index: 2;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.5'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 200px 200px;
      mix-blend-mode: multiply;
    }

    .hero-image-col {
      position: relative;
      padding: 2rem 0 2rem 4rem;
      z-index: 3;
    }

    .hero-image-wrapper {
      position: relative;
      overflow: hidden;
      border-radius: 16px;
    }

    .hero-image-wrapper img {
      width: 100%;
      height: 580px;
      object-fit: cover;
      border-radius: 16px;
      box-shadow: 12px 16px 48px rgba(61, 43, 31, 0.18),
                  0 4px 12px rgba(61, 43, 31, 0.08);
      transition: transform 8s var(--ease-in-out-smooth);
      will-change: transform;
    }

    /* Subtle Ken Burns on load */
    .hero-image-wrapper:hover img {
      transform: scale(1.03);
    }

    /* Decorative frame accent */
    .hero-image-wrapper::after {
      content: '';
      position: absolute;
      top: -12px;
      right: -12px;
      width: 120px;
      height: 120px;
      border-top: 2px solid var(--primary);
      border-right: 2px solid var(--primary);
      border-radius: 0 16px 0 0;
      opacity: 0.35;
      pointer-events: none;
    }

    .hero-text-col {
      position: relative;
      padding: 2rem 4rem 2rem 3.5rem;
      z-index: 3;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-headline {
      font-family: 'Libre Baskerville', Georgia, serif;
      font-size: 3.6rem;
      font-weight: 700;
      line-height: 1.12;
      letter-spacing: -0.01em;
      color: var(--text);
      margin-bottom: 2rem;
    }

    .hero-headline span {
      display: block;
      animation: fadeInUp 0.85s var(--ease-out-expo) backwards;
    }

    .hero-headline span:nth-child(1) { animation-delay: 0.2s; }
    .hero-headline span:nth-child(2) { animation-delay: 0.48s; }

    .hero-headline .word-accent {
      color: var(--primary);
    }

    /* Olive branch SVG decoration */
    .hero-olive-branch {
      width: 140px;
      height: auto;
      margin: 1.5rem 0 2rem 0;
      opacity: 0.5;
    }

    .hero-info {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.85rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--primary);
      font-weight: 600;
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .hero-info-dot {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background-color: var(--primary);
      opacity: 0.5;
      display: inline-block;
    }

    .hero-cta-group {
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }

    .hero-cta-link {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--primary);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding-bottom: 2px;
      border-bottom: 1.5px solid transparent;
      transition: border-color 0.4s var(--ease-out-expo), color 0.4s var(--ease-out-expo);
    }

    .hero-cta-link:hover {
      border-bottom-color: var(--primary);
    }

    .hero-cta-link svg {
      width: 16px;
      height: 16px;
      transition: transform 0.4s var(--ease-out-expo);
    }

    .hero-cta-link:hover svg {
      transform: translateX(4px);
    }

    /* ===== SECTION DIVIDER — OLIVE BRANCH ORNAMENT ===== */
    .section-ornament {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 0;
      margin: 0;
      position: relative;
      z-index: 5;
      overflow: visible;
    }

    .section-ornament svg {
      width: 200px;
      height: 40px;
      opacity: 0.35;
      display: block;
    }

    .section-ornament--on-secondary {
      background-color: var(--secondary);
      margin-top: -1px;
    }

    .section-ornament--on-bg {
      background-color: var(--bg);
      margin-top: -1px;
    }

    /* ===== SECTION 2 — PRODUCT SPOTLIGHTS ===== */
    .products {
      padding: 6rem 4rem;
      background-color: var(--secondary);
      position: relative;
      max-width: 1600px;
      margin-left: auto;
      margin-right: auto;
    }

    .products::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border-subtle), transparent);
    }

    .products-header {
      text-align: center;
      margin-bottom: 4rem;
    }

    .products-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
      margin-bottom: 0.75rem;
      line-height: 1.6;
    }

    .products-title {
      font-family: 'Libre Baskerville', Georgia, serif;
      font-size: 2.4rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.3;
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .product-card {
      background-color: var(--bg);
      border-radius: 12px;
      padding: 2rem 1.5rem;
      position: relative;
      transition: transform 0.5s var(--ease-out-expo), box-shadow 0.5s var(--ease-out-expo);
      border: 1px solid var(--border-subtle);
      cursor: default;
    }

    .product-card:hover {
      transform: translateY(-6px) rotate(0.8deg);
      box-shadow: 0 16px 40px var(--warm-shadow-lg), 0 4px 12px var(--warm-shadow);
    }

    .product-card-icon {
      width: 36px;
      height: 36px;
      margin-bottom: 1.25rem;
      color: var(--primary);
      transition: transform 0.5s var(--ease-out-expo);
    }

    .product-card:hover .product-card-icon {
      transform: scale(1.1) translateY(-2px);
    }

    .product-card-photo {
      position: relative;
      overflow: hidden;
      border-radius: 8px;
      height: 160px;
      margin-bottom: 1.25rem;
    }

    .product-card-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.55s ease;
    }

    .product-card:hover .product-card-photo img {
      transform: scale(1.05);
    }

    .product-card-origin {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
      margin-bottom: 0.5rem;
      line-height: 1.6;
    }

    .product-card-name {
      font-family: 'Libre Baskerville', Georgia, serif;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.5rem;
      line-height: 1.35;
    }

    .product-card-desc {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.9rem;
      color: var(--text);
      opacity: 0.75;
      line-height: 1.65;
      margin-bottom: 1.25rem;
    }

    .product-card-price {
      font-family: 'Libre Baskerville', Georgia, serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--primary);
      transition: color 0.4s var(--ease-in-out-smooth);
    }

    .product-card:hover .product-card-price {
      color: var(--primary-dark);
    }

    .product-card-unit {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.75rem;
      font-weight: 400;
      color: var(--text);
      opacity: 0.5;
      margin-left: 0.25rem;
    }

    /* ===== SECTION 3 — DIE REISE ===== */
    .journey {
      padding: 6rem 4rem;
      background-color: var(--bg);
      position: relative;
      overflow: hidden;
      max-width: 1600px;
      margin-left: auto;
      margin-right: auto;
    }

    .journey::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border-subtle), transparent);
    }

    .journey-header {
      text-align: center;
      margin-bottom: 4rem;
    }

    .journey-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
      margin-bottom: 0.75rem;
      line-height: 1.6;
    }

    .journey-title {
      font-family: 'Libre Baskerville', Georgia, serif;
      font-size: 2.4rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.3;
    }

    /* Timeline track */
    .journey-timeline {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      gap: 0;
      max-width: 1000px;
      margin: 0 auto 4rem auto;
      position: relative;
    }

    /* Horizontal connecting line — now an SVG drawn on scroll */
    .journey-timeline-line {
      position: absolute;
      top: 22px;
      left: 10%;
      right: 10%;
      height: 12px;
      z-index: 0;
      overflow: visible;
    }

    .journey-timeline-line line {
      stroke-dasharray: var(--line-length, 800);
      stroke-dashoffset: var(--line-length, 800);
      transition: stroke-dashoffset 1.6s var(--ease-out-expo);
    }

    .journey-timeline-line.animated line {
      stroke-dashoffset: 0;
    }

    .journey-stop {
      flex: 1;
      text-align: center;
      position: relative;
      z-index: 1;
      padding: 0 1rem;
    }

    .journey-stop-dot {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background-color: var(--primary);
      margin: 0 auto 1.25rem auto;
      position: relative;
      box-shadow: 0 0 0 4px var(--bg), 0 0 0 6px rgba(181, 101, 29, 0.2);
      transition: box-shadow 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
    }

    .journey-stop:hover .journey-stop-dot {
      animation: dotPulse 1.5s var(--ease-in-out-smooth) infinite;
      transform: scale(1.2);
    }

    /* Arrow between stops */
    .journey-stop-arrow {
      position: absolute;
      top: 4px;
      right: -8px;
      color: var(--primary);
      opacity: 0.3;
    }

    .journey-stop-arrow svg {
      width: 16px;
      height: 16px;
    }

    .journey-stop-location {
      font-family: 'Libre Baskerville', Georgia, serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.4rem;
      line-height: 1.35;
    }

    .journey-stop-product {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.85rem;
      color: var(--text);
      opacity: 0.7;
      line-height: 1.55;
    }

    /* Quote */
    .journey-quote {
      max-width: 700px;
      margin: 0 auto 4rem auto;
      text-align: center;
      position: relative;
      padding: 2.5rem 3rem;
    }

    .journey-quote::before {
      content: '';
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 60px;
      height: 2px;
      background-color: var(--primary);
      opacity: 0.3;
    }

    .journey-quote-text {
      font-family: 'Libre Baskerville', Georgia, serif;
      font-size: 1.35rem;
      font-style: italic;
      color: var(--text);
      line-height: 1.75;
      margin-bottom: 1rem;
    }

    .journey-quote-author {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--primary);
      letter-spacing: 0.1em;
    }

    /* Contact footer */
    .journey-contact {
      text-align: center;
      padding-top: 2.5rem;
      border-top: 1px solid var(--border-subtle);
      max-width: 500px;
      margin: 0 auto;
    }

    .journey-contact-address {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.95rem;
      color: var(--text);
      opacity: 0.7;
      line-height: 1.85;
    }

    .journey-contact-phone {
      font-family: 'Libre Baskerville', Georgia, serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--primary);
      margin-top: 0.5rem;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: color 0.4s var(--ease-in-out-smooth);
    }

    .journey-contact-phone:hover {
      color: var(--primary-dark);
    }

    .journey-contact-phone svg {
      width: 18px;
      height: 18px;
      opacity: 0.6;
      transition: transform 0.4s var(--ease-out-expo);
    }

    .journey-contact-phone:hover svg {
      transform: rotate(-12deg) scale(1.1);
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 1024px) {
      .hero {
        grid-template-columns: 1fr;
        min-height: auto;
        padding: 6rem 0 3rem 0;
      }

      .hero-image-col {
        padding: 0 2rem;
        order: 1;
      }

      .hero-image-wrapper img {
        height: 400px;
      }

      .hero-text-col {
        padding: 2.5rem 2rem 1rem 2rem;
        order: 2;
      }

      .hero-headline {
        font-size: 2.8rem;
      }

      .products {
        padding: 4rem 2rem;
      }

      .products-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }

      .journey {
        padding: 4rem 2rem;
      }
    }

    @media (max-width: 768px) {
      .navbar {
        padding: 1rem 1.5rem;
      }

      .navbar-links {
        display: none;
      }

      .navbar-toggle {
        display: flex;
      }

      .navbar.open .navbar-links {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background-color: rgba(250, 246, 238, 0.98);
        backdrop-filter: blur(12px);
        padding: 1.5rem 2rem;
        gap: 1.25rem;
        box-shadow: 0 8px 24px var(--warm-shadow);
      }

      .hero {
        padding-top: 5rem;
      }

      .hero-image-col {
        padding: 0 1.25rem;
      }

      .hero-image-wrapper img {
        height: 320px;
        border-radius: 12px;
      }

      .hero-image-wrapper::after {
        display: none;
      }

      .hero-text-col {
        padding: 2rem 1.25rem 1rem 1.25rem;
      }

      .hero-headline {
        font-size: 2.2rem;
      }

      .hero-olive-branch {
        width: 100px;
      }

      .products-grid {
        grid-template-columns: 1fr;
        max-width: 400px;
      }

      .products-title {
        font-size: 1.8rem;
      }

      /* Stack timeline vertically */
      .journey-timeline {
        flex-direction: column;
        align-items: center;
        gap: 2rem;
      }

      .journey-timeline-line {
        display: none;
      }

      .journey-stop {
        padding: 0;
      }

      .journey-stop-dot {
        margin-bottom: 0.75rem;
      }

      .journey-quote {
        padding: 2rem 1.5rem;
