        font-size: 1.15rem;
      }

      .journey-title {
        font-size: 1.8rem;
      }

      .section-ornament svg {
        width: 140px;
      }

      /* Disable card tilt on touch devices */
      .product-card:hover {
        transform: translateY(-4px) rotate(0deg);
      }
    }

    @media (max-width: 480px) {
      .hero-headline {
        font-size: 1.85rem;
      }

