  <!-- ===== SCRIPTS ===== -->
  <script>
    // --- Navbar scroll effect with smooth transition ---
    const navbar = document.getElementById('navbar');
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const currentScroll = window.pageYOffset;
      if (currentScroll > 40) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
      lastScroll = currentScroll;
    }, { passive: true });

    // --- Mobile nav toggle ---
    const navToggle = document.getElementById('navToggle');
    const navElement = document.getElementById('navbar');
    navToggle.addEventListener('click', () => {
      navElement.classList.toggle('open');
    });

    // Close mobile nav on link click
    const navLinks = document.querySelectorAll('.navbar-links a');
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        navElement.classList.remove('open');
      });
    });

    // --- IntersectionObserver: staggered fade-in on scroll ---
    const revealElements = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');

    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.12,
      rootMargin: '0px 0px -40px 0px'
    });

    revealElements.forEach(el => revealObserver.observe(el));

    // --- Timeline line draw animation ---
    const timelineContainer = document.getElementById('journeyTimeline');
    const timelineLine = document.getElementById('timelineLine');

    if (timelineContainer && timelineLine) {
      // Measure and set dasharray after layout
      const initTimelineLine = () => {
        const lineEl = timelineLine.querySelector('line');
        if (lineEl) {
          try {
            const lineLength = lineEl.getTotalLength ? lineEl.getTotalLength() : 800;
            lineEl.style.setProperty('stroke-dasharray', lineLength);
            lineEl.style.setProperty('stroke-dashoffset', lineLength);
            timelineLine.style.setProperty('--line-length', lineLength);
          } catch (e) {
            // Fallback if getTotalLength not supported
            lineEl.style.setProperty('stroke-dasharray', '800');
            lineEl.style.setProperty('stroke-dashoffset', '800');
            timelineLine.style.setProperty('--line-length', '800');
          }
        }
      };

      initTimelineLine();
      window.addEventListener('resize', initTimelineLine);

      const timelineObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            timelineLine.classList.add('animated');
            timelineObserver.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.3
      });

      timelineObserver.observe(timelineContainer);
    }

    // --- Subtle parallax on hero image ---
    const heroParallaxLayer = document.querySelector('.hero-parallax-layer');

    if (heroParallaxLayer && window.innerWidth > 768) {
      let ticking = false;

      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            const scrollY = window.pageYOffset;
            const heroBottom = heroParallaxLayer.closest('.hero')?.offsetHeight || 800;
            // Only apply parallax while hero is visible
            if (scrollY < heroBottom) {
              const parallaxOffset = scrollY * 0.08;
              heroParallaxLayer.style.transform = `translateY(${parallaxOffset}px)`;
            }
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }
  </script>

