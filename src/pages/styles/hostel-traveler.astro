---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Wanderherz — Hostel & Reisecafé | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,600;0,700;0,800;0,900;1,800&family=Work+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { background: #FFF8E7; overflow-x: hidden; }

    :root {
      --sky:    #0EA5E9;
      --sky-d:  #0284C7;
      --sand:   #F59E0B;
      --green:  #10B981;
      --coral:  #F87171;
      --purple: #8B5CF6;
      --bg:     #FFF8E7;
      --dark:   #1C1917;
      --muted:  rgba(28,25,23,0.5);
      --border: rgba(28,25,23,0.07);
    }

    body {
      background: var(--bg);
      color: var(--dark);
      font-family: 'Work Sans', sans-serif;
      overflow-x: hidden;
      max-width: 1440px;
      margin: 0 auto;
    }

    /* ─── Nav ──────────────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 3rem;
      background: rgba(255,248,231,0.96); backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: 'Nunito', sans-serif;
      font-weight: 900; font-size: 1.25rem;
      color: var(--sky);
    }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      font-size: 0.65rem; font-weight: 500;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--muted); text-decoration: none; transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--sky); }
    .nav-book {
      font-family: 'Nunito', sans-serif;
      font-weight: 700; font-size: 0.7rem;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: #fff; background: var(--sky);
      padding: 0.6rem 1.4rem; border-radius: 100px;
      text-decoration: none; transition: background 0.2s;
    }
    .nav-book:hover { background: var(--dark); }

    /* ─── Hero ─────────────────────────────────────────── */
    .hero {
      min-height: 100vh;
      padding-top: 60px;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .hero-left {
      display: flex; flex-direction: column;
      justify-content: center;
      padding: 4rem 3.5rem 4rem 4rem;
      gap: 2rem;
    }

    .eyebrow {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: 'Nunito', sans-serif;
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--sky);
      background: rgba(14,165,233,0.08);
      border: 1px solid rgba(14,165,233,0.2);
      padding: 0.35rem 0.9rem; border-radius: 100px;
      width: fit-content;
    }

    .hero-headline {
      font-family: 'Nunito', sans-serif;
      font-weight: 900;
      font-size: clamp(2.6rem, 4.5vw, 4rem);
      line-height: 1.1; letter-spacing: -0.02em;
    }
    .hero-headline .sky  { color: var(--sky); }
    .hero-headline .sand { color: var(--sand); }

    .hero-body {
      font-size: 0.9rem; font-weight: 300;
      line-height: 1.9; color: var(--muted); max-width: 44ch;
    }

    .feature-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
    .feature-pill {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.7rem 1rem;
      background: #fff; border: 1px solid var(--border); border-radius: 10px;
    }
    .fp-dot {
      width: 8px; height: 8px; border-radius: 50%;
      flex-shrink: 0;
    }
    .fp-text {
      font-family: 'Nunito', sans-serif;
      font-size: 0.78rem; font-weight: 700; color: var(--dark);
    }

    .cta-row { display: flex; align-items: center; gap: 1.25rem; }
    .cta-btn {
      font-family: 'Nunito', sans-serif;
      font-weight: 700; font-size: 0.72rem; letter-spacing: 0.08em;
      text-transform: uppercase; color: #fff; background: var(--sky);
      padding: 0.9rem 2rem; border-radius: 100px;
      text-decoration: none; transition: background 0.2s;
    }
    .cta-btn:hover { background: var(--dark); }
    .cta-price { font-size: 0.82rem; font-weight: 400; color: var(--muted); }
    .cta-price strong {
      font-family: 'Nunito', sans-serif;
      font-weight: 800; color: var(--dark); font-size: 1rem;
    }

    .hero-right {
      background: var(--sky);
      display: flex; flex-direction: column;
      padding: 4rem 3.5rem; gap: 1.5rem;
    }

    .right-label {
      font-family: 'Nunito', sans-serif;
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.15em;
      text-transform: uppercase; color: rgba(255,255,255,0.6);
    }

    .dest-list { display: flex; flex-direction: column; gap: 0.6rem; }
    .dest-card {
      display: flex; align-items: center; gap: 1rem;
      padding: 1rem 1.25rem;
      background: rgba(255,255,255,0.15);
      border-radius: 12px; border: 1px solid rgba(255,255,255,0.2);
      transition: background 0.2s;
    }
    .dest-card:hover { background: rgba(255,255,255,0.22); }
    .dc-circle {
      width: 38px; height: 38px; border-radius: 50%;
      flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 0.75rem; color: #fff;
    }
    .dc-info { flex: 1; }
    .dc-city {
      font-family: 'Nunito', sans-serif;
      font-weight: 700; font-size: 0.92rem; color: #fff;
    }
    .dc-route {
      font-size: 0.68rem; font-weight: 300;
      color: rgba(255,255,255,0.65); margin-top: 0.1rem;
    }
    .dc-tag {
      font-family: 'Nunito', sans-serif;
      font-size: 0.55rem; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--sky);
      background: #fff; padding: 0.2rem 0.55rem; border-radius: 100px;
    }

    .review-block {
      background: rgba(255,255,255,0.15);
      border-radius: 12px; padding: 1.25rem;
      border: 1px solid rgba(255,255,255,0.2);
    }
    .rb-stars { font-size: 0.75rem; color: var(--sand); margin-bottom: 0.5rem; }
    .rb-quote {
      font-size: 0.88rem; font-weight: 300;
      color: rgba(255,255,255,0.85); line-height: 1.6; font-style: italic;
    }
    .rb-author {
      font-family: 'Nunito', sans-serif;
      font-size: 0.65rem; font-weight: 700;
      color: rgba(255,255,255,0.55); letter-spacing: 0.06em; margin-top: 0.6rem;
    }

    .stats-strip {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 0.5rem; margin-top: auto;
    }
    .stat-item {
      background: rgba(255,255,255,0.12);
      border-radius: 10px; padding: 1rem; text-align: center;
    }
    .stat-num {
      font-family: 'Nunito', sans-serif;
      font-weight: 900; font-size: 1.6rem; color: #fff; line-height: 1;
    }
    .stat-label { font-size: 0.6rem; font-weight: 300; color: rgba(255,255,255,0.6); margin-top: 0.2rem; }

    /* ─── Section 2: Räume ─────────────────────────────── */
    .raeume {
      background: #fff;
      padding: 7rem 4rem;
      border-top: 1px solid var(--border);
    }

    .sec-intro {
      display: flex; align-items: flex-end;
      justify-content: space-between; margin-bottom: 4rem;
    }
    .sec-tag {
      font-family: 'Nunito', sans-serif;
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--sky); margin-bottom: 0.5rem;
    }
    .sec-h {
      font-family: 'Nunito', sans-serif;
      font-weight: 900; font-size: clamp(2rem, 3.5vw, 3rem);
      line-height: 1.1; letter-spacing: -0.02em;
    }
    .sec-h em { font-style: italic; color: var(--sky); }
    .sec-sub {
      font-size: 0.85rem; font-weight: 300;
      color: var(--muted); max-width: 38ch; text-align: right;
      line-height: 1.7;
    }

    .room-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

    .room-card {
      border: 1px solid var(--border); overflow: hidden;
      transition: box-shadow 0.3s, transform 0.3s;
      border-radius: 16px;
    }
    .room-card:hover {
      box-shadow: 0 16px 48px rgba(14,165,233,0.12);
      transform: translateY(-4px);
    }

    /* CSS Art areas */
    .room-art {
      height: 220px;
      position: relative; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }

    /* Art 1: Bunk dorm */
    .art-dorm6 { background: linear-gradient(160deg, #E0F2FE 0%, #BAE6FD 100%); }
    .bunk-scene {
      display: flex; gap: 18px; align-items: flex-end;
    }
    .bunk-unit {
      width: 52px;
      display: flex; flex-direction: column;
      gap: 0; position: relative;
    }
    .bunk-post {
      position: absolute; left: 0; top: 0; bottom: 0;
      width: 5px; background: var(--sky-d); border-radius: 3px;
    }
    .bunk-post-r {
      position: absolute; right: 0; top: 0; bottom: 0;
      width: 5px; background: var(--sky-d); border-radius: 3px;
    }
    .bunk-bed {
      height: 22px; margin: 0 5px;
      border-radius: 3px; position: relative;
      box-shadow: 0 2px 6px rgba(0,0,0,0.12);
    }
    .bunk-bed.top { margin-top: 8px; }
    .bunk-bed.bottom { margin-top: 36px; }
    .bunk-pillow {
      position: absolute; top: 3px; right: 4px;
      width: 16px; height: 10px;
      border-radius: 3px; opacity: 0.85;
    }
    .bunk-ladder {
      position: absolute; right: -12px; top: 0; bottom: 0;
      width: 10px; display: flex; flex-direction: column;
      justify-content: space-around; padding: 6px 0;
    }
    .ladder-rung {
      height: 2px; width: 100%;
      background: rgba(2,132,199,0.5); border-radius: 2px;
    }
    .bunk-unit.u1 { height: 105px; }
    .bunk-unit.u2 { height: 105px; }
    .bunk-unit.u3 { height: 105px; }
    .b-mattress { background: #fff; }
    .b-pillow   { background: #BAE6FD; }

    /* Art 2: Private room */
    .art-privat { background: linear-gradient(160deg, #FEF9C3 0%, #FDE68A 60%, #FCD34D 100%); }
    .private-scene {
      display: flex; flex-direction: column;
      align-items: center; gap: 12px;
    }
    .priv-window {
      width: 80px; height: 55px;
      background: rgba(255,255,255,0.6);
      border: 3px solid rgba(180,120,0,0.3);
      border-radius: 4px; position: relative;
      box-shadow: inset 0 0 12px rgba(255,255,255,0.4);
    }
    .priv-window::before {
      content: '';
      position: absolute; left: 50%; top: 0; bottom: 0;
      width: 2px; background: rgba(180,120,0,0.25);
      transform: translateX(-50%);
    }
    .priv-window::after {
      content: '';
      position: absolute; top: 50%; left: 0; right: 0;
      height: 2px; background: rgba(180,120,0,0.25);
      transform: translateY(-50%);
    }
    .priv-bed {
      width: 140px; height: 55px;
      background: #fff; border-radius: 8px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.1);
      position: relative; overflow: hidden;
    }
    .priv-headboard {
      position: absolute; left: 0; top: 0; bottom: 0;
      width: 12px; background: #FCD34D; border-radius: 8px 0 0 8px;
    }
    .priv-blanket {
      position: absolute; left: 12px; top: 8px; bottom: 8px; right: 0;
      background: linear-gradient(90deg, #FEF3C7, #FDE68A);
      border-radius: 0 4px 4px 0;
    }
    .priv-pillow {
      position: absolute; right: 12px; top: 8px;
      width: 30px; height: 39px;
      background: #fff; border-radius: 4px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    }
    .priv-rug {
      width: 120px; height: 10px;
      background: var(--sand); opacity: 0.4; border-radius: 3px;
    }

    /* Art 3: Café cowork */
    .art-cafe { background: linear-gradient(160deg, #DCFCE7 0%, #BBF7D0 100%); }
    .cafe-scene {
      display: flex; gap: 20px; align-items: flex-end;
    }
    .cafe-table {
      width: 90px; height: 8px;
      background: var(--green); border-radius: 4px;
      position: relative;
    }
    .cafe-table::before {
      content: '';
      position: absolute; bottom: 0; left: 14px;
      width: 6px; height: 40px;
      background: rgba(16,185,129,0.6); border-radius: 0 0 3px 3px;
    }
    .cafe-table::after {
      content: '';
      position: absolute; bottom: 0; right: 14px;
      width: 6px; height: 40px;
      background: rgba(16,185,129,0.6); border-radius: 0 0 3px 3px;
    }
    .cafe-cup {
      position: relative;
    }
    .cup-body {
      width: 32px; height: 28px;
      background: #fff;
      border-radius: 3px 3px 6px 6px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      position: relative;
      margin-bottom: 4px;
    }
    .cup-body::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0;
      height: 8px; background: #7C3AED; border-radius: 3px 3px 0 0;
    }
    .cup-handle {
      position: absolute; right: -10px; top: 6px;
      width: 10px; height: 14px;
      border: 3px solid #ddd; border-left: none;
      border-radius: 0 6px 6px 0;
    }
    .cup-saucer {
      width: 42px; height: 5px;
      background: #e5e5e5; border-radius: 3px; margin: 0 auto;
    }
    .steam {
      display: flex; gap: 5px; justify-content: center; margin-bottom: 3px;
    }
    .steam-line {
      width: 2px; background: rgba(124,58,237,0.3);
      border-radius: 2px;
      animation: steamRise 1.8s ease-in-out infinite;
    }
    .steam-line:nth-child(1) { height: 10px; animation-delay: 0s; }
    .steam-line:nth-child(2) { height: 14px; animation-delay: 0.3s; }
    .steam-line:nth-child(3) { height: 10px; animation-delay: 0.6s; }

    .laptop {
      width: 70px;
    }
    .laptop-screen {
      height: 44px; background: var(--dark);
      border-radius: 4px 4px 0 0;
      display: flex; align-items: center; justify-content: center;
      position: relative; overflow: hidden;
    }
    .ls-glow {
      width: 40px; height: 20px;
      background: var(--sky); opacity: 0.15;
      border-radius: 50%; filter: blur(6px);
    }
    .ls-lines {
      position: absolute; inset: 6px;
      display: flex; flex-direction: column; gap: 4px; justify-content: center;
    }
    .ls-line {
      height: 2px; border-radius: 2px;
      background: rgba(14,165,233,0.5);
    }
    .laptop-base {
      height: 5px; background: rgba(28,25,23,0.6);
      border-radius: 0 0 4px 4px;
    }
    .laptop-foot {
      height: 3px; width: 80%; margin: 0 auto;
      background: rgba(28,25,23,0.3); border-radius: 0 0 4px 4px;
    }

    .room-body { padding: 1.5rem; }
    .room-type {
      font-size: 0.6rem; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase; margin-bottom: 0.4rem;
    }
    .room-name {
      font-family: 'Nunito', sans-serif;
      font-weight: 800; font-size: 1.2rem; margin-bottom: 0.5rem;
    }
    .room-desc {
      font-size: 0.82rem; font-weight: 300;
      color: var(--muted); line-height: 1.6; margin-bottom: 1.2rem;
    }
    .room-features { display: flex; flex-direction: column; gap: 0.3rem; margin-bottom: 1.25rem; }
    .room-feat {
      display: flex; align-items: center; gap: 0.6rem;
      font-size: 0.78rem; font-weight: 400; color: var(--dark);
    }
    .rf-check {
      width: 16px; height: 16px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .rf-check svg { width: 8px; height: 8px; }
    .room-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding-top: 1rem; border-top: 1px solid var(--border);
    }
    .room-price { font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 1.1rem; }
    .room-price span { font-size: 0.65rem; font-weight: 400; color: var(--muted); }
    .room-book {
      font-family: 'Nunito', sans-serif;
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; text-decoration: none;
      padding: 0.5rem 1.1rem; border-radius: 100px;
      color: #fff; transition: background 0.2s;
    }

    /* ─── Section 3: Welt trifft Wanderherz ────────────── */
    .community {
      background: #0C2F4A;
      padding: 7rem 4rem;
    }

    .comm-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem; align-items: center;
    }

    /* Globe CSS art */
    .globe-wrap {
      display: flex; align-items: center; justify-content: center;
    }
    .globe-outer {
      width: 340px; height: 340px;
      border-radius: 50%;
      border: 1px solid rgba(14,165,233,0.25);
      position: relative;
      background: radial-gradient(circle at 40% 35%, rgba(14,165,233,0.12), rgba(14,165,233,0.04) 60%, transparent);
    }
    .globe-outer::before {
      content: '';
      position: absolute; inset: -20px;
      border-radius: 50%;
      border: 1px solid rgba(14,165,233,0.1);
    }
    /* Latitude arcs */
    .globe-lat {
      position: absolute; left: 0; right: 0;
      border-top: 1px solid rgba(14,165,233,0.15);
      border-radius: 50%;
    }
    .lat-1 { top: 25%; height: 50%; }
    .lat-2 { top: 40%; height: 20%; }
    .lat-3 { top: 12%; height: 76%; }
    /* Longitude arcs */
    .globe-lon {
      position: absolute; top: 0; bottom: 0; left: 50%;
      border-left: 1px solid rgba(14,165,233,0.15);
      transform-origin: top center;
    }
    .lon-1 { transform: rotate(30deg); }
    .lon-2 { transform: rotate(-30deg); }
    .lon-3 { transform: rotate(60deg); }
    .lon-4 { transform: rotate(-60deg); }
    /* Location pins */
    .globe-pin {
      position: absolute;
      width: 10px; height: 10px;
      border-radius: 50%;
      transform: translate(-50%, -50%);
    }
    .globe-pin::after {
      content: '';
      position: absolute;
      inset: -5px;
      border-radius: 50%;
      border: 1px solid currentColor;
      opacity: 0.5;
      animation: ping 2.5s ease infinite;
    }
    .pin-de { left: 52%; top: 30%; background: var(--sky); color: var(--sky); animation-delay: 0s; }
    .pin-fr { left: 40%; top: 35%; background: var(--sand); color: var(--sand); animation-delay: 0.4s; }
    .pin-jp { left: 76%; top: 38%; background: var(--coral); color: var(--coral); animation-delay: 0.8s; }
    .pin-us { left: 24%; top: 40%; background: var(--green); color: var(--green); animation-delay: 1.2s; }
    .pin-br { left: 30%; top: 60%; background: var(--sand); color: var(--sand); animation-delay: 0.6s; }
    .pin-au { left: 72%; top: 68%; background: var(--purple); color: var(--purple); animation-delay: 1.5s; }
    .pin-za { left: 54%; top: 72%; background: var(--green); color: var(--green); animation-delay: 0.3s; }

    .globe-center {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
    }
    .gc-num {
      font-family: 'Nunito', sans-serif;
      font-weight: 900; font-size: 2.2rem;
      color: #fff; line-height: 1;
    }
    .gc-label {
      font-size: 0.58rem; font-weight: 400; letter-spacing: 0.15em;
      text-transform: uppercase; color: rgba(255,255,255,0.4);
      margin-top: 0.15rem;
    }

    /* Right content */
    .comm-right {}
    .comm-tag {
      font-family: 'Nunito', sans-serif;
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--sky); margin-bottom: 0.5rem;
    }
    .comm-title {
      font-family: 'Nunito', sans-serif;
      font-weight: 900; font-size: clamp(1.8rem, 3vw, 2.6rem);
      line-height: 1.15; color: #fff; margin-bottom: 0.75rem;
      letter-spacing: -0.02em;
    }
    .comm-title em { font-style: italic; color: var(--sky); }
    .comm-sub {
      font-size: 0.88rem; font-weight: 300; line-height: 1.8;
      color: rgba(255,255,255,0.5); margin-bottom: 3rem;
    }

    /* Event list */
    .event-head {
      font-size: 0.58rem; font-weight: 700; letter-spacing: 0.2em;
      text-transform: uppercase; color: rgba(255,255,255,0.3);
      margin-bottom: 1rem;
    }
    .event-list { display: flex; flex-direction: column; gap: 0; margin-bottom: 3rem; }
    .event-item {
      display: flex; align-items: center; gap: 1.25rem;
      padding: 1rem 0; border-bottom: 1px solid rgba(255,255,255,0.06);
      transition: background 0.2s;
    }
    .event-date {
      flex-shrink: 0;
      width: 42px; height: 42px;
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 8px;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 0;
    }
