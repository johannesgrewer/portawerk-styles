---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Moselhome — Immobilien & Consulting, Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      overflow-x: hidden;
    }

    body {
      overflow-x: hidden;
      background-color: #FFFFFF;
      color: #1A2B3C;
      font-family: 'Source Sans 3', sans-serif;
    }

    /* ── HERO ── */
    .hero {
      display: flex;
      height: 100vh;
      min-height: 680px;
      position: relative;
      overflow: hidden;
    }

    /* ── LEFT — IMAGE PANEL (60%) ── */
    .hero-image-panel {
      flex: 0 0 60%;
      position: relative;
      overflow: hidden;
    }

    .image-wrapper {
      position: absolute;
      inset: 32px 16px 32px 32px;
      overflow: hidden;
      transform: translateX(-100%);
      transition: transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .image-wrapper.visible {
      transform: translateX(0);
    }

    .image-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
      transition: transform 10s ease-in-out;
    }

    .image-wrapper:hover img {
      transform: scale(1.04);
    }

    /* Offset border frame — gold accent */
    .image-frame-border {
      position: absolute;
      inset: 20px 4px 20px 20px;
      border: 4px solid #B8960C;
      pointer-events: none;
      z-index: 2;
      transform: translateX(-110%);
      transition: transform 1.2s 0.15s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .image-frame-border.visible {
      transform: translateX(0);
    }

    /* Subtle dark overlay on image bottom */
    .image-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 35%;
      background: linear-gradient(to top, rgba(26, 43, 60, 0.18), transparent);
      pointer-events: none;
      z-index: 1;
    }

    /* Image label tag */
    .image-label {
      position: absolute;
      bottom: 48px;
      left: 48px;
      z-index: 3;
      display: flex;
      align-items: center;
      gap: 10px;
      opacity: 0;
      transition: opacity 0.8s 0.9s ease;
    }

    .image-label.visible { opacity: 1; }

    .image-label-dot {
      width: 8px;
      height: 8px;
      background: #B8960C;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .image-label-text {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #FFFFFF;
    }

    /* ── RIGHT — CONTENT PANEL (40%) ── */
    .hero-content-panel {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 60px 56px 60px 52px;
      position: relative;
      background: #FFFFFF;
      opacity: 0;
      transform: translateX(40px);
      transition: opacity 1s 0.3s ease, transform 1s 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .hero-content-panel.visible {
      opacity: 1;
      transform: translateX(0);
    }

    /* Overline */
    .overline {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: #B8960C;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .overline::before {
      content: '';
      display: block;
      width: 28px;
      height: 2px;
      background: #B8960C;
      flex-shrink: 0;
    }

    /* Headline */
    .headline {
      font-family: 'Playfair Display', serif;
      font-size: clamp(30px, 3.2vw, 46px);
      font-weight: 700;
      line-height: 1.15;
      color: #1A2B3C;
      margin-bottom: 24px;
    }

    /* Descriptor */
    .descriptor {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 15px;
      font-weight: 300;
      line-height: 1.7;
      color: #4A5D6E;
      margin-bottom: 36px;
      max-width: 340px;
    }

    /* Stats row */
    .stats-row {
      display: flex;
      align-items: flex-start;
      gap: 0;
      margin-bottom: 40px;
      padding: 24px 0;
      border-top: 1px solid #E8ECF0;
      border-bottom: 1px solid #E8ECF0;
    }

    .stat-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }

    .stat-item + .stat-item {
      border-left: 1px solid #E8ECF0;
      padding-left: 20px;
      margin-left: 20px;
    }

    .stat-number {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 700;
      color: #1A2B3C;
      line-height: 1;
    }

    .stat-unit {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      font-weight: 400;
      color: #B8960C;
      margin-left: 2px;
    }

    .stat-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #8A9BAC;
      margin-top: 2px;
    }

    /* CTA button */
    .cta-group {
      display: flex;
      align-items: center;
      gap: 24px;
    }

    .cta-btn {
      display: inline-block;
      padding: 14px 32px;
      background: transparent;
      border: 2px solid #B8960C;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #B8960C;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      transition: color 0.35s ease;
    }

    .cta-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: #B8960C;
      transform: translateY(101%);
      transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .cta-btn:hover::before { transform: translateY(0); }
    .cta-btn:hover { color: #FFFFFF; }

    .cta-btn span { position: relative; z-index: 1; }

    .cta-secondary {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 12px;
      font-weight: 400;
      color: #8A9BAC;
      text-decoration: none;
      letter-spacing: 0.05em;
      border-bottom: 1px solid transparent;
      padding-bottom: 2px;
      transition: color 0.3s ease, border-color 0.3s ease;
    }

    .cta-secondary:hover {
      color: #1A2B3C;
      border-color: #1A2B3C;
    }

    /* ── LOGO / TOP BAR ── */
    .top-bar {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      padding: 28px 32px 28px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      z-index: 10;
    }

    .logo {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 400;
      color: #1A2B3C;
      letter-spacing: 0.04em;
      text-decoration: none;
    }

    .logo span {
      color: #B8960C;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 32px;
      list-style: none;
    }

    .nav-links a {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #4A5D6E;
      text-decoration: none;
      transition: color 0.25s ease;
    }

    .nav-links a:hover { color: #1A2B3C; }

    /* ── SCROLL INDICATOR ── */
    .scroll-indicator {
      position: absolute;
      bottom: 32px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      z-index: 5;
      opacity: 0;
      transition: opacity 1s 1.2s ease;
    }

    .scroll-indicator.visible { opacity: 1; }

    .scroll-mouse {
      width: 22px;
      height: 34px;
      border: 1.5px solid rgba(26, 43, 60, 0.25);
      border-radius: 11px;
      display: flex;
      justify-content: center;
      padding-top: 6px;
    }

    .scroll-mouse-dot {
      width: 3px;
      height: 7px;
      background: #B8960C;
      border-radius: 2px;
      animation: scrollDot 2s ease-in-out infinite;
    }

    @keyframes scrollDot {
      0%, 100% { opacity: 1; transform: translateY(0); }
      60% { opacity: 0; transform: translateY(8px); }
    }

    .scroll-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 9px;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #8A9BAC;
    }

    /* Background secondary panel */
    .bg-secondary-panel {
      position: absolute;
      top: 0;
      right: 0;
      width: 40%;
      height: 100%;
      background: #F5F7FA;
      z-index: 0;
    }

    @media (max-width: 900px) {
      .hero {
        flex-direction: column;
        height: auto;
        min-height: 100vh;
      }
      .bg-secondary-panel { display: none; }
      .hero-image-panel {
        flex: none;
        height: 55vh;
      }
      .image-wrapper { inset: 20px 20px 20px 20px; }
      .image-frame-border { inset: 12px 12px 12px 12px; }
      .hero-content-panel {
        flex: none;
        padding: 40px 28px 80px;
      }
      .nav-links { display: none; }
      .stats-row { gap: 0; }
    }
  </style>
</head>
<body>
  <main class="hero">
    <div class="bg-secondary-panel"></div>

    <!-- Top bar -->
    <nav class="top-bar">
      <a href="#" class="logo">Mosel<span>home</span></a>
      <ul class="nav-links">
        <li><a href="#">Objekte</a></li>
        <li><a href="#">Bewertung</a></li>
        <li><a href="#">Über uns</a></li>
        <li><a href="#">Kontakt</a></li>
      </ul>
    </nav>

    <!-- LEFT: Image -->
    <div class="hero-image-panel">
      <div class="image-frame-border animate-frame"></div>
      <div class="image-wrapper animate-image">
        <img
          src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=1200&q=80&auto=format"
          alt="Moselhome — Moderne Immobilien Trier"
          loading="eager"
        />
        <div class="image-overlay"></div>
      </div>
      <div class="image-label animate-label">
        <div class="image-label-dot"></div>
        <span class="image-label-text">Trier · Moseltal</span>
      </div>
    </div>

    <!-- RIGHT: Content -->
    <div class="hero-content-panel animate-content">
      <p class="overline">Immobilien &middot; Trier</p>
      <h1 class="headline">Wo Sie zu Hause<br>sein wollen.</h1>
      <p class="descriptor">
        Wir begleiten Sie beim Kauf, Verkauf und der Bewertung von Immobilien im Trierer Raum — persönlich, transparent und mit über einem Jahrzehnt regionaler Expertise.
      </p>

      <div class="stats-row">
        <div class="stat-item">
          <div class="stat-number">
            <span class="counter" data-target="47">0</span><span class="stat-unit">+</span>
          </div>
          <span class="stat-label">Objekte</span>
        </div>
        <div class="stat-item">
          <div class="stat-number">
            <span class="counter" data-target="12">0</span>
          </div>
          <span class="stat-label">Jahre Erfahrung</span>
        </div>
        <div class="stat-item">
          <div class="stat-number">
            <span class="counter" data-target="380">0</span><span class="stat-unit">+</span>
          </div>
          <span class="stat-label">Kunden</span>
        </div>
      </div>

      <div class="cta-group">
        <a href="#" class="cta-btn"><span>Objekte ansehen</span></a>
        <a href="#" class="cta-secondary">Kostenlose Bewertung</a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator animate-scroll">
      <div class="scroll-mouse">
        <div class="scroll-mouse-dot"></div>
      </div>
      <span class="scroll-label">Scrollen</span>
    </div>
  </main>

  <script>
    // Entrance animations
    const imageEl    = document.querySelector('.animate-image');
    const frameEl    = document.querySelector('.animate-frame');
    const contentEl  = document.querySelector('.animate-content');
    const labelEl    = document.querySelector('.animate-label');
    const scrollEl   = document.querySelector('.animate-scroll');

    requestAnimationFrame(() => {
      setTimeout(() => { if (imageEl)   imageEl.classList.add('visible');   }, 100);
      setTimeout(() => { if (frameEl)   frameEl.classList.add('visible');   }, 200);
      setTimeout(() => { if (contentEl) contentEl.classList.add('visible'); }, 350);
      setTimeout(() => { if (labelEl)   labelEl.classList.add('visible');   }, 900);
      setTimeout(() => { if (scrollEl)  scrollEl.classList.add('visible');  }, 1200);
    });

    // Counter animation
    function animateCounter(el, target, duration) {
      const startTime = performance.now();
      const update = (currentTime) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        // Ease out cubic
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(eased * target);
        if (progress < 1) requestAnimationFrame(update);
      };
      requestAnimationFrame(update);
    }

    // Trigger counters after content fades in
    setTimeout(() => {
      document.querySelectorAll('.counter').forEach(counter => {
        const target = parseInt(counter.dataset.target, 10);
        animateCounter(counter, target, 1800);
      });
    }, 700);
  </script>
</body>
</html>
