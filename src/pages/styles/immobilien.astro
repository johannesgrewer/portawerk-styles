  <script>
    // ── Nav scrolled state ──
    const nav = document.getElementById('mainNav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 20);
    }, { passive: true });

    // ── Hero entrance animations ──
    const imgEl     = document.querySelector('.js-img');
    const frameEl   = document.querySelector('.js-frame');
    const contentEl = document.querySelector('.js-content');
    const tagEl     = document.querySelector('.js-tag');
    const scrollEl  = document.querySelector('.js-scroll');

    requestAnimationFrame(() => {
      setTimeout(() => imgEl     && imgEl.classList.add('visible'),     80);
      setTimeout(() => frameEl   && frameEl.classList.add('visible'),   180);
      setTimeout(() => contentEl && contentEl.classList.add('visible'), 320);
      setTimeout(() => tagEl     && tagEl.classList.add('visible'),     920);
      setTimeout(() => scrollEl  && scrollEl.classList.add('visible'), 1250);
    });

    // ── Counting animation ──
    function animateCount(el, target, dur) {
      const start = performance.now();
      const tick = (now) => {
        const p = Math.min((now - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = Math.round(eased * target);
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    setTimeout(() => {
      document.querySelectorAll('.counter').forEach(c => {
        animateCount(c, parseInt(c.dataset.target, 10), 1800);
      });
    }, 650);
  </script>
