---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Moselhome Immobilien — Trier & Moselregion</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { overflow-x: hidden; scroll-behavior: smooth; }

    body {
      overflow-x: hidden;
      background: #FFFFFF;
      color: #1A2B3C;
      font-family: 'Source Sans 3', sans-serif;
    }

    /* ─── PHOTO UTIL ─── */
    .ph { position: relative; overflow: hidden; }
    .ph img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }
    .ph:hover img { transform: scale(1.04); }

    /* ─── OVERLINE UTIL ─── */
    .overline {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: #B8960C;
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
    }
    .overline::before {
      content: '';
      display: block;
      width: 28px;
      height: 1.5px;
      background: #B8960C;
      flex-shrink: 0;
    }

    /* ─── NAV ─── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 0 40px;
      height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(255,255,255,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(26,43,60,0.06);
      transition: background 0.3s ease, box-shadow 0.3s ease;
    }

    .nav.scrolled {
      box-shadow: 0 2px 20px rgba(26,43,60,0.08);
    }

    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 19px;
      font-weight: 400;
      color: #1A2B3C;
      text-decoration: none;
      letter-spacing: 0.03em;
    }
    .nav-logo em { color: #B8960C; font-style: normal; }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 36px;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #4A5D6E;
      text-decoration: none;
      transition: color 0.25s;
    }
    .nav-links a:hover { color: #1A2B3C; }

    .nav-cta {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #B8960C;
      text-decoration: none;
      padding: 9px 22px;
      border: 1.5px solid #B8960C;
      transition: background 0.25s, color 0.25s;
    }
    .nav-cta:hover { background: #B8960C; color: #fff; }

    @media (max-width: 860px) {
      .nav { padding: 0 24px; }
      .nav-links { display: none; }
    }

    /* ─── HERO ─── */
    .hero {
      display: flex;
      height: 100vh;
      min-height: 700px;
      padding-top: 72px;
      position: relative;
      overflow: hidden;
    }

    .hero-bg-panel {
      position: absolute;
      top: 72px; right: 0;
      width: 42%;
      bottom: 0;
      background: #F5F7FA;
      z-index: 0;
    }

    /* Image side */
    .hero-img-side {
      flex: 0 0 58%;
      position: relative;
      z-index: 1;
    }

    .hero-img-frame {
      position: absolute;
      inset: 28px 14px 28px 28px;
      overflow: hidden;
      transform: translateX(-105%);
      transition: transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .hero-img-frame.visible { transform: translateX(0); }

    .hero-img-frame img {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 12s ease;
    }

    .hero-img-border {
      position: absolute;
      inset: 16px 2px 16px 16px;
      border: 3px solid rgba(184,150,12,0.55);
      pointer-events: none;
      z-index: 2;
      transform: translateX(-110%);
      transition: transform 1.2s 0.12s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .hero-img-border.visible { transform: translateX(0); }

    .hero-img-tag {
      position: absolute;
      bottom: 44px;
      left: 44px;
      z-index: 3;
      display: flex;
      align-items: center;
      gap: 9px;
      opacity: 0;
      transition: opacity 0.8s 0.95s ease;
    }
    .hero-img-tag.visible { opacity: 1; }
    .hero-img-tag-dot {
      width: 7px; height: 7px;
      background: #B8960C;
      border-radius: 50%;
    }
    .hero-img-tag-text {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #fff;
    }

    /* Content side */
    .hero-content-side {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 48px 56px 48px 52px;
      position: relative;
      z-index: 1;
      opacity: 0;
      transform: translateX(30px);
      transition: opacity 0.9s 0.3s ease, transform 0.9s 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .hero-content-side.visible {
      opacity: 1;
      transform: translateX(0);
    }

    .hero-headline {
      font-family: 'Playfair Display', serif;
      font-size: clamp(28px, 3vw, 44px);
      font-weight: 700;
      line-height: 1.18;
      color: #1A2B3C;
      margin-bottom: 20px;
    }

    .hero-sub {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 15px;
      font-weight: 300;
      line-height: 1.75;
      color: #4A5D6E;
      margin-bottom: 36px;
      max-width: 36ch;
    }

    /* Stats */
    .stats {
      display: flex;
      align-items: flex-start;
      gap: 0;
      padding: 22px 0;
      border-top: 1px solid #E2E8EE;
      border-bottom: 1px solid #E2E8EE;
      margin-bottom: 36px;
    }
    .stat {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .stat + .stat {
      border-left: 1px solid #E2E8EE;
      padding-left: 20px;
      margin-left: 20px;
    }
    .stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 700;
      color: #1A2B3C;
      line-height: 1;
    }
    .stat-num sup {
      font-size: 14px;
      color: #B8960C;
      font-weight: 400;
    }
    .stat-lbl {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #8A9BAC;
    }

    /* CTA */
    .cta-row {
      display: flex;
      align-items: center;
      gap: 24px;
    }
    .btn-gold {
      display: inline-block;
      padding: 14px 30px;
      background: #B8960C;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #fff;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      transition: background 0.3s ease;
    }
    .btn-gold:hover { background: #9A7D0A; }

    .btn-ghost {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 12px;
      font-weight: 400;
      color: #8A9BAC;
      text-decoration: none;
      letter-spacing: 0.04em;
      border-bottom: 1px solid transparent;
      padding-bottom: 2px;
      transition: color 0.25s, border-color 0.25s;
    }
    .btn-ghost:hover { color: #1A2B3C; border-color: #1A2B3C; }

    /* Scroll indicator */
    .scroll-hint {
      position: absolute;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 7px;
      z-index: 5;
      opacity: 0;
      transition: opacity 1s 1.3s ease;
    }
    .scroll-hint.visible { opacity: 1; }
    .scroll-mouse {
      width: 20px; height: 32px;
      border: 1.5px solid rgba(26,43,60,0.2);
      border-radius: 10px;
      display: flex;
      justify-content: center;
      padding-top: 5px;
    }
    .scroll-dot {
      width: 2.5px; height: 6px;
      background: #B8960C;
      border-radius: 2px;
      animation: dotScroll 2.2s ease-in-out infinite;
    }
    @keyframes dotScroll {
      0%,100% { opacity:1; transform:translateY(0); }
      65% { opacity:0; transform:translateY(8px); }
    }
    .scroll-lbl {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 9px;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #8A9BAC;
    }

    @media (max-width: 860px) {
      .hero { flex-direction: column; height: auto; min-height: 100svh; }
      .hero-bg-panel { display: none; }
      .hero-img-side { flex: none; height: 52vw; min-height: 280px; }
      .hero-img-frame { inset: 16px; }
      .hero-img-border { inset: 8px; }
      .hero-content-side { padding: 36px 24px 72px; }
      .hero-headline { max-width: none; }
      .hero-sub { max-width: none; }
    }

    /* ─── SECTION 2 — OBJEKTE ─── */
    .listings {
      background: #F5F7FA;
      padding: 96px 40px;
    }
    .listings-inner {
      max-width: 1340px;
      margin: 0 auto;
    }
    .listings-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 48px;
    }
    .listings-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(26px, 3vw, 38px);
      font-weight: 700;
      color: #1A2B3C;
      line-height: 1.2;
    }
    .all-link {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #B8960C;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
      white-space: nowrap;
      border-bottom: 1px solid transparent;
      padding-bottom: 2px;
      transition: border-color 0.25s;
    }
    .all-link:hover { border-color: #B8960C; }
    .all-link::after { content: '→'; }

    .listings-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .prop-card {
      background: #fff;
      overflow: hidden;
      transition: box-shadow 0.35s ease, transform 0.35s ease;
    }
    .prop-card:hover {
      box-shadow: 0 16px 48px rgba(26,43,60,0.11);
      transform: translateY(-5px);
    }

    .prop-badge {
      position: absolute;
      top: 14px; left: 14px;
      z-index: 2;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 4px 10px;
    }
    .badge-gold { background: #B8960C; color: #fff; }
    .badge-navy { background: #1A2B3C; color: #fff; }
    .badge-grey { background: rgba(26,43,60,0.55); color: #fff; }

    .prop-info {
      padding: 20px 22px 22px;
    }
    .prop-price {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      font-weight: 700;
      color: #1A2B3C;
      margin-bottom: 5px;
    }
    .prop-address {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 13px;
      font-weight: 400;
      color: #4A5D6E;
      margin-bottom: 14px;
    }
    .prop-specs {
      display: flex;
      gap: 20px;
      padding-top: 14px;
      border-top: 1px solid #EEF1F5;
    }
    .prop-spec {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .prop-spec-lbl {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #9AAABB;
    }
    .prop-spec-val {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 13px;
      font-weight: 400;
      color: #1A2B3C;
    }

    @media (max-width: 860px) {
      .listings { padding: 72px 24px; }
      .listings-header { flex-direction: column; align-items: flex-start; gap: 16px; }
      .listings-grid { grid-template-columns: 1fr; }
    }

    /* ─── SECTION 3 — ÜBER UNS ─── */
    .about {
      background: #1A2B3C;
      padding: 0;
      overflow: hidden;
    }
    .about-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 560px;
    }

    .about-img-side {
      position: relative;
    }
    .about-img-side img {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
      filter: brightness(0.82);
    }

    .about-content-side {
      padding: 80px 64px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .about-overline {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: #B8960C;
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    .about-overline::before {
      content: '';
      display: block;
      width: 28px; height: 1.5px;
      background: #B8960C;
      flex-shrink: 0;
    }

    .about-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(24px, 2.8vw, 36px);
      font-weight: 700;
      color: #FFFFFF;
      line-height: 1.25;
      margin-bottom: 22px;
    }

    .about-body {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 15px;
      font-weight: 300;
      line-height: 1.8;
      color: rgba(255,255,255,0.65);
      margin-bottom: 36px;
      max-width: 40ch;
    }

    .about-qualities {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px 24px;
      margin-bottom: 40px;
    }
    .quality-item {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .quality-dot {
      width: 5px; height: 5px;
      background: #B8960C;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .quality-text {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 13px;
      font-weight: 400;
      color: rgba(255,255,255,0.75);
      letter-spacing: 0.01em;
    }

    .btn-outline-white {
      display: inline-block;
      padding: 13px 28px;
      border: 1.5px solid rgba(255,255,255,0.25);
      font-family: 'Source Sans 3', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.85);
      text-decoration: none;
      transition: border-color 0.25s, color 0.25s, background 0.25s;
    }
    .btn-outline-white:hover {
      border-color: #B8960C;
      color: #B8960C;
    }

    @media (max-width: 860px) {
      .about-inner { grid-template-columns: 1fr; }
      .about-img-side { height: 50vw; min-height: 240px; position: relative; }
      .about-img-side img { position: static; width: 100%; height: 100%; }
      .about-content-side { padding: 56px 24px; }
      .about-body { max-width: none; }
    }

    /* ─── SECTION 4 — KONTAKT ─── */
    .contact {
      background: #FFFFFF;
      padding: 96px 40px;
    }
    .contact-inner {
      max-width: 1340px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
    }

    .contact-left {}
    .contact-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(26px, 3vw, 40px);
      font-weight: 700;
      color: #1A2B3C;
      line-height: 1.2;
      margin-bottom: 20px;
    }
    .contact-sub {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 15px;
      font-weight: 300;
      line-height: 1.75;
      color: #4A5D6E;
      margin-bottom: 40px;
      max-width: 38ch;
    }

    .contact-details {
      display: flex;
      flex-direction: column;
      gap: 18px;
    }
    .contact-detail-row {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .contact-icon {
      width: 36px; height: 36px;
      border: 1px solid #E2E8EE;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .contact-icon svg {
      width: 15px; height: 15px;
      stroke: #B8960C;
      fill: none;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    .contact-detail-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #9AAABB;
      margin-bottom: 2px;
    }
    .contact-detail-value {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 14px;
      font-weight: 400;
      color: #1A2B3C;
    }

    /* Form */
    .contact-form {
      background: #F5F7FA;
      padding: 40px;
    }
    .form-title {
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      font-weight: 700;
      color: #1A2B3C;
      margin-bottom: 6px;
    }
    .form-sub {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 13px;
      font-weight: 300;
      color: #8A9BAC;
      margin-bottom: 28px;
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-bottom: 14px;
    }
    .form-field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .form-field.full { grid-column: 1 / -1; }
    .form-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #8A9BAC;
    }
    .form-input,
    .form-textarea {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 14px;
      font-weight: 300;
      color: #1A2B3C;
      background: #fff;
      border: 1px solid #E2E8EE;
      padding: 11px 14px;
      outline: none;
      transition: border-color 0.2s;
      resize: none;
    }
    .form-input:focus,
    .form-textarea:focus { border-color: #B8960C; }
    .form-textarea { height: 100px; }
    .form-submit {
      width: 100%;
      padding: 14px;
      background: #1A2B3C;
      border: none;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #fff;
      cursor: pointer;
      margin-top: 6px;
      transition: background 0.25s;
    }
    .form-submit:hover { background: #B8960C; }

    @media (max-width: 860px) {
      .contact { padding: 72px 24px; }
      .contact-inner { grid-template-columns: 1fr; gap: 48px; }
      .contact-sub { max-width: none; }
      .contact-form { padding: 28px 24px; }
      .form-row { grid-template-columns: 1fr; }
    }

    /* ─── FOOTER ─── */
    .footer {
      background: #0E1B28;
      padding: 28px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }
    .footer-logo {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      font-weight: 400;
      color: rgba(255,255,255,0.7);
      letter-spacing: 0.03em;
    }
    .footer-logo em { color: #B8960C; font-style: normal; }
    .footer-copy {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 11px;
      font-weight: 300;
      color: rgba(255,255,255,0.3);
      letter-spacing: 0.04em;
    }
    @media (max-width: 600px) {
      .footer { flex-direction: column; align-items: flex-start; padding: 24px; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav" id="mainNav">
    <a href="#" class="nav-logo">Mosel<em>home</em></a>
    <ul class="nav-links">
      <li><a href="#objekte">Objekte</a></li>
      <li><a href="#agentur">Agentur</a></li>
      <li><a href="#kontakt">Kontakt</a></li>
    </ul>
    <a href="#kontakt" class="nav-cta">Bewertung anfragen</a>
  </nav>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="hero-bg-panel"></div>

    <!-- Image side -->
    <div class="hero-img-side">
      <div class="hero-img-border js-frame"></div>
      <div class="hero-img-frame js-img">
        <img
          src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1400&h=1600&q=85"
