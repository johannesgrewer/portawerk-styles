---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Basswerk — Musikschule Trier</title>
  <meta name="description" content="Basswerk Musikschule Trier. Gitarre, Bass, Schlagzeug, Gesang, Klavier. Dein Sound. Dein Weg." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    html { overflow-x: hidden; }
    body { overflow-x: hidden; max-width: 100%; }
    /* ===== RESET & BASE ===== */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --amber: #F5A623;
      --amber-dim: rgba(245, 166, 35, 0.15);
      --amber-glow: rgba(245, 166, 35, 0.4);
      --pink: #E94E77;
      --pink-dim: rgba(233, 78, 119, 0.15);
      --pink-glow: rgba(233, 78, 119, 0.4);
      --dark: #141414;
      --dark-raised: #1C1C1C;
      --dark-surface: #222222;
      --text: #F0ECE3;
      --text-muted: #8A857D;
      --font-display: "Unbounded", system-ui, sans-serif;
      --font-body: "Manrope", system-ui, sans-serif;
    }

    html {
      background: var(--dark);
      color: var(--text);
      font-family: var(--font-body);
      font-weight: 400;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      scroll-behavior: smooth;
    }

    body {
      overflow-x: hidden;
      line-height: 1.7;
    }

    ::selection {
      background: var(--amber);
      color: var(--dark);
    }

    a { text-decoration: none; color: inherit; }

    h1, h2, h3, h4 {
      font-family: var(--font-display);
      line-height: 1.15;
    }

    /* ═══════════════════════════════════════════
       NAV
    ═══════════════════════════════════════════ */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem clamp(1.5rem, 5vw, 4rem);
      background: rgba(20, 20, 20, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(245, 166, 35, 0.1);
      transition: background 0.4s ease;
    }

    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: var(--text);
      text-decoration: none;
    }

    .nav-logo span {
      color: var(--amber);
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-family: var(--font-body);
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--text-muted);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      transition: color 0.3s ease;
    }

    .nav-links a:hover {
      color: var(--amber);
    }

    /* Mobile Nav */
    .nav-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
    }

    .nav-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--text);
      margin: 5px 0;
      transition: all 0.3s ease;
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-toggle { display: block; }

      .nav-links.open {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: rgba(20, 20, 20, 0.97);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        padding: 1.5rem;
        gap: 1.25rem;
        border-bottom: 1px solid rgba(245, 166, 35, 0.1);
      }
    }

    /* ═══════════════════════════════════════════
       HERO — Equalizer Bars
    ═══════════════════════════════════════════ */
    .hero {
      position: relative;
      width: 100%;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: var(--dark);
    }

    .hero-bg-img {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .hero-bg-img img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center;
      opacity: 0.35;
    }

    /* Gradient overlay for depth + text legibility */
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      background:
        radial-gradient(ellipse 80% 60% at 50% 50%, rgba(245, 166, 35, 0.08) 0%, transparent 70%),
        linear-gradient(to top, rgba(20,20,20,0.85) 0%, rgba(20,20,20,0.45) 50%, rgba(20,20,20,0.6) 100%);
      pointer-events: none;
    }

    .img-wrap:hover img { transform: scale(1.05); }

    /* Equalizer Container — above hero-bg but below content */
    .equalizer {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 2;
      height: 65%;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      gap: clamp(3px, 0.5vw, 6px);
      padding: 0 5%;
      opacity: 0.35;
      pointer-events: none;
    }

    .eq-bar {
      flex: 1;
      max-width: 14px;
      border-radius: 4px 4px 0 0;
      animation: eqPulse var(--duration) ease-in-out infinite alternate;
      animation-delay: var(--delay);
      will-change: height;
    }

    .eq-bar--amber {
      background: linear-gradient(to top, var(--amber), rgba(245, 166, 35, 0.3));
      box-shadow: 0 0 12px var(--amber-glow);
    }

    .eq-bar--pink {
      background: linear-gradient(to top, var(--pink), rgba(233, 78, 119, 0.3));
      box-shadow: 0 0 12px var(--pink-glow);
    }

    @keyframes eqPulse {
      0% { height: var(--h-min); }
      100% { height: var(--h-max); }
    }

    /* Hero Content */
    .hero-content {
      position: relative;
      z-index: 3;
      text-align: center;
      padding: 0 1.5rem;
      max-width: 860px;
    }

    .hero-tagline {
      font-family: var(--font-body);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 1.5rem;
    }

    .hero-title {
      font-size: clamp(2.8rem, 8vw, 6rem);
      font-weight: 900;
      color: #FFFFFF;
      letter-spacing: -0.02em;
      line-height: 1.05;
      margin-bottom: 1.5rem;
      text-shadow: 0 0 60px rgba(245, 166, 35, 0.15);
    }

    .hero-title span {
      display: block;
      background: linear-gradient(135deg, var(--amber), var(--pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: clamp(0.85rem, 1.8vw, 1.05rem);
      color: var(--text-muted);
      letter-spacing: 0.12em;
      margin-bottom: 2.5rem;
      font-weight: 400;
    }

    .hero-cta {
      display: inline-block;
      font-family: var(--font-display);
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--dark);
      background: var(--amber);
      padding: 1rem 2.5rem;
      border-radius: 4px;
      letter-spacing: 0.04em;
      transition: all 0.3s ease;
      box-shadow: 0 0 30px var(--amber-glow), 0 4px 20px rgba(0,0,0,0.4);
    }

    .hero-cta:hover {
      background: #FFB940;
      box-shadow: 0 0 50px var(--amber-glow), 0 4px 30px rgba(0,0,0,0.5);
      transform: translateY(-2px);
    }

    .hero-stats {
      margin-top: 3rem;
      font-size: 0.85rem;
      color: var(--text-muted);
      letter-spacing: 0.1em;
      font-weight: 500;
    }

    .hero-stats span {
      display: inline-block;
      margin: 0 0.75rem;
    }

    .hero-stats .stat-divider {
      color: rgba(245, 166, 35, 0.3);
    }

    /* ═══════════════════════════════════════════
       SECTION 2 — Instrumente
    ═══════════════════════════════════════════ */
    .instrumente {
      padding: clamp(4rem, 10vw, 8rem) clamp(1.5rem, 5vw, 4rem);
      background: var(--dark);
      position: relative;
    }

    .instrumente::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--amber-dim), transparent);
    }

    .section-header {
      text-align: center;
      margin-bottom: clamp(2.5rem, 5vw, 4rem);
    }

    .section-label {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 1rem;
    }

    .section-title {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 800;
      color: var(--text);
      letter-spacing: -0.01em;
    }

    .instrumente-inner {
      max-width: 1600px;
      margin: 0 auto;
    }

    /* Instrument Cards Grid */
    .instrument-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 1.25rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    @media (max-width: 1024px) {
      .instrument-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 640px) {
      .instrument-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 420px) {
      .instrument-grid {
        grid-template-columns: 1fr;
      }
    }

    .instrument-card {
      background: var(--dark-raised);
      border-radius: 8px;
      padding: 2rem 1.5rem;
      border: 1px solid rgba(255,255,255,0.04);
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .instrument-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
    }

    .instrument-card--amber::before {
      background: var(--amber);
      box-shadow: 0 0 15px var(--amber-glow);
    }

    .instrument-card--pink::before {
      background: var(--pink);
      box-shadow: 0 0 15px var(--pink-glow);
    }

    .instrument-card:hover {
      border-color: rgba(255,255,255,0.08);
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.4);
    }

    .instrument-icon {
      width: 48px;
      height: 48px;
      margin-bottom: 1.25rem;
      opacity: 0.9;
    }

    .instrument-icon svg {
      width: 100%;
      height: 100%;
    }

    .instrument-card h3 {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: var(--text);
    }

    .instrument-card p {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 0.25rem;
      line-height: 1.5;
    }

    .instrument-meta {
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid rgba(255,255,255,0.06);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .instrument-age {
      font-size: 0.75rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    .instrument-price {
      font-family: var(--font-display);
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--amber);
    }

    /* ═══════════════════════════════════════════
       SECTION 3 — Die Buehne
    ═══════════════════════════════════════════ */
    .buehne {
      padding: clamp(4rem, 10vw, 8rem) clamp(1.5rem, 5vw, 4rem);
      background: var(--dark-raised);
      position: relative;
    }

    .buehne::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--pink-dim), transparent);
    }

    .buehne-wrapper {
      max-width: 1600px;
      margin: 0 auto;
    }

    .buehne-inner {
      max-width: 900px;
      margin: 0 auto;
    }

    .buehne-intro {
      text-align: center;
      margin-bottom: 3rem;
    }

    .buehne-intro .section-label {
      color: var(--pink);
    }

    .buehne-text {
      font-size: clamp(1rem, 2vw, 1.15rem);
      color: var(--text);
      line-height: 1.8;
      max-width: 640px;
      margin: 1.5rem auto 0;
      text-align: center;
    }

    /* Event Card */
    .event-card {
      background: var(--dark);
      border: 1px solid rgba(233, 78, 119, 0.15);
      border-radius: 8px;
      padding: clamp(2rem, 4vw, 3rem);
      margin: 3rem auto;
      max-width: 700px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .event-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 60%;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--pink), transparent);
    }

    .event-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--pink);
      margin-bottom: 1rem;
    }

    .event-title {
      font-size: clamp(1.3rem, 3vw, 1.8rem);
      font-weight: 800;
      color: var(--text);
      margin-bottom: 0.75rem;
    }

    .event-details {
      font-size: 1rem;
      color: var(--text-muted);
      line-height: 1.8;
    }

    .event-details strong {
      color: var(--text);
      font-weight: 600;
    }

    .event-free {
      display: inline-block;
      margin-top: 1rem;
      font-family: var(--font-display);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      color: var(--amber);
      background: var(--amber-dim);
      padding: 0.4rem 1.2rem;
      border-radius: 50px;
    }

    /* Quote */
    .quote-block {
      max-width: 600px;
      margin: 3rem auto;
      text-align: center;
      position: relative;
    }

    .quote-block::before {
      content: "\201C";
      font-family: var(--font-display);
      font-size: 5rem;
      color: var(--amber);
      opacity: 0.2;
      position: absolute;
      top: -2.5rem;
      left: 50%;
      transform: translateX(-50%);
      line-height: 1;
    }

    .quote-text {
      font-family: var(--font-display);
      font-size: clamp(1.1rem, 2.5vw, 1.4rem);
      font-weight: 500;
      color: var(--text);
      line-height: 1.6;
      font-style: italic;
      position: relative;
    }

    .quote-author {
      margin-top: 1rem;
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    .quote-author strong {
      color: var(--amber);
      font-weight: 600;
    }

    /* Contact Row */
    .contact-row {
      display: flex;
      justify-content: center;
      gap: 2.5rem;
      margin-top: 3rem;
      flex-wrap: wrap;
    }

    .contact-item {
      font-size: 0.9rem;
      color: var(--text-muted);
    }

    .contact-item strong {
      color: var(--text);
      font-weight: 600;
    }

    .contact-item a {
      color: var(--amber);
      transition: color 0.2s ease;
    }

    .contact-item a:hover {
      color: #FFB940;
    }

    /* ═══════════════════════════════════════════
       FOOTER
    ═══════════════════════════════════════════ */
    .footer {
      padding: 2.5rem clamp(1.5rem, 5vw, 4rem);
      background: var(--dark);
      border-top: 1px solid rgba(255,255,255,0.04);
      text-align: center;
    }

    .footer p {
      font-size: 0.75rem;
      color: var(--text-muted);
      letter-spacing: 0.05em;
    }

    .footer a {
      color: var(--amber);
      transition: color 0.2s;
    }

    .footer a:hover {
      color: #FFB940;
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <a href="#" class="nav-logo">Bass<span>werk</span></a>
    <ul class="nav-links" id="navLinks">
      <li><a href="#instrumente">Instrumente</a></li>
      <li><a href="#buehne">Buehne</a></li>
      <li><a href="#kontakt">Kontakt</a></li>
    </ul>
    <button class="nav-toggle" id="navToggle" aria-label="Navigation oeffnen">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- HERO — Equalizer Bars -->
  <section class="hero">

    <!-- Background concert photo -->
    <div class="hero-bg-img">
      <img src="https://images.unsplash.com/photo-1470229722913-7c0e2dbbafd3?auto=format&fit=crop&w=1600&h=1000&q=80" alt="Konzert Bühne Lichter" loading="eager" />
    </div>

    <!-- Equalizer bars generated via inline script -->
    <div class="equalizer" id="equalizer" aria-hidden="true"></div>

    <div class="hero-content">
      <p class="hero-tagline">Musikschule Trier</p>
      <h1 class="hero-title">
        Dein Sound.<br />
        <span>Dein Weg.</span>
      </h1>
      <p class="hero-sub">Gitarre &middot; Bass &middot; Schlagzeug &middot; Gesang &middot; Klavier</p>
      <a href="#kontakt" class="hero-cta">Probestunde buchen</a>
      <div class="hero-stats">
        <span>230+ Schueler</span>
        <span class="stat-divider">|</span>
        <span>8 Lehrkraefte</span>
        <span class="stat-divider">|</span>
        <span>Seit 2016</span>
      </div>
    </div>
  </section>

  <!-- SECTION 2 — Instrumente -->
  <section class="instrumente" id="instrumente">
    <div class="instrumente-inner">
    <div class="section-header">
      <p class="section-label">Was wir unterrichten</p>
      <h2 class="section-title">Instrumente</h2>
    </div>

    <div class="instrument-grid">

      <!-- Gitarre -->
      <div class="instrument-card instrument-card--amber">
        <div class="instrument-icon">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M30 4L34 8L28 14L30 16C30 16 32 18 32 22C32 26 28 30 24 30C20 30 16 26 16 22C16 18 20 14 24 16L26 14L20 8L24 4" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24" cy="23" r="3" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="24" y1="30" x2="24" y2="44" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3>Gitarre</h3>
        <p>Akustik & E-Gitarre</p>
        <div class="instrument-meta">
          <span class="instrument-age">Ab 8 Jahren</span>
          <span class="instrument-price">ab 79 EUR/Monat</span>
        </div>
      </div>

      <!-- Bass -->
      <div class="instrument-card instrument-card--pink">
        <div class="instrument-icon">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="18" y="6" width="12" height="6" rx="2" stroke="#E94E77" stroke-width="1.5"/>
            <line x1="20" y1="6" x2="20" y2="2" stroke="#E94E77" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="24" y1="6" x2="24" y2="2" stroke="#E94E77" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="28" y1="6" x2="28" y2="2" stroke="#E94E77" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="24" y1="12" x2="24" y2="20" stroke="#E94E77" stroke-width="1.5"/>
            <ellipse cx="24" cy="32" rx="10" ry="14" stroke="#E94E77" stroke-width="1.5"/>
            <circle cx="24" cy="32" r="3" stroke="#E94E77" stroke-width="1.5"/>
          </svg>
        </div>
        <h3>Bass</h3>
        <p>E-Bass & Kontrabass</p>
        <div class="instrument-meta">
          <span class="instrument-age">Ab 10 Jahren</span>
          <span class="instrument-price">ab 79 EUR/Monat</span>
        </div>
      </div>

      <!-- Schlagzeug -->
      <div class="instrument-card instrument-card--amber">
        <div class="instrument-icon">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="24" cy="28" rx="14" ry="6" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="10" y1="28" x2="10" y2="40" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="38" y1="28" x2="38" y2="40" stroke="#F5A623" stroke-width="1.5"/>
            <ellipse cx="24" cy="40" rx="14" ry="4" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="16" y1="8" x2="22" y2="22" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="32" y1="8" x2="26" y2="22" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="14" cy="6" r="3" fill="#F5A623" opacity="0.3" stroke="#F5A623" stroke-width="1.5"/>
            <circle cx="34" cy="6" r="3" fill="#F5A623" opacity="0.3" stroke="#F5A623" stroke-width="1.5"/>
          </svg>
        </div>
