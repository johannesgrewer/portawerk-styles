  <!-- SCRIPTS -->
  <script>
    // Mobile nav toggle
    document.getElementById('navToggle').addEventListener('click', function() {
      document.getElementById('navLinks').classList.toggle('open');
    });

    // Generate equalizer bars
    (function() {
      var container = document.getElementById('equalizer');
      var barCount = 50;
      var colors = ['amber', 'pink'];

      for (var i = 0; i < barCount; i++) {
        var bar = document.createElement('div');
        bar.className = 'eq-bar eq-bar--' + colors[i % 2];

        var hMin = 8 + Math.random() * 15;
        var hMax = 30 + Math.random() * 55;
        var duration = 0.6 + Math.random() * 1.2;
        var delay = Math.random() * 2;

        bar.style.setProperty('--h-min', hMin + '%');
        bar.style.setProperty('--h-max', hMax + '%');
        bar.style.setProperty('--duration', duration + 's');
        bar.style.setProperty('--delay', delay + 's');

        container.appendChild(bar);
      }
    })();
  </script>

