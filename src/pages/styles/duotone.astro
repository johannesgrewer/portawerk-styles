---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Zweiklang — Eventfotografie & Filmproduktion | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Work+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --orange: #FF5C00;
      --dark:   #0D0D0D;
      --white:  #FFFFFF;
    }

    body {
      background: var(--dark);
      color: var(--white);
      font-family: 'Work Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 3.5rem;
      background: var(--dark);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.2rem;
      letter-spacing: -0.02em;
      color: var(--white);
    }
    .nav-logo span { color: var(--orange); }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.62rem;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--orange); }
    .nav-cta {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--dark);
      background: var(--orange);
      padding: 0.65rem 1.5rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .nav-cta:hover { background: var(--white); }

    .hero {
      min-height: 100vh;
      padding-top: 57px;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    /* LEFT — dark side */
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 3rem 4rem 4.5rem;
      gap: 2rem;
      border-right: 1px solid rgba(255,255,255,0.06);
    }

    .label-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--orange);
    }
    .label-row::before {
      content: '';
      display: block;
      width: 2rem;
      height: 2px;
      background: var(--orange);
    }

    .hero-headline {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(3.5rem, 8vw, 7rem);
      line-height: 0.88;
      letter-spacing: -0.03em;
      text-transform: uppercase;
    }
    .line-white  { display: block; color: var(--white); }
    .line-orange { display: block; color: var(--orange); }
    .line-outline {
      display: block;
      -webkit-text-stroke: 2px rgba(255,255,255,0.3);
      color: transparent;
    }

    .hero-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.9;
      color: rgba(255,255,255,0.4);
      max-width: 42ch;
    }

    .service-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .svc-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.9rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .svc-name {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--white);
    }
    .svc-arrow { color: var(--orange); font-size: 0.8rem; }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 1.75rem;
    }
    .cta-btn {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--dark);
      background: var(--orange);
      text-decoration: none;
      padding: 0.9rem 2rem;
      transition: background 0.2s;
    }
    .cta-btn:hover { background: var(--white); }
    .cta-link {
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
      text-decoration: none;
    }

    /* RIGHT — orange side */
    .hero-right {
      background: var(--orange);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 6rem 3.5rem 4rem;
    }

    .right-eyebrow {
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(13,13,13,0.5);
    }

    .right-quote {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(1.8rem, 4vw, 3rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--dark);
    }

    .project-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: rgba(0,0,0,0.15);
    }
    .proj-cell {
      background: var(--orange);
      padding: 1.5rem;
    }
    .pc-type {
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(13,13,13,0.45);
      margin-bottom: 0.4rem;
    }
    .pc-name {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--dark);
    }

    .right-stats {
      display: flex;
      gap: 2.5rem;
    }
    .rs-item {}
    .rs-num {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 2rem;
      line-height: 1;
      letter-spacing: -0.03em;
      color: var(--dark);
    }
    .rs-label {
      font-size: 0.58rem;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(13,13,13,0.45);
      margin-top: 0.2rem;
    }

    /* Photo container */
    .ph { position: relative; overflow: hidden; }
    .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
    .ph:hover img { transform: scale(1.05); }

    /* Section 2 — Portfolio */
    .portfolio-section {
      background: var(--dark);
      padding: 5rem 4rem;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .portfolio-inner {
      max-width: 1600px;
      margin-left: auto;
      margin-right: auto;
    }
    .sec-label {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 2.5rem;
    }
    .sec-label::before {
      content: '';
      display: block;
      width: 2rem;
      height: 2px;
      background: var(--orange);
    }
    .portfolio-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      background: rgba(255,255,255,0.04);
    }
    .port-card {
      position: relative;
      background: #111;
    }
    .port-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13,13,13,0.85) 0%, transparent 55%);
      pointer-events: none;
      z-index: 1;
    }
    .port-meta {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1.5rem;
      z-index: 2;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
    }
    .port-type {
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 0.35rem;
    }
    .port-name {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      color: var(--white);
      letter-spacing: -0.01em;
    }
    .port-arrow {
      color: var(--orange);
      font-size: 1.1rem;
      flex-shrink: 0;
    }

    /* Section 3 — Kontakt + Prozess */
    .contact-section {
      background: var(--dark);
      padding: 5rem 4rem;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .contact-inner {
      max-width: 1600px;
      margin-left: auto;
      margin-right: auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      background: rgba(255,255,255,0.04);
    }
    .contact-left {
      background: var(--dark);
      padding: 3.5rem;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .contact-headline {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(2rem, 4vw, 3.2rem);
      line-height: 0.9;
      letter-spacing: -0.03em;
      text-transform: uppercase;
    }
    .ch-white { display: block; color: var(--white); }
    .ch-orange { display: block; color: var(--orange); }
    .contact-detail-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .cd-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .cd-label {
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
    }
    .cd-value {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--white);
    }
    .cta-full {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--dark);
      background: var(--orange);
      text-decoration: none;
      padding: 1rem 2rem;
      display: inline-block;
      transition: background 0.2s;
      align-self: flex-start;
    }
    .cta-full:hover { background: var(--white); }

    .contact-right {
      background: #111;
      padding: 3.5rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .process-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      background: rgba(255,255,255,0.04);
      flex: 1;
    }
    .proc-cell {
      background: #111;
      padding: 1.75rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      transition: background 0.2s;
    }
    .proc-cell:hover { background: #161616; }
    .proc-num {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 2rem;
      line-height: 1;
      color: var(--orange);
      letter-spacing: -0.04em;
    }
    .proc-name {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--white);
      letter-spacing: -0.01em;
    }
    .proc-desc {
      font-size: 0.72rem;
      font-weight: 300;
      line-height: 1.7;
      color: rgba(255,255,255,0.35);
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Zwei<span>klang</span></div>
    <ul class="nav-links">
      <li><a href="#">Events</a></li>
      <li><a href="#">Film</a></li>
      <li><a href="#">Portraits</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <a href="#" class="nav-cta">Anfrage stellen</a>
  </nav>

  <section class="hero">
    <div class="hero-left">
      <div class="label-row">Eventfotografie · Trier</div>

      <h1 class="hero-headline">
        <span class="line-white">Zwei</span>
        <span class="line-orange">Töne.</span>
        <span class="line-outline">Ein</span>
        <span class="line-white">Bild.</span>
      </h1>

      <p class="hero-body">
        Wir halten fest, was wirklich passiert.
        Nicht das Gestellte — das Echte.
        Für Marken, die verstehen, dass Bilder Entscheidungen treffen.
      </p>

      <div class="service-list">
        <div class="svc-row">
          <span class="svc-name">Event-Fotografie</span>
          <span class="svc-arrow">→</span>
        </div>
        <div class="svc-row">
          <span class="svc-name">Werbefilm</span>
          <span class="svc-arrow">→</span>
        </div>
        <div class="svc-row">
          <span class="svc-name">Portrait & Team</span>
          <span class="svc-arrow">→</span>
        </div>
        <div class="svc-row">
          <span class="svc-name">Social Content</span>
          <span class="svc-arrow">→</span>
        </div>
      </div>

      <div class="cta-row">
        <a href="#" class="cta-btn">Projekt anfragen →</a>
        <a href="#" class="cta-link">Portfolio ansehen</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="right-eyebrow">Eventfotografie & Filmproduktion · Trier</div>

      <div class="right-quote">
        Bilder, die<br>Entscheidungen<br>treffen.
      </div>

      <div class="project-grid">
        <div class="proj-cell">
          <div class="pc-type">Letztes Projekt</div>
          <div class="pc-name">Weinfest Mosel 2024</div>
        </div>
        <div class="proj-cell">
          <div class="pc-type">Aktuell</div>
          <div class="pc-name">Stadtwerke Trier Kampagne</div>
        </div>
        <div class="proj-cell">
          <div class="pc-type">Referenz</div>
          <div class="pc-name">Porta Nigra Festival</div>
        </div>
        <div class="proj-cell">
          <div class="pc-type">Film</div>
          <div class="pc-name">Moseltherme Kamp-Bornhofen</div>
        </div>
      </div>

      <div class="right-stats">
        <div class="rs-item">
          <div class="rs-num">240+</div>
          <div class="rs-label">Events</div>
        </div>
        <div class="rs-item">
          <div class="rs-num">7</div>
          <div class="rs-label">Jahre</div>
        </div>
        <div class="rs-item">
          <div class="rs-num">2</div>
          <div class="rs-label">Auszeichnungen</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Portfolio Grid -->
  <section class="portfolio-section">
    <div class="portfolio-inner">
      <div class="sec-label">Ausgewählte Arbeiten</div>
      <div class="portfolio-grid">

        <div class="port-card">
          <div class="ph" style="height:340px;">
            <img src="https://images.unsplash.com/photo-1519671482749-fd09be7ccebf?auto=format&fit=crop&w=1200&h=800&q=80" alt="Event Fotografie" loading="lazy" />
          </div>
          <div class="port-overlay"></div>
          <div class="port-meta">
            <div>
              <div class="port-type">Event-Fotografie</div>
              <div class="port-name">Weinfest Mosel 2024</div>
            </div>
            <div class="port-arrow">→</div>
          </div>
        </div>

        <div class="port-card">
          <div class="ph" style="height:340px;">
            <img src="https://images.unsplash.com/photo-1471193945509-9ad0617afabf?auto=format&fit=crop&w=1200&h=800&q=80" alt="Werbefilm Produktion" loading="lazy" />
          </div>
          <div class="port-overlay"></div>
          <div class="port-meta">
            <div>
              <div class="port-type">Werbefilm</div>
              <div class="port-name">Stadtwerke Trier Kampagne</div>
            </div>
            <div class="port-arrow">→</div>
          </div>
        </div>

        <div class="port-card">
          <div class="ph" style="height:340px;">
            <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?auto=format&fit=crop&w=1200&h=800&q=80" alt="Portrait" loading="lazy" />
          </div>
          <div class="port-overlay"></div>
          <div class="port-meta">
            <div>
              <div class="port-type">Portrait & Team</div>
              <div class="port-name">Porta Nigra Festival</div>
            </div>
            <div class="port-arrow">→</div>
          </div>
        </div>

        <div class="port-card">
          <div class="ph" style="height:340px;">
            <img src="https://images.unsplash.com/photo-1598440947619-2c35fc9aa908?auto=format&fit=crop&w=1200&h=800&q=80" alt="Film Produktion" loading="lazy" />
          </div>
          <div class="port-overlay"></div>
          <div class="port-meta">
            <div>
              <div class="port-type">Film</div>
              <div class="port-name">Moseltherme Kamp-Bornhofen</div>
            </div>
            <div class="port-arrow">→</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Section 3: Kontakt + Prozess -->
  <section class="contact-section">
    <div class="contact-inner">

      <div class="contact-left">
        <div class="sec-label">Kontakt</div>
        <h2 class="contact-headline">
          <span class="ch-white">Projekt</span>
          <span class="ch-orange">anfragen.</span>
        </h2>
        <div class="contact-detail-list">
          <div class="cd-row">
            <span class="cd-label">Standort</span>
            <span class="cd-value">Trier, Deutschland</span>
          </div>
          <div class="cd-row">
            <span class="cd-label">Telefon</span>
            <span class="cd-value">+49 651 123 456 0</span>
          </div>
          <div class="cd-row">
            <span class="cd-label">E-Mail</span>
            <span class="cd-value">hallo@zweiklang.de</span>
          </div>
          <div class="cd-row">
            <span class="cd-label">Instagram</span>
            <span class="cd-value">@zweiklang.trier</span>
          </div>
        </div>
        <a href="#" class="cta-full">Anfrage stellen →</a>
      </div>

      <div class="contact-right">
        <div class="sec-label">Wie wir arbeiten</div>
        <div class="process-grid">
          <div class="proc-cell">
            <div class="proc-num">01</div>
            <div class="proc-name">Briefing</div>
            <div class="proc-desc">Wir lernen euer Projekt, eure Marke und eure Ziele kennen.</div>
          </div>
          <div class="proc-cell">
            <div class="proc-num">02</div>
            <div class="proc-name">Konzept</div>
            <div class="proc-desc">Wir entwickeln ein visuelles Konzept — Stil, Bildsprache, Dramaturgie.</div>
          </div>
          <div class="proc-cell">
            <div class="proc-num">03</div>
            <div class="proc-name">Produktion</div>
            <div class="proc-desc">Dreh- oder Shooting-Tag mit professionellem Equipment vor Ort.</div>
          </div>
          <div class="proc-cell">
            <div class="proc-num">04</div>
            <div class="proc-name">Delivery</div>
            <div class="proc-desc">Finaler Output in euren gewünschten Formaten — schnell, sauber, fertig.</div>
          </div>
        </div>
      </div>

    </div>
  </section>
</body>
</html>
