      </div>
      <div class="hero-credit-divider"></div>
      <div class="hero-credit">
        <span class="hero-credit-number">2019</span>
        <span class="hero-credit-text">In den Gewoelben<br />der Altstadt</span>
      </div>
    </div>
    <div class="hero-actions">
      <a href="#weinkarte" class="hero-link">
