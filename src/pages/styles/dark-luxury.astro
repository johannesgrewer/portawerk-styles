---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>AURUM Trier — Uhren & Schmuck seit 1923</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    html { overflow-x: hidden; }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --gold:        #C8A96E;
      --gold-dim:    rgba(200,169,110,0.18);
      --gold-faint:  rgba(200,169,110,0.07);
      --ink:         #080808;
      --charcoal:    #111111;
      --charcoal-2:  #181818;
      --cream:       #F0EAE0;
      --muted:       #6A6055;
      --font-display: "Cormorant Garamond", Georgia, "Times New Roman", serif;
      --font-body:    "Montserrat", system-ui, sans-serif;
    }

    html {
      background: var(--ink);
      color: var(--cream);
      font-family: var(--font-body);
      font-weight: 300;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      scroll-behavior: smooth;
    }

    body { overflow-x: hidden; position: relative; }

    /* Persistent film grain */
    body::after {
      content: "";
      position: fixed;
      inset: -50%;
      width: 200%;
      height: 200%;
      z-index: 9999;
      pointer-events: none;
      opacity: 0.035;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-size: 200px 200px;
      animation: grainDrift 0.6s steps(3) infinite;
    }

    @keyframes grainDrift {
      0%   { transform: translate(0, 0); }
      33%  { transform: translate(-2%, -3%); }
      66%  { transform: translate(3%, 1%); }
      100% { transform: translate(-1%, 2%); }
    }

    ::selection { background: var(--gold); color: var(--ink); }

    img { display: block; max-width: 100%; }


    /* ═══════════════════════════════════════════
       ANIMATIONS
    ═══════════════════════════════════════════ */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    @keyframes lineGrow {
      from { transform: scaleX(0); }
      to   { transform: scaleX(1); }
    }

    @keyframes kenBurns {
      0%   { transform: scale(1.04); }
      100% { transform: scale(1); }
    }

    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
                  transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-d1 { transition-delay: 0.1s; }
    .reveal-d2 { transition-delay: 0.2s; }
    .reveal-d3 { transition-delay: 0.32s; }
    .reveal-d4 { transition-delay: 0.44s; }


    /* ═══════════════════════════════════════════
       NAVIGATION
    ═══════════════════════════════════════════ */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.6rem clamp(1.5rem, 5vw, 4rem);
      transition: background 0.5s ease, padding 0.4s ease;
    }

    .nav.scrolled {
      background: rgba(8,8,8,0.92);
      padding-top: 1rem;
      padding-bottom: 1rem;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(200,169,110,0.08);
    }

    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.4rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--cream);
      text-decoration: none;
      line-height: 1;
    }

    .nav-logo span {
      color: var(--gold);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(240,234,224,0.45);
      text-decoration: none;
      transition: color 0.3s ease;
      position: relative;
    }

    .nav-links a::after {
      content: "";
      position: absolute;
      bottom: -3px;
      left: 0;
      width: 0;
      height: 1px;
      background: var(--gold);
      transition: width 0.35s ease;
    }

    .nav-links a:hover { color: var(--gold); }
    .nav-links a:hover::after { width: 100%; }

    .nav-reserve {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      border: 1px solid rgba(200,169,110,0.35);
      padding: 0.55rem 1.4rem;
      transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    }

    .nav-reserve:hover {
      background: var(--gold);
      color: var(--ink);
      border-color: var(--gold);
    }

    .nav-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      min-width: 44px;
      min-height: 44px;
      align-items: center;
      justify-content: center;
    }

    .nav-toggle span {
      display: block;
      width: 22px;
      height: 1px;
      background: var(--cream);
      transition: transform 0.3s ease, opacity 0.3s ease;
    }


    /* ═══════════════════════════════════════════
       HERO
    ═══════════════════════════════════════════ */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
      filter: brightness(0.45) saturate(0.75);
      animation: kenBurns 16s cubic-bezier(0.25, 0, 0.1, 1) both;
      will-change: transform;
    }

    /* Gradient mask bottom-up + left vignette */
    .hero-bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg,
          rgba(8,8,8,0.25) 0%,
          rgba(8,8,8,0)    35%,
          rgba(8,8,8,0.55) 70%,
          rgba(8,8,8,0.92) 100%
        ),
        linear-gradient(90deg,
          rgba(8,8,8,0.5) 0%,
          rgba(8,8,8,0)   50%
        );
    }

    .hero-content {
      position: relative;
      z-index: 10;
      padding: clamp(8rem, 15vh, 12rem) clamp(1.5rem, 5vw, 4rem) clamp(4rem, 8vh, 6rem);
      max-width: 1200px;
    }

    .hero-eyebrow {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeInUp 0.7s ease 0.4s both;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .hero-eyebrow::before {
      content: "";
      display: block;
      width: 2.5rem;
      height: 1px;
      background: var(--gold);
      transform-origin: left;
      animation: lineGrow 0.7s ease 0.6s both;
    }

    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(3.2rem, 7.5vw, 7rem);
      font-weight: 400;
      line-height: 1.0;
      letter-spacing: -0.01em;
      color: var(--cream);
      margin-bottom: 2rem;
    }

    .hero-title-line {
      display: block;
      opacity: 0;
      animation: fadeInUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .hero-title-line:nth-child(1) { animation-delay: 0.7s; }
    .hero-title-line:nth-child(2) { animation-delay: 0.95s; }

    .hero-title-line em {
      font-style: italic;
      color: var(--gold);
    }

    .hero-subtitle {
      font-size: 0.8rem;
      font-weight: 300;
      line-height: 1.75;
      color: rgba(240,234,224,0.55);
      max-width: 34ch;
      margin-bottom: 2.5rem;
      opacity: 0;
      animation: fadeInUp 0.7s ease 1.25s both;
      letter-spacing: 0.02em;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
      opacity: 0;
      animation: fadeInUp 0.7s ease 1.5s both;
    }

    .btn-gold {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--gold);
      text-decoration: none;
      padding: 0.9rem 2.2rem;
      display: inline-block;
      transition: background 0.3s ease, color 0.3s ease;
      min-height: 48px;
      display: flex;
      align-items: center;
    }

    .btn-gold:hover {
      background: #D4B87A;
    }

    .btn-ghost {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(240,234,224,0.6);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      transition: color 0.3s ease;
      min-height: 48px;
    }

    .btn-ghost:hover { color: var(--gold); }

    .btn-ghost svg {
      width: 14px; height: 14px;
      transition: transform 0.35s ease;
    }

    .btn-ghost:hover svg { transform: translateX(5px); }

    /* Hero stats row */
    .hero-stats {
      position: absolute;
      right: clamp(1.5rem, 5vw, 4rem);
      bottom: clamp(4rem, 8vh, 6rem);
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 1.75rem;
      opacity: 0;
      animation: fadeIn 1s ease 1.8s both;
    }

    .hero-stat {
      text-align: right;
    }

    .hero-stat-number {
      font-family: var(--font-display);
      font-size: 2rem;
      font-weight: 400;
      color: var(--cream);
      line-height: 1;
    }

    .hero-stat-label {
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 0.25rem;
    }

    .hero-stat-divider {
      width: 1px;
      height: 1.5rem;
      background: rgba(200,169,110,0.2);
      align-self: flex-end;
    }


    /* ═══════════════════════════════════════════
       SECTION SHARED
    ═══════════════════════════════════════════ */
    .section-eyebrow {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
    }

    .section-eyebrow::before {
      content: "";
      display: block;
      width: 2rem;
      height: 1px;
      background: var(--gold);
      flex-shrink: 0;
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4.5vw, 3.8rem);
      font-weight: 400;
      line-height: 1.1;
      color: var(--cream);
    }

    .section-lead {
      font-size: 0.85rem;
      font-weight: 300;
      line-height: 1.85;
      color: var(--muted);
      max-width: 50ch;
    }

    /* Gold rule */
    hr.gold {
      border: none;
      width: 3rem;
      height: 1px;
      background: var(--gold);
      margin: 1.5rem 0;
    }


    /* ═══════════════════════════════════════════
       KOLLEKTION
    ═══════════════════════════════════════════ */
    .kollektion {
      padding: clamp(6rem, 12vh, 10rem) clamp(1.5rem, 5vw, 4rem);
      max-width: 1300px;
      margin: 0 auto;
    }

    .kollektion-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 2rem;
      margin-bottom: 4rem;
      flex-wrap: wrap;
    }

    .kollektion-header-text {}

    .kollektion-link {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.6rem;
      white-space: nowrap;
      flex-shrink: 0;
      transition: gap 0.3s ease;
      min-height: 44px;
    }

    .kollektion-link:hover { gap: 1rem; }

    .watch-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .watch-card {
      position: relative;
      background: var(--charcoal);
      cursor: crosshair;
      overflow: hidden;
    }

    .watch-card-img-wrap {
      position: relative;
      overflow: hidden;
      aspect-ratio: 3 / 4;
    }

    .watch-card-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: brightness(0.88) saturate(0.85);
      transition: transform 0.9s cubic-bezier(0.22, 1, 0.36, 1),
                  filter 0.6s ease;
    }

    .watch-card:hover .watch-card-img-wrap img {
      transform: scale(1.05);
      filter: brightness(0.96) saturate(1.0);
    }

    /* Gold line sweep on hover */
    .watch-card-img-wrap::after {
      content: "";
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: var(--gold);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .watch-card:hover .watch-card-img-wrap::after {
      transform: scaleX(1);
    }

    .watch-card-body {
      padding: 1.5rem;
    }

    .watch-card-brand {
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.6rem;
    }

    .watch-card-name {
      font-family: var(--font-display);
      font-size: 1.4rem;
      font-weight: 400;
      line-height: 1.2;
      color: var(--cream);
      margin-bottom: 0.4rem;
    }

    .watch-card-ref {
      font-size: 0.65rem;
      font-weight: 300;
      color: var(--muted);
      letter-spacing: 0.08em;
      margin-bottom: 1.25rem;
    }

    .watch-card-footer {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding-top: 1rem;
      border-top: 1px solid rgba(240,234,224,0.06);
    }

    .watch-card-movement {
      font-size: 0.7rem;
      font-weight: 300;
      color: var(--muted);
      font-style: italic;
    }

    .watch-card-price {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 400;
      color: var(--cream);
    }

    /* Featured card — spans 2 rows */
    .watch-card.featured .watch-card-img-wrap {
      aspect-ratio: 3 / 5;
    }


    /* ═══════════════════════════════════════════
       ATELIER SPLIT
    ═══════════════════════════════════════════ */
    .atelier {
      background: var(--charcoal);
      padding: clamp(6rem, 12vh, 10rem) 0;
    }

    .atelier-inner {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 clamp(1.5rem, 5vw, 4rem);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(3rem, 6vw, 7rem);
      align-items: center;
    }

    .atelier-img-wrap {
      position: relative;
      overflow: hidden;
    }

    .atelier-img-wrap img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      object-position: center;
      filter: brightness(0.8) saturate(0.7);
      transition: transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);
      display: block;
    }

    .atelier-img-wrap:hover img {
      transform: scale(1.03);
    }

    /* Gold frame accent */
    .atelier-img-wrap::before {
      content: "";
      position: absolute;
      top: -1rem;
      left: -1rem;
      width: 5rem;
      height: 5rem;
      border-top: 1px solid var(--gold);
      border-left: 1px solid var(--gold);
      z-index: 2;
      pointer-events: none;
    }

    .atelier-img-wrap::after {
      content: "";
      position: absolute;
      bottom: -1rem;
      right: -1rem;
      width: 5rem;
      height: 5rem;
      border-bottom: 1px solid var(--gold);
      border-right: 1px solid var(--gold);
      z-index: 2;
      pointer-events: none;
    }

    .atelier-text {}

    .atelier-body {
      font-size: 0.85rem;
      font-weight: 300;
      line-height: 1.9;
      color: var(--muted);
      margin-bottom: 2.5rem;
      max-width: 48ch;
    }

    .atelier-services {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .atelier-service {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(240,234,224,0.06);
    }

    .atelier-service:first-child {
      border-top: 1px solid rgba(240,234,224,0.06);
    }

    .atelier-service-name {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 400;
      color: var(--cream);
      letter-spacing: 0.01em;
    }

    .atelier-service-detail {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
      opacity: 0.7;
    }


    /* ═══════════════════════════════════════════
       HERITAGE — Atmosphärische Vollbild-Sektion
    ═══════════════════════════════════════════ */
    .heritage {
      position: relative;
      overflow: hidden;
    }

    .heritage-bg {
      position: relative;
    }

    .heritage-bg img {
      width: 100%;
      aspect-ratio: 16 / 7;
      object-fit: cover;
      object-position: center 55%;
      filter: brightness(0.35) saturate(0.6);
      display: block;
    }

    .heritage-overlay {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg,
          rgba(8,8,8,0.85) 0%,
          rgba(8,8,8,0.6)  40%,
          rgba(8,8,8,0.15) 70%,
          rgba(8,8,8,0.0)  100%
        );
    }

    .heritage-content {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      padding: 0 clamp(1.5rem, 5vw, 5rem);
      max-width: 1300px;
      margin: 0 auto;
      left: 0; right: 0;
    }

    .heritage-text {
      max-width: 46ch;
    }

    .heritage-quote {
      font-family: var(--font-display);
      font-style: italic;
      font-size: clamp(1.5rem, 3.5vw, 2.8rem);
      font-weight: 400;
      line-height: 1.4;
      color: var(--cream);
      margin-bottom: 2rem;
    }

    .heritage-quote span {
      color: var(--gold);
      font-style: normal;
    }

    .heritage-attribution {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .heritage-role {
      font-size: 0.75rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 0.3rem;
      letter-spacing: 0;
    }

    /* Timeline / milestones below image */
    .heritage-milestones {
      background: var(--charcoal-2);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 1px solid rgba(200,169,110,0.1);
    }

    .milestone {
      padding: 2.5rem clamp(1.5rem, 3vw, 2.5rem);
      border-right: 1px solid rgba(200,169,110,0.08);
      position: relative;
    }

    .milestone:last-child { border-right: none; }

    .milestone::before {
      content: "";
      position: absolute;
      top: 0; left: clamp(1.5rem, 3vw, 2.5rem);
      width: 1.5rem;
      height: 2px;
      background: var(--gold);
    }

    .milestone-year {
      font-family: var(--font-display);
      font-size: 2.2rem;
      font-weight: 400;
      color: rgba(240,234,224,0.15);
      line-height: 1;
      margin-bottom: 0.6rem;
    }

    .milestone-title {
      font-family: var(--font-display);
      font-size: 1.05rem;
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 0.5rem;
    }

    .milestone-text {
      font-size: 0.75rem;
      font-weight: 300;
      line-height: 1.7;
      color: var(--muted);
    }


    /* ═══════════════════════════════════════════
       BOUTIQUE & KONTAKT
    ═══════════════════════════════════════════ */
    .boutique {
      padding: clamp(6rem, 12vh, 10rem) clamp(1.5rem, 5vw, 4rem);
      max-width: 1300px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(3rem, 6vw, 8rem);
      align-items: start;
    }

    .boutique-text {}

    .boutique-address {
      font-family: var(--font-display);
      font-style: normal;
      font-size: 1rem;
      font-weight: 300;
      line-height: 2;
      color: var(--muted);
      not-style: none;
      margin-bottom: 2.5rem;
    }

    .boutique-address strong {
      display: block;
      font-family: var(--font-display);
      font-size: 1.2rem;
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 0.5rem;
    }

    .boutique-hours {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-bottom: 3rem;
    }

    .boutique-hour-row {
      display: flex;
      justify-content: space-between;
      padding: 0.65rem 0;
      border-bottom: 1px solid rgba(240,234,224,0.06);
    }

    .boutique-hour-row:first-child {
      border-top: 1px solid rgba(240,234,224,0.06);
    }

    .boutique-hour-day {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(240,234,224,0.5);
    }

    .boutique-hour-time {
      font-family: var(--font-display);
      font-size: 0.95rem;
      font-weight: 400;
      color: var(--cream);
    }

    .boutique-contact-links {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .boutique-contact-link {
      font-size: 0.75rem;
      font-weight: 300;
      color: var(--muted);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      transition: color 0.3s ease;
      min-height: 44px;
    }

    .boutique-contact-link::before {
      content: "";
      display: block;
      width: 1.25rem;
      height: 1px;
      background: var(--gold);
      flex-shrink: 0;
      opacity: 0.5;
      transition: width 0.3s ease, opacity 0.3s ease;
    }

    .boutique-contact-link:hover { color: var(--cream); }
    .boutique-contact-link:hover::before { width: 2rem; opacity: 1; }

    .boutique-img-wrap {
      position: relative;
      overflow: hidden;
    }

    .boutique-img-wrap img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      object-position: center;
      filter: brightness(0.75) saturate(0.7);
      display: block;
      transition: transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .boutique-img-wrap:hover img {
      transform: scale(1.03);
    }

    .boutique-img-caption {
      margin-top: 1rem;
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      opacity: 0.6;
    }


    /* ═══════════════════════════════════════════
       FOOTER
    ═══════════════════════════════════════════ */
    .footer {
      background: var(--charcoal);
      border-top: 1px solid rgba(200,169,110,0.1);
      padding: 2.5rem clamp(1.5rem, 5vw, 4rem);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .footer-brand {
      font-family: var(--font-display);
      font-size: 1rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(240,234,224,0.35);
    }

    .footer-brand span { color: var(--gold); opacity: 0.6; }

    .footer-copy {
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.1em;
      color: var(--muted);
      opacity: 0.5;
    }

    .footer-tagline {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 0.8rem;
      color: rgba(200,169,110,0.35);
    }


    /* ═══════════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════════ */
    @media (max-width: 1024px) {
      .nav-links { display: none; }

      .nav-toggle {
        display: flex;
      }

      .hero-stats {
        display: none;
      }

      .watch-grid {
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      .watch-card.featured .watch-card-img-wrap {
        aspect-ratio: 3 / 4;
      }

      .atelier-inner {
        grid-template-columns: 1fr;
        gap: 4rem;
      }

      .atelier-img-wrap img {
        aspect-ratio: 4 / 3;
      }

      .heritage-bg img {
        aspect-ratio: 4 / 3;
        object-position: 70% center;
      }

      .heritage-overlay {
        background: linear-gradient(180deg,
          rgba(8,8,8,0) 0%,
          rgba(8,8,8,0.7) 60%,
          rgba(8,8,8,0.95) 100%
        );
      }

      .heritage-content {
        align-items: flex-end;
        padding-bottom: 3rem;
      }

      .heritage-milestones {
        grid-template-columns: 1fr 1fr;
      }

      .milestone:nth-child(2) { border-right: none; }
      .milestone:nth-child(3) { border-right: 1px solid rgba(200,169,110,0.08); }

      .boutique {
        grid-template-columns: 1fr;
        gap: 3rem;
      }

      .boutique-img-wrap {
        order: -1;
      }

      .boutique-img-wrap img {
        aspect-ratio: 16 / 9;
      }
    }

    @media (max-width: 640px) {
      .hero-content {
        padding-top: 7rem;
        padding-bottom: 3rem;
      }

      .hero-title {
        font-size: clamp(2.5rem, 11vw, 3.5rem);
      }

      .kollektion-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.75rem;
      }

      .watch-grid {
        grid-template-columns: 1fr;
      }

      .atelier-img-wrap::before,
      .atelier-img-wrap::after {
        display: none;
      }

      .heritage-bg img {
        aspect-ratio: 1 / 1;
      }

      .heritage-milestones {
        grid-template-columns: 1fr 1fr;
      }

      .milestone {
        padding: 1.75rem 1.25rem;
      }

      .footer {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
      }

      .footer-tagline { display: none; }
    }
  </style>
</head>
