---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Maison Noir — Weinbar & Lounge, Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --gold: #C9A84C;
      --gold-light: #D4B96A;
      --gold-dim: rgba(201,168,76,0.15);
      --black: #0C0C0C;
      --charcoal: #1A1A1A;
      --charcoal-light: #222222;
      --cream: #F5F0E8;
      --muted: #8B8178;
      --font-display: "Playfair Display", Georgia, "Times New Roman", serif;
      --font-body: "Inter", system-ui, -apple-system, sans-serif;
    }

    html {
      background: var(--black);
      color: var(--cream);
      font-family: var(--font-body);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      scroll-behavior: smooth;
    }

    body { overflow-x: hidden; }

    ::selection { background: var(--gold); color: var(--black); }

    img { display: block; max-width: 100%; }

    /* ═══════════════════════════════════════════
       NAV
    ═══════════════════════════════════════════ */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.75rem clamp(1.5rem, 5vw, 4rem);
      background: linear-gradient(to bottom, rgba(12,12,12,0.9) 0%, rgba(12,12,12,0.4) 60%, transparent 100%);
      transition: background 0.4s ease;
    }

    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.2rem;
      font-weight: 400;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--cream);
      text-decoration: none;
    }

    .nav-logo span {
      color: var(--gold);
      font-style: italic;
      text-transform: none;
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(245,240,232,0.5);
      text-decoration: none;
      transition: color 0.3s ease;
      position: relative;
    }

    .nav-links a::after {
      content: "";
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 1px;
      background: var(--gold);
      transition: width 0.3s ease;
    }

    .nav-links a:hover { color: var(--gold); }
    .nav-links a:hover::after { width: 100%; }

    .nav-cta {
      font-family: var(--font-body);
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      background: none;
      border: 1px solid var(--gold);
      padding: 0.6rem 1.5rem;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.3s ease, color 0.3s ease;
    }

    .nav-cta:hover {
      background: var(--gold);
      color: var(--black);
    }

    /* Mobile menu toggle */
    .nav-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }

    .nav-toggle span {
      display: block;
      width: 22px;
      height: 1px;
      background: var(--cream);
      transition: transform 0.3s ease, opacity 0.3s ease;
    }

    /* ═══════════════════════════════════════════
       HERO
    ═══════════════════════════════════════════ */
    .hero {
      position: relative;
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
      filter: brightness(0.25) saturate(0.7) contrast(1.1);
      transform: scale(1.05);
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
      background:
        linear-gradient(180deg, rgba(12,12,12,0.6) 0%, rgba(12,12,12,0.1) 40%, rgba(12,12,12,0.5) 70%, rgba(12,12,12,0.95) 100%),
        linear-gradient(90deg, rgba(12,12,12,0.7) 0%, transparent 60%);
    }

    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 clamp(1.5rem, 5vw, 4rem);
      padding-bottom: clamp(4rem, 10vh, 8rem);
      width: 100%;
    }

    .hero-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .hero-label::before {
      content: "";
      display: block;
      width: 2.5rem;
      height: 1px;
      background: var(--gold);
    }

    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(3.5rem, 8vw, 7rem);
      font-weight: 400;
      line-height: 1;
      letter-spacing: -0.02em;
      color: var(--cream);
      margin-bottom: 2rem;
    }

    .hero-title em {
      font-style: italic;
      color: var(--gold);
      display: block;
    }

    .hero-meta {
      display: flex;
      gap: 2.5rem;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
    }

    .hero-meta-item {
      font-size: 0.85rem;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.5;
      padding-left: 1rem;
      border-left: 1px solid rgba(201,168,76,0.3);
    }

    .hero-meta-item strong {
      display: block;
      font-weight: 500;
      color: var(--cream);
      font-size: 0.9rem;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .btn-gold {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--black);
      background: var(--gold);
      border: 1px solid var(--gold);
      padding: 1rem 2.25rem;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.3s ease, transform 0.2s ease;
    }

    .btn-gold:hover { background: var(--gold-light); transform: translateY(-1px); }

    .btn-gold svg {
      width: 14px;
      height: 14px;
      transition: transform 0.3s ease;
    }

    .btn-gold:hover svg { transform: translateX(3px); }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--cream);
      background: none;
      border: 1px solid rgba(245,240,232,0.15);
      padding: 1rem 2.25rem;
      cursor: pointer;
      text-decoration: none;
      transition: border-color 0.3s ease, color 0.3s ease;
    }

    .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

    /* ═══════════════════════════════════════════
       SECTION SHARED
    ═══════════════════════════════════════════ */
    .section-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .section-label::before {
      content: "";
      display: block;
      width: 2rem;
      height: 1px;
      background: var(--gold);
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4.5vw, 3.5rem);
      font-weight: 400;
      line-height: 1.15;
      letter-spacing: -0.01em;
      color: var(--cream);
      margin-bottom: 1rem;
    }

    .gold-rule {
      width: 3rem;
      height: 1px;
      background: var(--gold);
      border: none;
      margin: 0;
    }

    /* ═══════════════════════════════════════════
       WEINKARTE / EMPFEHLUNGEN
    ═══════════════════════════════════════════ */
    .weinkarte {
      padding: clamp(5rem, 12vw, 9rem) clamp(1.5rem, 5vw, 4rem);
      max-width: 1200px;
      margin: 0 auto;
    }

    .weinkarte-header {
      text-align: center;
      max-width: 600px;
      margin: 0 auto 4rem;
    }

    .weinkarte-header .section-label {
      justify-content: center;
    }

    .weinkarte-header .section-label::before { display: none; }

    .weinkarte-header .section-label::after {
      content: "";
      display: block;
      width: 2rem;
      height: 1px;
      background: var(--gold);
    }

    .weinkarte-header .section-title {
      margin-bottom: 1.25rem;
    }

    .weinkarte-subtitle {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.8;
      color: var(--muted);
    }

    .wine-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(201,168,76,0.1);
      margin-bottom: 4rem;
    }

    .wine-card {
      background: var(--charcoal);
      padding: clamp(2rem, 3vw, 3rem);
      display: flex;
      flex-direction: column;
      position: relative;
      transition: background 0.4s ease;
    }

    .wine-card:hover { background: var(--charcoal-light); }

    .wine-card-number {
      font-family: var(--font-display);
      font-size: 3.5rem;
      font-weight: 400;
      color: rgba(201,168,76,0.08);
      line-height: 1;
      position: absolute;
      top: 1.5rem;
      right: 1.5rem;
    }

    .wine-card-region {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .wine-card-name {
      font-family: var(--font-display);
      font-size: 1.35rem;
      font-weight: 400;
      line-height: 1.3;
      color: var(--cream);
      margin-bottom: 0.5rem;
    }

    .wine-card-grape {
      font-size: 0.8rem;
      font-weight: 400;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }

    .wine-card-divider {
      width: 2rem;
      height: 1px;
      background: rgba(201,168,76,0.3);
      margin-bottom: 1.5rem;
    }

    .wine-card-note {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 0.95rem;
      line-height: 1.6;
      color: rgba(245,240,232,0.6);
      flex-grow: 1;
      margin-bottom: 2rem;
    }

    .wine-card-price {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding-top: 1.25rem;
      border-top: 1px solid rgba(245,240,232,0.06);
    }

    .wine-card-price-glass,
    .wine-card-price-bottle {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .wine-card-price-glass span,
    .wine-card-price-bottle span {
      display: block;
      font-family: var(--font-display);
      font-size: 1.1rem;
      color: var(--cream);
      margin-top: 0.25rem;
      letter-spacing: 0;
      text-transform: none;
    }

    /* Sommeliere Quote */
    .quote-block {
      display: flex;
      align-items: flex-start;
      gap: clamp(2rem, 4vw, 3.5rem);
      padding: 3rem 0;
      border-top: 1px solid rgba(201,168,76,0.1);
      border-bottom: 1px solid rgba(201,168,76,0.1);
    }

    .quote-mark {
      font-family: var(--font-display);
      font-size: 6rem;
      line-height: 0.8;
      color: rgba(201,168,76,0.2);
      flex-shrink: 0;
      user-select: none;
    }

    .quote-content {
      padding-top: 0.5rem;
    }

    .quote-text {
      font-family: var(--font-display);
      font-style: italic;
      font-size: clamp(1.1rem, 2vw, 1.4rem);
      line-height: 1.7;
      color: var(--cream);
      margin-bottom: 1.5rem;
    }

    .quote-author {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .quote-author-role {
      font-size: 0.8rem;
      font-weight: 300;
      letter-spacing: 0;
      text-transform: none;
      color: var(--muted);
      margin-top: 0.25rem;
    }

    /* ═══════════════════════════════════════════
       ABENDE & EVENTS
    ═══════════════════════════════════════════ */
    .events {
      background: var(--charcoal);
      padding: clamp(5rem, 12vw, 9rem) clamp(1.5rem, 5vw, 4rem);
    }

    .events-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .events-header {
      max-width: 500px;
      margin-bottom: 4rem;
    }

    .events-header .section-title {
      margin-bottom: 1rem;
    }

    .events-subtitle {
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 1.8;
      color: var(--muted);
    }

    .events-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(1rem, 2vw, 1.5rem);
      margin-bottom: 4rem;
    }

    .event-card {
      background: var(--black);
      border: 1px solid rgba(245,240,232,0.04);
      padding: clamp(2rem, 3vw, 2.75rem);
      display: flex;
      flex-direction: column;
      transition: border-color 0.4s ease, transform 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .event-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--gold), transparent);
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .event-card:hover {
      border-color: rgba(201,168,76,0.2);
      transform: translateY(-3px);
    }

    .event-card:hover::before { opacity: 1; }

    .event-card-schedule {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid rgba(245,240,232,0.06);
    }

    .event-card-title {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 1rem;
      line-height: 1.3;
    }

    .event-card-desc {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.75;
      color: var(--muted);
      flex-grow: 1;
      margin-bottom: 2rem;
    }

    .event-card-detail {
      font-size: 0.85rem;
      font-weight: 400;
      color: var(--cream);
      padding-top: 1.25rem;
      border-top: 1px solid rgba(245,240,232,0.06);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .event-card-price {
      font-family: var(--font-display);
      font-size: 1rem;
      color: var(--gold);
    }

    .event-card-tag {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      background: rgba(245,240,232,0.04);
      padding: 0.35rem 0.75rem;
    }

    /* Contact bar */
    .contact-bar {
      border-top: 1px solid rgba(201,168,76,0.12);
      padding-top: 3rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      flex-wrap: wrap;
      gap: 2rem;
    }

    .contact-bar-left {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .contact-bar-label {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.25rem;
    }

    .contact-bar-address {
      font-size: 0.9rem;
      font-weight: 300;
      color: var(--cream);
      line-height: 1.6;
    }

    .contact-bar-right {
      display: flex;
      gap: 3rem;
      align-items: flex-end;
    }

    .contact-bar-item {
      text-align: right;
    }

    .contact-bar-item-label {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.35rem;
    }

    .contact-bar-item-value {
      font-size: 0.9rem;
      font-weight: 300;
      color: var(--cream);
    }

    .contact-bar-item-value a {
      color: var(--cream);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .contact-bar-item-value a:hover { color: var(--gold); }

    /* ═══════════════════════════════════════════
       FOOTER
    ═══════════════════════════════════════════ */
    .footer {
      background: var(--black);
      padding: 2.5rem clamp(1.5rem, 5vw, 4rem);
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid rgba(245,240,232,0.04);
    }

    .footer-brand {
      font-family: var(--font-display);
      font-size: 0.85rem;
      color: rgba(245,240,232,0.3);
    }

    .footer-hours {
      font-size: 0.75rem;
      font-weight: 300;
      color: rgba(245,240,232,0.25);
      letter-spacing: 0.05em;
    }

    /* ═══════════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════════ */
    @media (max-width: 1024px) {
      .wine-grid { grid-template-columns: 1fr 1fr; }
      .wine-card:last-child { grid-column: 1 / -1; }
      .events-grid { grid-template-columns: 1fr 1fr; }
      .event-card:last-child { grid-column: 1 / -1; }
    }

    @media (max-width: 768px) {
      .nav-links,
      .nav-cta { display: none; }

      .nav-toggle { display: flex; }

      .hero { align-items: flex-end; }

      .hero-title {
        font-size: clamp(2.75rem, 10vw, 4rem);
      }

      .hero-meta { flex-direction: column; gap: 1.25rem; }

      .wine-grid {
        grid-template-columns: 1fr;
        gap: 1px;
      }

      .wine-card:last-child { grid-column: auto; }

      .wine-card-number { display: none; }

      .quote-block { flex-direction: column; gap: 0; }
      .quote-mark { font-size: 4rem; margin-bottom: -0.5rem; }

      .events-grid { grid-template-columns: 1fr; }
      .event-card:last-child { grid-column: auto; }

      .contact-bar {
        flex-direction: column;
        align-items: flex-start;
      }

      .contact-bar-right {
        flex-direction: column;
        align-items: flex-start;
        gap: 1.5rem;
      }

      .contact-bar-item { text-align: left; }

      .footer {
        flex-direction: column;
        gap: 0.75rem;
        text-align: center;
      }
    }

    @media (max-width: 480px) {
      .hero-actions {
        flex-direction: column;
        align-items: stretch;
      }

      .btn-gold,
      .btn-ghost {
        justify-content: center;
        text-align: center;
      }
    }
  </style>
</head>
<body>

  <!-- ═══ NAV ═══ -->
  <nav class="nav">
    <a href="#" class="nav-logo">Maison <span>Noir</span></a>
    <ul class="nav-links">
      <li><a href="#weinkarte">Weinkarte</a></li>
      <li><a href="#abende">Abende</a></li>
    </ul>
    <a href="#abende" class="nav-cta">Reservieren</a>
    <button class="nav-toggle" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?w=1920&q=80&auto=format"
        alt="Dunkle Weinbar-Atmosphaere mit warmem Licht"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-label">Weinbar & Lounge — Trier Altstadt</div>
      <h1 class="hero-title">Wein ist<em>Emotion.</em></h1>
      <div class="hero-meta">
        <div class="hero-meta-item">
          <strong>200+ Positionen</strong>
          aus 6 Laendern
        </div>
        <div class="hero-meta-item">
          <strong>Jeden Abend</strong>
          ab 18 Uhr geoeffnet
        </div>
        <div class="hero-meta-item">
          <strong>Seit 2019</strong>
          in den Gewoelben der Altstadt
        </div>
      </div>
      <div class="hero-actions">
        <a href="#weinkarte" class="btn-gold">
          Weinkarte entdecken
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
