---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Maison Noir — Weinbar & Lounge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --gold: #C9A84C;
      --gold-light: #D4B96A;
      --black: #0C0C0C;
      --charcoal: #1A1A1A;
      --charcoal-light: #252525;
      --cream: #F5F0E8;
      --muted: #8B8178;
      --font-display: "Playfair Display", Georgia, serif;
      --font-body: "Inter", system-ui, sans-serif;
    }

    html {
      background: var(--black);
      color: var(--cream);
      font-family: var(--font-body);
      -webkit-font-smoothing: antialiased;
      scroll-behavior: smooth;
    }

    ::selection { background: var(--gold); color: var(--black); }

    /* ═══ HERO ═══ */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      filter: brightness(0.3) saturate(0.8);
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to right,
        rgba(12,12,12,0.95) 0%,
        rgba(12,12,12,0.6) 50%,
        rgba(12,12,12,0.3) 100%
      );
      z-index: 1;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 clamp(1.5rem, 5vw, 4rem);
      width: 100%;
    }

    .hero-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
    }

    .hero-label span {
      display: inline-block;
      width: 2rem;
      height: 1px;
      background: var(--gold);
      vertical-align: middle;
      margin-right: 0.75rem;
    }

    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(3rem, 7vw, 6rem);
      font-weight: 400;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--cream);
      max-width: 10ch;
      margin-bottom: 1.5rem;
    }

    .hero-title em {
      font-style: italic;
      color: var(--gold);
    }

    .hero-subtitle {
      font-size: 1.05rem;
      font-weight: 300;
      line-height: 1.7;
      color: var(--muted);
      max-width: 38ch;
      margin-bottom: 2.5rem;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .btn-gold {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-body);
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--black);
      background: var(--gold);
      border: none;
      padding: 0.9rem 2rem;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.3s;
    }

    .btn-gold:hover { background: var(--gold-light); }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-body);
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--cream);
      background: none;
      border: 1px solid rgba(245,240,232,0.2);
      padding: 0.9rem 2rem;
      cursor: pointer;
      text-decoration: none;
      transition: border-color 0.3s, color 0.3s;
    }

    .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

    /* Nav */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 50;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem clamp(1.5rem, 5vw, 4rem);
      background: linear-gradient(to bottom, rgba(12,12,12,0.8), transparent);
    }

    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 400;
      letter-spacing: 0.05em;
      color: var(--cream);
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.75rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.3s;
    }

    .nav-links a:hover { color: var(--gold); }

    /* ═══ ABOUT ═══ */
    .about {
      padding: clamp(4rem, 10vw, 8rem) clamp(1.5rem, 5vw, 4rem);
      max-width: 1200px;
      margin: 0 auto;
    }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 5rem);
      align-items: center;
    }

    .about-image {
      position: relative;
      aspect-ratio: 3/4;
      overflow: hidden;
    }

    .about-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: brightness(0.85) saturate(0.9);
    }

    .about-image-frame {
      position: absolute;
      inset: 1rem;
      border: 1px solid rgba(201,168,76,0.3);
      pointer-events: none;
    }

    .about-label {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
    }

    .about-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 400;
      line-height: 1.2;
      color: var(--cream);
      margin-bottom: 1.5rem;
    }

    .about-text {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.8;
      color: var(--muted);
      margin-bottom: 1rem;
    }

    .about-divider {
      width: 3rem;
      height: 1px;
      background: var(--gold);
      margin: 2rem 0;
    }

    .about-signature {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 1.1rem;
      color: var(--gold);
    }

    /* ═══ CONTACT / RESERVE ═══ */
    .reserve {
      padding: clamp(4rem, 10vw, 8rem) clamp(1.5rem, 5vw, 4rem);
      background: var(--charcoal);
    }

    .reserve-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 5rem);
    }

    .reserve-info {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .reserve-label {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
    }

    .reserve-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 400;
      line-height: 1.2;
      color: var(--cream);
      margin-bottom: 1.5rem;
    }

    .reserve-text {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.8;
      color: var(--muted);
      margin-bottom: 2rem;
    }

    .reserve-details {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .reserve-detail {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }

    .reserve-detail-icon {
      width: 20px;
      height: 20px;
      color: var(--gold);
      flex-shrink: 0;
      margin-top: 2px;
    }

    .reserve-detail-label {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.25rem;
    }

    .reserve-detail-value {
      font-size: 0.9rem;
      color: var(--cream);
      font-weight: 300;
    }

    .reserve-form {
      background: var(--black);
      padding: clamp(2rem, 4vw, 3rem);
      border: 1px solid rgba(201,168,76,0.15);
    }

    .reserve-form h3 {
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 2rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .form-field {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .form-field.full { grid-column: 1 / -1; }

    .form-field label {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .form-field input,
    .form-field select,
    .form-field textarea {
      font-family: var(--font-body);
      font-size: 0.9rem;
      color: var(--cream);
      background: var(--charcoal);
      border: 1px solid rgba(245,240,232,0.1);
      padding: 0.75rem 1rem;
      outline: none;
      transition: border-color 0.3s;
    }

    .form-field input:focus,
    .form-field select:focus,
    .form-field textarea:focus {
      border-color: var(--gold);
    }

    .form-field textarea { resize: vertical; min-height: 80px; }

    .form-submit {
      margin-top: 1.5rem;
      width: 100%;
    }

    /* ═══ RESPONSIVE ═══ */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .about-grid { grid-template-columns: 1fr; }
      .about-image { max-height: 400px; }
      .reserve-inner { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <!-- Nav -->
  <nav class="nav">
    <a href="#" class="nav-logo">Maison Noir</a>
    <ul class="nav-links">
      <li><a href="#about">Geschichte</a></li>
      <li><a href="#reserve">Reservieren</a></li>
    </ul>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?w=1920&q=80&auto=format"
        alt="Weinbar Atmosphaere"
        loading="eager"
      />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-label"><span></span>Weinbar & Lounge — Trier</div>
      <h1 class="hero-title">Wein ist <em>Emotion.</em></h1>
      <p class="hero-subtitle">
        Handverlesene Weine aus kleinen Weingutern, serviert in einer
        Atmosphare, die zum Verweilen einladt. Jeden Abend ab 18 Uhr.
      </p>
      <div class="hero-actions">
        <a href="#reserve" class="btn-gold">Tisch reservieren</a>
        <a href="#about" class="btn-ghost">Unsere Geschichte</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="about" id="about">
    <div class="about-grid">
      <div class="about-image">
        <img
          src="https://images.unsplash.com/photo-1543007630-9710e4a00a20?w=800&q=80&auto=format"
          alt="Weinsortiment"
          loading="lazy"
        />
        <div class="about-image-frame"></div>
      </div>
      <div>
        <div class="about-label">Unsere Geschichte</div>
        <h2 class="about-title">Wo jeder Schluck eine Geschichte erzahlt</h2>
        <p class="about-text">
          Maison Noir entstand aus einer einfachen Uberzeugung: Guter Wein verdient
          einen besonderen Rahmen. In den historischen Gewolben der Trierer Altstadt
          haben wir einen Ort geschaffen, an dem Zeit keine Rolle spielt.
        </p>
        <p class="about-text">
          Unsere Karte wechselt monatlich. Wir arbeiten ausschliesslich mit
          Winzern, die wir personlich kennen — von der Mosel, aus dem Burgund
          und den Hugeln der Toskana.
        </p>
        <div class="about-divider"></div>
        <div class="about-signature">— Lukas & Marie, Grunderjahr 2019</div>
      </div>
    </div>
  </section>

  <!-- Reservation -->
  <section class="reserve" id="reserve">
    <div class="reserve-inner">
      <div class="reserve-info">
        <div class="reserve-label">Reservierung</div>
        <h2 class="reserve-title">Ihr Abend beginnt hier</h2>
        <p class="reserve-text">
          Reservieren Sie Ihren Tisch und lassen Sie sich von unserer
          Sommelier-Auswahl uberraschen. Fur Gruppen ab 8 Personen
          bieten wir private Weinproben in unserem Gewolbekeller an.
        </p>
        <div class="reserve-details">
          <div class="reserve-detail">
            <svg class="reserve-detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <div>
              <div class="reserve-detail-label">Offnungszeiten</div>
              <div class="reserve-detail-value">Di — Sa, 18:00 — 00:00 Uhr</div>
            </div>
          </div>
          <div class="reserve-detail">
            <svg class="reserve-detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <div class="reserve-detail-label">Adresse</div>
              <div class="reserve-detail-value">Fleischstrasse 12, 54290 Trier</div>
            </div>
          </div>
          <div class="reserve-detail">
            <svg class="reserve-detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <div>
              <div class="reserve-detail-label">Telefon</div>
              <div class="reserve-detail-value">0651 — 999 88 77</div>
            </div>
          </div>
        </div>
      </div>

      <div class="reserve-form">
        <h3>Tisch reservieren</h3>
        <form>
          <div class="form-row">
            <div class="form-field">
              <label for="name">Name</label>
              <input type="text" id="name" placeholder="Ihr Name" />
            </div>
            <div class="form-field">
              <label for="guests">Personen</label>
              <select id="guests">
                <option>2 Personen</option>
                <option>3 Personen</option>
                <option>4 Personen</option>
                <option>5 Personen</option>
                <option>6+ Personen</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label for="date">Datum</label>
              <input type="date" id="date" />
            </div>
            <div class="form-field">
              <label for="time">Uhrzeit</label>
              <select id="time">
                <option>18:00</option>
                <option>18:30</option>
                <option>19:00</option>
                <option>19:30</option>
                <option>20:00</option>
                <option>20:30</option>
                <option>21:00</option>
              </select>
            </div>
          </div>
          <div class="form-field full">
            <label for="message">Anmerkungen</label>
            <textarea id="message" placeholder="Allergien, Anlass, besondere Wunsche..."></textarea>
          </div>
          <button type="button" class="btn-gold form-submit">Reservierung anfragen</button>
        </form>
      </div>
    </div>
  </section>
</body>
</html>
