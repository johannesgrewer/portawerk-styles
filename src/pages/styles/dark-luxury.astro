---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Maison Noir — Weinbar & Lounge, Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --gold: #C9A84C;
      --gold-light: #D4B96A;
      --gold-dim: rgba(201,168,76,0.15);
      --black: #0C0C0C;
      --charcoal: #1A1A1A;
      --charcoal-light: #222222;
      --cream: #F5F0E8;
      --muted: #8B8178;
      --font-display: "Playfair Display", Georgia, "Times New Roman", serif;
      --font-body: "Inter", system-ui, -apple-system, sans-serif;
    }

    html {
      background: var(--black);
      color: var(--cream);
      font-family: var(--font-body);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      scroll-behavior: smooth;
    }

    body { overflow-x: hidden; }

    ::selection { background: var(--gold); color: var(--black); }

    img { display: block; max-width: 100%; }

    /* ═══════════════════════════════════════════
       NAV
    ═══════════════════════════════════════════ */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.75rem clamp(1.5rem, 5vw, 4rem);
      background: transparent;
      transition: background 0.4s ease;
    }

    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.2rem;
      font-weight: 400;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--cream);
      text-decoration: none;
    }

    .nav-logo span {
      color: var(--gold);
      font-style: italic;
      text-transform: none;
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
      align-items: center;
    }

    .nav-links a {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(245,240,232,0.5);
      text-decoration: none;
      transition: color 0.3s ease;
      position: relative;
    }

    .nav-links a::after {
      content: "";
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 1px;
      background: var(--gold);
      transition: width 0.3s ease;
    }

    .nav-links a:hover { color: var(--gold); }
    .nav-links a:hover::after { width: 100%; }

    .nav-cta {
      font-family: var(--font-body);
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .nav-cta:hover {
      color: var(--cream);
    }

    /* Mobile menu toggle */
    .nav-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }

    .nav-toggle span {
      display: block;
      width: 22px;
      height: 1px;
      background: var(--cream);
      transition: transform 0.3s ease, opacity 0.3s ease;
    }

    /* ═══════════════════════════════════════════
       HERO — Cinematic Letterbox
    ═══════════════════════════════════════════ */

    /* Film grain noise texture */
    @keyframes grainShift {
      0%, 100% { transform: translate(0, 0); }
      10% { transform: translate(-2%, -3%); }
      20% { transform: translate(3%, 1%); }
      30% { transform: translate(-1%, 2%); }
      40% { transform: translate(2%, -2%); }
      50% { transform: translate(-3%, 3%); }
      60% { transform: translate(1%, -1%); }
      70% { transform: translate(-2%, 2%); }
      80% { transform: translate(3%, -3%); }
      90% { transform: translate(-1%, 1%); }
    }

    /* Staggered fade-in animations */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes scaleIn {
      from { opacity: 0; transform: scale(1.03); }
      to { opacity: 1; transform: scale(1); }
    }

    @keyframes lineGrow {
      from { width: 0; }
      to { width: 3rem; }
    }

    .hero {
      position: relative;
      padding: clamp(7rem, 14vh, 10rem) clamp(1.5rem, 5vw, 4rem) clamp(3rem, 6vh, 5rem);
      max-width: 1400px;
      margin: 0 auto;
      overflow: visible;
    }

    /* Pre-heading label */
    .hero-label {
      font-family: var(--font-body);
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.25rem;
      opacity: 0;
      animation: fadeInUp 0.8s ease forwards;
      animation-delay: 0.2s;
    }

    /* Gold horizontal rule */
    .hero-rule {
      width: 3rem;
      height: 1px;
      background: var(--gold);
      border: none;
      margin: 0 0 1.5rem 0;
      opacity: 0;
      animation: lineGrow 0.6s ease forwards, fadeIn 0.6s ease forwards;
      animation-delay: 0.5s, 0.5s;
    }

    /* Title — sits above and bleeds into the image */
    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 400;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--cream);
      margin-bottom: -0.5em;
      position: relative;
      z-index: 3;
    }

    .hero-title-line {
      display: block;
      opacity: 0;
      animation: fadeInUp 0.7s ease forwards;
    }

    .hero-title-line:nth-child(1) { animation-delay: 0.7s; }
    .hero-title-line:nth-child(2) { animation-delay: 0.95s; }

    .hero-title em {
      font-style: italic;
      color: var(--gold);
      font-size: 1.15em;
    }

    /* Cinematic image frame */
    .hero-frame {
      position: relative;
      width: 100%;
      aspect-ratio: 2.39 / 1;
      overflow: hidden;
      cursor: crosshair;
      opacity: 0;
      animation: scaleIn 1.2s ease forwards;
      animation-delay: 1.2s;
    }

    .hero-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
      filter: brightness(0.35) saturate(0.7) contrast(1.1);
    }

    /* Film grain overlay */
    .hero-frame::after {
      content: "";
      position: absolute;
      inset: -50%;
      width: 200%;
      height: 200%;
      z-index: 2;
      opacity: 0.06;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-size: 128px 128px;
      pointer-events: none;
      animation: grainShift 0.8s steps(4) infinite;
    }

    /* Subtle gradient overlay on image */
    .hero-frame::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      background:
        linear-gradient(180deg, rgba(12,12,12,0.5) 0%, transparent 30%, transparent 70%, rgba(12,12,12,0.4) 100%),
        linear-gradient(90deg, rgba(12,12,12,0.4) 0%, transparent 40%);
      pointer-events: none;
    }

    /* Credits row — film-credits style below image */
    .hero-credits {
      display: flex;
      justify-content: flex-start;
      gap: clamp(2rem, 5vw, 4rem);
      padding-top: 1.75rem;
      opacity: 0;
      animation: fadeInUp 0.7s ease forwards;
      animation-delay: 1.6s;
    }

    .hero-credit {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
    }

    .hero-credit-number {
      font-family: var(--font-display);
      font-size: clamp(1.4rem, 2.5vw, 1.8rem);
      font-weight: 400;
      color: var(--cream);
      line-height: 1;
    }

    .hero-credit-text {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 300;
      color: var(--muted);
      letter-spacing: 0.02em;
      line-height: 1.3;
    }

    .hero-credit-divider {
      width: 1px;
      height: 1.5rem;
      background: rgba(201,168,76,0.25);
      align-self: center;
    }

    /* CTA text links — understated luxury */
    .hero-actions {
      display: flex;
      gap: 2.5rem;
      align-items: center;
      padding-top: 2rem;
      opacity: 0;
      animation: fadeInUp 0.7s ease forwards;
      animation-delay: 1.9s;
    }

    .hero-link {
      font-family: var(--font-body);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--cream);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      transition: color 0.3s ease;
    }

    .hero-link:hover { color: var(--gold); }

    .hero-link svg {
      width: 14px;
      height: 14px;
      transition: transform 0.3s ease;
    }

    .hero-link:hover svg { transform: translateX(4px); }

    /* ═══════════════════════════════════════════
       SECTION SHARED
    ═══════════════════════════════════════════ */
    .section-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .section-label::before {
      content: "";
      display: block;
      width: 2rem;
      height: 1px;
      background: var(--gold);
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4.5vw, 3.5rem);
      font-weight: 400;
      line-height: 1.15;
      letter-spacing: -0.01em;
      color: var(--cream);
      margin-bottom: 1rem;
    }

    .gold-rule {
      width: 3rem;
      height: 1px;
      background: var(--gold);
      border: none;
      margin: 0;
    }

    /* ═══════════════════════════════════════════
       WEINKARTE / EMPFEHLUNGEN
    ═══════════════════════════════════════════ */
    .weinkarte {
      padding: clamp(5rem, 12vw, 9rem) clamp(1.5rem, 5vw, 4rem);
      max-width: 1200px;
      margin: 0 auto;
    }

    .weinkarte-header {
      text-align: center;
      max-width: 600px;
      margin: 0 auto 4rem;
    }

    .weinkarte-header .section-label {
      justify-content: center;
    }

    .weinkarte-header .section-label::before { display: none; }

    .weinkarte-header .section-label::after {
      content: "";
      display: block;
      width: 2rem;
      height: 1px;
      background: var(--gold);
    }

    .weinkarte-header .section-title {
      margin-bottom: 1.25rem;
    }

    .weinkarte-subtitle {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.8;
      color: var(--muted);
    }

    .wine-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(201,168,76,0.1);
      margin-bottom: 4rem;
    }

    .wine-card {
      background: var(--charcoal);
      padding: clamp(2rem, 3vw, 3rem);
      display: flex;
      flex-direction: column;
      position: relative;
      transition: background 0.4s ease;
    }

    .wine-card:hover { background: var(--charcoal-light); }

    .wine-card-number {
      font-family: var(--font-display);
      font-size: 3.5rem;
      font-weight: 400;
      color: rgba(201,168,76,0.08);
      line-height: 1;
      position: absolute;
      top: 1.5rem;
      right: 1.5rem;
    }

    .wine-card-region {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .wine-card-name {
      font-family: var(--font-display);
      font-size: 1.35rem;
      font-weight: 400;
      line-height: 1.3;
      color: var(--cream);
      margin-bottom: 0.5rem;
    }

    .wine-card-grape {
      font-size: 0.8rem;
      font-weight: 400;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }

    .wine-card-divider {
      width: 2rem;
      height: 1px;
      background: rgba(201,168,76,0.3);
      margin-bottom: 1.5rem;
    }

    .wine-card-note {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 0.95rem;
      line-height: 1.6;
      color: rgba(245,240,232,0.6);
      flex-grow: 1;
      margin-bottom: 2rem;
    }

    .wine-card-price {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding-top: 1.25rem;
      border-top: 1px solid rgba(245,240,232,0.06);
    }

    .wine-card-price-glass,
    .wine-card-price-bottle {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .wine-card-price-glass span,
    .wine-card-price-bottle span {
      display: block;
      font-family: var(--font-display);
      font-size: 1.1rem;
      color: var(--cream);
      margin-top: 0.25rem;
      letter-spacing: 0;
      text-transform: none;
    }

    /* Sommeliere Quote */
    .quote-block {
      display: flex;
      align-items: flex-start;
      gap: clamp(2rem, 4vw, 3.5rem);
      padding: 3rem 0;
      border-top: 1px solid rgba(201,168,76,0.1);
      border-bottom: 1px solid rgba(201,168,76,0.1);
    }

    .quote-mark {
      font-family: var(--font-display);
      font-size: 6rem;
      line-height: 0.8;
      color: rgba(201,168,76,0.2);
      flex-shrink: 0;
      user-select: none;
    }

    .quote-content {
      padding-top: 0.5rem;
    }

    .quote-text {
      font-family: var(--font-display);
      font-style: italic;
      font-size: clamp(1.1rem, 2vw, 1.4rem);
      line-height: 1.7;
      color: var(--cream);
      margin-bottom: 1.5rem;
    }

    .quote-author {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .quote-author-role {
      font-size: 0.8rem;
      font-weight: 300;
      letter-spacing: 0;
      text-transform: none;
      color: var(--muted);
      margin-top: 0.25rem;
    }

    /* ═══════════════════════════════════════════
       ABENDE & EVENTS
    ═══════════════════════════════════════════ */
    .events {
      background: var(--charcoal);
      padding: clamp(5rem, 12vw, 9rem) clamp(1.5rem, 5vw, 4rem);
    }

    .events-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .events-header {
      max-width: 500px;
      margin-bottom: 4rem;
    }

    .events-header .section-title {
      margin-bottom: 1rem;
    }

    .events-subtitle {
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 1.8;
      color: var(--muted);
    }

    .events-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(1rem, 2vw, 1.5rem);
      margin-bottom: 4rem;
    }

    .event-card {
      background: var(--black);
      border: 1px solid rgba(245,240,232,0.04);
      padding: clamp(2rem, 3vw, 2.75rem);
      display: flex;
      flex-direction: column;
      transition: border-color 0.4s ease, transform 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .event-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--gold), transparent);
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .event-card:hover {
      border-color: rgba(201,168,76,0.2);
      transform: translateY(-3px);
    }

    .event-card:hover::before { opacity: 1; }

    .event-card-schedule {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid rgba(245,240,232,0.06);
    }

    .event-card-title {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 1rem;
      line-height: 1.3;
    }

    .event-card-desc {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.75;
      color: var(--muted);
      flex-grow: 1;
      margin-bottom: 2rem;
    }

    .event-card-detail {
      font-size: 0.85rem;
      font-weight: 400;
      color: var(--cream);
      padding-top: 1.25rem;
      border-top: 1px solid rgba(245,240,232,0.06);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .event-card-price {
      font-family: var(--font-display);
      font-size: 1rem;
      color: var(--gold);
    }

    .event-card-tag {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      background: rgba(245,240,232,0.04);
      padding: 0.35rem 0.75rem;
    }

    /* Contact bar */
    .contact-bar {
      border-top: 1px solid rgba(201,168,76,0.12);
      padding-top: 3rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      flex-wrap: wrap;
      gap: 2rem;
    }

    .contact-bar-left {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .contact-bar-label {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.25rem;
    }

    .contact-bar-address {
      font-size: 0.9rem;
      font-weight: 300;
      color: var(--cream);
      line-height: 1.6;
    }

    .contact-bar-right {
      display: flex;
      gap: 3rem;
      align-items: flex-end;
    }

    .contact-bar-item {
      text-align: right;
    }

    .contact-bar-item-label {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.35rem;
    }

    .contact-bar-item-value {
      font-size: 0.9rem;
      font-weight: 300;
      color: var(--cream);
    }

    .contact-bar-item-value a {
      color: var(--cream);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .contact-bar-item-value a:hover { color: var(--gold); }

    /* ═══════════════════════════════════════════
       FOOTER
    ═══════════════════════════════════════════ */
    .footer {
      background: var(--black);
      padding: 2.5rem clamp(1.5rem, 5vw, 4rem);
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid rgba(245,240,232,0.04);
    }

    .footer-brand {
      font-family: var(--font-display);
      font-size: 0.85rem;
      color: rgba(245,240,232,0.3);
    }

    .footer-hours {
      font-size: 0.75rem;
      font-weight: 300;
      color: rgba(245,240,232,0.25);
      letter-spacing: 0.05em;
    }

    /* ═══════════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════════ */
    @media (max-width: 1024px) {
      .wine-grid { grid-template-columns: 1fr 1fr; }
      .wine-card:last-child { grid-column: 1 / -1; }
      .events-grid { grid-template-columns: 1fr 1fr; }
      .event-card:last-child { grid-column: 1 / -1; }
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }

      .nav-toggle { display: flex; }

      .hero {
        padding-top: clamp(6rem, 12vh, 8rem);
      }

      .hero-title {
        font-size: clamp(2.5rem, 10vw, 3.5rem);
        margin-bottom: -0.3em;
      }

      .hero-frame {
        aspect-ratio: 16 / 9;
      }

      .hero-credits {
        flex-wrap: wrap;
        gap: 1.25rem;
      }

      .hero-credit-divider {
        display: none;
      }

      .hero-actions {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
      }

      .wine-grid {
        grid-template-columns: 1fr;
        gap: 1px;
      }

      .wine-card:last-child { grid-column: auto; }

      .wine-card-number { display: none; }

      .quote-block { flex-direction: column; gap: 0; }
      .quote-mark { font-size: 4rem; margin-bottom: -0.5rem; }

      .events-grid { grid-template-columns: 1fr; }
      .event-card:last-child { grid-column: auto; }

      .contact-bar {
        flex-direction: column;
        align-items: flex-start;
      }

      .contact-bar-right {
        flex-direction: column;
        align-items: flex-start;
        gap: 1.5rem;
      }

      .contact-bar-item { text-align: left; }

      .footer {
        flex-direction: column;
        gap: 0.75rem;
        text-align: center;
      }
    }

    @media (max-width: 480px) {
      .hero-credits {
        flex-direction: column;
        gap: 1rem;
      }

      .hero-credit-number {
        font-size: 1.3rem;
      }
    }
  </style>
</head>
<body>

  <!-- ═══ NAV ═══ -->
  <nav class="nav">
    <a href="#" class="nav-logo">Maison <span>Noir</span></a>
