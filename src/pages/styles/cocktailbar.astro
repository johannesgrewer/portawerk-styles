---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Dunkel — Bar & Cocktails | Trier Altstadt</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Jost:wght@200;300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --bg-deep:     #0C0806;
      --bg-mid:      #130D09;
      --bg-warm:     #191009;
      --gold:        #C89B2A;
      --gold-dim:    rgba(200,155,42,0.38);
      --gold-faint:  rgba(200,155,42,0.12);
      --cream:       #EDE4CE;
      --cream-dim:   rgba(237,228,206,0.55);
      --cream-faint: rgba(237,228,206,0.22);
    }

    body {
      background: var(--bg-deep);
      color: var(--cream);
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
      line-height: 1.6;
    }

    /* Grain overlay */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.78' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
    }

    /* ===== NAV ===== */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 3.5rem;
      transition: background 0.5s, border-bottom 0.5s;
    }
    nav.scrolled {
      background: rgba(12,8,6,0.92);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--gold-dim);
    }
    .nav-logo {
      font-family: 'Cormorant Garant', serif;
      font-style: italic;
      font-weight: 300;
      font-size: 1.85rem;
      letter-spacing: 0.07em;
      color: var(--gold);
    }
    .nav-links {
      display: flex;
      gap: 2.8rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.62rem;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--cream-dim);
      text-decoration: none;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: var(--gold); }

    /* ===== HERO ===== */
    .hero {
      position: relative;
      height: 100vh;
      min-height: 720px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
    }
    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 55%;
      filter: brightness(0.32) saturate(0.75);
      animation: heroPan 20s ease-in-out infinite alternate;
    }
    @keyframes heroPan {
      from { transform: scale(1.04) translateX(-1%); }
      to   { transform: scale(1.08) translateX(1%); }
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to top, var(--bg-deep) 0%, transparent 32%),
        radial-gradient(ellipse 90% 70% at 50% 55%, transparent 35%, rgba(12,8,6,0.55) 100%);
    }

    /* Art Deco frame border */
    .hero-frame {
      position: absolute;
      inset: 70px 55px 55px;
      border: 1px solid var(--gold-dim);
      pointer-events: none;
      opacity: 0;
      animation: fadeIn 1.5s ease 0.5s forwards;
    }
    .hero-frame::before {
      content: '';
      position: absolute;
      inset: 7px;
      border: 1px solid rgba(200,155,42,0.13);
    }
    .hf-corner {
      position: absolute;
      width: 14px;
      height: 14px;
      background: var(--gold);
      transform: rotate(45deg);
    }
    .hf-corner.tl { top: -7px; left: -7px; }
    .hf-corner.tr { top: -7px; right: -7px; }
    .hf-corner.bl { bottom: -7px; left: -7px; }
    .hf-corner.br { bottom: -7px; right: -7px; }

    /* Hero content */
    .hero-content {
      position: relative;
      z-index: 10;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .hero-eyebrow {
      font-size: 0.58rem;
      font-weight: 300;
      letter-spacing: 0.38em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.4rem;
      opacity: 0;
      animation: fadeIn 0.9s ease 1s forwards;
    }

    .hero-name {
      font-family: 'Cormorant Garant', serif;
      font-style: italic;
      font-weight: 300;
      font-size: clamp(5.5rem, 13vw, 15rem);
      line-height: 0.88;
      letter-spacing: -0.01em;
      color: var(--cream);
      opacity: 0;
      animation: heroSlide 1.2s cubic-bezier(0.16,1,0.3,1) 0.25s forwards;
    }
    @keyframes heroSlide {
      from { opacity: 0; transform: translateY(40px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero-deco {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin: 1.8rem 0;
      opacity: 0;
      animation: fadeIn 0.9s ease 1.2s forwards;
    }
    .hd-line { height: 1px; width: 70px; background: var(--gold-dim); }
    .hd-star { color: var(--gold); font-size: 0.75rem; }

    .hero-tagline {
      font-family: 'Cormorant Garant', serif;
      font-style: italic;
      font-weight: 300;
      font-size: clamp(1.1rem, 2.4vw, 1.65rem);
      color: var(--cream-dim);
      letter-spacing: 0.04em;
      margin-bottom: 3.2rem;
      opacity: 0;
      animation: fadeIn 0.9s ease 1.4s forwards;
    }

    .hero-cta-group {
      display: flex;
      align-items: center;
      gap: 3.5rem;
      opacity: 0;
      animation: fadeIn 0.9s ease 1.7s forwards;
    }

    .btn-reserve {
      position: relative;
      display: inline-block;
      padding: 1rem 2.8rem;
      font-family: 'Jost', sans-serif;
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--cream);
      text-decoration: none;
      border: 1px solid var(--gold);
      background: transparent;
      overflow: hidden;
      transition: color 0.4s;
    }
    .btn-reserve::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--gold);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.45s cubic-bezier(0.16,1,0.3,1);
    }
    .btn-reserve:hover::before { transform: scaleX(1); }
    .btn-reserve:hover { color: var(--bg-deep); }
    .btn-reserve span { position: relative; z-index: 1; }

    .hero-hours .h-label {
      display: block;
      font-size: 0.52rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.25rem;
    }
    .hero-hours .h-time {
      font-family: 'Cormorant Garant', serif;
      font-weight: 300;
      font-size: 1.1rem;
      color: var(--cream-dim);
    }

    .scroll-hint {
      position: absolute;
      bottom: 2.5rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.6rem;
      opacity: 0;
      animation: fadeIn 0.9s ease 2.2s forwards;
    }
    .scroll-hint span {
      font-size: 0.48rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--cream-faint);
    }
    .scroll-line {
      width: 1px;
      height: 38px;
      background: linear-gradient(to bottom, var(--gold-dim), transparent);
      animation: scrollPulse 2.2s ease infinite;
    }
    @keyframes scrollPulse {
      0%,100% { opacity: 1; transform: scaleY(1) translateY(0); }
      50%      { opacity: 0.35; transform: scaleY(0.6) translateY(4px); }
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    /* ===== SHARED SECTION STYLES ===== */
    .sect-label {
      font-size: 0.55rem;
      font-weight: 300;
      letter-spacing: 0.38em;
      text-transform: uppercase;
      color: var(--gold);
    }
    .sect-title {
      font-family: 'Cormorant Garant', serif;
      font-weight: 300;
      font-size: clamp(2.2rem, 4.5vw, 4.2rem);
      line-height: 1.1;
      color: var(--cream);
    }
    .sect-title em {
      font-style: italic;
      color: var(--gold);
    }

    /* Art Deco fan */
    .deco-fan {
      display: flex;
      align-items: flex-end;
      gap: 3px;
      height: 22px;
    }
    .deco-fan span {
      display: block;
      background: var(--gold);
      border-radius: 1px 1px 0 0;
      opacity: 0.65;
      width: 2px;
    }
    .deco-fan span:nth-child(1) { height: 7px; }
    .deco-fan span:nth-child(2) { height: 12px; }
    .deco-fan span:nth-child(3) { height: 17px; }
    .deco-fan span:nth-child(4) { height: 22px; }
    .deco-fan span:nth-child(5) { height: 17px; }
    .deco-fan span:nth-child(6) { height: 12px; }
    .deco-fan span:nth-child(7) { height: 7px; }

    /* Scroll reveal */
    .reveal {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity 0.85s ease, transform 0.85s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .rd1 { transition-delay: 0.12s; }
    .rd2 { transition-delay: 0.24s; }
    .rd3 { transition-delay: 0.36s; }
    .rd4 { transition-delay: 0.48s; }

    /* ===== SECTION 2: COCKTAIL KARTE ===== */
    .karte {
      background: var(--bg-mid);
      padding: 7rem 4rem 5rem;
    }

    .karte-head {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.9rem;
      text-align: center;
      margin-bottom: 3.5rem;
    }

    /* Asymmetric 3-card layout */
    .cocktail-layout {
      display: grid;
      grid-template-columns: 3fr 2fr;
      grid-template-rows: 1fr 1fr;
      gap: 3px;
      max-width: 1240px;
      margin: 0 auto;
    }

    .c-card {
      position: relative;
      overflow: hidden;
    }
    .c-card-main { grid-row: 1 / 3; }

    .c-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.8s cubic-bezier(0.16,1,0.3,1);
      filter: brightness(0.88);
    }
    .c-card-main img { min-height: 640px; }
    .c-card-side  img { height: 318px; }
    .c-card:hover img { transform: scale(1.055); }

    .c-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(12,8,6,0.96) 0%, rgba(12,8,6,0.25) 45%, transparent 72%);
    }

    .c-info {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 2.2rem 2.4rem;
    }
    .c-cat {
      font-size: 0.48rem;
      font-weight: 300;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.4rem;
    }
    .c-name {
      font-family: 'Cormorant Garant', serif;
      font-style: italic;
      font-weight: 300;
      font-size: 1.75rem;
      color: var(--cream);
      line-height: 1.15;
    }
    .c-card-main .c-name { font-size: 2.6rem; }
    .c-desc {
      font-size: 0.68rem;
      font-weight: 300;
      color: var(--cream-dim);
      margin-top: 0.45rem;
      line-height: 1.75;
    }
    .c-price-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-top: 1rem;
    }
    .c-price {
      font-family: 'Cormorant Garant', serif;
      font-weight: 300;
      font-size: 1.4rem;
      color: var(--gold);
      white-space: nowrap;
    }
    .c-rule {
      flex: 1;
      height: 1px;
      background: var(--gold-dim);
    }

    /* Menu strip */
    .karte-strip {
      max-width: 1240px;
      margin: 3px auto 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-top: 1px solid var(--gold-faint);
    }
    .ki {
      padding: 1.75rem 2rem 1.75rem 0;
      border-right: 1px solid rgba(200,155,42,0.1);
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
    }
    .ki:first-child { padding-left: 0; }
    .ki:last-child { border-right: none; padding-right: 0; }
    .ki-left { min-width: 0; }
    .ki-name {
      display: block;
      font-family: 'Cormorant Garant', serif;
      font-style: italic;
      font-weight: 300;
      font-size: 1.15rem;
      color: var(--cream);
      white-space: nowrap;
    }
    .ki-ing {
      display: block;
      font-size: 0.6rem;
      font-weight: 300;
      color: var(--cream-faint);
      letter-spacing: 0.04em;
      margin-top: 0.15rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .ki-price {
      font-family: 'Cormorant Garant', serif;
      font-weight: 300;
      font-size: 1.05rem;
      color: var(--gold);
      white-space: nowrap;
    }

    /* ===== SECTION 3: ATMOSPHÄRE ===== */
    .atmo {
      position: relative;
      min-height: 88vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }
    .atmo-bg {
      position: absolute;
      inset: 0;
    }
    .atmo-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
      filter: brightness(0.38) saturate(0.72);
    }
    .atmo-gradient {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to right, rgba(12,8,6,0.92) 0%, rgba(12,8,6,0.28) 62%, transparent 100%),
        linear-gradient(to top, var(--bg-deep) 0%, transparent 18%);
    }

    .atmo-content {
      position: relative;
      z-index: 10;
      padding: 7rem 5.5rem;
      max-width: 640px;
    }

    .atmo-quote {
      font-family: 'Cormorant Garant', serif;
      font-style: italic;
      font-weight: 300;
      font-size: clamp(1.9rem, 3.5vw, 3.1rem);
      line-height: 1.42;
      color: var(--cream);
      margin: 1.4rem 0;
      position: relative;
      padding-left: 1.5rem;
    }
    .atmo-quote::before {
      content: '';
      position: absolute;
      left: 0; top: 0.25em; bottom: 0.25em;
      width: 2px;
      background: var(--gold);
    }

    .atmo-body {
      font-size: 0.84rem;
      font-weight: 300;
      line-height: 2.1;
      color: var(--cream-dim);
      max-width: 50ch;
      margin-top: 1.75rem;
    }

    .atmo-stats {
      display: flex;
      gap: 0;
      margin-top: 3.5rem;
      padding-top: 2.5rem;
      border-top: 1px solid rgba(200,155,42,0.18);
    }
    .atmo-stat {
      flex: 1;
      padding-right: 2rem;
      border-right: 1px solid rgba(200,155,42,0.12);
      margin-right: 2rem;
    }
    .atmo-stat:last-child { border-right: none; margin-right: 0; }
    .as-num {
      display: block;
      font-family: 'Cormorant Garant', serif;
      font-weight: 300;
      font-size: 2.6rem;
      line-height: 1;
      color: var(--gold);
    }
    .as-label {
      display: block;
      font-size: 0.55rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cream-faint);
      margin-top: 0.35rem;
    }

    /* ===== SECTION 4: EVENTS ===== */
    .events {
      background: var(--bg-warm);
      padding: 7rem 4rem;
    }
    .events-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 7rem;
      align-items: start;
    }

    .events-head {
      margin-bottom: 3.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
    }

    .event-list { display: flex; flex-direction: column; }

    .event-item {
      display: grid;
      grid-template-columns: 60px 1fr;
      gap: 0;
      padding: 2rem 0;
      border-bottom: 1px solid rgba(200,155,42,0.11);
      cursor: default;
      transition: background 0.3s;
    }
    .event-item:first-child { border-top: 1px solid rgba(200,155,42,0.11); }

    .event-date {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-right: 1.4rem;
      border-right: 1px solid rgba(200,155,42,0.14);
    }
    .ed-day {
      font-family: 'Cormorant Garant', serif;
      font-weight: 300;
      font-size: 2.2rem;
      color: var(--gold);
      line-height: 1;
    }
    .ed-month {
      font-size: 0.48rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--cream-faint);
      margin-top: 0.1rem;
    }

    .event-body { padding-left: 1.5rem; }
    .ev-type {
      font-size: 0.48rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.35rem;
    }
    .ev-name {
      font-family: 'Cormorant Garant', serif;
      font-weight: 300;
      font-size: 1.2rem;
      color: var(--cream);
      line-height: 1.3;
    }
    .ev-desc {
      font-size: 0.68rem;
      font-weight: 300;
      color: var(--cream-dim);
      margin-top: 0.35rem;
      line-height: 1.75;
    }
    .ev-time {
      font-size: 0.53rem;
      letter-spacing: 0.1em;
      color: var(--cream-faint);
      margin-top: 0.55rem;
    }

    .events-photo-col {
      position: sticky;
      top: 6rem;
    }
    .events-photo {
      position: relative;
      overflow: hidden;
    }
    .events-photo img {
      width: 100%;
      height: 640px;
      object-fit: cover;
      display: block;
      filter: brightness(0.78) saturate(0.85);
      transition: transform 0.8s cubic-bezier(0.16,1,0.3,1);
    }
    .events-photo:hover img { transform: scale(1.03); }
    .events-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent 55%, rgba(12,8,6,0.75) 100%);
    }
    .events-photo-cap {
      position: absolute;
      bottom: 2.2rem;
      left: 2.2rem;
      right: 2.2rem;
    }
    .epc-label {
      display: block;
      font-size: 0.5rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.4rem;
    }
    .epc-text {
      font-family: 'Cormorant Garant', serif;
      font-style: italic;
      font-weight: 300;
      font-size: 1.25rem;
      color: var(--cream);
      line-height: 1.4;
    }

    /* ===== SECTION 5: RESERVIERUNG ===== */
    .reservation {
      position: relative;
      background: var(--bg-deep);
      padding: 9rem 4rem;
      overflow: hidden;
    }
    .reservation::before {
      content: '';
      position: absolute;
      left: 50%; top: 50%;
      transform: translate(-50%, -50%);
      width: 700px; height: 700px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(200,155,42,0.06) 0%, transparent 70%);
      pointer-events: none;
    }
    /* Decorative outer ring */
    .reservation::after {
      content: '';
      position: absolute;
      left: 50%; top: 50%;
      transform: translate(-50%, -50%);
      width: 500px; height: 500px;
      border-radius: 50%;
      border: 1px solid rgba(200,155,42,0.08);
      pointer-events: none;
    }

    .reservation-inner {
      max-width: 680px;
      margin: 0 auto;
      text-align: center;
      position: relative;
      z-index: 1;
    }

    .res-ornament {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.1rem;
      margin-bottom: 2.2rem;
    }
    .ro-line { height: 1px; width: 90px; background: var(--gold-dim); }
    .ro-diamond {
      width: 7px; height: 7px;
      background: var(--gold);
      transform: rotate(45deg);
    }

    .res-title {
      font-family: 'Cormorant Garant', serif;
      font-style: italic;
      font-weight: 300;
      font-size: clamp(3.2rem, 7vw, 6.5rem);
      line-height: 1.05;
      color: var(--cream);
      margin-bottom: 1.1rem;
    }
    .res-subtitle {
      font-family: 'Cormorant Garant', serif;
      font-style: italic;
      font-weight: 300;
      font-size: 1.1rem;
      color: var(--cream-dim);
      margin-bottom: 3.5rem;
    }

    .res-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border: 1px solid rgba(200,155,42,0.18);
      margin-bottom: 3.5rem;
    }
    .res-block {
      padding: 2.2rem 1.8rem;
      border-right: 1px solid rgba(200,155,42,0.18);
    }
    .res-block:last-child { border-right: none; }
    .rb-label {
      display: block;
      font-size: 0.5rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.65rem;
    }
    .rb-val {
      font-family: 'Cormorant Garant', serif;
      font-weight: 300;
      font-size: 1rem;
      color: var(--cream);
      line-height: 1.8;
    }

    .btn-cta {
      display: inline-block;
      padding: 1.2rem 4.5rem;
      font-family: 'Jost', sans-serif;
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--bg-deep);
      background: var(--gold);
      text-decoration: none;
      transition: background 0.35s, transform 0.35s;
    }
    .btn-cta:hover {
      background: #D4A93C;
      transform: translateY(-2px);
    }

    .res-note {
      font-size: 0.6rem;
      font-weight: 300;
      color: var(--cream-faint);
      margin-top: 1.6rem;
      letter-spacing: 0.08em;
    }

    /* ===== FOOTER ===== */
    footer {
      background: var(--bg-deep);
      border-top: 1px solid rgba(200,155,42,0.12);
      padding: 2.8rem 4rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .footer-logo {
      font-family: 'Cormorant Garant', serif;
      font-style: italic;
      font-size: 1.5rem;
      color: var(--gold);
    }
    .footer-copy {
      font-size: 0.57rem;
      letter-spacing: 0.12em;
      color: var(--cream-faint);
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 1024px) {
      .cocktail-layout {
        grid-template-columns: 1fr;
        grid-template-rows: auto;
      }
      .c-card-main { grid-row: auto; }
      .c-card-main img { min-height: 420px; }
      .c-card-side  img { height: 260px; }

      .karte-strip { grid-template-columns: 1fr; }
      .ki { border-right: none; border-bottom: 1px solid rgba(200,155,42,0.1); padding: 1.5rem 0; }

      .events-inner { grid-template-columns: 1fr; gap: 3rem; }
      .events-photo-col { position: static; }
    }

    @media (max-width: 768px) {
      nav { padding: 1.2rem 1.5rem; }
      .nav-links { display: none; }
      .hero-frame { inset: 40px 20px 40px; }
      .hero-name { font-size: clamp(4.5rem, 20vw, 8rem); }
      .hero-cta-group { flex-direction: column; gap: 1.8rem; align-items: center; }

      .karte { padding: 5rem 1.5rem 4rem; }
      .atmo-content { padding: 5rem 2rem; }
      .events { padding: 5rem 1.5rem; }

      .res-grid { grid-template-columns: 1fr; }
      .res-block { border-right: none; border-bottom: 1px solid rgba(200,155,42,0.18); }
      .res-block:last-child { border-bottom: none; }
      .reservation { padding: 5rem 1.5rem; }

      footer { flex-direction: column; gap: 1rem; text-align: center; }
    }
  </style>
</head>
<body>

