---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Dunkel — Bar & Cocktails | Trier Altstadt</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,600&family=Karla:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }
    body {
      overflow-x: hidden;
      background: #140A02;
      color: #EDE0C4;
      font-family: 'Karla', sans-serif;
      min-height: 100vh;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.6rem 3rem;
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.6rem;
      letter-spacing: 0.04em;
      color: #D4891A;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.7rem;
      font-weight: 300;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(237, 224, 196, 0.5);
      text-decoration: none;
      transition: color 0.4s;
    }
    .nav-links a:hover { color: #D4891A; }

    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    /* CSS atmosphere — no photo */
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 70% at 50% 60%, rgba(212, 137, 26, 0.18) 0%, transparent 65%),
        radial-gradient(ellipse 30% 40% at 50% 55%, rgba(212, 137, 26, 0.12) 0%, transparent 50%);
    }

    /* Grain texture */
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.07'/%3E%3C/svg%3E");
      pointer-events: none;
      opacity: 1;
    }

    /* Amber glow orb — animated candle flicker */
    .glow-orb {
      position: absolute;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(212, 137, 26, 0.14) 0%, transparent 70%);
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      animation: flicker 4s ease-in-out infinite;
    }
    @keyframes flicker {
      0%, 100% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
      25%       { opacity: 0.85; transform: translate(-50%, -51%) scale(0.97); }
      50%       { opacity: 1; transform: translate(-50%, -50%) scale(1.02); }
      75%       { opacity: 0.9; transform: translate(-50%, -49.5%) scale(0.99); }
    }

    /* Central content */
    .hero-content {
      position: relative;
      z-index: 10;
      text-align: center;
      max-width: 700px;
      padding: 2rem;
    }

    /* Large ornamental ring */
    .ring-wrap {
      position: relative;
      width: 320px; height: 320px;
      margin: 0 auto 3rem;
      opacity: 0;
      animation: fadeIn 1.2s ease 0.2s forwards;
    }
    .ring {
      position: absolute;
      inset: 0;
      border: 1px solid rgba(212, 137, 26, 0.35);
      border-radius: 50%;
      animation: slowRotate 30s linear infinite;
    }
    .ring-inner {
      position: absolute;
      inset: 16px;
      border: 1px solid rgba(212, 137, 26, 0.2);
      border-radius: 50%;
    }
    @keyframes slowRotate {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }

    /* Ring tick marks */
    .ring-tick {
      position: absolute;
      width: 8px; height: 1px;
      background: rgba(212, 137, 26, 0.5);
      top: 50%;
      left: 50%;
      transform-origin: left center;
    }

    .ring-center-text {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    .ring-est {
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(212, 137, 26, 0.6);
      margin-bottom: 0.4rem;
    }
    .ring-year {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-weight: 400;
      color: #D4891A;
      line-height: 1;
    }
    .ring-location {
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(237, 224, 196, 0.4);
      margin-top: 0.4rem;
    }

    .eyebrow {
      font-size: 0.68rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(212, 137, 26, 0.7);
      margin-bottom: 1.4rem;
      opacity: 0;
      animation: fadeIn 0.8s ease 0.8s forwards;
    }

    .headline {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3.5rem, 6vw, 7rem);
      line-height: 1.05;
      letter-spacing: 0.01em;
      color: #EDE0C4;
      margin-bottom: 0.5rem;
    }
    .headline em {
      font-style: italic;
      color: #D4891A;
    }
    .headline .ln {
      display: block;
      opacity: 0;
      animation: slideUp 0.8s ease forwards;
    }
    .headline .ln:nth-child(1) { animation-delay: 0.9s; }
    .headline .ln:nth-child(2) { animation-delay: 1.1s; }

    .ornament-bar {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.7rem;
      margin: 1.6rem 0;
      opacity: 0;
      animation: fadeIn 0.8s ease 1.3s forwards;
    }
    .ob-line { width: 50px; height: 1px; background: rgba(212, 137, 26, 0.5); }
    .ob-dot { width: 3px; height: 3px; background: #D4891A; border-radius: 50%; }

    .tagline {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.05rem;
      color: rgba(237, 224, 196, 0.6);
      margin-bottom: 2.4rem;
      letter-spacing: 0.03em;
      opacity: 0;
      animation: fadeIn 0.8s ease 1.4s forwards;
    }

    .cta-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
      opacity: 0;
      animation: fadeIn 0.8s ease 1.6s forwards;
    }
    .btn-main {
      border: 1px solid rgba(212, 137, 26, 0.6);
      color: #EDE0C4;
      padding: 0.85rem 2.2rem;
      font-family: 'Karla', sans-serif;
      font-size: 0.7rem;
      font-weight: 300;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      background: transparent;
      transition: all 0.4s;
    }
    .btn-main:hover {
      background: rgba(212, 137, 26, 0.15);
      border-color: #D4891A;
    }
    .hours {
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      color: rgba(237, 224, 196, 0.35);
      line-height: 1.6;
    }
    .hours strong {
      display: block;
      color: rgba(212, 137, 26, 0.7);
      font-weight: 400;
      margin-bottom: 0.1rem;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ===== SECTION 2 — SIGNATURE COCKTAILS ===== */
    .karte {
      padding: 6rem 5rem;
      background: #1A0D04;
    }
    .karte-head {
      text-align: center;
      margin-bottom: 3.5rem;
    }
    .karte-eyebrow {
      font-size: 0.58rem;
      font-weight: 300;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: #D4891A;
      margin-bottom: 1rem;
    }
    .karte-title {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: clamp(2rem, 4vw, 3.5rem);
      color: #EDE0C4;
      line-height: 1.2;
    }
    .karte-rule {
      width: 3rem;
      height: 1px;
      background: rgba(212,137,26,0.4);
      margin: 1.25rem auto 0;
    }

    .cocktail-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    .cocktail-card {
      position: relative;
      overflow: hidden;
    }
    .cocktail-card img {
      width: 100%;
      height: 420px;
      object-fit: cover;
      display: block;
      transition: transform 0.6s ease;
      filter: brightness(0.9);
    }
    .cocktail-card:hover img { transform: scale(1.06); }
    .cocktail-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(20,10,2,0.9) 0%, rgba(20,10,2,0.2) 50%, transparent 100%);
    }
    .cocktail-info {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 2rem 2rem;
    }
    .cocktail-category {
      font-size: 0.5rem;
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: #D4891A;
      margin-bottom: 0.5rem;
    }
    .cocktail-name {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.5rem;
      color: #EDE0C4;
      line-height: 1.2;
    }
    .cocktail-desc {
      font-size: 0.68rem;
      font-weight: 300;
      color: rgba(237,224,196,0.55);
      margin-top: 0.4rem;
    }
    .cocktail-price {
      font-size: 0.75rem;
      color: #D4891A;
      margin-top: 0.75rem;
      letter-spacing: 0.06em;
    }

    /* ===== SECTION 3 — BAR ATMO ===== */
    .bar-atmo {
      position: relative;
      min-height: 580px;
      overflow: hidden;
    }
    .bar-atmo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: brightness(0.45);
    }
    .bar-atmo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, rgba(20,10,2,0.7) 0%, transparent 60%);
    }
    .bar-atmo-content {
      position: relative;
      z-index: 1;
      max-width: 540px;
      padding: 6rem 5rem;
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
      height: 100%;
      justify-content: center;
    }
    .bar-atmo-quote {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: clamp(1.5rem, 3vw, 2.4rem);
      color: #EDE0C4;
      line-height: 1.45;
    }
    .bar-atmo-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.9;
      color: rgba(237,224,196,0.55);
      max-width: 46ch;
    }
    .bar-atmo-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #D4891A;
      text-decoration: none;
      border-bottom: 1px solid rgba(212,137,26,0.35);
      padding-bottom: 2px;
      align-self: flex-start;
      transition: opacity 0.2s;
    }
    .bar-atmo-cta:hover { opacity: 0.7; }

    @media (max-width: 1024px) {
      .cocktail-grid { grid-template-columns: 1fr 1fr; }
      .cocktail-card:last-child { grid-column: 1 / -1; }
      .cocktail-card:last-child img { height: 300px; }
    }
    @media (max-width: 768px) {
      .karte { padding: 4rem 2rem; }
      .cocktail-grid { grid-template-columns: 1fr; }
      .cocktail-card:last-child { grid-column: auto; }
      .cocktail-card img, .cocktail-card:last-child img { height: 300px; }
      .bar-atmo-content { padding: 4rem 2rem; }
    }
  </style>
</head>
<body>
  <nav>
    <span class="nav-logo">Dunkel</span>
    <ul class="nav-links">
      <li><a href="#">Karte</a></li>
      <li><a href="#">Reservierung</a></li>
      <li><a href="#">Events</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
  </nav>

  <section class="hero">
    <div class="glow-orb"></div>

    <div class="hero-content">
      <div class="ring-wrap">
        <div class="ring">
          <!-- tick marks every 30deg -->
          <div class="ring-tick" style="transform: rotate(0deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(30deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(60deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(90deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(120deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(150deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(180deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(210deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(240deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(270deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(300deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(330deg) translateX(150px)"></div>
        </div>
        <div class="ring-inner"></div>
        <div class="ring-center-text">
          <div class="ring-est">Est.</div>
          <div class="ring-year">2018</div>
          <div class="ring-location">Trier Altstadt</div>
        </div>
      </div>

      <p class="eyebrow">Bar & Cocktails · Trier</p>

      <h1 class="headline">
        <span class="ln">Der Abend</span>
        <span class="ln">gehört dir.</span>
      </h1>

      <div class="ornament-bar">
        <div class="ob-line"></div>
        <div class="ob-dot"></div>
        <div class="ob-line"></div>
      </div>

      <p class="tagline">Gezapft. Geschüttelt. Gelebt.</p>

      <div class="cta-row">
        <a href="#" class="btn-main">Tisch reservieren</a>
        <div class="hours">
          <strong>Di – Sa</strong>
          18:00 – 02:00 Uhr
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 2: COCKTAIL KARTE ===== -->
  <section class="karte">
    <div class="karte-head">
      <div class="karte-eyebrow">Handcrafted Cocktails</div>
      <h2 class="karte-title">Unsere Signaturen.</h2>
      <div class="karte-rule"></div>
    </div>
    <div class="cocktail-grid">
      <div class="cocktail-card">
        <img src="https://images.unsplash.com/photo-1551538827-9c037cb4f32a?auto=format&fit=crop&w=800&h=700&q=80"
             alt="Signature Cocktail mit Garnish" loading="lazy" />
        <div class="cocktail-overlay"></div>
        <div class="cocktail-info">
          <div class="cocktail-category">Signature · Bitter</div>
          <div class="cocktail-name">Dunkel Negroni</div>
          <div class="cocktail-desc">Campari, Gin, roter Wermut, Orangenzeste</div>
          <div class="cocktail-price">14 €</div>
        </div>
      </div>
      <div class="cocktail-card">
        <img src="https://images.unsplash.com/photo-1470337458703-46ad1756a187?auto=format&fit=crop&w=800&h=700&q=80"
             alt="Frischer Cocktail mit Limette" loading="lazy" />
        <div class="cocktail-overlay"></div>
        <div class="cocktail-info">
          <div class="cocktail-category">Frisch · Zitrus</div>
          <div class="cocktail-name">Trier Mule</div>
          <div class="cocktail-desc">Vodka, Ingwerbier, Limette, Gurke</div>
          <div class="cocktail-price">12 €</div>
        </div>
      </div>
      <div class="cocktail-card">
        <img src="https://images.unsplash.com/photo-1499638673689-79a0b5115d87?auto=format&fit=crop&w=800&h=700&q=80"
             alt="Eleganter Martini" loading="lazy" />
        <div class="cocktail-overlay"></div>
        <div class="cocktail-info">
          <div class="cocktail-category">Classic · Trocken</div>
          <div class="cocktail-name">Dry Martini</div>
          <div class="cocktail-desc">Gin, trockener Wermut, Olive oder Zitronenzeste</div>
          <div class="cocktail-price">13 €</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 3: BAR ATMOSPHÄRE ===== -->
  <section class="bar-atmo">
    <img src="https://images.unsplash.com/photo-1572116469696-31de0f17cc34?auto=format&fit=crop&w=1600&h=900&q=80"
         alt="Dunkle Bar-Atmosphäre mit warmem Licht" loading="lazy" />
    <div class="bar-atmo-overlay"></div>
    <div class="bar-atmo-content">
      <div class="karte-eyebrow">Der Ort</div>
      <p class="bar-atmo-quote">"Ein guter Cocktail braucht keinen Lärm."</p>
      <p class="bar-atmo-body">
        Dunkel liegt versteckt in einem Gewölbe nahe der Trierer Altstadt.
        Kein DJ, keine Warteschlange. Nur handgemischte Drinks,
        wechselnde Karten und das Gespräch, das beim zweiten Glas anfängt.
      </p>
      <p class="bar-atmo-body">
        Dienstag bis Samstag ab 18 Uhr.
        Reservierungen für Gruppen ab 6 Personen.
      </p>
      <a href="#" class="bar-atmo-cta">Tisch reservieren →</a>
    </div>
  </section>

</body>
</html>
