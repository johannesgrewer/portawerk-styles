---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Dunkel — Bar & Cocktails | Trier Altstadt</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,600&family=Karla:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }
    body {
      overflow-x: hidden;
      background: #140A02;
      color: #EDE0C4;
      font-family: 'Karla', sans-serif;
      min-height: 100vh;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.6rem 3rem;
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.6rem;
      letter-spacing: 0.04em;
      color: #D4891A;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.7rem;
      font-weight: 300;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(237, 224, 196, 0.5);
      text-decoration: none;
      transition: color 0.4s;
    }
    .nav-links a:hover { color: #D4891A; }

    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    /* CSS atmosphere — no photo */
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 70% at 50% 60%, rgba(212, 137, 26, 0.18) 0%, transparent 65%),
        radial-gradient(ellipse 30% 40% at 50% 55%, rgba(212, 137, 26, 0.12) 0%, transparent 50%);
    }

    /* Grain texture */
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.07'/%3E%3C/svg%3E");
      pointer-events: none;
      opacity: 1;
    }

    /* Amber glow orb — animated candle flicker */
    .glow-orb {
      position: absolute;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(212, 137, 26, 0.14) 0%, transparent 70%);
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      animation: flicker 4s ease-in-out infinite;
    }
    @keyframes flicker {
      0%, 100% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
      25%       { opacity: 0.85; transform: translate(-50%, -51%) scale(0.97); }
      50%       { opacity: 1; transform: translate(-50%, -50%) scale(1.02); }
      75%       { opacity: 0.9; transform: translate(-50%, -49.5%) scale(0.99); }
    }

    /* Central content */
    .hero-content {
      position: relative;
      z-index: 10;
      text-align: center;
      max-width: 700px;
      padding: 2rem;
    }

    /* Large ornamental ring */
    .ring-wrap {
      position: relative;
      width: 320px; height: 320px;
      margin: 0 auto 3rem;
      opacity: 0;
      animation: fadeIn 1.2s ease 0.2s forwards;
    }
    .ring {
      position: absolute;
      inset: 0;
      border: 1px solid rgba(212, 137, 26, 0.35);
      border-radius: 50%;
      animation: slowRotate 30s linear infinite;
    }
    .ring-inner {
      position: absolute;
      inset: 16px;
      border: 1px solid rgba(212, 137, 26, 0.2);
      border-radius: 50%;
    }
    @keyframes slowRotate {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }

    /* Ring tick marks */
    .ring-tick {
      position: absolute;
      width: 8px; height: 1px;
      background: rgba(212, 137, 26, 0.5);
      top: 50%;
      left: 50%;
      transform-origin: left center;
    }

    .ring-center-text {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    .ring-est {
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(212, 137, 26, 0.6);
      margin-bottom: 0.4rem;
    }
    .ring-year {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-weight: 400;
      color: #D4891A;
      line-height: 1;
    }
    .ring-location {
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(237, 224, 196, 0.4);
      margin-top: 0.4rem;
    }

    .eyebrow {
      font-size: 0.68rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(212, 137, 26, 0.7);
      margin-bottom: 1.4rem;
      opacity: 0;
      animation: fadeIn 0.8s ease 0.8s forwards;
    }

    .headline {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3.5rem, 6vw, 7rem);
      line-height: 1.05;
      letter-spacing: 0.01em;
      color: #EDE0C4;
      margin-bottom: 0.5rem;
    }
    .headline em {
      font-style: italic;
      color: #D4891A;
    }
    .headline .ln {
      display: block;
      opacity: 0;
      animation: slideUp 0.8s ease forwards;
    }
    .headline .ln:nth-child(1) { animation-delay: 0.9s; }
    .headline .ln:nth-child(2) { animation-delay: 1.1s; }

    .ornament-bar {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.7rem;
      margin: 1.6rem 0;
      opacity: 0;
      animation: fadeIn 0.8s ease 1.3s forwards;
    }
    .ob-line { width: 50px; height: 1px; background: rgba(212, 137, 26, 0.5); }
    .ob-dot { width: 3px; height: 3px; background: #D4891A; border-radius: 50%; }

    .tagline {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.05rem;
      color: rgba(237, 224, 196, 0.6);
      margin-bottom: 2.4rem;
      letter-spacing: 0.03em;
      opacity: 0;
      animation: fadeIn 0.8s ease 1.4s forwards;
    }

    .cta-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
      opacity: 0;
      animation: fadeIn 0.8s ease 1.6s forwards;
    }
    .btn-main {
      border: 1px solid rgba(212, 137, 26, 0.6);
      color: #EDE0C4;
      padding: 0.85rem 2.2rem;
      font-family: 'Karla', sans-serif;
      font-size: 0.7rem;
      font-weight: 300;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      background: transparent;
      transition: all 0.4s;
    }
    .btn-main:hover {
      background: rgba(212, 137, 26, 0.15);
      border-color: #D4891A;
    }
    .hours {
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      color: rgba(237, 224, 196, 0.35);
      line-height: 1.6;
    }
    .hours strong {
      display: block;
      color: rgba(212, 137, 26, 0.7);
      font-weight: 400;
      margin-bottom: 0.1rem;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <nav>
    <span class="nav-logo">Dunkel</span>
    <ul class="nav-links">
      <li><a href="#">Karte</a></li>
      <li><a href="#">Reservierung</a></li>
      <li><a href="#">Events</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
  </nav>

  <section class="hero">
    <div class="glow-orb"></div>

    <div class="hero-content">
      <div class="ring-wrap">
        <div class="ring">
          <!-- tick marks every 30deg -->
          <div class="ring-tick" style="transform: rotate(0deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(30deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(60deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(90deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(120deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(150deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(180deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(210deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(240deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(270deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(300deg) translateX(150px)"></div>
          <div class="ring-tick" style="transform: rotate(330deg) translateX(150px)"></div>
        </div>
        <div class="ring-inner"></div>
        <div class="ring-center-text">
          <div class="ring-est">Est.</div>
          <div class="ring-year">2018</div>
          <div class="ring-location">Trier Altstadt</div>
        </div>
      </div>

      <p class="eyebrow">Bar & Cocktails · Trier</p>

      <h1 class="headline">
        <span class="ln">Der Abend</span>
        <span class="ln">gehört dir.</span>
      </h1>

      <div class="ornament-bar">
        <div class="ob-line"></div>
        <div class="ob-dot"></div>
        <div class="ob-line"></div>
      </div>

      <p class="tagline">Gezapft. Geschüttelt. Gelebt.</p>

      <div class="cta-row">
        <a href="#" class="btn-main">Tisch reservieren</a>
        <div class="hours">
          <strong>Di – Sa</strong>
          18:00 – 02:00 Uhr
        </div>
      </div>
    </div>
  </section>
</body>
</html>
