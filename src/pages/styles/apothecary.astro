      .handwerk-photo { height: 380px; }
      .handwerk-photo img { position: absolute; }
      .handwerk-photo-overlay { display: none; }
      .footer-grid { grid-template-columns: 1fr; }
      .footer-col { border-right: none; border-bottom: 1px solid rgba(192,146,66,0.07); }
      .footer-col:last-child { border-bottom: none; }
    }
    @media (max-width: 768px) {
      nav { padding: 1.25rem 1.5rem; }
      .nav-links, .nav-cta { display: none; }
      .katalog, .sortiment { padding: 4.5rem 1.5rem; }
