---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Materia Medica — Kräuterapotheke & Naturmanufaktur Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; overflow-x: hidden; }

    :root {
      --parchment:    #F0E6CC;
      --parchment-dk: #D8C9A3;
      --ink:          #1A1108;
      --forest:       #1B2B1B;
      --moss:         #243624;
      --gold:         #C09242;
      --gold-f:       rgba(192,146,66,1);
      --gold-mid:     rgba(192,146,66,0.35);
      --gold-faint:   rgba(192,146,66,0.12);
      --cream:        #FAF4E4;
      --cream-dim:    rgba(250,244,228,0.45);
      --sage:         #6B7A5C;
    }

    body {
      background: var(--forest);
      color: var(--cream);
      font-family: 'Lora', serif;
      overflow-x: hidden;
    }

    /* Grain overlay */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)' opacity='0.04'/%3E%3C/svg%3E");
      background-size: 200px;
      pointer-events: none;
      z-index: 9999;
      mix-blend-mode: overlay;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 200;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.4rem 4rem;
      background: rgba(27,43,27,0.97);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--gold-faint);
    }
    .nav-brand {
      display: flex; flex-direction: column; gap: 0.05rem;
    }
    .nav-brand-name {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600; font-size: 1.3rem;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--cream); line-height: 1;
    }
    .nav-brand-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 0.6rem;
      letter-spacing: 0.22em; color: var(--gold);
      text-transform: lowercase;
    }
    .nav-links {
      display: flex; gap: 2.75rem; list-style: none;
    }
    .nav-links a {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.7rem; font-weight: 400;
      letter-spacing: 0.24em; text-transform: uppercase;
      color: rgba(250,244,228,0.38); text-decoration: none;
      position: relative; transition: color 0.3s;
    }
    .nav-links a::after {
      content: ''; position: absolute;
      bottom: -3px; left: 0; width: 0; height: 1px;
      background: var(--gold); transition: width 0.35s;
    }
    .nav-links a:hover { color: var(--gold); }
    .nav-links a:hover::after { width: 100%; }
    .nav-cta {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.68rem; font-weight: 600;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--ink); background: var(--gold);
      text-decoration: none; padding: 0.65rem 1.75rem;
      border: 1px solid var(--gold);
      transition: background 0.3s, color 0.3s;
    }
    .nav-cta:hover { background: transparent; color: var(--gold); }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      display: grid; grid-template-columns: 1fr 1fr;
      padding-top: 64px; position: relative;
    }

    .hero-left {
      display: flex; flex-direction: column;
      justify-content: center;
      padding: 6rem 3.5rem 9rem 4.5rem;
      position: relative; z-index: 2;
    }

    .hero-provenance {
      display: flex; align-items: center; gap: 1rem;
      margin-bottom: 2.75rem;
      animation: fadeUp 0.9s ease both 0.2s;
    }
    .prov-line { width: 36px; height: 1px; background: var(--gold); }
    .prov-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.6rem; font-weight: 400;
      letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--gold);
    }

    .hero-headline {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: clamp(3.2rem, 6.5vw, 6rem);
      line-height: 1.02; letter-spacing: 0.01em;
      color: var(--cream); margin-bottom: 2rem;
      animation: fadeUp 0.9s ease both 0.35s;
    }
    .hero-headline em {
      font-style: italic; color: var(--gold); font-weight: 300;
    }

    .hero-ornament {
      display: flex; align-items: center; gap: 0.75rem;
      margin-bottom: 1.75rem;
      animation: fadeUp 0.9s ease both 0.45s;
    }
    .orn-line {
      height: 1px;
      background: linear-gradient(to right, var(--gold-mid), transparent);
      width: 80px;
    }
    .orn-diamond {
      width: 5px; height: 5px;
      background: var(--gold-mid);
      transform: rotate(45deg);
    }

    .hero-body {
      font-size: 0.88rem; font-weight: 400;
      line-height: 1.9; color: rgba(250,244,228,0.48);
      max-width: 42ch; margin-bottom: 2.75rem;
      animation: fadeUp 0.9s ease both 0.5s;
    }

    .hero-cta {
      display: flex; align-items: center; gap: 2rem;
      animation: fadeUp 0.9s ease both 0.6s;
    }
    .btn-gold {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.72rem; font-weight: 600;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--ink); background: var(--gold);
      text-decoration: none;
      padding: 1rem 2.5rem;
      border: 1px solid var(--gold);
      transition: background 0.3s, color 0.3s;
    }
    .btn-gold:hover { background: transparent; color: var(--gold); }
    .btn-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.7rem; font-weight: 400;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(250,244,228,0.3); text-decoration: none;
      transition: color 0.3s;
    }
    .btn-text:hover { color: var(--cream); }

    /* Hero right — photo */
    .hero-right {
      position: relative; overflow: hidden;
    }
    .hero-photo {
      position: absolute; inset: 0;
      width: 100%; height: 100%; object-fit: cover;
      filter: sepia(20%) brightness(0.68) saturate(0.9);
      transition: transform 9s ease;
    }
    .hero:hover .hero-photo { transform: scale(1.04); }
    .hero-photo-veil {
      position: absolute; inset: 0;
      background:
        linear-gradient(to right, var(--forest) 0%, transparent 25%),
        linear-gradient(to top, rgba(27,43,27,0.5) 0%, transparent 45%);
    }

    /* Botanical SVG corner ornament */
    .botanical-corner {
      position: absolute; bottom: 2.5rem; right: 2.5rem;
      width: 120px; opacity: 0.2; pointer-events: none;
    }

    /* Hero strip */
    .hero-strip {
      position: absolute; bottom: 0; left: 0; right: 0;
      display: flex;
      background: rgba(36,54,36,0.92);
      border-top: 1px solid var(--gold-faint);
      backdrop-filter: blur(8px);
      z-index: 10;
    }
    .strip-cell {
      flex: 1;
      padding: 1.1rem 1.4rem;
      border-right: 1px solid rgba(192,146,66,0.07);
      display: flex; align-items: center; gap: 0.9rem;
      animation: fadeUp 0.8s ease both;
    }
    .strip-cell:nth-child(1) { animation-delay: 0.7s; }
    .strip-cell:nth-child(2) { animation-delay: 0.8s; }
    .strip-cell:nth-child(3) { animation-delay: 0.9s; }
    .strip-cell:nth-child(4) { animation-delay: 1.0s; }
    .strip-cell:nth-child(5) { animation-delay: 1.1s; border-right: none; }
    .strip-num {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 1.3rem;
      font-weight: 300; color: var(--gold-mid);
      line-height: 1; flex-shrink: 0;
    }
    .strip-names {}
    .strip-herb-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.75rem; font-weight: 400;
      color: rgba(250,244,228,0.72); letter-spacing: 0.04em;
    }
    .strip-herb-latin {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 0.57rem;
      color: rgba(250,244,228,0.22);
      display: block; margin-top: 0.1rem;
    }

    /* ─── SECTION: HEILKRÄUTER KATALOG (LIGHT) ─── */
    .katalog {
      background: var(--parchment);
      padding: 7rem 4.5rem;
      position: relative;
    }

    .sec-header {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 4rem; align-items: end;
      margin-bottom: 4rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid rgba(26,17,8,0.1);
    }
    .sec-eyebrow {
      display: flex; align-items: center; gap: 0.75rem;
      margin-bottom: 0.85rem;
    }
    .eyebrow-line { width: 28px; height: 1px; background: var(--gold); }
    .eyebrow-label {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 0.68rem;
      letter-spacing: 0.18em; color: var(--gold);
    }
    .sec-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300; line-height: 1.05;
      font-size: clamp(2rem, 3.8vw, 3.2rem);
      color: var(--ink);
    }
    .sec-title em { font-style: italic; color: #7A4F1A; }
    .sec-desc {
      font-size: 0.83rem; line-height: 1.9;
      color: rgba(26,17,8,0.48);
      max-width: 46ch; align-self: end;
    }

    /* Herb catalog */
    .herb-catalog {
      display: grid; grid-template-columns: 1fr 1fr;
      border: 1px solid rgba(26,17,8,0.1);
    }
    .herb-entry {
      display: grid;
      grid-template-columns: 72px 1fr 160px;
      border-bottom: 1px solid rgba(26,17,8,0.08);
      border-right: 1px solid rgba(26,17,8,0.08);
      overflow: hidden; cursor: default;
      transition: background 0.35s;
    }
    .herb-entry:nth-child(even) { border-right: none; }
    .herb-entry:nth-last-child(-n+2) { border-bottom: none; }
    .herb-entry:hover { background: rgba(192,146,66,0.07); }

    .herb-numcol {
      padding: 2rem 1.25rem;
      border-right: 1px solid rgba(26,17,8,0.07);
      display: flex; align-items: center; justify-content: center;
      align-self: stretch;
    }
    .herb-roman {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 1.75rem;
      font-weight: 300; color: rgba(192,146,66,0.3);
      line-height: 1;
    }
    .herb-body { padding: 2rem 1.75rem; }
    .herb-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem; font-weight: 500;
      color: var(--ink); margin-bottom: 0.2rem;
    }
    .herb-latin {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 0.7rem;
      color: rgba(26,17,8,0.32); margin-bottom: 0.55rem;
    }
    .herb-desc {
      font-size: 0.75rem; line-height: 1.65;
      color: rgba(26,17,8,0.5);
    }
    .herb-tagcol {
      padding: 2rem 1.25rem;
      border-left: 1px solid rgba(26,17,8,0.07);
      align-self: stretch;
      display: flex; flex-direction: column;
      gap: 0.35rem; justify-content: center;
    }
    .herb-tag {
      font-size: 0.54rem; font-weight: 400;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: rgba(26,17,8,0.32);
      padding: 0.22rem 0.55rem;
      border: 1px solid rgba(26,17,8,0.12);
      display: inline-block; width: fit-content;
    }

    /* ─── SECTION: SORTIMENT (DARK) ─── */
    .sortiment {
      background: var(--forest);
      padding: 7rem 4.5rem;
    }
    .sortiment .sec-title { color: var(--cream); }
    .sortiment .sec-title em { color: var(--gold); }
    .sortiment .sec-desc { color: rgba(250,244,228,0.38); }
    .sortiment .sec-header {
      border-bottom-color: var(--gold-faint);
    }
    .sec-header-link {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.68rem; font-weight: 400;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(250,244,228,0.28); text-decoration: none;
      border-bottom: 1px solid var(--gold-faint);
      padding-bottom: 2px;
      white-space: nowrap; align-self: flex-end;
      transition: color 0.3s, border-color 0.3s;
    }
    .sec-header-link:hover { color: var(--gold); border-bottom-color: var(--gold); }

    /* Magazine-style asymmetric grid */
    .sort-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: 360px 260px;
      gap: 3px;
    }
    .sort-card { position: relative; overflow: hidden; }
    .sort-card:nth-child(1) { grid-column: 1; grid-row: 1; }
    .sort-card:nth-child(2) { grid-column: 2; grid-row: 1; }
    .sort-card:nth-child(3) { grid-column: 3; grid-row: 1 / 3; } /* tall */
    .sort-card:nth-child(4) { grid-column: 1; grid-row: 2; }
    .sort-card:nth-child(5) { grid-column: 2; grid-row: 2; }

    .sort-card img {
      position: absolute; inset: 0;
      width: 100%; height: 100%; object-fit: cover;
      filter: sepia(22%) brightness(0.72) saturate(0.85);
      transition: transform 0.75s ease, filter 0.4s ease;
    }
    .sort-card:hover img {
      transform: scale(1.07);
      filter: sepia(8%) brightness(0.86) saturate(1);
    }
    .sort-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(27,43,27,0.88) 0%, transparent 52%);
    }
    .sort-info {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 1.6rem 1.75rem;
    }
    .sort-cat {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 0.65rem;
      color: var(--gold); letter-spacing: 0.1em;
      margin-bottom: 0.2rem;
    }
    .sort-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem; font-weight: 500;
      color: var(--cream);
    }

    /* ─── SECTION: HANDWERK (SPLIT) ─── */
    .handwerk {
      display: grid; grid-template-columns: 1fr 1fr;
      min-height: 620px;
    }
    .handwerk-photo {
      position: relative; overflow: hidden;
    }
    .handwerk-photo img {
      position: absolute; inset: 0;
      width: 100%; height: 100%; object-fit: cover;
      filter: sepia(25%) brightness(0.75) saturate(0.8);
      transition: transform 9s ease;
    }
    .handwerk:hover .handwerk-photo img { transform: scale(1.04); }
    .handwerk-photo-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to right, transparent 65%, var(--parchment) 100%);
    }

    .handwerk-text {
      background: var(--parchment);
      padding: 5.5rem 5rem;
      display: flex; flex-direction: column;
      justify-content: center; gap: 0;
    }
    .handwerk-text .sec-title {
      color: var(--ink); margin-bottom: 2.5rem;
    }

    .process-list {
      border-top: 1px solid rgba(26,17,8,0.09);
    }
    .process-item {
      display: grid; grid-template-columns: 52px 1fr;
      gap: 1.5rem; padding: 1.75rem 0;
      border-bottom: 1px solid rgba(26,17,8,0.09);
      align-items: start;
      transition: padding-left 0.35s;
    }
    .process-item:hover { padding-left: 0.5rem; }
    .process-num {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 1.7rem;
      font-weight: 300; color: rgba(192,146,66,0.3);
      line-height: 1; margin-top: -0.1rem;
    }
    .process-step-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.05rem; font-weight: 500;
      color: var(--ink); margin-bottom: 0.3rem;
    }
    .process-step-desc {
      font-size: 0.77rem; line-height: 1.72;
      color: rgba(26,17,8,0.45);
    }

    /* ─── SECTION: MANIFESTO ─── */
    .manifesto {
      background: var(--moss);
      padding: 9rem 4.5rem;
      position: relative; overflow: hidden;
      display: flex; flex-direction: column;
      align-items: center; text-align: center;
      gap: 2.25rem;
    }
    /* Subtle cross-hatch pattern */
    .manifesto::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        repeating-linear-gradient(
          0deg,
          transparent, transparent 48px,
          rgba(192,146,66,0.04) 48px, rgba(192,146,66,0.04) 49px
        ),
        repeating-linear-gradient(
          90deg,
          transparent, transparent 48px,
          rgba(192,146,66,0.04) 48px, rgba(192,146,66,0.04) 49px
        );
      pointer-events: none;
    }
    .manifesto-mark {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: 5rem; line-height: 1;
      color: rgba(192,146,66,0.12);
      position: relative; z-index: 1;
      margin-bottom: -1rem;
    }
    .manifesto-quote {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-weight: 300;
      font-size: clamp(1.75rem, 3.2vw, 2.9rem);
      line-height: 1.35; color: var(--cream);
      max-width: 820px;
      position: relative; z-index: 1;
    }
    .manifesto-attr {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.65rem; font-weight: 400;
      letter-spacing: 0.26em; text-transform: uppercase;
      color: var(--gold);
      display: flex; align-items: center; gap: 1.25rem;
      position: relative; z-index: 1;
    }
    .manifesto-attr::before, .manifesto-attr::after {
      content: '';
      width: 44px; height: 1px;
      background: rgba(192,146,66,0.35);
    }

    /* ─── FOOTER / KONTAKT ─── */
    .site-footer {
      background: var(--ink);
      border-top: 1px solid rgba(192,146,66,0.1);
    }
    .footer-grid {
      display: grid; grid-template-columns: 1.2fr 1fr 1fr;
    }
    .footer-col {
      padding: 4.5rem 4rem;
      border-right: 1px solid rgba(192,146,66,0.07);
    }
    .footer-col:last-child { border-right: none; }

    .footer-brand-name {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600; font-size: 1.6rem;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--cream); line-height: 1;
      margin-bottom: 0.2rem;
    }
    .footer-brand-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 0.62rem;
      letter-spacing: 0.2em; color: var(--gold);
      margin-bottom: 1.75rem;
    }
    .footer-brand-text {
      font-size: 0.78rem; line-height: 1.8;
      color: rgba(250,244,228,0.3); max-width: 30ch;
      margin-bottom: 2rem;
    }
    .footer-tagline {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 0.88rem;
      color: rgba(192,146,66,0.5);
    }

    .footer-col-label {
      font-size: 0.52rem; font-weight: 400;
      letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 1.5rem;
    }
    .footer-addr {
      font-size: 0.82rem; line-height: 1.85;
      color: rgba(250,244,228,0.45); margin-bottom: 1.5rem;
    }
    .footer-contact-item {
      font-size: 0.78rem; color: rgba(250,244,228,0.3);
      margin-bottom: 0.4rem;
    }
    .footer-contact-item a {
      color: inherit; text-decoration: none;
      transition: color 0.3s;
    }
    .footer-contact-item a:hover { color: var(--gold); }

    .hours-row {
      display: flex; justify-content: space-between;
      align-items: center; padding: 0.65rem 0;
      border-bottom: 1px solid rgba(192,146,66,0.06);
      font-size: 0.78rem;
    }
    .hours-row:first-of-type { border-top: 1px solid rgba(192,146,66,0.06); }
    .hours-day { color: rgba(250,244,228,0.55); }
    .hours-time { color: rgba(250,244,228,0.28); }
    .hours-closed { color: rgba(250,244,228,0.18); }

    .footer-bar {
      border-top: 1px solid rgba(192,146,66,0.07);
      padding: 1.25rem 4rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .footer-copy {
      font-size: 0.58rem; letter-spacing: 0.14em;
      color: rgba(250,244,228,0.15);
    }
    .footer-est {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 0.7rem;
      color: rgba(192,146,66,0.25);
    }

    /* ─── SCROLL REVEAL ─── */
    .reveal {
      opacity: 0; transform: translateY(22px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .reveal.in { opacity: 1; transform: none; }
    .reveal.d1 { transition-delay: 0.08s; }
    .reveal.d2 { transition-delay: 0.16s; }
    .reveal.d3 { transition-delay: 0.24s; }
    .reveal.d4 { transition-delay: 0.32s; }
    .reveal.d5 { transition-delay: 0.40s; }
    .reveal.d6 { transition-delay: 0.48s; }
    .reveal.d7 { transition-delay: 0.56s; }
    .reveal.d8 { transition-delay: 0.64s; }

    /* ─── HERO ANIMATIONS ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: none; }
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 1100px) {
      .hero { grid-template-columns: 1fr; }
      .hero-right { display: none; }
      .hero-left { padding: 5rem 2.5rem 8rem; min-height: 100vh; }
      .herb-catalog { grid-template-columns: 1fr; }
      .herb-entry:nth-child(even) { border-right: 1px solid rgba(26,17,8,0.08); }
      .herb-entry:nth-last-child(-n+2) { border-bottom: 1px solid rgba(26,17,8,0.08); }
      .herb-entry:last-child { border-bottom: none; }
      .sort-grid {
