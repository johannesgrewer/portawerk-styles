---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Grünzeit — Blumen & Botanik Atelier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Lora:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      overflow-x: hidden;
    }

    body {
      overflow-x: hidden;
      background-color: #F9F6F0;
      color: #2A3028;
      font-family: 'Lora', serif;
    }

    /* Paper grain texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 180px 180px;
      pointer-events: none;
      z-index: 100;
      opacity: 0.5;
    }

    /* ── HERO ── */
    .hero {
      display: flex;
      height: 100vh;
      min-height: 700px;
      position: relative;
      overflow: hidden;
    }

    /* ── LEFT COLUMN ── */
    .hero-left {
      flex: 0 0 42%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 60px 48px 60px 64px;
      position: relative;
      z-index: 2;
    }

    .label-latin {
      font-family: 'Lora', serif;
      font-size: 9px;
      font-weight: 400;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #C4853A;
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .label-latin.visible { opacity: 1; transform: translateY(0); }

    .headline-group {
      margin-top: 20px;
    }

    .hl-small {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #3B5C3A;
      opacity: 0;
      transform: translateY(22px);
      transition: opacity 0.75s 0.1s ease, transform 0.75s 0.1s ease;
    }

    .hl-small.visible { opacity: 1; transform: translateY(0); }

    .hl-main {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(58px, 6.5vw, 88px);
      font-weight: 300;
      font-style: italic;
      line-height: 0.92;
      color: #2A3028;
      margin-top: 6px;
    }

    .hl-main .word {
      display: inline-block;
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }

    .hl-main .word.visible { opacity: 1; transform: translateY(0); }

    .hl-accent {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(58px, 6.5vw, 88px);
      font-weight: 600;
      font-style: italic;
      line-height: 0.92;
      color: #3B5C3A;
    }

    .hl-accent .word {
      display: inline-block;
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }

    .hl-accent .word.visible { opacity: 1; transform: translateY(0); }

    /* Decorative divider — hand-drawn feel */
    .divider-botanical {
      margin: 32px 0 28px;
      opacity: 0;
      transform: scaleX(0);
      transform-origin: left center;
      transition: opacity 0.9s 0.5s ease, transform 0.9s 0.5s ease;
    }

    .divider-botanical.visible { opacity: 1; transform: scaleX(1); }

    .tagline {
      font-family: 'Cormorant Garamond', serif;
      font-size: 18px;
      font-weight: 400;
      font-style: italic;
      color: #3B5C3A;
      line-height: 1.5;
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.8s 0.6s ease, transform 0.8s 0.6s ease;
    }

    .tagline.visible { opacity: 1; transform: translateY(0); }

    .label-secondary {
      font-family: 'Lora', serif;
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #8a9e87;
      margin-top: 16px;
      opacity: 0;
      transform: translateY(14px);
      transition: opacity 0.7s 0.65s ease, transform 0.7s 0.65s ease;
    }

    .label-secondary.visible { opacity: 1; transform: translateY(0); }

    .cta-group {
      margin-top: 40px;
      display: flex;
      align-items: center;
      gap: 28px;
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.8s 0.8s ease, transform 0.8s 0.8s ease;
    }

    .cta-group.visible { opacity: 1; transform: translateY(0); }

    .cta-btn {
      display: inline-block;
      padding: 13px 28px;
      border: 1.5px solid #3B5C3A;
      font-family: 'Lora', serif;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #3B5C3A;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      transition: color 0.35s ease;
    }

    .cta-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: #3B5C3A;
      transform: translateX(-101%);
      transition: transform 0.35s ease;
    }

    .cta-btn:hover::before { transform: translateX(0); }
    .cta-btn:hover { color: #F9F6F0; }

    .cta-btn span { position: relative; z-index: 1; }

    .cta-link {
      font-family: 'Lora', serif;
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #C4853A;
      text-decoration: none;
      border-bottom: 1px solid rgba(196, 133, 58, 0.4);
      padding-bottom: 2px;
      transition: border-color 0.3s ease;
    }

    .cta-link:hover { border-color: #C4853A; }

    /* ── CENTER BOTANICAL LINE ── */
    .center-line {
      position: absolute;
      left: 42%;
      top: 0;
      bottom: 0;
      width: 1px;
      z-index: 3;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
      padding: 40px 0;
      pointer-events: none;
    }

    .center-line svg {
      flex-shrink: 0;
    }

    .center-line-stem {
      flex: 1;
      width: 1px;
      background: linear-gradient(to bottom, transparent, #3B5C3A 20%, #3B5C3A 80%, transparent);
      opacity: 0.25;
    }

    /* ── RIGHT COLUMN ── */
    .hero-right {
      flex: 1;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 48px 56px 48px 72px;
    }

    .image-frame {
      width: 100%;
      height: 80vh;
      max-height: 680px;
      position: relative;
      opacity: 0;
      transform: translateY(24px) scale(0.98);
      transition: opacity 1.1s 0.3s ease, transform 1.1s 0.3s ease;
    }

    .image-frame.visible {
      opacity: 1;
      transform: translateY(0) scale(1);
    }

    .image-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
      clip-path: polygon(0 3%, 4% 0, 96% 0, 100% 4%, 100% 97%, 95% 100%, 5% 100%, 0 97%);
      transition: transform 8s ease-in-out;
    }

    .image-frame:hover img {
      transform: scale(1.04);
    }

    /* Organic accent border */
    .image-frame::before {
      content: '';
      position: absolute;
      inset: -8px;
      border: 1.5px solid rgba(59, 92, 58, 0.18);
      clip-path: polygon(0 4%, 5% 0, 95% 0, 100% 5%, 100% 96%, 94% 100%, 6% 100%, 0 95%);
      z-index: 1;
      pointer-events: none;
    }

    /* Accent dot top-right */
    .image-frame::after {
      content: '';
      position: absolute;
      top: -12px;
      right: -12px;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: #C4853A;
      opacity: 0.7;
      z-index: 2;
    }

    /* Image caption */
    .image-caption {
      position: absolute;
      bottom: -32px;
      right: 0;
      font-family: 'Lora', serif;
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #8a9e87;
    }

    /* Bottom-left accent label */
    .location-tag {
      position: absolute;
      bottom: 28px;
      left: 64px;
      font-family: 'Cormorant Garamond', serif;
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #C4853A;
      opacity: 0;
      transition: opacity 1s 1.1s ease;
    }

    .location-tag.visible { opacity: 1; }

    /* ── SCROLL INDICATOR ── */
    .scroll-indicator {
      position: absolute;
      bottom: 32px;
      right: 56px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      opacity: 0;
      transition: opacity 1s 1.3s ease;
    }

    .scroll-indicator.visible { opacity: 1; }

    .scroll-text {
      font-family: 'Lora', serif;
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #8a9e87;
      writing-mode: vertical-rl;
    }

    .scroll-line {
      width: 1px;
      height: 48px;
      background: linear-gradient(to bottom, #8a9e87, transparent);
      animation: scrollPulse 2s ease-in-out infinite;
    }

    @keyframes scrollPulse {
      0%, 100% { opacity: 0.4; transform: scaleY(1); }
      50% { opacity: 1; transform: scaleY(1.15); }
    }

    /* ── BACKGROUND ORGANIC CIRCLES ── */
    .bg-circle {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }

    .bg-circle-1 {
      width: 600px;
      height: 600px;
      top: -200px;
      right: -100px;
      background: radial-gradient(circle, rgba(238, 242, 232, 0.6) 0%, transparent 70%);
    }

    .bg-circle-2 {
      width: 300px;
      height: 300px;
      bottom: -80px;
      left: 30%;
      background: radial-gradient(circle, rgba(196, 133, 58, 0.06) 0%, transparent 70%);
    }

    /* ── YEAR TAG ── */
    .year-tag {
      position: absolute;
      top: 32px;
      right: 56px;
      font-family: 'Cormorant Garamond', serif;
      font-size: 11px;
      font-weight: 300;
      letter-spacing: 0.22em;
      color: #b8c5b6;
    }

    @media (max-width: 900px) {
      .hero {
        flex-direction: column;
        height: auto;
        min-height: 100vh;
      }
      .hero-left {
        flex: none;
        padding: 80px 32px 40px;
      }
      .hero-right {
        flex: none;
        padding: 0 32px 60px;
        height: 50vh;
      }
      .center-line { display: none; }
      .image-frame { height: 100%; max-height: none; }
    }
  </style>
</head>
<body>
  <main class="hero">
    <div class="bg-circle bg-circle-1"></div>
    <div class="bg-circle bg-circle-2"></div>

    <div class="year-tag">Est. 2017</div>

    <!-- LEFT -->
    <div class="hero-left">
      <span class="label-latin animate-item">Plantae · Floralis · Atelier</span>

      <div class="headline-group">
        <span class="hl-small animate-item">Grünzeit</span>
        <span class="hl-main">
          <span class="word">Blumen</span>
        </span>
        <span class="hl-accent">
          <span class="word">&amp; Botanik</span>
        </span>
      </div>

      <svg class="divider-botanical animate-item" width="220" height="28" viewBox="0 0 220 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 14 C30 14 40 6 60 14 C80 22 90 6 110 14 C130 22 140 8 160 14" stroke="#3B5C3A" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.5"/>
        <circle cx="170" cy="14" r="2" fill="#C4853A" opacity="0.6"/>
        <line x1="175" y1="14" x2="220" y2="14" stroke="#3B5C3A" stroke-width="0.8" opacity="0.3"/>
        <circle cx="55" cy="6" r="1.5" fill="#3B5C3A" opacity="0.35"/>
        <circle cx="105" cy="22" r="1.5" fill="#3B5C3A" opacity="0.35"/>
      </svg>

      <p class="tagline animate-item">"Pflanzen, die erzählen."</p>
      <span class="label-secondary animate-item">Trier Altstadt · Atelier & Ausstellung</span>

      <div class="cta-group animate-item">
        <a href="#" class="cta-btn"><span>Atelier besuchen</span></a>
        <a href="#" class="cta-link">Sortiment</a>
      </div>
    </div>

    <!-- CENTER BOTANICAL LINE -->
    <div class="center-line">
      <div class="center-line-stem"></div>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
        <circle cx="6" cy="6" r="4" stroke="#3B5C3A" stroke-width="0.8" opacity="0.4"/>
        <circle cx="6" cy="6" r="1.5" fill="#C4853A" opacity="0.5"/>
      </svg>
      <div class="center-line-stem"></div>
      <svg width="20" height="32" viewBox="0 0 20 32" fill="none">
        <path d="M10 0 C10 0 0 8 0 16 C0 24 10 32 10 32" stroke="#3B5C3A" stroke-width="0.7" opacity="0.3" fill="none"/>
        <path d="M10 0 C10 0 20 8 20 16 C20 24 10 32 10 32" stroke="#3B5C3A" stroke-width="0.7" opacity="0.3" fill="none"/>
      </svg>
      <div class="center-line-stem"></div>
    </div>

    <!-- RIGHT -->
    <div class="hero-right">
      <div class="image-frame animate-item" id="imageFrame">
        <img
          src="https://images.unsplash.com/photo-1490750967868-88df5691cc45?w=900&q=80&auto=format"
          alt="Botanik Atelier Grünzeit"
          loading="eager"
        />
        <span class="image-caption">Sorte Atropa · Sommer 2024</span>
      </div>

      <span class="location-tag animate-item">Trier, Mosel</span>
    </div>

    <!-- SCROLL INDICATOR -->
    <div class="scroll-indicator animate-item">
      <span class="scroll-text">Scrollen</span>
      <div class="scroll-line"></div>
    </div>
  </main>

  <script>
    // Staggered entrance on load
    const items = document.querySelectorAll('.animate-item');
    const words = document.querySelectorAll('.word');

    // Animate words with custom stagger
    const wordDelays = [0.2, 0.35];
    words.forEach((word, i) => {
      word.style.transitionDelay = wordDelays[i] ? wordDelays[i] + 's' : '0.2s';
    });

    // Observer for all .animate-item elements
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          // Also trigger words inside
          entry.target.querySelectorAll('.word').forEach(w => w.classList.add('visible'));
        }
      });
    }, { threshold: 0.1 });

    items.forEach(item => observer.observe(item));

    // Trigger immediately for hero items (already in view)
    requestAnimationFrame(() => {
      items.forEach((item, i) => {
        setTimeout(() => {
          item.classList.add('visible');
          item.querySelectorAll('.word').forEach(w => w.classList.add('visible'));
        }, i * 80);
      });
    });

    // Subtle parallax on image
    const imageFrame = document.getElementById('imageFrame');
    if (imageFrame) {
      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;
        imageFrame.style.transform = `translateY(${scrollY * 0.08}px)`;
      }, { passive: true });
    }
  </script>
</body>
</html>
