---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Grünzeit — Blumen & Botanik Atelier, Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream: #F9F6F0;
      --cream-dark: #EEE8DE;
      --cream-blush: #F2E8E4;
      --green-deep: #1C281B;
      --green-forest: #3B5C3A;
      --green-sage: #8a9e87;
      --green-mist: #EEF2E8;
      --amber: #C4853A;
      --blush: #B8796E;
      --text: #2A3028;
    }

    html { overflow-x: hidden; scroll-behavior: smooth; }

    body {
      overflow-x: hidden;
      background: var(--cream);
      color: var(--text);
      font-family: 'Lora', serif;
    }

    /* Grain overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      background-size: 180px;
      pointer-events: none;
      z-index: 9999;
      opacity: 0.45;
    }

    /* ── NAVIGATION ── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 64px;
      height: 70px;
      transition: background 0.4s ease, box-shadow 0.4s ease;
    }
    .nav.scrolled {
      background: rgba(249, 246, 240, 0.95);
      backdrop-filter: blur(12px);
      box-shadow: 0 1px 0 rgba(59, 92, 58, 0.1);
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 400;
      font-style: italic;
      color: var(--green-forest);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .nav-logo-dot {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--amber);
      flex-shrink: 0;
      margin-bottom: 2px;
    }
    .nav-links {
      display: flex;
      gap: 36px;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Lora', serif;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text);
      text-decoration: none;
      opacity: 0.55;
      transition: opacity 0.3s ease;
    }
    .nav-links a:hover { opacity: 1; }

    /* ── HERO ── */
    .hero {
      display: grid;
      grid-template-columns: 46% 54%;
      min-height: 100vh;
      padding-top: 70px;
      position: relative;
      overflow: hidden;
    }

    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 56px 80px 80px;
      position: relative;
      z-index: 2;
    }

    /* Large decorative initial */
    .hero-initial {
      position: absolute;
      top: 50%;
      left: -60px;
      transform: translateY(-55%);
      font-family: 'Cormorant Garamond', serif;
      font-size: 420px;
      font-weight: 300;
      font-style: italic;
      color: transparent;
      -webkit-text-stroke: 1px rgba(59, 92, 58, 0.055);
      line-height: 1;
      pointer-events: none;
      user-select: none;
      z-index: 0;
    }

    .hero-eyebrow {
      font-family: 'Lora', serif;
      font-size: 9px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--amber);
      position: relative;
      z-index: 1;
    }

    .hero-title {
      position: relative;
      z-index: 1;
      margin-top: 20px;
      line-height: 0.88;
    }

    .title-clip {
      overflow: hidden;
      display: block;
    }

    .title-clip .inner {
      display: block;
      transform: translateY(105%);
      opacity: 0;
      transition: transform 0.95s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.9s ease;
    }

    .title-clip .inner.visible {
      transform: translateY(0);
      opacity: 1;
    }

    .hero-t1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(62px, 7vw, 100px);
      font-weight: 300;
      font-style: italic;
      color: var(--text);
    }

    .hero-t2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(62px, 7vw, 100px);
      font-weight: 600;
      font-style: italic;
      color: var(--green-forest);
    }

    .hero-divider {
      margin: 30px 0 26px;
      opacity: 0;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 1s 0.5s ease, opacity 1s 0.5s ease;
      position: relative;
      z-index: 1;
    }
    .hero-divider.visible { opacity: 1; transform: scaleX(1); }

    .hero-tagline {
      font-family: 'Cormorant Garamond', serif;
      font-size: 17px;
      font-style: italic;
      color: var(--green-forest);
      line-height: 1.6;
      max-width: 320px;
      position: relative;
      z-index: 1;
    }

    .hero-meta {
      font-family: 'Lora', serif;
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--green-sage);
      margin-top: 10px;
      position: relative;
      z-index: 1;
    }

    .hero-cta {
      display: flex;
      align-items: center;
      gap: 32px;
      margin-top: 40px;
      position: relative;
      z-index: 1;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      padding: 13px 28px;
      background: var(--green-forest);
      font-family: 'Lora', serif;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--cream);
      text-decoration: none;
      transition: background 0.3s ease;
    }
    .btn-primary:hover { background: var(--green-deep); }

    .btn-ghost {
      font-family: 'Lora', serif;
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--amber);
      text-decoration: none;
      border-bottom: 1px solid rgba(196, 133, 58, 0.35);
      padding-bottom: 2px;
      transition: border-color 0.3s ease;
    }
    .btn-ghost:hover { border-color: var(--amber); }

    /* Hero right */
    .hero-right {
      position: relative;
    }

    .hero-image-wrap {
      position: absolute;
      inset: 20px 20px 20px 0;
      overflow: hidden;
    }

    .hero-image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      transition: transform 8s ease;
    }
    .hero-image-wrap:hover img { transform: scale(1.04); }

    /* Floating info card */
    .hero-float-card {
      position: absolute;
      bottom: 64px;
      left: 40px;
      background: var(--cream);
      padding: 18px 24px;
      z-index: 3;
      box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    }

    .hero-float-label {
      font-family: 'Lora', serif;
      font-size: 8px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 6px;
    }

    .hero-float-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 15px;
      font-style: italic;
      color: var(--text);
      line-height: 1.45;
    }

    /* Scroll hint */
    .scroll-hint {
      position: absolute;
      bottom: 36px;
      left: 80px;
      display: flex;
      align-items: center;
      gap: 12px;
      z-index: 3;
    }

    .scroll-hint-line {
      width: 40px;
      height: 1px;
      background: linear-gradient(to right, var(--green-sage), transparent);
      animation: scrollLineAnim 2.2s ease-in-out infinite;
    }
    @keyframes scrollLineAnim {
      0%, 100% { transform: scaleX(1); opacity: 0.45; }
      50% { transform: scaleX(1.4); opacity: 1; }
    }

    .scroll-hint-text {
      font-family: 'Lora', serif;
      font-size: 8px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--green-sage);
    }

    /* ── IMG-WRAP UTILITY ── */
    .img-wrap { position: relative; overflow: hidden; }
    .img-wrap img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.65s ease;
    }
    .img-wrap:hover img { transform: scale(1.06); }

    .img-overlay-dark {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(28, 40, 27, 0.55) 0%, transparent 55%);
      pointer-events: none;
    }
    .img-overlay-light {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(42, 48, 40, 0.28) 0%, transparent 50%);
      pointer-events: none;
    }

    /* ── SECTION LABELS ── */
    .section-label {
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: 'Lora', serif;
      font-size: 9px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--amber);
    }
    .section-label::before {
      content: '';
      display: inline-block;
      width: 22px;
      height: 1px;
      background: var(--amber);
      opacity: 0.55;
      flex-shrink: 0;
    }

    .section-h2 {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-weight: 300;
      color: var(--text);
      line-height: 1.0;
    }

    /* ── ANIMATION UTILITIES ── */
    .fade-in {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.9s ease, transform 0.9s ease;
    }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    .fade-in-left {
      opacity: 0;
      transform: translateX(-24px);
      transition: opacity 0.9s ease, transform 0.9s ease;
    }
    .fade-in-left.visible { opacity: 1; transform: translateX(0); }

    .fade-in-right {
      opacity: 0;
      transform: translateX(24px);
      transition: opacity 0.9s ease, transform 0.9s ease;
    }
    .fade-in-right.visible { opacity: 1; transform: translateX(0); }

    .d1 { transition-delay: 0.1s; }
    .d2 { transition-delay: 0.2s; }
    .d3 { transition-delay: 0.3s; }
    .d4 { transition-delay: 0.4s; }
    .d5 { transition-delay: 0.5s; }

    /* ── SECTION 2: ARRANGEMENTS ── */
    .section-arrangements {
      background: var(--cream);
      padding: 7rem 0 0;
    }

    .arr-header {
      padding: 0 80px;
      margin-bottom: 4rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: end;
    }

    .arr-header .section-label { margin-bottom: 14px; }
    .arr-header .section-h2 { font-size: clamp(2.2rem, 3.8vw, 3.4rem); }

    .arr-header-right p {
      font-family: 'Lora', serif;
      font-size: 0.88rem;
      line-height: 1.85;
      color: var(--green-sage);
      margin-bottom: 16px;
    }

    /* Main: large left photo + right column */
    .arr-main {
      padding: 0 80px;
      display: grid;
      grid-template-columns: 1.45fr 1fr;
      gap: 32px;
      margin-bottom: 0;
    }

    .arr-featured-img { height: 560px; }

    .arr-featured-caption {
      margin-top: 14px;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .arr-featured-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      font-style: italic;
      color: var(--text);
    }

    .arr-featured-price {
      font-family: 'Lora', serif;
      font-size: 0.78rem;
      color: var(--green-sage);
      letter-spacing: 0.06em;
    }

    .arr-secondary {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .arr-secondary .section-label { margin-bottom: 4px; }

    .arr-secondary .section-h2 {
      font-size: clamp(1.5rem, 2.2vw, 2rem);
      margin-bottom: 12px;
    }

    .arr-secondary > p {
      font-family: 'Lora', serif;
      font-size: 0.86rem;
      line-height: 1.85;
      color: var(--green-sage);
    }

    .arr-small-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: auto;
      flex: 1;
      align-self: flex-end;
    }

    .arr-small-label {
      margin-top: 8px;
      font-family: 'Lora', serif;
      font-size: 8px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--green-sage);
    }

    /* Categories row */
    .arr-categories {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(59, 92, 58, 0.09);
      margin-top: 4rem;
      border-top: 1px solid rgba(59, 92, 58, 0.09);
    }

    .category-card {
      background: var(--cream);
      padding: 40px 36px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      position: relative;
      overflow: hidden;
      transition: background 0.3s ease;
      cursor: default;
    }
    .category-card:hover { background: var(--green-mist); }

    .category-num {
      position: absolute;
      top: 20px;
      right: 28px;
      font-family: 'Cormorant Garamond', serif;
      font-size: 52px;
      font-weight: 300;
      font-style: italic;
      color: rgba(59, 92, 58, 0.08);
      line-height: 1;
    }

    .category-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.45rem;
      font-style: italic;
      color: var(--text);
    }

    .category-desc {
      font-family: 'Lora', serif;
      font-size: 0.82rem;
      line-height: 1.75;
      color: var(--green-sage);
    }

    .category-price {
      font-family: 'Lora', serif;
      font-size: 9px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--amber);
      margin-top: 6px;
    }

    /* ── SECTION 3: WORKSHOPS ── */
    .section-workshops {
      background: var(--green-deep);
      padding: 7rem 80px;
      position: relative;
      overflow: hidden;
    }

    .workshops-bg-ring {
      position: absolute;
      width: 720px;
      height: 720px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.03);
      top: 50%;
      right: -220px;
      transform: translateY(-50%);
      pointer-events: none;
    }

    .workshops-bg-ring-2 {
      position: absolute;
      width: 480px;
      height: 480px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.04);
      top: 50%;
      right: -80px;
      transform: translateY(-50%);
      pointer-events: none;
    }

    .workshops-header {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      margin-bottom: 5rem;
      position: relative;
      z-index: 1;
    }

    .workshops-header-left .section-label {
      color: rgba(196, 133, 58, 0.85);
      margin-bottom: 18px;
    }
    .workshops-header-left .section-label::before { background: rgba(196, 133, 58, 0.55); }

    .workshops-header-left .section-h2 {
      font-size: clamp(2.2rem, 3.8vw, 3.4rem);
      color: #EEF2E8;
    }

    .workshops-header-right {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      gap: 20px;
    }

    .workshops-header-right p {
      font-family: 'Lora', serif;
      font-size: 0.88rem;
      line-height: 1.85;
      color: rgba(238, 242, 232, 0.55);
    }

    .btn-light {
      display: inline-flex;
      align-items: center;
      padding: 12px 26px;
      border: 1.5px solid rgba(238, 242, 232, 0.3);
      font-family: 'Lora', serif;
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(238, 242, 232, 0.75);
      text-decoration: none;
      align-self: flex-start;
      transition: all 0.3s ease;
    }
    .btn-light:hover {
      background: rgba(238, 242, 232, 0.08);
      border-color: rgba(238, 242, 232, 0.6);
    }

    .workshops-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      position: relative;
      z-index: 1;
    }

    .workshop-card {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.06);
      overflow: hidden;
      transition: border-color 0.3s ease, background 0.3s ease;
    }
    .workshop-card:hover {
      background: rgba(255, 255, 255, 0.07);
      border-color: rgba(59, 92, 58, 0.45);
    }

    .workshop-img { height: 230px; }

    .workshop-body { padding: 26px 26px 30px; }

    .workshop-tag {
      display: inline-block;
      font-family: 'Lora', serif;
      font-size: 8px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 10px;
    }

    .workshop-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      font-style: italic;
      color: #EEF2E8;
      line-height: 1.2;
      margin-bottom: 10px;
    }

    .workshop-desc {
      font-family: 'Lora', serif;
      font-size: 0.81rem;
      line-height: 1.8;
      color: rgba(238, 242, 232, 0.5);
      margin-bottom: 18px;
    }

    .workshop-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 14px;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    .workshop-date {
      font-family: 'Lora', serif;
      font-size: 10px;
      letter-spacing: 0.08em;
      color: rgba(238, 242, 232, 0.45);
    }

    .workshop-price {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem;
      font-style: italic;
      color: var(--amber);
    }

    /* ── SECTION 4: HOCHZEITEN ── */
    .section-weddings {
      background: var(--cream-blush);
    }

    .weddings-hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 580px;
    }

    .weddings-text {
      padding: 80px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .weddings-text .section-label {
      color: var(--blush);
      margin-bottom: 18px;
    }
    .weddings-text .section-label::before { background: var(--blush); }

    .weddings-text .section-h2 {
      font-size: clamp(2.4rem, 4.5vw, 4rem);
      margin-bottom: 22px;
    }

    .weddings-text p {
      font-family: 'Lora', serif;
      font-size: 0.88rem;
      line-height: 1.85;
      color: rgba(42, 48, 40, 0.6);
      max-width: 380px;
      margin-bottom: 30px;
    }

    .btn-blush {
      display: inline-flex;
      align-items: center;
      padding: 13px 28px;
      border: 1.5px solid var(--blush);
      font-family: 'Lora', serif;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--blush);
      text-decoration: none;
      align-self: flex-start;
      transition: all 0.35s ease;
    }
    .btn-blush:hover { background: var(--blush); color: #fff; }

    .weddings-main-img {
      position: relative;
      overflow: hidden;
    }
    .weddings-main-img img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.9s ease;
    }
    .weddings-main-img:hover img { transform: scale(1.04); }

    /* Wedding gallery 3-col */
    .weddings-gallery {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }

    .wedding-gallery-item {
      position: relative;
      overflow: hidden;
      height: 360px;
    }

    .wedding-gallery-item img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }
    .wedding-gallery-item:hover img { transform: scale(1.07); }

    .wedding-gallery-overlay {
      position: absolute;
      inset: 0;
      background: rgba(28, 40, 27, 0);
      transition: background 0.4s ease;
      display: flex;
      align-items: flex-end;
      padding: 24px;
    }
    .wedding-gallery-item:hover .wedding-gallery-overlay { background: rgba(28, 40, 27, 0.35); }

    .wedding-gallery-label {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      font-style: italic;
      color: #fff;
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .wedding-gallery-item:hover .wedding-gallery-label { opacity: 1; transform: translateY(0); }

    /* Wedding services strip */
    .weddings-services {
      background: var(--cream-blush);
      padding: 4rem 80px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 48px;
      border-top: 1px solid rgba(184, 121, 110, 0.12);
    }

    .ws-item {}

    .ws-numeral {
