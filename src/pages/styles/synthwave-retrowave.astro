---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Neon Drive — Music & Event Production | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Exo+2:wght@200;300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --magenta: #FF00FF;
      --cyan:    #00FFFF;
      --purple:  #7B00FF;
      --bg:      #0D001A;
      --mid:     #130025;
    }

    body {
      background: var(--bg);
      color: #FFFFFF;
      font-family: 'Exo 2', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Retro grid floor */
    body::before {
      content: '';
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 45vh;
      background:
        linear-gradient(to bottom, transparent 0%, rgba(255,0,255,0.08) 100%),
        repeating-linear-gradient(
          90deg,
          transparent,
          transparent calc(8vw - 1px),
          rgba(255,0,255,0.18) calc(8vw - 1px),
          rgba(255,0,255,0.18) 8vw
        ),
        repeating-linear-gradient(
          0deg,
          transparent,
          transparent calc(8vw - 1px),
          rgba(255,0,255,0.12) calc(8vw - 1px),
          rgba(255,0,255,0.12) 8vw
        );
      transform: perspective(400px) rotateX(35deg);
      transform-origin: bottom center;
      pointer-events: none;
      z-index: 0;
    }

    /* Scanlines */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(0,0,0,0.08) 3px,
        rgba(0,0,0,0.08) 4px
      );
      pointer-events: none;
      z-index: 1;
    }

    /* Sun / horizon */
    .retro-sun {
      position: fixed;
      bottom: 44vh;
      left: 50%;
      transform: translateX(-50%);
      width: 220px;
      height: 110px;
      border-radius: 110px 110px 0 0;
      background: linear-gradient(to bottom, #FF6600, #FF00FF, #7B00FF);
      overflow: hidden;
      z-index: 0;
    }
    .retro-sun::before,
    .retro-sun::after,
    .sun-line1,
    .sun-line2,
    .sun-line3 {
      content: '';
      position: absolute;
      left: 0; right: 0;
      height: 6px;
      background: var(--bg);
    }
    .retro-sun::before { bottom: 72px; }
    .retro-sun::after  { bottom: 52px; }
    .sun-line1 { bottom: 36px; height: 5px; }
    .sun-line2 { bottom: 23px; height: 4px; }
    .sun-line3 { bottom: 13px; height: 3px; }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 3rem;
      background: rgba(13,0,26,0.85);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255,0,255,0.2);
    }
    .nav-logo {
      font-family: 'Orbitron', sans-serif;
      font-weight: 900;
      font-size: 1.2rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: linear-gradient(90deg, var(--magenta), var(--cyan));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 8px rgba(255,0,255,0.5));
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      text-decoration: none;
      transition: color 0.2s, text-shadow 0.2s;
    }
    .nav-links a:hover {
      color: var(--cyan);
      text-shadow: 0 0 8px rgba(0,255,255,0.6);
    }
    .nav-btn {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--magenta);
      padding: 0.55rem 1.25rem;
      text-decoration: none;
      box-shadow: 0 0 16px rgba(255,0,255,0.4);
      transition: box-shadow 0.2s;
    }
    .nav-btn:hover { box-shadow: 0 0 30px rgba(255,0,255,0.7); }

    .hero {
      min-height: 100vh;
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 8rem 3rem 16rem;
      text-align: center;
      gap: 2rem;
    }

    .eyebrow {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--cyan);
      text-shadow: 0 0 12px rgba(0,255,255,0.7);
    }

    .hero-headline {
      font-family: 'Orbitron', sans-serif;
      font-weight: 900;
      font-size: clamp(3rem, 9vw, 7.5rem);
      line-height: 0.92;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .glow-mag {
      display: block;
      color: var(--magenta);
      text-shadow:
        0 0 20px rgba(255,0,255,0.9),
        0 0 40px rgba(255,0,255,0.5),
        0 0 80px rgba(255,0,255,0.25);
    }
    .glow-cyan {
      display: block;
      color: var(--cyan);
      text-shadow:
        0 0 20px rgba(0,255,255,0.9),
        0 0 40px rgba(0,255,255,0.5),
        0 0 80px rgba(0,255,255,0.25);
    }
    .glow-white {
      display: block;
      color: #FFFFFF;
      text-shadow: 0 0 30px rgba(255,255,255,0.3);
    }

    .hero-sub {
      font-size: 0.82rem;
      font-weight: 200;
      line-height: 1.9;
      color: rgba(255,255,255,0.45);
      max-width: 42ch;
    }

    /* Genre tags */
    .genre-tags {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: center;
    }
    .genre-tag {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0.35rem 0.9rem;
      border: 1px solid;
    }
    .gt-mag   { color: var(--magenta); border-color: rgba(255,0,255,0.35); }
    .gt-cyan  { color: var(--cyan);    border-color: rgba(0,255,255,0.35);  }
    .gt-purp  { color: #BF80FF;        border-color: rgba(123,0,255,0.4);   }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 2rem;
    }
    .cta-btn {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bg);
      background: linear-gradient(90deg, var(--magenta), var(--purple));
      text-decoration: none;
      padding: 0.9rem 2.5rem;
      box-shadow:
        0 0 24px rgba(255,0,255,0.4),
        inset 0 1px 0 rgba(255,255,255,0.15);
      transition: box-shadow 0.2s;
    }
    .cta-btn:hover { box-shadow: 0 0 40px rgba(255,0,255,0.65); }
    .cta-link {
      font-size: 0.6rem;
      font-weight: 200;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      text-decoration: none;
      transition: color 0.2s;
    }
    .cta-link:hover { color: var(--cyan); }

    /* Stats row */
    .stats-row {
      display: flex;
      gap: 4rem;
      margin-top: 1rem;
    }
    .stat-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
    }
    .stat-num {
      font-family: 'Orbitron', sans-serif;
      font-weight: 900;
      font-size: 1.8rem;
      line-height: 1;
      color: var(--magenta);
      text-shadow: 0 0 14px rgba(255,0,255,0.6);
    }
    .stat-label {
      font-size: 0.5rem;
      font-weight: 200;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
    }

    /* Corner coords */
    .corner {
      position: fixed;
      font-family: 'Orbitron', sans-serif;
      font-size: 0.42rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      color: rgba(255,0,255,0.25);
      text-transform: uppercase;
      z-index: 10;
    }
    .corner.tl { top: 5rem; left: 2rem; }
    .corner.tr { top: 5rem; right: 2rem; }

    /* Photo container */
    .ph { position: relative; overflow: hidden; }
    .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
    .ph:hover img { transform: scale(1.05); }

    /* Page wrap */
    .page-wrap { max-width: 1600px; margin-left: auto; margin-right: auto; }

    /* Section 2: Releases */
    .releases-section {
      position: relative;
      z-index: 2;
      padding: 7rem 3rem;
      border-top: 1px solid rgba(255,0,255,0.12);
    }
    .sec-eyebrow-sw {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--cyan);
      text-shadow: 0 0 10px rgba(0,255,255,0.5);
      margin-bottom: 2.5rem;
    }
    .sec-headline-sw {
      font-family: 'Orbitron', sans-serif;
      font-weight: 900;
      font-size: clamp(1.8rem, 4vw, 3.5rem);
      line-height: 1;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--magenta);
      text-shadow: 0 0 20px rgba(255,0,255,0.5), 0 0 40px rgba(255,0,255,0.2);
      margin-bottom: 3.5rem;
    }
    .releases-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(255,0,255,0.15);
    }
    .release-card {
      background: var(--bg);
      position: relative;
    }
    .release-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13,0,26,0.85) 0%, transparent 50%);
      pointer-events: none;
      z-index: 1;
    }
    .release-tint {
      position: absolute;
      inset: 0;
      background: rgba(123,0,255,0.25);
      mix-blend-mode: multiply;
      pointer-events: none;
      z-index: 1;
    }
    .release-meta {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 1.5rem;
      z-index: 2;
    }
    .release-type {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.42rem;
      font-weight: 400;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--cyan);
      margin-bottom: 0.4rem;
    }
    .release-title {
      font-family: 'Orbitron', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      color: #FFFFFF;
      letter-spacing: 0.05em;
      text-shadow: 0 0 12px rgba(255,0,255,0.4);
    }

    /* Section 3: Events */
    .events-section {
      position: relative;
      z-index: 2;
      padding: 7rem 3rem;
      border-top: 1px solid rgba(255,0,255,0.12);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .events-photo-wrap {
      position: relative;
    }
    .events-photo-glow {
      position: absolute;
      inset: -2px;
      background: linear-gradient(135deg, var(--magenta), var(--purple), var(--cyan));
      opacity: 0.4;
      filter: blur(12px);
      z-index: 0;
    }
    .events-content {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .event-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .event-item {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      padding: 1.25rem 0;
      border-bottom: 1px solid rgba(255,0,255,0.1);
    }
    .event-date {
      font-family: 'Orbitron', sans-serif;
      font-weight: 700;
      font-size: 0.7rem;
      color: var(--magenta);
      text-shadow: 0 0 8px rgba(255,0,255,0.5);
      min-width: 80px;
    }
    .event-info {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      flex: 1;
    }
    .event-name {
      font-size: 0.85rem;
      font-weight: 300;
      color: rgba(255,255,255,0.85);
    }
    .event-location {
      font-size: 0.58rem;
      font-weight: 200;
      letter-spacing: 0.15em;
      color: rgba(255,255,255,0.3);
      text-transform: uppercase;
    }
    .event-ticket {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.48rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--cyan);
      padding: 0.35rem 0.75rem;
      text-decoration: none;
      box-shadow: 0 0 10px rgba(0,255,255,0.35);
      white-space: nowrap;
    }
    .merch-cta {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--bg);
      background: linear-gradient(90deg, var(--magenta), var(--purple));
      text-decoration: none;
      padding: 0.9rem 2rem;
      align-self: flex-start;
      box-shadow: 0 0 20px rgba(255,0,255,0.35);
    }
  </style>
</head>
<body>
  <div class="retro-sun">
    <div class="sun-line1"></div>
    <div class="sun-line2"></div>
    <div class="sun-line3"></div>
  </div>

  <div class="corner tl">SYN-TRW-001</div>
  <div class="corner tr">TRIER · 2024</div>

  <nav>
    <div class="nav-logo">Neon Drive</div>
    <ul class="nav-links">
      <li><a href="#">Events</a></li>
      <li><a href="#">Artists</a></li>
      <li><a href="#">Studio</a></li>
      <li><a href="#">Merch</a></li>
    </ul>
    <a href="#" class="nav-btn">Tickets</a>
  </nav>

  <div class="page-wrap">

  <section class="hero">
    <div class="eyebrow">Music & Event Production · Trier</div>

    <h1 class="hero-headline">
      <span class="glow-mag">Neon</span>
      <span class="glow-white">Drive</span>
      <span class="glow-cyan">Records</span>
    </h1>

    <p class="hero-sub">
      Synthwave. Retrowave. Darksynth.<br>
      Wir produzieren Klänge aus einer Zukunft,<br>
      die nie stattgefunden hat.
    </p>

    <div class="genre-tags">
      <span class="genre-tag gt-mag">Synthwave</span>
      <span class="genre-tag gt-cyan">Retrowave</span>
      <span class="genre-tag gt-purp">Darksynth</span>
      <span class="genre-tag gt-mag">Outrun</span>
      <span class="genre-tag gt-cyan">Lo-Fi</span>
    </div>

    <div class="cta-row">
      <a href="#" class="cta-btn">Nächste Show →</a>
      <a href="#" class="cta-link">Releases hören →</a>
    </div>

    <div class="stats-row">
      <div class="stat-item">
        <div class="stat-num">47</div>
        <div class="stat-label">Shows / Jahr</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">12</div>
        <div class="stat-label">Releases</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">6</div>
        <div class="stat-label">Artists</div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Releases -->
  <section class="releases-section">
    <div class="sec-eyebrow-sw">// Latest Releases</div>
    <h2 class="sec-headline-sw">Neue Musik</h2>
    <div class="releases-grid">
      <div class="release-card">
        <div class="ph" style="height:340px;">
          <img src="https://images.unsplash.com/photo-1542736667-069246bdbc6d?auto=format&fit=crop&w=1200&h=800&q=80" alt="Chrome Horizon Album" loading="lazy"/>
        </div>
        <div class="release-tint"></div>
        <div class="release-overlay"></div>
        <div class="release-meta">
          <div class="release-type">Album · 2025</div>
          <div class="release-title">Chrome Horizon</div>
        </div>
      </div>
      <div class="release-card">
        <div class="ph" style="height:340px;">
          <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?auto=format&fit=crop&w=1200&h=800&q=80" alt="Midnight Protocol EP" loading="lazy"/>
        </div>
        <div class="release-tint"></div>
        <div class="release-overlay"></div>
        <div class="release-meta">
          <div class="release-type">EP · 2024</div>
          <div class="release-title">Midnight Protocol</div>
        </div>
      </div>
      <div class="release-card">
        <div class="ph" style="height:340px;">
          <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=1200&h=800&q=80" alt="Neon City Nights Single" loading="lazy"/>
        </div>
        <div class="release-tint"></div>
        <div class="release-overlay"></div>
        <div class="release-meta">
          <div class="release-type">Single · 2024</div>
          <div class="release-title">Neon City Nights</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Events + Merch -->
  <section class="events-section">
    <div class="events-content">
      <div class="sec-eyebrow-sw">// Upcoming Shows</div>
      <h2 class="sec-headline-sw">Live Events</h2>
      <div class="event-list">
        <div class="event-item">
          <div class="event-date">15 APR</div>
          <div class="event-info">
            <span class="event-name">Neon Drive Live — Release Show</span>
            <span class="event-location">Trier · Exhaus</span>
          </div>
          <a href="#" class="event-ticket">Tickets</a>
        </div>
        <div class="event-item">
          <div class="event-date">03 MAI</div>
          <div class="event-info">
            <span class="event-name">Retrowave Night Vol. 12</span>
            <span class="event-location">Köln · Gewölbe</span>
          </div>
          <a href="#" class="event-ticket">Tickets</a>
        </div>
        <div class="event-item">
          <div class="event-date">21 JUN</div>
          <div class="event-info">
            <span class="event-name">Synthwave Summer Festival</span>
            <span class="event-location">Berlin · Tresor</span>
          </div>
          <a href="#" class="event-ticket">Tickets</a>
        </div>
        <div class="event-item">
          <div class="event-date">08 JUL</div>
          <div class="event-info">
            <span class="event-name">Chrome Horizon Tour — Frankfurt</span>
            <span class="event-location">Frankfurt · Batschkapp</span>
          </div>
          <a href="#" class="event-ticket">Tickets</a>
        </div>
      </div>
      <a href="#" class="merch-cta">Merch Shop →</a>
    </div>
    <div class="events-photo-wrap" style="position:relative;">
      <div class="events-photo-glow"></div>
      <div class="ph" style="height:500px;position:relative;z-index:1;">
        <img src="https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=1200&h=1600&q=80" alt="Live Show Atmosphäre" loading="lazy"/>
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(13,0,26,0.6) 0%,transparent 50%);pointer-events:none;"></div>
      </div>
    </div>
  </section>

  </div><!-- /page-wrap -->
</body>
</html>
