---
export const prerender = true;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Waldhaus Eifel — Outdoor-Lodge & gefuehrte Touren</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Work+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --forest:   #1C3229;
      --forest-2: #2A4A3B;
      --beige:    #EDE8DC;
      --beige-2:  #F3EEE4;
      --wood:     #8B5E3C;
      --amber:    #C97D2E;
      --text:     #1A2219;
      --muted:    rgba(26,34,25,0.55);
      --ff-serif: 'Instrument Serif', Georgia, serif;
      --ff-sans:  'Work Sans', -apple-system, sans-serif;
    }

    body {
      font-family: var(--ff-sans);
      color: var(--text);
      background: var(--beige-2);
      -webkit-font-smoothing: antialiased;
    }

    img { display: block; max-width: 100%; height: auto; }

    /* ── NAV ── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.1rem 2.5rem;
      transition: background 0.4s, backdrop-filter 0.4s;
    }

    .nav.scrolled {
      background: rgba(243,238,228,0.94);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(28,50,41,0.07);
    }

    .nav-logo {
      font-family: var(--ff-serif);
      font-size: 1.35rem;
      color: var(--beige);
      text-decoration: none;
      letter-spacing: -0.01em;
      transition: color 0.4s;
    }

    .nav.scrolled .nav-logo { color: var(--forest); }

    .nav-links {
      display: flex; gap: 2rem; list-style: none;
    }

    .nav-links a {
      font-size: 0.78rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: rgba(237,232,220,0.8);
      text-decoration: none;
      transition: color 0.3s;
    }

    .nav.scrolled .nav-links a { color: var(--muted); }
    .nav-links a:hover { color: var(--amber) !important; }

    .nav-cta {
      font-size: 0.78rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--forest);
      background: var(--beige);
      padding: 0.6rem 1.4rem;
      text-decoration: none;
      transition: background 0.3s, color 0.3s;
    }

    .nav.scrolled .nav-cta {
      background: var(--forest);
      color: var(--beige);
    }

    .nav-cta:hover { background: var(--amber) !important; color: var(--beige) !important; }

    .nav-hamburger {
      display: none; flex-direction: column; gap: 5px;
      background: none; border: none; cursor: pointer; padding: 4px;
    }

    .nav-hamburger span {
      display: block; width: 24px; height: 2px;
      background: var(--beige);
      transition: background 0.4s, transform 0.3s, opacity 0.3s;
    }

    .nav.scrolled .nav-hamburger span { background: var(--forest); }

    /* ── HERO — FULLSCREEN ── */
    .hero {
      position: relative;
      height: 100vh; min-height: 620px;
      display: flex; align-items: flex-end;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute; inset: 0;
    }

    .hero-bg img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center 40%;
      transform: scale(1.06);
      transition: transform 8s ease-out;
    }

    .hero-bg img.loaded { transform: scale(1); }

    /* Gradient overlay */
    .hero-bg::after {
      content: '';
      position: absolute; inset: 0;
      background:
        linear-gradient(to top, rgba(14,26,20,0.88) 0%, rgba(14,26,20,0.45) 45%, rgba(14,26,20,0.15) 100%);
    }

    /* Topo line overlay */
    .topo-svg {
      position: absolute; inset: 0; z-index: 1; pointer-events: none;
    }

    .topo-svg svg { width: 100%; height: 100%; }

    .topo-path {
      fill: none; stroke: rgba(237,232,220,0.06);
      stroke-width: 1.5;
      stroke-dasharray: 1200;
      stroke-dashoffset: 1200;
      animation: drawLine 5s cubic-bezier(0.4,0,0.2,1) 0.5s forwards;
    }

    .topo-path:nth-child(2) { animation-delay: 1s; stroke: rgba(237,232,220,0.045); }
    .topo-path:nth-child(3) { animation-delay: 1.5s; stroke: rgba(237,232,220,0.03); }
    .topo-path:nth-child(4) { animation-delay: 2s; stroke: rgba(237,232,220,0.025); }

    @keyframes drawLine { to { stroke-dashoffset: 0; } }

    .hero-content {
      position: relative; z-index: 2;
      width: 100%;
      padding: 0 2.5rem 5rem;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      align-items: flex-end;
    }

    .hero-text {}

    .hero-eyebrow {
      font-family: var(--ff-sans);
      font-size: 0.72rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.2em;
      color: var(--amber);
      margin-bottom: 1rem;
      opacity: 0; transform: translateY(16px);
      animation: fadeUp 0.7s ease 0.3s forwards;
    }

    .hero-headline {
      font-family: var(--ff-serif);
      font-weight: 400;
      line-height: 0.95;
      color: var(--beige);
      margin-bottom: 1.75rem;
    }

    .hero-headline .line {
      display: block;
      font-size: clamp(3.5rem, 7vw, 7rem);
      opacity: 0; transform: translateY(32px);
      animation: fadeUp 0.8s cubic-bezier(0.22,1,0.36,1) forwards;
    }

    .hero-headline .line:nth-child(1) { animation-delay: 0.5s; }
    .hero-headline .line:nth-child(2) { animation-delay: 0.72s; font-style: italic; color: rgba(237,232,220,0.75); }
    .hero-headline .line:nth-child(3) { animation-delay: 0.94s; }

    .hero-tagline {
      font-size: 1rem; font-weight: 300;
      color: rgba(237,232,220,0.65);
      letter-spacing: 0.03em;
      max-width: 380px;
      opacity: 0; transform: translateY(16px);
      animation: fadeUp 0.7s ease 1.15s forwards;
    }

    .hero-meta {
      display: flex; flex-direction: column;
      align-items: flex-end; gap: 1.5rem;
      opacity: 0;
      animation: fadeUp 0.7s ease 1.3s forwards;
    }

    .hero-scroll-hint {
      display: flex; flex-direction: column;
      align-items: center; gap: 0.5rem;
    }

    .hero-scroll-hint span {
      font-size: 0.65rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.15em;
      color: rgba(237,232,220,0.45);
      writing-mode: vertical-rl;
    }

    .scroll-line {
      width: 1px; height: 60px;
      background: linear-gradient(to bottom, var(--amber), transparent);
      animation: scrollPulse 2s ease-in-out 1.8s infinite;
    }

    @keyframes scrollPulse {
      0%, 100% { opacity: 0.5; transform: scaleY(1); }
      50% { opacity: 1; transform: scaleY(1.2); }
    }

    .hero-badges {
      display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-end;
    }

    .hero-badge {
      font-size: 0.7rem; font-weight: 500;
      letter-spacing: 0.06em;
      color: rgba(237,232,220,0.6);
      border: 1px solid rgba(237,232,220,0.15);
      padding: 0.35rem 0.8rem;
      white-space: nowrap;
    }

    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── INTRO STRIP ── */
    .intro-strip {
      background: var(--forest);
      padding: 1.75rem 2.5rem;
      display: flex; justify-content: center; gap: 4rem;
      flex-wrap: wrap;
    }

    .strip-item {
      display: flex; align-items: center; gap: 0.75rem;
    }

    .strip-dot {
      width: 6px; height: 6px;
      background: var(--amber); border-radius: 50%;
      flex-shrink: 0;
    }

    .strip-item span {
      font-size: 0.78rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: rgba(237,232,220,0.65);
    }

    /* ── SECTION SHARED ── */
    .section { padding: 7rem 2.5rem; }

    .sec-label {
      font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.2em;
      color: var(--amber);
      margin-bottom: 1rem;
    }

    .sec-title {
      font-family: var(--ff-serif);
      font-size: clamp(2rem, 3.5vw, 3rem);
      font-weight: 400; line-height: 1.1;
      color: var(--forest);
      margin-bottom: 0.75rem;
    }

    .sec-rule {
      width: 40px; height: 3px;
      background: var(--amber); border-radius: 2px;
      margin-bottom: 3rem;
    }

    /* ── SECTION 1: ERLEBNISSE — 3-COL PHOTO GRID ── */
    .erlebnisse { background: var(--beige-2); }

    .erlebnisse-inner {
      max-width: 1180px; margin: 0 auto;
    }

    .erlebnisse-header {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      align-items: flex-end;
      margin-bottom: 4rem;
    }

    .erlebnisse-lead {
      font-size: 1.05rem; line-height: 1.7;
      color: var(--muted);
      max-width: 420px;
    }

    .erlebnisse-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .erlebnisse-card {
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }

    .erlebnisse-card--tall {
      grid-row: span 2;
    }

    .erlebnisse-card .photo-wrap {
      position: relative;
      overflow: hidden;
      height: 100%;
    }

    .erlebnisse-card--short .photo-wrap { aspect-ratio: 4 / 3; }
    .erlebnisse-card--tall .photo-wrap { aspect-ratio: unset; height: 100%; min-height: 580px; }

    .erlebnisse-card img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.7s cubic-bezier(0.22,1,0.36,1);
    }

    .erlebnisse-card:hover img { transform: scale(1.06); }

    .erlebnisse-card .photo-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(14,26,20,0.75) 0%, transparent 55%);
      pointer-events: none;
    }

    .erlebnisse-card .card-label {
      position: absolute; bottom: 1.5rem; left: 1.5rem; right: 1.5rem;
      z-index: 2;
    }

    .card-label-title {
      font-family: var(--ff-serif);
      font-size: 1.4rem; font-weight: 400;
      color: var(--beige);
      line-height: 1.2;
      margin-bottom: 0.25rem;
    }

    .card-label-sub {
      font-size: 0.72rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: rgba(237,232,220,0.65);
    }

    /* ── SECTION 2: DIE HUETTE — SPLIT ── */
    .huette {
      background: var(--forest);
      padding: 0;
      overflow: hidden;
    }

    .huette-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 680px;
    }

    .huette-photo {
      position: relative;
      overflow: hidden;
    }

    .huette-photo img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      filter: sepia(12%) saturate(0.95) brightness(0.9);
      transition: transform 0.8s ease;
    }

    .huette-photo:hover img { transform: scale(1.04); }

    .huette-photo::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to right, transparent 60%, var(--forest) 100%);
      pointer-events: none;
    }

    .huette-text {
      padding: 6rem 4rem 6rem 3rem;
      display: flex; flex-direction: column;
      justify-content: center;
    }

    .huette-text .sec-label { color: var(--amber); }
    .huette-text .sec-title { color: var(--beige); }
    .huette-text .sec-rule { background: var(--amber); }

    .huette-body {
      font-size: 1.05rem; line-height: 1.8;
      color: rgba(237,232,220,0.75);
      margin-bottom: 2.5rem;
    }

    .huette-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .stat-num {
      font-family: var(--ff-serif);
      font-size: 2.5rem; font-weight: 400;
      color: var(--beige);
      line-height: 1;
      margin-bottom: 0.25rem;
    }

    .stat-label {
      font-size: 0.75rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: rgba(237,232,220,0.45);
    }

    .cta-primary {
      display: inline-flex; align-items: center; gap: 0.6rem;
      font-size: 0.82rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--forest);
      background: var(--beige);
      padding: 1rem 2rem;
      text-decoration: none;
      transition: background 0.3s, transform 0.2s;
      align-self: flex-start;
    }

    .cta-primary:hover {
      background: var(--amber); color: var(--beige);
      transform: translateY(-2px);
    }

    .cta-primary svg { transition: transform 0.3s; }
    .cta-primary:hover svg { transform: translateX(4px); }

    /* ── SECTION 3: TOUREN ── */
    .touren { background: var(--beige); }

    .touren-inner {
      max-width: 1180px; margin: 0 auto;
    }

    .touren-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 3.5rem;
    }

    .touren-link {
      font-size: 0.8rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--forest);
      text-decoration: none;
      border-bottom: 1px solid var(--forest);
      padding-bottom: 2px;
      transition: color 0.3s, border-color 0.3s;
    }

    .touren-link:hover { color: var(--amber); border-color: var(--amber); }

    .touren-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .tour-card {
      background: var(--beige-2);
      border: 1px solid rgba(28,50,41,0.08);
      overflow: hidden;
      transition: transform 0.4s cubic-bezier(0.22,1,0.36,1),
                  box-shadow 0.4s cubic-bezier(0.22,1,0.36,1);
    }

    .tour-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 24px 48px rgba(28,50,41,0.12);
    }

    .tour-photo {
      position: relative; overflow: hidden;
      aspect-ratio: 16 / 9;
    }

    .tour-photo img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.22,1,0.36,1);
    }

    .tour-card:hover .tour-photo img { transform: scale(1.06); }

    .tour-photo-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(14,26,20,0.5) 0%, transparent 50%);
      pointer-events: none;
    }

    .tour-badge {
      position: absolute; top: 1rem; right: 1rem;
      background: var(--amber);
      color: var(--forest);
      font-size: 0.65rem; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.1em;
      padding: 0.3rem 0.7rem;
    }

    .tour-body {
      padding: 1.5rem 1.75rem 1.75rem;
    }

    .tour-name {
      font-family: var(--ff-serif);
      font-size: 1.35rem; font-weight: 400;
      color: var(--forest);
      margin-bottom: 0.6rem;
    }

    .tour-info {
      display: flex; flex-wrap: wrap; gap: 1rem;
      margin-bottom: 1.25rem;
    }

    .tour-info-item {
      font-size: 0.78rem; color: var(--muted);
      display: flex; align-items: center; gap: 0.4rem;
    }

    .tour-info-item svg { opacity: 0.5; flex-shrink: 0; }

    .tour-divider {
      height: 1px;
      background: rgba(28,50,41,0.08);
      margin-bottom: 1.25rem;
    }

    .tour-bottom {
      display: flex; justify-content: space-between; align-items: center;
    }

    .tour-price {
      font-family: var(--ff-serif);
      font-size: 1.6rem; font-weight: 400;
      color: var(--forest);
    }

    .tour-price-unit {
      font-family: var(--ff-sans);
      font-size: 0.75rem; font-weight: 400;
      color: var(--muted);
    }

    .tour-cta {
      font-size: 0.72rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--forest);
      border: 1.5px solid var(--forest);
      padding: 0.55rem 1.1rem;
      text-decoration: none;
      transition: background 0.3s, color 0.3s;
    }

    .tour-cta:hover {
      background: var(--forest);
      color: var(--beige);
    }

    /* ── SECTION 4: PHOTO STRIP (Atmosphaere) ── */
    .atmosphere {
      background: var(--beige-2);
      padding: 7rem 2.5rem;
      overflow: hidden;
    }

    .atmosphere-inner {
      max-width: 1180px; margin: 0 auto;
    }

    .atmosphere-header {
      text-align: center;
      margin-bottom: 4rem;
    }

    .atmosphere-header .sec-label { justify-content: center; display: flex; }
    .atmosphere-header .sec-title { text-align: center; }
    .atmosphere-header .sec-rule { margin: 0.75rem auto 0; }

    .photo-strip {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr 1.4fr;
      gap: 1rem;
      align-items: stretch;
    }

    .strip-item-photo {
      position: relative;
      overflow: hidden;
    }

    .strip-item-photo img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.7s cubic-bezier(0.22,1,0.36,1);
    }

    .strip-item-photo:hover img { transform: scale(1.05); }

    .strip-item-photo::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, transparent 50%, rgba(14,26,20,0.35) 100%);
      pointer-events: none;
    }

    .strip-tall { aspect-ratio: 3 / 4; }
    .strip-short { aspect-ratio: 4 / 3; }

    .strip-quote {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      background: var(--forest);
      padding: 3rem 2rem;
      text-align: center;
    }

    .strip-quote-mark {
      font-family: var(--ff-serif);
      font-size: 5rem; line-height: 0.6;
      color: var(--amber); opacity: 0.5;
      margin-bottom: 1.5rem;
      font-style: italic;
    }

    .strip-quote-text {
      font-family: var(--ff-serif);
      font-size: 1.25rem; font-style: italic; line-height: 1.55;
      color: var(--beige);
      margin-bottom: 1.5rem;
    }

    .strip-quote-author {
      font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.15em;
      color: var(--amber);
    }

    /* ── MOUNTAIN DIVIDER ── */
    .mountain-div {
      width: 100%; overflow: hidden;
      line-height: 0; margin: 0;
    }

    .mountain-div svg {
      display: block; width: 100%;
      height: 56px;
    }

    /* ── FOOTER ── */
    .footer {
      background: var(--forest);
      padding: 3.5rem 2.5rem;
    }

    .footer-inner {
      max-width: 1180px; margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 2rem;
    }

    .footer-logo {
      font-family: var(--ff-serif);
      font-size: 1.25rem;
      color: var(--beige);
    }

    .footer-logo span {
      display: block;
      font-family: var(--ff-sans);
      font-size: 0.7rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.15em;
      color: rgba(237,232,220,0.45);
      margin-top: 0.2rem;
    }

    .footer-center {
      display: flex; flex-direction: column;
      align-items: center; gap: 0.75rem;
    }

    .footer-divider {
      width: 1px; height: 40px;
      background: linear-gradient(to bottom, transparent, var(--amber), transparent);
    }

    .footer-note {
      font-size: 0.7rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.15em;
      color: rgba(237,232,220,0.3);
    }

    .footer-contact {
      display: flex; flex-direction: column;
      align-items: flex-end; gap: 0.4rem;
    }

    .footer-contact a {
      font-size: 0.88rem; color: rgba(237,232,220,0.6);
      text-decoration: none;
      transition: color 0.3s;
    }

    .footer-contact a:hover { color: var(--amber); }

    /* ── REVEAL ── */
    .reveal {
      opacity: 0; transform: translateY(28px);
      transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1),
                  transform 0.8s cubic-bezier(0.22,1,0.36,1);
    }

    .reveal.visible { opacity: 1; transform: translateY(0); }

    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }
    .reveal-delay-5 { transition-delay: 0.5s; }
    .reveal-delay-6 { transition-delay: 0.6s; }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .erlebnisse-grid {
        grid-template-columns: 1fr 1fr;
      }
      .erlebnisse-card--tall {
        grid-row: auto;
      }
      .erlebnisse-card--tall .photo-wrap { min-height: auto; aspect-ratio: 4/3; }

