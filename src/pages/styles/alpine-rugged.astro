---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Gipfelstuermer — Outdoor-Touren & Kurse</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Work+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ── Reset & Base ── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --primary: #2D4A3E;
      --secondary: #F0EBE0;
      --accent: #D4883A;
      --bg: #F5F1EA;
      --text: #1F2D25;
      --font-display: 'Instrument Serif', Georgia, serif;
      --font-body: 'Work Sans', -apple-system, sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      color: var(--text);
      background: var(--bg);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    img { display: block; max-width: 100%; height: auto; }

    /* ── Navigation ── */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 2rem;
      background: rgba(245, 241, 234, 0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(45, 74, 62, 0.08);
    }

    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.5rem;
      color: var(--primary);
      text-decoration: none;
      letter-spacing: -0.02em;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-family: var(--font-body);
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--primary);
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      transition: color 0.3s;
    }

    .nav-links a:hover { color: var(--accent); }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }

    .nav-hamburger span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--primary);
      transition: transform 0.3s, opacity 0.3s;
    }

    /* ── Hero — Split Mountain ── */
    .hero {
      display: flex;
      min-height: 100vh;
      padding-top: 60px;
    }

    .hero-image {
      position: relative;
      width: 55%;
      overflow: hidden;
    }

    .hero-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
    }

    .hero-image::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        repeating-linear-gradient(
          0deg,
          transparent,
          transparent 18px,
          rgba(45, 74, 62, 0.06) 18px,
          rgba(45, 74, 62, 0.06) 19px
        ),
        repeating-linear-gradient(
          60deg,
          transparent,
          transparent 24px,
          rgba(45, 74, 62, 0.04) 24px,
          rgba(45, 74, 62, 0.04) 25px
        ),
        repeating-linear-gradient(
          -30deg,
          transparent,
          transparent 30px,
          rgba(45, 74, 62, 0.03) 30px,
          rgba(45, 74, 62, 0.03) 31px
        );
      pointer-events: none;
    }

    .hero-content {
      width: 45%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 3.5rem;
      background: var(--secondary);
    }

    .hero-headline {
      font-family: var(--font-display);
      font-weight: 400;
      line-height: 1.05;
      color: var(--primary);
      margin-bottom: 1.5rem;
    }

    .hero-headline span {
      display: block;
      font-size: clamp(2.8rem, 5vw, 4.5rem);
    }

    .hero-sub {
      font-size: 1rem;
      font-weight: 400;
      color: var(--text);
      opacity: 0.75;
      letter-spacing: 0.02em;
      margin-bottom: 0.5rem;
    }

    .hero-underline {
      width: 60px;
      height: 3px;
      background: var(--accent);
      border-radius: 2px;
      margin: 1.5rem 0 2rem;
    }

    .cta-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-body);
      font-size: 0.9rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--secondary);
      background: var(--primary);
      padding: 1rem 2rem;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.3s, transform 0.2s;
    }

    .cta-primary:hover {
      background: #1F3A2E;
      transform: translateY(-1px);
    }

    /* ── Section Shared ── */
    .section {
      padding: 6rem 2rem;
    }

    .section-label {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 3.5vw, 3rem);
      font-weight: 400;
      color: var(--primary);
      line-height: 1.15;
      margin-bottom: 1rem;
    }

    .section-divider {
      width: 40px;
      height: 3px;
      background: var(--accent);
      border-radius: 2px;
      margin-bottom: 3rem;
    }

    /* ── Touren Section ── */
    .touren { background: var(--bg); }

    .touren-inner {
      max-width: 1100px;
      margin: 0 auto;
    }

    .tour-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .tour-card {
      background: var(--secondary);
      border: 1px solid rgba(45, 74, 62, 0.1);
      border-left: 3px solid var(--accent);
      padding: 2rem 1.75rem;
      position: relative;
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .tour-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(31, 45, 37, 0.1);
    }

    .tour-name {
      font-family: var(--font-display);
      font-size: 1.5rem;
      color: var(--primary);
      margin-bottom: 0.25rem;
    }

    .tour-type {
      font-size: 0.8rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent);
      margin-bottom: 1.25rem;
    }

    .tour-meta {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      margin-bottom: 1.5rem;
    }

    .tour-meta-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.85rem;
      color: var(--text);
      opacity: 0.8;
    }

    .tour-meta-label {
      font-weight: 500;
    }

    .difficulty {
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }

    .difficulty-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      border: 1.5px solid var(--primary);
    }

    .difficulty-dot.filled { background: var(--primary); }

    .tour-price {
      font-family: var(--font-display);
      font-size: 1.75rem;
      color: var(--primary);
      padding-top: 1rem;
      border-top: 1px solid rgba(45, 74, 62, 0.1);
    }

    .tour-price-unit {
      font-family: var(--font-body);
      font-size: 0.8rem;
      font-weight: 400;
      color: var(--text);
      opacity: 0.6;
    }

    /* ── Guide Section ── */
    .guide {
      background: var(--primary);
      color: var(--secondary);
    }

    .guide-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 4rem;
      align-items: center;
    }

    .guide .section-label { color: var(--accent); }
    .guide .section-title { color: var(--secondary); }
    .guide .section-divider { background: var(--accent); }

    .guide-photo-wrapper {
      position: relative;
    }

    .guide-photo {
      width: 100%;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      filter: grayscale(15%) contrast(1.05);
    }

    .guide-photo-wrapper::after {
      content: '';
      position: absolute;
      bottom: -12px;
      right: -12px;
      width: 100%;
      height: 100%;
      border: 2px solid var(--accent);
      z-index: -1;
    }

    .guide-text p {
      font-size: 1.05rem;
      line-height: 1.75;
      color: var(--secondary);
      opacity: 0.85;
      margin-bottom: 2rem;
    }

    .guide-quote {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 1.3rem;
      line-height: 1.5;
      color: var(--secondary);
      border-left: 3px solid var(--accent);
      padding-left: 1.25rem;
      margin-bottom: 2.5rem;
    }

    .credentials {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 2.5rem;
    }

    .credential {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(240, 235, 224, 0.08);
      border: 1px solid rgba(240, 235, 224, 0.15);
      padding: 0.6rem 1rem;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.03em;
      color: var(--secondary);
    }

    .credential-icon {
      width: 6px;
      height: 6px;
      background: var(--accent);
      border-radius: 50%;
      flex-shrink: 0;
    }

    .guide-contact {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .guide-contact a {
      color: var(--accent);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      transition: opacity 0.3s;
    }

    .guide-contact a:hover { opacity: 0.8; }

    .guide-contact-phone {
      font-family: var(--font-body);
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--secondary) !important;
      letter-spacing: 0.03em;
    }

    /* ── Footer ── */
    .footer {
      text-align: center;
      padding: 3rem 2rem;
      background: var(--bg);
      border-top: 1px solid rgba(45, 74, 62, 0.08);
    }

    .footer-logo {
      font-family: var(--font-display);
      font-size: 1.25rem;
      color: var(--primary);
      margin-bottom: 0.5rem;
    }

    .footer-note {
      font-size: 0.78rem;
      color: var(--text);
      opacity: 0.5;
    }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .hero {
        flex-direction: column;
        min-height: auto;
      }

      .hero-image {
        width: 100%;
        height: 50vh;
      }

      .hero-content {
        width: 100%;
        padding: 3rem 2rem;
      }

      .tour-grid {
        grid-template-columns: 1fr;
        max-width: 480px;
      }

      .guide-inner {
        grid-template-columns: 1fr;
        gap: 2.5rem;
      }

      .guide-photo-wrapper {
        max-width: 340px;
      }

      .guide-photo-wrapper::after { display: none; }
    }

    @media (max-width: 600px) {
      .nav { padding: 0.75rem 1.25rem; }
      .nav-links { display: none; }
      .nav-hamburger { display: flex; }
      .nav-links.open {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: rgba(245, 241, 234, 0.97);
        backdrop-filter: blur(12px);
        padding: 1.5rem 2rem;
        gap: 1rem;
        border-bottom: 1px solid rgba(45, 74, 62, 0.1);
      }

      .hero-image { height: 40vh; }
      .hero-content { padding: 2.5rem 1.5rem; }
      .hero-headline span { font-size: 2.4rem; }
      .section { padding: 4rem 1.5rem; }
      .credentials { flex-direction: column; }
    }
  </style>
</head>
<body>

  <!-- Navigation -->
  <nav class="nav">
    <a href="#" class="nav-logo">Gipfelstuermer</a>
    <ul class="nav-links" id="navLinks">
      <li><a href="#touren">Touren</a></li>
      <li><a href="#guide">Der Guide</a></li>
      <li><a href="#guide">Kontakt</a></li>
    </ul>
    <button class="nav-hamburger" id="navToggle" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- Hero — Split Mountain -->
  <section class="hero">
    <div class="hero-image">
      <img
        src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1000&q=80&auto=format"
        alt="Dramatische Berglandschaft mit schroffen Gipfeln"
        loading="eager"
      />
    </div>
    <div class="hero-content">
      <div class="hero-headline">
        <span>Raus.</span>
        <span>Rauf.</span>
        <span>Ankommen.</span>
      </div>
      <p class="hero-sub">Gefuehrte Touren in Eifel & Mosel &middot; Seit 2020</p>
      <div class="hero-underline"></div>
      <a href="#touren" class="cta-primary">Naechste Tour &rarr;</a>
    </div>
  </section>

  <!-- Touren -->
  <section class="section touren" id="touren">
    <div class="touren-inner">
      <p class="section-label">Touren</p>
      <h2 class="section-title">Unterwegs in Eifel & Mosel</h2>
      <div class="section-divider"></div>

      <div class="tour-grid">
        <!-- Eifelsteig Etappe -->
        <div class="tour-card">
          <h3 class="tour-name">Eifelsteig Etappe</h3>
          <p class="tour-type">Tageswanderung</p>
          <div class="tour-meta">
            <div class="tour-meta-row">
              <span class="tour-meta-label">Distanz</span>
              <span>18 km</span>
            </div>
            <div class="tour-meta-row">
              <span class="tour-meta-label">Dauer</span>
              <span>Ganzer Tag</span>
            </div>
            <div class="tour-meta-row">
              <span class="tour-meta-label">Schwierigkeit</span>
              <div class="difficulty">
                <span class="difficulty-dot filled"></span>
                <span class="difficulty-dot filled"></span>
                <span class="difficulty-dot"></span>
              </div>
            </div>
          </div>
          <div class="tour-price">35 &euro;</div>
        </div>

        <!-- Mosel-Klettersteig -->
        <div class="tour-card">
          <h3 class="tour-name">Mosel-Klettersteig</h3>
          <p class="tour-type">Halbtag</p>
          <div class="tour-meta">
            <div class="tour-meta-row">
              <span class="tour-meta-label">Dauer</span>
              <span>ca. 4 Stunden</span>
            </div>
            <div class="tour-meta-row">
              <span class="tour-meta-label">Anforderung</span>
              <span>Trittsicherheit</span>
            </div>
            <div class="tour-meta-row">
              <span class="tour-meta-label">Schwierigkeit</span>
              <div class="difficulty">
                <span class="difficulty-dot filled"></span>
                <span class="difficulty-dot filled"></span>
                <span class="difficulty-dot filled"></span>
              </div>
            </div>
          </div>
          <div class="tour-price">55 &euro;</div>
        </div>

        <!-- Familien-Waldtag -->
        <div class="tour-card">
          <h3 class="tour-name">Familien-Waldtag</h3>
          <p class="tour-type">Erlebniswanderung</p>
          <div class="tour-meta">
            <div class="tour-meta-row">
              <span class="tour-meta-label">Dauer</span>
              <span>5 Stunden</span>
            </div>
            <div class="tour-meta-row">
              <span class="tour-meta-label">Fuer</span>
              <span>Familien mit Kindern</span>
            </div>
            <div class="tour-meta-row">
              <span class="tour-meta-label">Schwierigkeit</span>
              <div class="difficulty">
                <span class="difficulty-dot filled"></span>
                <span class="difficulty-dot"></span>
                <span class="difficulty-dot"></span>
              </div>
            </div>
          </div>
          <div class="tour-price">25 &euro; <span class="tour-price-unit">/ Person</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Der Guide -->
  <section class="section guide" id="guide">
    <div class="guide-inner">
      <div class="guide-photo-wrapper">
        <img
          class="guide-photo"
          src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=600&q=80&auto=format"
          alt="Niklas, zertifizierter Wanderfuehrer"
          loading="lazy"
        />
      </div>
      <div class="guide-text">
        <p class="section-label">Der Guide</p>
        <h2 class="section-title">Niklas</h2>
        <div class="section-divider"></div>

        <p class="guide-quote">Aufgewachsen zwischen Weinbergen und Vulkankratern. Zertifizierter Wanderfuehrer seit 2018.</p>

        <p>
          Ich kenne jeden Pfad in der Eifel und an der Mosel — die offiziellen und die,
          die auf keiner Karte stehen. Meine Touren sind keine Spaziergaenge mit Vortrag.
          Wir gehen raus, atmen durch und kommen an Orte, die man allein nicht findet.
        </p>

        <div class="credentials">
          <div class="credential">
            <span class="credential-icon"></span>
            DAV Wanderfuehrer
          </div>
          <div class="credential">
            <span class="credential-icon"></span>
            Erste Hilfe Outdoor
          </div>
          <div class="credential">
            <span class="credential-icon"></span>
            120+ gefuehrte Touren
          </div>
        </div>

        <div class="guide-contact">
          <a href="tel:+491701234567" class="guide-contact-phone">+49 170 123 4567</a>
          <a href="mailto:niklas@gipfelstuermer.de">Schreib mir eine Nachricht</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <p class="footer-logo">Gipfelstuermer</p>
    <p class="footer-note">Outdoor-Touren & Kurse in Eifel & Mosel</p>
  </footer>

  <script>
    const navToggle = document.getElementById('navToggle');
    const navLinks = document.getElementById('navLinks');
    if (navToggle && navLinks) {
      navToggle.addEventListener('click', () => {
        navLinks.classList.toggle('open');
      });
      navLinks.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          navLinks.classList.remove('open');
        });
      });
    }
  </script>

</body>
</html>
