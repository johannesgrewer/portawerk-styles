---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Lichtfang — Hochzeitsfotografie an der Mosel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Italiana&family=Raleway:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --cream: #E8DCC8;
      --dark: #1A1816;
      --gold: #A68B6B;
      --bg: #121110;
      --text: #E8DCC8;
      --font-display: "Italiana", Georgia, serif;
      --font-body: "Raleway", system-ui, sans-serif;
    }

    html {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-weight: 300;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      scroll-behavior: smooth;
    }

    body { overflow-x: hidden; }

    ::selection { background: var(--gold); color: var(--bg); }

    img { display: block; max-width: 100%; }

    /* ═══════════════════════════════════════════
       HERO — Full-Bleed Photo with Overlay Type
    ═══════════════════════════════════════════ */
    .hero {
      position: relative;
      width: 100%;
      height: 100vh;
      min-height: 600px;
      overflow: hidden;
    }

    .hero-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(18, 17, 16, 0.15) 0%,
        rgba(18, 17, 16, 0.3) 40%,
        rgba(18, 17, 16, 0.7) 70%,
        rgba(18, 17, 16, 0.92) 100%
      );
    }

    .hero-content {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-bottom: 12vh;
      text-align: center;
    }

    .hero-headline {
      font-family: var(--font-display);
      font-size: clamp(2.8rem, 6vw, 5.5rem);
      font-weight: 400;
      letter-spacing: 0.02em;
      line-height: 1.1;
      color: var(--cream);
    }

    .hero-sub {
      margin-top: 1.5rem;
      font-family: var(--font-body);
      font-size: clamp(0.65rem, 1.2vw, 0.85rem);
      font-weight: 400;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .scroll-indicator {
      position: absolute;
      bottom: 3vh;
      left: 50%;
      transform: translateX(-50%);
      width: 1px;
      height: 48px;
      overflow: hidden;
    }

    .scroll-indicator::after {
      content: "";
      display: block;
      width: 1px;
      height: 100%;
      background: var(--gold);
      animation: scrollLine 2s ease-in-out infinite;
    }

    @keyframes scrollLine {
      0% { transform: translateY(-100%); opacity: 0; }
      30% { opacity: 1; }
      70% { opacity: 1; }
      100% { transform: translateY(100%); opacity: 0; }
    }

    /* ═══════════════════════════════════════════
       SECTION 2 — Arbeiten (Cinematic Gallery)
    ═══════════════════════════════════════════ */
    .arbeiten {
      padding: clamp(4rem, 10vw, 8rem) clamp(1rem, 4vw, 3rem);
      max-width: 1400px;
      margin: 0 auto;
    }

    .arbeiten-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 3rem;
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-auto-rows: minmax(60px, auto);
      gap: 1rem;
    }

    .gallery-item {
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: filter 0.5s ease, transform 0.6s ease;
      filter: brightness(0.85);
    }

    .gallery-item:hover img {
      filter: brightness(1);
      transform: scale(1.02);
    }

    .gallery-caption {
      position: absolute;
      bottom: 0.75rem;
      left: 1rem;
      font-family: var(--font-body);
      font-size: 0.65rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(232, 220, 200, 0.6);
      transition: color 0.4s ease;
    }

    .gallery-item:hover .gallery-caption {
      color: rgba(232, 220, 200, 0.9);
    }

    /* Item 1 — wide letterbox 21:9 spanning left */
    .gallery-item-1 {
      grid-column: 1 / 8;
      grid-row: 1 / 5;
      aspect-ratio: 21 / 9;
    }

    /* Item 2 — portrait 2:3 on the right */
    .gallery-item-2 {
      grid-column: 8 / 13;
      grid-row: 1 / 8;
    }

    .gallery-item-2 img {
      aspect-ratio: 2 / 3;
    }

    /* Item 3 — square, below item 1 left side */
    .gallery-item-3 {
      grid-column: 1 / 5;
      grid-row: 5 / 11;
      aspect-ratio: 1 / 1;
    }

    /* Item 4 — letterbox wide, below item 1 right side */
    .gallery-item-4 {
      grid-column: 5 / 13;
      grid-row: 8 / 12;
      aspect-ratio: 21 / 9;
    }

    /* Item 5 — wide cinematic bottom */
    .gallery-item-5 {
      grid-column: 1 / 13;
      grid-row: 12 / 16;
      aspect-ratio: 21 / 9;
    }

    /* ═══════════════════════════════════════════
       SECTION 3 — Ueber mich
    ═══════════════════════════════════════════ */
    .ueber {
      padding: clamp(5rem, 12vw, 10rem) clamp(1.5rem, 5vw, 3rem);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      max-width: 640px;
      margin: 0 auto;
    }

    .ueber-portrait {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      object-fit: cover;
      filter: grayscale(30%) brightness(0.9);
      margin-bottom: 2rem;
    }

    .ueber-name {
      font-family: var(--font-display);
      font-size: clamp(1.4rem, 2.5vw, 1.8rem);
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 2rem;
    }

    .ueber-text {
      font-family: var(--font-body);
      font-size: clamp(1rem, 1.8vw, 1.2rem);
      font-weight: 300;
      line-height: 1.8;
      color: var(--cream);
      font-style: italic;
      margin-bottom: 3rem;
    }

    .ueber-contact {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      color: var(--gold);
    }

    /* ═══════════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════════ */
    @media (max-width: 768px) {
      .gallery-grid {
        grid-template-columns: 1fr;
        grid-auto-rows: auto;
        gap: 0.75rem;
      }

      .gallery-item-1,
      .gallery-item-2,
      .gallery-item-3,
      .gallery-item-4,
      .gallery-item-5 {
        grid-column: 1 / -1;
        grid-row: auto;
      }

      .gallery-item-1 { aspect-ratio: 21 / 9; }
      .gallery-item-2 { aspect-ratio: 3 / 4; }
      .gallery-item-3 { aspect-ratio: 1 / 1; }
      .gallery-item-4 { aspect-ratio: 21 / 9; }
      .gallery-item-5 { aspect-ratio: 21 / 9; }

      .gallery-item-2 img { aspect-ratio: unset; }

      .hero-content {
        padding-bottom: 15vh;
      }

      .ueber-portrait {
        width: 110px;
        height: 110px;
      }
    }
  </style>
</head>
<body>

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <img
      class="hero-image"
      src="https://images.unsplash.com/photo-1519741497674-611481863552?w=1920&q=80&auto=format"
      alt="Hochzeitsfotografie — Brautpaar im Licht"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 class="hero-headline">Momente, die bleiben.</h1>
      <p class="hero-sub">Lichtfang &middot; Hochzeitsfotografie &middot; Mosel & Trier</p>
    </div>
    <div class="scroll-indicator"></div>
  </section>

  <!-- ═══ ARBEITEN ═══ -->
  <section class="arbeiten">
    <p class="arbeiten-label">Arbeiten</p>
    <div class="gallery-grid">
      <div class="gallery-item gallery-item-1">
        <img
          src="https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=1200&q=80&auto=format"
          alt="Hochzeit an der Mosel"
          loading="lazy"
        />
        <span class="gallery-caption">Mosel &middot; Sommer 2025</span>
      </div>
      <div class="gallery-item gallery-item-2">
        <img
          src="https://images.unsplash.com/photo-1583939003579-730e3918a45a?w=800&q=80&auto=format"
          alt="Braut-Portrait"
          loading="lazy"
        />
        <span class="gallery-caption">Portrait</span>
      </div>
      <div class="gallery-item gallery-item-3">
        <img
          src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=800&q=80&auto=format"
          alt="Ringtausch"
          loading="lazy"
        />
        <span class="gallery-caption">Details</span>
      </div>
      <div class="gallery-item gallery-item-4">
        <img
          src="https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=1200&q=80&auto=format"
          alt="Brautpaar bei Sonnenuntergang"
          loading="lazy"
        />
        <span class="gallery-caption">Longuich &middot; Herbst 2024</span>
      </div>
      <div class="gallery-item gallery-item-5">
        <img
          src="https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=1400&q=80&auto=format"
          alt="Feier im Weinberg"
          loading="lazy"
        />
        <span class="gallery-caption">Sommer 2025</span>
      </div>
    </div>
  </section>

  <!-- ═══ UEBER MICH ═══ -->
  <section class="ueber">
    <img
      class="ueber-portrait"
      src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80&auto=format"
      alt="Julian Wehr — Fotograf"
      loading="lazy"
    />
    <h2 class="ueber-name">Julian Wehr</h2>
    <p class="ueber-text">
      Ich fotografiere keine Hochzeiten.<br />
      Ich fotografiere das Gefühl, wenn alles stimmt.
    </p>
    <p class="ueber-contact">
      Anfragen: julian@lichtfang.de &middot; 0176 — 33 44 55 66
    </p>
  </section>

</body>
</html>
