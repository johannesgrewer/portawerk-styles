---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Lichtblick — Yoga & Meditation in Konz</title>
  <meta name="description" content="Dein Raum fuer innere Ruhe. Yoga, Meditation und Achtsamkeit in Konz bei Trier." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #7C9885;
      --primary-dark: #6a8573;
      --primary-light: rgba(124, 152, 133, 0.10);
      --secondary: #F7F3EE;
      --accent: #D4A574;
      --accent-light: #e4c4a0;
      --bg: #FDFBF8;
      --text: #2D3436;
      --text-light: #636e72;
      --text-muted: #9ca3a8;
      --white: #ffffff;
      --shadow-soft: 0 2px 20px rgba(124, 152, 133, 0.08);
      --shadow-medium: 0 8px 40px rgba(124, 152, 133, 0.12);
      --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.05);
      --radius: 20px;
      --radius-lg: 28px;
      --radius-sm: 14px;
      --radius-full: 9999px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
      background-color: var(--bg);
      line-height: 1.7;
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ==================== NAV ==================== */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: rgba(253, 251, 248, 0.82);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(124, 152, 133, 0.08);
      transition: box-shadow 0.3s ease;
    }

    .nav.scrolled {
      box-shadow: var(--shadow-soft);
    }

    .nav-inner {
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 28px;
      height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--primary);
      text-decoration: none;
      letter-spacing: -0.02em;
    }

    .nav-logo span {
      color: var(--accent);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 36px;
      list-style: none;
    }

    .nav-links a {
      text-decoration: none;
      color: var(--text-light);
      font-size: 0.88rem;
      font-weight: 500;
      transition: color 0.2s ease;
    }

    .nav-links a:hover {
      color: var(--primary);
    }

    .nav-links .nav-cta {
      background: var(--primary);
      color: var(--white);
      padding: 10px 24px;
      border-radius: var(--radius-full);
      font-weight: 500;
      transition: background 0.2s ease, transform 0.2s ease;
    }

    .nav-links .nav-cta:hover {
      background: var(--primary-dark);
      color: var(--white);
      transform: translateY(-1px);
    }

    .nav-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
    }

    .nav-toggle span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--text);
      margin: 5px 0;
      border-radius: 2px;
      transition: all 0.3s ease;
    }

    /* ==================== HERO ==================== */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      position: relative;
      overflow: hidden;
      padding-top: 72px;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        160deg,
        rgba(253, 251, 248, 0.95) 0%,
        rgba(253, 251, 248, 0.88) 40%,
        rgba(253, 251, 248, 0.6) 100%
      );
      z-index: 1;
    }

    /* Floating organic shapes */
    .hero-shape {
      position: absolute;
      border-radius: 50%;
      z-index: 1;
      pointer-events: none;
    }

    .hero-shape-1 {
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(124, 152, 133, 0.08) 0%, transparent 70%);
      top: -100px;
      right: -100px;
    }

    .hero-shape-2 {
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(212, 165, 116, 0.1) 0%, transparent 70%);
      bottom: -50px;
      left: -80px;
    }

    .hero-shape-3 {
      width: 200px;
      height: 200px;
      background: radial-gradient(circle, rgba(124, 152, 133, 0.06) 0%, transparent 70%);
      top: 40%;
      right: 20%;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 1120px;
      margin: 0 auto;
      padding: 80px 28px 80px;
      width: 100%;
    }

    .hero-inner {
      max-width: 600px;
    }

    .hero-location {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--primary);
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: 28px;
    }

    .hero-location svg {
      width: 14px;
      height: 14px;
      opacity: 0.7;
    }

    .hero h1 {
      font-size: clamp(3rem, 6vw, 4.5rem);
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -0.035em;
      color: var(--text);
      margin-bottom: 28px;
    }

    .hero h1 em {
      font-style: italic;
      font-weight: 300;
      color: var(--primary);
    }

    .hero-details {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 40px;
    }

    .hero-detail {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 1rem;
      color: var(--text-light);
    }

    .hero-detail svg {
      width: 18px;
      height: 18px;
      color: var(--primary);
      flex-shrink: 0;
      opacity: 0.7;
    }

    .hero-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-bottom: 56px;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--primary);
      color: var(--white);
      padding: 16px 36px;
      border-radius: var(--radius-full);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      border: none;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(124, 152, 133, 0.3);
    }

    .btn-primary:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(124, 152, 133, 0.4);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--white);
      color: var(--text);
      padding: 16px 36px;
      border-radius: var(--radius-full);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.95rem;
      border: 1.5px solid rgba(124, 152, 133, 0.2);
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: var(--shadow-soft);
    }

    .btn-secondary:hover {
      border-color: var(--primary);
      color: var(--primary);
      transform: translateY(-2px);
    }

    .hero-trust {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .hero-trust-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--white);
      border: 1px solid rgba(124, 152, 133, 0.12);
      padding: 8px 18px;
      border-radius: var(--radius-full);
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--text);
      box-shadow: var(--shadow-soft);
    }

    .hero-trust-pill svg {
      width: 14px;
      height: 14px;
      color: var(--accent);
    }

    .trust-separator {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: rgba(124, 152, 133, 0.3);
    }

    /* ==================== PHILOSOPHIE ==================== */
    .philosophie {
      padding: 120px 28px;
      background: var(--secondary);
      position: relative;
      overflow: hidden;
    }

    .philosophie-shape {
      position: absolute;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(124, 152, 133, 0.06) 0%, transparent 70%);
      top: -150px;
      right: -200px;
      pointer-events: none;
    }

    .philosophie-inner {
      max-width: 1120px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 80px;
      align-items: center;
      position: relative;
      z-index: 1;
    }

    .philosophie-image {
      position: relative;
    }

    .philosophie-image img {
      width: 100%;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-medium);
    }

    .philosophie-image-badge {
      position: absolute;
      bottom: -20px;
      right: -20px;
      background: var(--white);
      border-radius: var(--radius);
      padding: 20px 24px;
      box-shadow: var(--shadow-card);
      display: flex;
      align-items: center;
      gap: 14px;
      max-width: 240px;
    }

    .philosophie-image-badge-icon {
      width: 44px;
      height: 44px;
      background: var(--primary-light);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .philosophie-image-badge-icon svg {
      width: 22px;
      height: 22px;
      color: var(--primary);
    }

    .philosophie-image-badge-text {
      font-size: 0.82rem;
      line-height: 1.4;
    }

    .philosophie-image-badge-text strong {
      display: block;
      font-weight: 600;
      color: var(--text);
    }

    .philosophie-image-badge-text span {
      color: var(--text-light);
    }

    .philosophie-text {
      max-width: 520px;
    }

    .philosophie-tag {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--accent);
      margin-bottom: 20px;
    }

    .philosophie-text h2 {
      font-size: clamp(1.8rem, 3vw, 2.2rem);
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: -0.025em;
      margin-bottom: 24px;
    }

    .philosophie-quote {
      font-size: 1.05rem;
      color: var(--text-light);
      line-height: 1.8;
      margin-bottom: 20px;
      font-style: italic;
      border-left: 3px solid var(--accent);
      padding-left: 20px;
    }

    .philosophie-body {
      font-size: 0.95rem;
      color: var(--text-light);
      line-height: 1.8;
      margin-bottom: 48px;
    }

    .philosophie-principles {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .principle-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 24px 20px;
      text-align: center;
      box-shadow: var(--shadow-soft);
      transition: transform 0.3s ease;
    }

    .principle-card:hover {
      transform: translateY(-4px);
    }

    .principle-icon {
      width: 48px;
      height: 48px;
      background: var(--primary-light);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 14px;
    }

    .principle-icon svg {
      width: 22px;
      height: 22px;
      color: var(--primary);
    }

    .principle-card h4 {
      font-size: 0.88rem;
      font-weight: 600;
      margin-bottom: 6px;
      letter-spacing: -0.01em;
    }

    .principle-card p {
      font-size: 0.78rem;
      color: var(--text-light);
      line-height: 1.5;
    }

    /* ==================== WOCHENPLAN ==================== */
    .wochenplan {
      padding: 120px 28px;
      background: var(--bg);
    }

    .wochenplan-inner {
      max-width: 1120px;
      margin: 0 auto;
    }

    .wochenplan-header {
      text-align: center;
      margin-bottom: 56px;
    }

    .wochenplan-tag {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--primary);
      margin-bottom: 16px;
    }

    .wochenplan-header h2 {
      font-size: clamp(1.8rem, 3vw, 2.2rem);
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: -0.025em;
      margin-bottom: 12px;
    }

    .wochenplan-header p {
      font-size: 0.95rem;
      color: var(--text-light);
      max-width: 440px;
      margin: 0 auto;
    }

    /* Schedule Grid */
    .schedule-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
      margin-bottom: 56px;
    }

    .schedule-day {
      background: var(--white);
      border-radius: var(--radius);
      padding: 24px 20px;
      box-shadow: var(--shadow-soft);
      min-height: 180px;
      display: flex;
      flex-direction: column;
    }

    .schedule-day-name {
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      margin-bottom: 18px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(124, 152, 133, 0.1);
    }

    .schedule-slot {
      margin-bottom: 16px;
      padding: 14px;
      border-radius: var(--radius-sm);
      background: var(--bg);
      transition: transform 0.2s ease;
    }

    .schedule-slot:last-child {
      margin-bottom: 0;
    }

    .schedule-slot:hover {
      transform: scale(1.02);
    }

    .schedule-time {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-muted);
      margin-bottom: 4px;
      letter-spacing: 0.02em;
    }

    .schedule-class {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 8px;
    }

    .schedule-level {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.72rem;
      font-weight: 500;
      padding: 3px 10px;
      border-radius: var(--radius-full);
    }

    .schedule-level::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
    }

    .level-einsteiger {
      background: rgba(124, 152, 133, 0.1);
      color: var(--primary-dark);
    }

    .level-einsteiger::before {
      background: var(--primary);
    }

    .level-mittel {
      background: rgba(212, 165, 116, 0.15);
      color: #b8895a;
    }

    .level-mittel::before {
      background: var(--accent);
    }

    .level-alle {
      background: rgba(124, 152, 133, 0.08);
      color: var(--text-light);
    }

    .level-alle::before {
      background: var(--text-muted);
    }

    /* CTA line */
    .wochenplan-cta {
      text-align: center;
      background: var(--secondary);
      border-radius: var(--radius-lg);
      padding: 48px 40px;
    }

    .wochenplan-cta-phone {
      font-size: clamp(1.2rem, 2.5vw, 1.5rem);
      font-weight: 600;
      color: var(--text);
      margin-bottom: 8px;
    }

    .wochenplan-cta-phone a {
      color: var(--primary);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .wochenplan-cta-phone a:hover {
      color: var(--primary-dark);
    }

    .wochenplan-cta-sub {
      font-size: 0.9rem;
      color: var(--text-light);
      margin-bottom: 0;
    }

    .wochenplan-cta-note {
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-top: 20px;
      font-style: italic;
    }

    /* ==================== FOOTER ==================== */
    .footer {
      background: var(--text);
      color: rgba(255, 255, 255, 0.7);
      padding: 48px 28px 32px;
    }

    .footer-inner {
      max-width: 1120px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
    }

    .footer-logo {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--white);
    }

    .footer-logo span {
      color: var(--accent);
    }

    .footer-links {
      display: flex;
      gap: 24px;
      list-style: none;
    }

    .footer-links a {
      color: rgba(255, 255, 255, 0.45);
      text-decoration: none;
      font-size: 0.82rem;
      transition: color 0.2s ease;
    }

    .footer-links a:hover {
      color: var(--white);
    }

    .footer-copy {
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.3);
      width: 100%;
      text-align: center;
      margin-top: 24px;
      padding-top: 24px;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    /* ==================== MOBILE ==================== */
    @media (max-width: 1024px) {
      .schedule-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .philosophie-principles {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 768px) {
      .nav-links {
        display: none;
        position: fixed;
        top: 72px;
        left: 0;
        right: 0;
        bottom: 0;
        background: var(--bg);
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 28px;
        padding: 40px;
      }

      .nav-links.open {
        display: flex;
      }

      .nav-links a {
        font-size: 1.1rem;
      }

      .nav-toggle {
        display: block;
      }

      .nav-toggle.active span:nth-child(1) {
        transform: rotate(45deg) translate(5px, 5px);
      }

      .nav-toggle.active span:nth-child(2) {
        opacity: 0;
      }

      .nav-toggle.active span:nth-child(3) {
        transform: rotate(-45deg) translate(5px, -5px);
      }

      .hero h1 {
        font-size: 2.6rem;
      }

      .hero-content {
        padding: 50px 24px 60px;
      }

      .hero-trust {
        gap: 8px;
      }

      .philosophie {
        padding: 80px 24px;
      }

      .philosophie-inner {
        grid-template-columns: 1fr;
        gap: 48px;
      }

      .philosophie-image {
        max-width: 400px;
        margin: 0 auto;
      }

      .philosophie-image-badge {
        right: -10px;
        bottom: -16px;
      }

      .philosophie-principles {
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
      }

      .wochenplan {
        padding: 80px 24px;
      }

      .schedule-grid {
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }

      .wochenplan-cta {
        padding: 36px 24px;
      }

      .footer-inner {
        flex-direction: column;
        text-align: center;
      }

      .footer-links {
        flex-direction: column;
        gap: 12px;
      }
    }

    @media (max-width: 480px) {
      .hero h1 {
        font-size: 2.2rem;
      }

      .hero-actions {
        flex-direction: column;
      }

      .btn-primary,
      .btn-secondary {
        justify-content: center;
        width: 100%;
      }

      .hero-trust {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }

      .trust-separator {
        display: none;
      }

      .philosophie-principles {
        grid-template-columns: 1fr;
      }

      .schedule-grid {
        grid-template-columns: 1fr;
      }

      .schedule-day {
        min-height: auto;
      }
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav class="nav" id="navbar">
    <div class="nav-inner">
      <a href="#" class="nav-logo">licht<span>blick</span></a>
      <ul class="nav-links" id="navLinks">
        <li><a href="#philosophie">Sarah</a></li>
        <li><a href="#wochenplan">Wochenplan</a></li>
        <li><a href="tel:+496501943210" class="nav-cta">Anrufen</a></li>
      </ul>
      <button class="nav-toggle" id="navToggle" aria-label="Menu oeffnen">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1545389336-cf090694435e?w=1920&q=80&auto=format"
        alt="Yoga-Praxis in friedlicher Atmosphaere"
        loading="eager"
      />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-shape hero-shape-1"></div>
    <div class="hero-shape hero-shape-2"></div>
    <div class="hero-shape hero-shape-3"></div>

    <div class="hero-content">
      <div class="hero-inner">
        <div class="hero-location">
