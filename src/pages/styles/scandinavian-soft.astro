---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Lichtblick — Yoga & Meditation in Konz</title>
  <meta name="description" content="Dein Raum fuer innere Ruhe. Yoga, Meditation und Achtsamkeit in Konz bei Trier." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,300;1,9..144,400;1,9..144,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />

  <style>
    html { overflow-x: hidden; }
    body { overflow-x: hidden; max-width: 100%; }
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #7C9885;
      --primary-dark: #6a8573;
      --primary-light: rgba(124, 152, 133, 0.10);
      --secondary: #F7F3EE;
      --accent: #D4A574;
      --accent-light: #e4c4a0;
      --bg: #FDFBF8;
      --text: #2D3436;
      --text-light: #636e72;
      --text-muted: #9ca3a8;
      --white: #ffffff;
      --shadow-soft: 0 2px 20px rgba(124, 152, 133, 0.08);
      --shadow-medium: 0 8px 40px rgba(124, 152, 133, 0.12);
      --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.05);
      --radius: 20px;
      --radius-lg: 28px;
      --radius-sm: 14px;
      --radius-full: 9999px;
      --font-display: 'Fraunces', Georgia, serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
      background-color: var(--bg);
      line-height: 1.7;
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ==================== NAV ==================== */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: rgba(253, 251, 248, 0.82);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(124, 152, 133, 0.08);
      transition: box-shadow 0.3s ease;
    }

    .nav.scrolled {
      box-shadow: var(--shadow-soft);
    }

    .nav-inner {
      max-width: 1600px;
      margin: 0 auto;
      padding: 0 28px;
      height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 300;
      font-style: italic;
      color: var(--text);
      text-decoration: none;
      letter-spacing: 0.01em;
    }

    .nav-logo-icon {
      flex-shrink: 0;
      color: var(--primary);
    }

    .nav-logo span {
      color: var(--primary);
      font-weight: 600;
      font-style: normal;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 36px;
      list-style: none;
    }

    .nav-links a {
      text-decoration: none;
      color: var(--text-light);
      font-size: 0.88rem;
      font-weight: 500;
      transition: color 0.2s ease;
    }

    .nav-links a:hover {
      color: var(--primary);
    }

    .nav-links .nav-cta {
      background: var(--primary);
      color: var(--white);
      padding: 10px 24px;
      border-radius: var(--radius-full);
      font-weight: 500;
      transition: background 0.2s ease, transform 0.2s ease;
    }

    .nav-links .nav-cta:hover {
      background: var(--primary-dark);
      color: var(--white);
      transform: translateY(-1px);
    }

    .nav-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
    }

    .nav-toggle span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--text);
      margin: 5px 0;
      border-radius: 2px;
      transition: all 0.3s ease;
    }

    /* ==================== HERO ==================== */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      position: relative;
      overflow: hidden;
      padding-top: 72px;
      background: var(--bg);
    }

    /* Floating organic blob shapes */
    .hero-blob {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }

    .hero-blob-1 {
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(124, 152, 133, 0.07) 0%, transparent 70%);
      top: -120px;
      right: -80px;
    }

    .hero-blob-2 {
      width: 450px;
      height: 450px;
      background: radial-gradient(circle, rgba(212, 165, 116, 0.06) 0%, transparent 70%);
      bottom: -100px;
      left: -120px;
    }

    .hero-blob-3 {
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(124, 152, 133, 0.05) 0%, transparent 70%);
      top: 30%;
      left: 40%;
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      max-width: 1600px;
      margin: 0 auto;
      padding: 80px 28px 100px;
      width: 100%;
      display: grid;
      grid-template-columns: 1fr 1.3fr;
      align-items: center;
      gap: 60px;
    }

    /* --- Hero Text --- */
    .hero-text {
      opacity: 0;
      transform: translateX(-40px);
      animation: heroTextIn 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
    }

    @keyframes heroTextIn {
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2.8rem, 5.5vw, 4.2rem);
      font-weight: 600;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--text);
      margin-bottom: 32px;
    }

    .hero h1 span {
      display: block;
    }

    .hero h1 .hero-headline-accent {
      font-style: italic;
      font-weight: 300;
      color: var(--primary);
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--primary-light);
      color: var(--primary-dark);
      padding: 8px 20px;
      border-radius: var(--radius-full);
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      margin-bottom: 24px;
    }

    .hero-desc {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.85;
      color: var(--text-light);
      max-width: 44ch;
      margin-bottom: 28px;
    }

    .hero-features {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 36px;
    }

    .hero-feature {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 0.83rem;
      font-weight: 500;
      color: var(--text);
    }

    .hero-feature svg {
      width: 17px;
      height: 17px;
      color: var(--primary);
      flex-shrink: 0;
    }

    .hero-badge-dot {
      display: inline-block;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--primary);
      opacity: 0.5;
    }

    .hero-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      color: var(--text);
      font-size: 0.95rem;
      font-weight: 500;
      transition: color 0.2s ease;
    }

    .hero-link:hover {
      color: var(--primary);
    }

    .hero-link-arrow {
      display: inline-block;
      transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .hero-link:hover .hero-link-arrow {
      transform: translateX(6px);
    }

    /* --- Hero Photos --- */
    .hero-photos {
      position: relative;
      height: 520px;
    }

    .hero-photo {
      position: absolute;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(45, 52, 54, 0.10), 0 8px 24px rgba(45, 52, 54, 0.06);
      opacity: 0;
    }

    .hero-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.55s ease;
    }

    .hero-photo:hover img {
      transform: scale(1.05);
    }

    .hero-photo-1 {
      width: 380px;
      height: 460px;
      top: 0;
      right: 0;
      transform: rotate(2deg) translateY(20px);
      animation: photoOneIn 1s cubic-bezier(0.22, 1, 0.36, 1) 0.5s forwards;
      z-index: 1;
    }

    @keyframes photoOneIn {
      to {
        opacity: 1;
        transform: rotate(2deg) translateY(0);
      }
    }

    .hero-photo-2 {
      width: 240px;
      height: 300px;
      bottom: 0;
      left: 20px;
      transform: rotate(-3deg) translateY(20px);
      animation: photoTwoIn 1s cubic-bezier(0.22, 1, 0.36, 1) 0.75s forwards;
      z-index: 2;
    }

    @keyframes photoTwoIn {
      to {
        opacity: 1;
        transform: rotate(-3deg) translateY(0);
      }
    }

    .hero-est {
      position: absolute;
      bottom: 46px;
      left: 280px;
      z-index: 3;
      font-family: 'DM Sans', sans-serif;
      font-style: italic;
      font-weight: 300;
      font-size: 0.82rem;
      color: var(--text-muted);
      opacity: 0;
      animation: fadeIn 0.8s ease 1.2s forwards;
      transform: rotate(-2deg);
    }

    @keyframes fadeIn {
      to { opacity: 1; }
    }

    /* --- Decorative SVG Curve --- */
    .hero-curve {
      position: absolute;
      top: 50%;
      left: -40px;
      z-index: 0;
      opacity: 0;
      animation: fadeIn 1s ease 1s forwards;
    }

    .hero-curve path {
      fill: none;
      stroke: var(--primary);
      stroke-width: 2;
      stroke-linecap: round;
      opacity: 0.28;
      stroke-dasharray: 300;
      stroke-dashoffset: 300;
      animation: drawLine 1.5s ease 1.2s forwards;
    }

    @keyframes drawLine {
      to { stroke-dashoffset: 0; }
    }

    /* ==================== PHILOSOPHIE ==================== */
    .philosophie {
      padding: 120px 28px;
      background: var(--secondary);
      position: relative;
      overflow: hidden;
    }

    .philosophie-shape {
      position: absolute;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(124, 152, 133, 0.06) 0%, transparent 70%);
      top: -150px;
      right: -200px;
      pointer-events: none;
    }

    .philosophie-inner {
      max-width: 1600px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 80px;
      align-items: center;
      position: relative;
      z-index: 1;
    }

    .philosophie-image {
      position: relative;
    }

    .philosophie-img-wrap {
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-medium);
    }

    .philosophie-img-wrap img {
      width: 100%;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      display: block;
      transition: transform 0.55s ease;
    }

    .philosophie-img-wrap:hover img {
      transform: scale(1.05);
    }

    .philosophie-image-badge {
      position: absolute;
      bottom: -20px;
      right: -20px;
      background: var(--white);
      border-radius: var(--radius);
      padding: 20px 24px;
      box-shadow: var(--shadow-card);
      display: flex;
      align-items: center;
      gap: 14px;
      max-width: 240px;
    }

    .philosophie-image-badge-icon {
      width: 44px;
      height: 44px;
      background: var(--primary-light);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .philosophie-image-badge-icon svg {
      width: 22px;
      height: 22px;
      color: var(--primary);
    }

    .philosophie-image-badge-text {
      font-size: 0.82rem;
      line-height: 1.4;
    }

    .philosophie-image-badge-text strong {
      display: block;
      font-weight: 600;
      color: var(--text);
    }

    .philosophie-image-badge-text span {
      color: var(--text-light);
    }

    .philosophie-text {
      max-width: 520px;
    }

    .philosophie-tag {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--accent);
      margin-bottom: 20px;
    }

    .philosophie-text h2 {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3vw, 2.2rem);
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 24px;
    }

    .philosophie-quote {
      font-size: 1.05rem;
      color: var(--text-light);
      line-height: 1.8;
      margin-bottom: 20px;
      font-style: italic;
      border-left: 3px solid var(--accent);
      padding-left: 20px;
    }

    .philosophie-body {
      font-size: 0.95rem;
      color: var(--text-light);
      line-height: 1.8;
      margin-bottom: 48px;
    }

    .principle-list {
      display: flex;
      flex-direction: column;
    }

    .principle-item {
      display: flex;
      align-items: flex-start;
      gap: 20px;
      padding: 18px 0;
      border-bottom: 1px solid rgba(124, 152, 133, 0.12);
    }

    .principle-item:first-child {
      border-top: 1px solid rgba(124, 152, 133, 0.12);
    }

    .principle-num {
      font-family: var(--font-display);
      font-size: 1.05rem;
      font-weight: 300;
      font-style: italic;
      color: var(--accent);
      min-width: 28px;
      line-height: 1.6;
      flex-shrink: 0;
    }

    .principle-item-text strong {
      display: block;
      font-size: 0.92rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 2px;
    }

    .principle-item-text span {
      font-size: 0.83rem;
      color: var(--text-light);
    }

    /* ==================== WOCHENPLAN ==================== */
    .wochenplan {
      padding: 120px 28px;
      background: var(--bg);
    }

    .wochenplan-inner {
      max-width: 1600px;
      margin: 0 auto;
    }

    .wochenplan-header {
      text-align: center;
      margin-bottom: 56px;
    }

    .wochenplan-tag {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--primary);
      margin-bottom: 16px;
    }

    .wochenplan-header h2 {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3vw, 2.2rem);
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 12px;
    }

    .wochenplan-header p {
      font-size: 0.95rem;
      color: var(--text-light);
      max-width: 440px;
      margin: 0 auto;
    }

    /* Schedule List */
    .schedule-list {
      display: flex;
      flex-direction: column;
      margin-bottom: 56px;
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow-soft);
      background: var(--white);
    }

    .schedule-row {
      display: grid;
      grid-template-columns: 130px 70px 1fr auto;
      align-items: center;
      padding: 18px 32px;
      border-bottom: 1px solid rgba(124, 152, 133, 0.08);
      gap: 16px;
      transition: background 0.2s ease;
    }

    .schedule-row:last-child {
      border-bottom: none;
    }

    .schedule-row:hover {
      background: var(--bg);
    }

    .schedule-row-day {
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
    }

    .schedule-row-time {
      font-family: var(--font-display);
      font-size: 0.95rem;
      font-weight: 300;
      font-style: italic;
      color: var(--accent);
    }

    .schedule-row-class {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text);
    }

    .schedule-level {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.72rem;
      font-weight: 500;
      padding: 4px 12px;
      border-radius: var(--radius-full);
    }

    .schedule-level::before {
      content: '';
      width: 5px;
      height: 5px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .level-einsteiger {
      background: rgba(124, 152, 133, 0.1);
      color: var(--primary-dark);
    }

    .level-einsteiger::before {
      background: var(--primary);
    }

    .level-mittel {
      background: rgba(212, 165, 116, 0.15);
      color: #b8895a;
    }

    .level-mittel::before {
      background: var(--accent);
    }

    .level-alle {
      background: rgba(124, 152, 133, 0.08);
      color: var(--text-light);
    }

    .level-alle::before {
      background: var(--text-muted);
    }

    /* CTA line */
    .wochenplan-cta {
      text-align: center;
      background: var(--secondary);
      border-radius: var(--radius-lg);
      padding: 48px 40px;
    }

    .wochenplan-cta-phone {
      font-size: clamp(1.2rem, 2.5vw, 1.5rem);
      font-weight: 600;
      color: var(--text);
      margin-bottom: 8px;
    }

    .wochenplan-cta-phone a {
      color: var(--primary);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .wochenplan-cta-phone a:hover {
      color: var(--primary-dark);
    }

    .wochenplan-cta-sub {
      font-size: 0.9rem;
      color: var(--text-light);
      margin-bottom: 0;
    }

    .wochenplan-cta-note {
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-top: 20px;
      font-style: italic;
    }

    /* ==================== FOOTER ==================== */
    .footer {
      background: var(--text);
      color: rgba(255, 255, 255, 0.7);
      padding: 48px 28px 32px;
    }

    .footer-inner {
      max-width: 1120px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
    }

    .footer-logo {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 300;
      font-style: italic;
      color: rgba(255,255,255,0.7);
    }

    .footer-logo .nav-logo-icon {
      color: var(--accent);
      opacity: 0.8;
    }

    .footer-logo span {
      color: var(--accent);
      font-weight: 600;
      font-style: normal;
    }

    .footer-links {
      display: flex;
      gap: 24px;
      list-style: none;
    }

    .footer-links a {
      color: rgba(255, 255, 255, 0.45);
      text-decoration: none;
      font-size: 0.82rem;
      transition: color 0.2s ease;
    }

    .footer-links a:hover {
      color: var(--white);
    }

    .footer-copy {
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.3);
      width: 100%;
      text-align: center;
      margin-top: 24px;
      padding-top: 24px;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    /* ==================== MOBILE ==================== */
    @media (max-width: 1024px) {
      .schedule-row {
        grid-template-columns: 110px 60px 1fr auto;
        padding: 16px 24px;
      }
    }

    @media (max-width: 768px) {
      .nav-links {
        display: none;
        position: fixed;
        top: 72px;
        left: 0;
        right: 0;
        bottom: 0;
        background: var(--bg);
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 28px;
        padding: 40px;
      }

      .nav-links.open {
        display: flex;
      }

      .nav-links a {
        font-size: 1.1rem;
      }

      .nav-toggle {
        display: block;
      }

      .nav-toggle.active span:nth-child(1) {
        transform: rotate(45deg) translate(5px, 5px);
      }

      .nav-toggle.active span:nth-child(2) {
        opacity: 0;
      }

      .nav-toggle.active span:nth-child(3) {
        transform: rotate(-45deg) translate(5px, -5px);
      }

      .hero-inner {
        grid-template-columns: 1fr;
        gap: 40px;
        padding: 50px 24px 60px;
      }

      .hero-text {
        text-align: center;
        transform: none;
        opacity: 1;
        animation: none;
      }

      .hero h1 {
        font-size: 2.6rem;
      }

      .hero h1 span {
        display: inline;
      }

      .hero-badge {
        margin-bottom: 28px;
      }

      .hero-photos {
        height: auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
      }

      .hero-photo {
        position: relative;
        opacity: 1;
        animation: none;
      }

      .hero-photo-1 {
        width: 100%;
        max-width: 380px;
        height: 320px;
        top: auto;
        right: auto;
        transform: none;
      }

      .hero-photo-2 {
        width: 70%;
        max-width: 260px;
        height: 220px;
        bottom: auto;
        left: auto;
        transform: none;
      }

      .hero-est {
        position: relative;
        bottom: auto;
        left: auto;
        opacity: 1;
        animation: none;
