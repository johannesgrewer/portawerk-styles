<script>
  // ── 1. IntersectionObserver: Scroll Reveals with glow entrance ────────────
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));

  // ── 2. Charging Progress Bar ──────────────────────────────────────────────
  // Fills to 73% (simulated network load) when scrolled into view
  const chargeBarFill = document.getElementById('charge-bar-fill');
  const chargePercent = document.getElementById('charge-percent');
  const TARGET_PERCENT = 73;
  let chargeAnimated = false;

  function animateChargeBar() {
    if (chargeAnimated || !chargeBarFill || !chargePercent) return;
    chargeAnimated = true;

    const startTime = performance.now();
    const duration = 1800;

    function updateBar(currentTime) {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      // Ease-out quint
      const eased = 1 - Math.pow(1 - progress, 5);
      const current = Math.round(TARGET_PERCENT * eased);

      chargeBarFill.style.width = current + '%';
      chargePercent.textContent = current + '%';

      if (progress < 1) {
        requestAnimationFrame(updateBar);
      }
    }

    requestAnimationFrame(updateBar);
  }

  const chargeBarWrapper = document.querySelector('.charge-bar-wrapper');
  if (chargeBarWrapper) {
    const chargeObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setTimeout(animateChargeBar, 400);
            chargeObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 }
    );
    chargeObserver.observe(chargeBarWrapper);
  }

  // ── 3. CO2 Live Counter ───────────────────────────────────────────────────
  // Starts at 1247 kg and increments every second (~0.004 kg/s = ~340 kg/year realistic estimate)
  const co2ValueEl = document.getElementById('co2-value');
  let co2Kg = 1247.0;
  const CO2_INCREMENT_PER_SECOND = 0.011; // ~340 t/year / 365 / 24 / 3600 * 1000 ~ 0.011 kg/s

  function formatCO2(value) {
    // Show as "1.247,8 kg" German format
    if (value >= 1000) {
      const thousands = Math.floor(value / 1000);
      const remainder = (value % 1000).toFixed(1);
      const paddedRemainder = remainder.padStart(5, '0');
      return thousands + '.' + paddedRemainder + ' kg';
    }
    return value.toFixed(1) + ' kg';
  }

  if (co2ValueEl) {
    // Start counter when visible
    const co2Observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            co2Observer.unobserve(entry.target);
            // Update every second
            setInterval(() => {
              co2Kg += CO2_INCREMENT_PER_SECOND;
              co2ValueEl.textContent = formatCO2(co2Kg);
            }, 1000);
          }
        });
      },
      { threshold: 0.5 }
    );
    co2Observer.observe(co2ValueEl);
  }
</script>
</body>
</html>
