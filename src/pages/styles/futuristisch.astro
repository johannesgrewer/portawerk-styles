---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Neovolt — E-Mobilitat & Ladestationen, Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Exo+2:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --primary: #00F0FF;
      --secondary: #0A0E17;
      --accent: #B347EA;
      --bg: #0A0E17;
      --bg-card: #0D1220;
      --bg-card-hover: #111828;
      --text: #E0E8F0;
      --text-muted: #6B7A8D;
      --glow-cyan: rgba(0, 240, 255, 0.4);
      --glow-purple: rgba(179, 71, 234, 0.4);
      --font-display: "Orbitron", sans-serif;
      --font-body: "Exo 2", sans-serif;
      --font-mono: "Share Tech Mono", monospace;
    }

    html {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      scroll-behavior: smooth;
    }

    body { overflow-x: hidden; }

    ::selection { background: var(--primary); color: var(--bg); }

    /* ═══════════════════════════════════════════
       NAV
    ═══════════════════════════════════════════ */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 0 2rem;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(10, 14, 23, 0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(0, 240, 255, 0.1);
    }

    .nav-logo {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.1rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--primary);
      text-decoration: none;
      text-shadow: 0 0 20px var(--glow-cyan);
    }

    .nav-logo span {
      color: var(--text);
      text-shadow: none;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.3s, text-shadow 0.3s;
      position: relative;
    }

    .nav-links a::before {
      content: "//";
      color: rgba(0, 240, 255, 0.3);
      margin-right: 0.3em;
    }

    .nav-links a:hover {
      color: var(--primary);
      text-shadow: 0 0 10px var(--glow-cyan);
    }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }

    .nav-hamburger span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--primary);
      transition: transform 0.3s, opacity 0.3s;
      box-shadow: 0 0 6px var(--glow-cyan);
    }

    /* ═══════════════════════════════════════════
       SCAN-LINE OVERLAY
    ═══════════════════════════════════════════ */
    .scanlines {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 99;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 240, 255, 0.015) 2px,
        rgba(0, 240, 255, 0.015) 4px
      );
    }

    /* ═══════════════════════════════════════════
       HERO — HUD INTERFACE
    ═══════════════════════════════════════════ */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 6rem 2rem 4rem;
      overflow: hidden;
    }

    /* Dot matrix grid background */
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle, rgba(0, 240, 255, 0.08) 1px, transparent 1px);
      background-size: 24px 24px;
      z-index: 0;
    }

    /* Subtle radial glow */
    .hero::after {
      content: "";
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 800px;
      height: 800px;
      background: radial-gradient(circle, rgba(0, 240, 255, 0.06) 0%, transparent 70%);
      z-index: 0;
    }

    .hero-content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      max-width: 800px;
    }

    /* Glowing ring with bolt icon */
    .hero-ring {
      width: 160px;
      height: 160px;
      border-radius: 50%;
      border: 2px solid var(--primary);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 3rem;
      position: relative;
      box-shadow: 0 0 30px var(--glow-cyan), inset 0 0 30px rgba(0, 240, 255, 0.05);
      animation: ringPulse 3s ease-in-out infinite;
    }

    .hero-ring::before {
      content: "";
      position: absolute;
      inset: -8px;
      border-radius: 50%;
      border: 1px solid rgba(0, 240, 255, 0.15);
      animation: ringRotate 20s linear infinite;
      background: conic-gradient(from 0deg, transparent 0%, rgba(0, 240, 255, 0.15) 25%, transparent 50%);
    }

    .hero-ring svg {
      width: 56px;
      height: 56px;
      filter: drop-shadow(0 0 12px var(--glow-cyan));
    }

    @keyframes ringPulse {
      0%, 100% { box-shadow: 0 0 30px var(--glow-cyan), inset 0 0 30px rgba(0, 240, 255, 0.05); }
      50% { box-shadow: 0 0 50px var(--glow-cyan), inset 0 0 50px rgba(0, 240, 255, 0.08); }
    }

    @keyframes ringRotate {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    /* Typing headline */
    .hero-headline {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: clamp(2.2rem, 6vw, 4.5rem);
      line-height: 1.15;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 2.5rem;
    }

    .hero-headline .line {
      display: block;
      overflow: hidden;
      white-space: nowrap;
      border-right: 3px solid var(--primary);
      width: 0;
      animation: typeIn 0.8s steps(20) forwards, blinkCaret 0.6s step-end 3;
    }

    .hero-headline .line:nth-child(1) {
      animation-delay: 0.5s, 0.5s;
      color: var(--primary);
      text-shadow: 0 0 30px var(--glow-cyan);
    }

    .hero-headline .line:nth-child(2) {
      animation-delay: 1.5s, 1.5s;
      color: var(--text);
    }

    .hero-headline .line:nth-child(3) {
      animation-delay: 2.5s, 2.5s;
      color: var(--accent);
      text-shadow: 0 0 30px var(--glow-purple);
    }

    @keyframes typeIn {
      from { width: 0; }
      to { width: 100%; border-right-color: transparent; }
    }

    @keyframes blinkCaret {
      50% { border-right-color: transparent; }
    }

    /* Data readouts */
    .hero-data {
      display: flex;
      gap: 2rem;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .hero-data-item {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .hero-data-item .value {
      color: var(--primary);
      font-size: 1.1rem;
      font-weight: 700;
      text-shadow: 0 0 8px var(--glow-cyan);
    }

    .hero-data-item .separator {
      color: rgba(0, 240, 255, 0.2);
      font-size: 1.2rem;
    }

    /* CTA button */
    .cta {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-family: var(--font-display);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--primary);
      padding: 1rem 2.5rem;
      border: 1px solid var(--primary);
      background: transparent;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      transition: all 0.4s;
      cursor: pointer;
      box-shadow: 0 0 15px rgba(0, 240, 255, 0.15), inset 0 0 15px rgba(0, 240, 255, 0.05);
    }

    .cta::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(0, 240, 255, 0.1), transparent);
      transform: translateX(-100%);
      transition: transform 0.6s;
    }

    .cta:hover {
      background: rgba(0, 240, 255, 0.08);
      box-shadow: 0 0 30px rgba(0, 240, 255, 0.3), inset 0 0 30px rgba(0, 240, 255, 0.08);
    }

    .cta:hover::before {
      transform: translateX(100%);
    }

    .cta .arrow {
      transition: transform 0.3s;
    }

    .cta:hover .arrow {
      transform: translateX(4px);
    }

    /* ═══════════════════════════════════════════
       SECTION SHARED
    ═══════════════════════════════════════════ */
    section {
      position: relative;
      padding: 6rem 2rem;
    }

    .section-inner {
      max-width: 1100px;
      margin: 0 auto;
    }

    .section-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .section-label::before {
      content: "";
      display: block;
      width: 24px;
      height: 1px;
      background: var(--accent);
    }

    .section-title {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 1rem;
      color: var(--text);
    }

    .section-title span {
      color: var(--primary);
      text-shadow: 0 0 20px var(--glow-cyan);
    }

    .section-desc {
      font-size: 1.05rem;
      line-height: 1.7;
      color: var(--text-muted);
      max-width: 600px;
      margin-bottom: 3rem;
    }

    /* ═══════════════════════════════════════════
       SECTION 2 — LADESTATIONEN
    ═══════════════════════════════════════════ */
    .stations {
      background: linear-gradient(180deg, var(--bg) 0%, #080C14 100%);
    }

    .stations-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .station-card {
      background: var(--bg-card);
      border: 1px solid rgba(0, 240, 255, 0.08);
      padding: 2rem 1.75rem;
      position: relative;
      overflow: hidden;
      transition: border-color 0.4s, box-shadow 0.4s;
    }

    /* Holographic border effect */
    .station-card::before {
      content: "";
      position: absolute;
      inset: -1px;
      z-index: -1;
      background: linear-gradient(
        var(--holo-angle, 135deg),
        var(--primary),
        var(--accent),
        var(--primary),
        var(--accent)
      );
      background-size: 300% 300%;
      animation: holoShift 6s ease-in-out infinite;
      opacity: 0;
      transition: opacity 0.4s;
    }

    .station-card::after {
      content: "";
      position: absolute;
      inset: 1px;
      background: var(--bg-card);
      z-index: -1;
    }

    .station-card:hover::before {
      opacity: 1;
    }

    .station-card:hover {
      box-shadow: 0 0 30px rgba(0, 240, 255, 0.08);
    }

    @keyframes holoShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .station-card:nth-child(2)::before { --holo-angle: 180deg; animation-delay: -2s; }
    .station-card:nth-child(3)::before { --holo-angle: 225deg; animation-delay: -4s; }

    .station-badge {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--primary);
      padding: 0.25rem 0.75rem;
      display: inline-block;
      margin-bottom: 1.25rem;
    }

    .station-name {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.3rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text);
      margin-bottom: 0.5rem;
    }

    .station-type {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--primary);
      margin-bottom: 1.25rem;
      text-shadow: 0 0 8px var(--glow-cyan);
    }

    .station-specs {
      list-style: none;
      margin-bottom: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .station-specs li {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .station-specs li::before {
      content: ">";
      color: var(--primary);
      font-size: 0.7rem;
    }

    .station-line {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, var(--primary), transparent);
      margin-bottom: 1.25rem;
      opacity: 0.3;
    }

    .station-price {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.5rem;
      color: var(--text);
      letter-spacing: 0.03em;
    }

    .station-price .unit {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 400;
      color: var(--text-muted);
      margin-left: 0.25rem;
    }

    .station-price .note {
      display: block;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 400;
      color: var(--text-muted);
      margin-top: 0.25rem;
    }

    /* ═══════════════════════════════════════════
       SECTION 3 — VISION
    ═══════════════════════════════════════════ */
    .vision {
      border-top: 1px solid rgba(0, 240, 255, 0.06);
    }

    .vision-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }

    .vision-manifesto {
      font-size: 1.1rem;
      line-height: 1.8;
      color: var(--text-muted);
    }

    .vision-manifesto strong {
      color: var(--text);
      font-weight: 600;
    }

    .vision-manifesto .highlight {
      color: var(--primary);
      text-shadow: 0 0 8px var(--glow-cyan);
    }

    .vision-quote {
      font-family: var(--font-display);
      font-size: 1.4rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--text);
      line-height: 1.4;
      margin: 2rem 0;
      padding-left: 1.5rem;
      border-left: 2px solid var(--primary);
      text-transform: uppercase;
    }

    /* Counter stats */
    .vision-counters {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .counter-item {
      background: var(--bg-card);
      border: 1px solid rgba(0, 240, 255, 0.06);
      padding: 1.5rem;
      position: relative;
    }

    .counter-item::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 3px;
      height: 100%;
      background: linear-gradient(180deg, var(--primary), var(--accent));
      box-shadow: 0 0 8px var(--glow-cyan);
    }

    .counter-value {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 2rem;
      color: var(--primary);
      text-shadow: 0 0 20px var(--glow-cyan);
      letter-spacing: 0.03em;
      margin-bottom: 0.25rem;
    }

    .counter-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    /* Founder */
    .founder {
      background: var(--bg-card);
      border: 1px solid rgba(0, 240, 255, 0.06);
      padding: 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .founder-avatar {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      border: 2px solid var(--primary);
      background: linear-gradient(135deg, rgba(0, 240, 255, 0.1), rgba(179, 71, 234, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      box-shadow: 0 0 15px var(--glow-cyan);
    }

    .founder-avatar svg {
      width: 28px;
      height: 28px;
    }

    .founder-name {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text);
      margin-bottom: 0.2rem;
    }

    .founder-role {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--text-muted);
      letter-spacing: 0.08em;
    }

    /* Contact */
    .vision-contact {
      margin-top: 2rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .vision-contact a {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      color: var(--primary);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      transition: text-shadow 0.3s;
      text-shadow: 0 0 0 transparent;
    }

    .vision-contact a:hover {
      text-shadow: 0 0 12px var(--glow-cyan);
    }

    .vision-contact a svg {
      width: 16px;
      height: 16px;
      opacity: 0.6;
    }

    /* ═══════════════════════════════════════════
       FOOTER
    ═══════════════════════════════════════════ */
    .footer {
      border-top: 1px solid rgba(0, 240, 255, 0.06);
      padding: 2.5rem 2rem;
      text-align: center;
    }

    .footer-text {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      color: var(--text-muted);
    }

    .footer-text span {
      color: var(--primary);
    }

    /* ═══════════════════════════════════════════
       MOBILE NAV
    ═══════════════════════════════════════════ */
    .mobile-menu {
      display: none;
      position: fixed;
      top: 64px;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(10, 14, 23, 0.97);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      z-index: 98;
      padding: 2rem;
      flex-direction: column;
      gap: 0.5rem;
    }

    .mobile-menu.active {
      display: flex;
    }

    .mobile-menu a {
      font-family: var(--font-mono);
      font-size: 0.9rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      text-decoration: none;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(0, 240, 255, 0.06);
      transition: color 0.3s;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .mobile-menu a::before {
      content: "//";
      color: rgba(0, 240, 255, 0.3);
    }

    .mobile-menu a:hover {
      color: var(--primary);
    }

    /* ═══════════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════════ */
    @media (max-width: 900px) {
      .stations-grid {
        grid-template-columns: 1fr;
        max-width: 480px;
        margin-left: auto;
        margin-right: auto;
      }

      .vision-content {
        grid-template-columns: 1fr;
        gap: 3rem;
      }
    }

    @media (max-width: 700px) {
      .nav-links { display: none; }
      .nav-hamburger { display: flex; }

      .hero { padding: 5rem 1.25rem 3rem; }

      .hero-ring {
        width: 120px;
        height: 120px;
        margin-bottom: 2rem;
      }

      .hero-ring svg { width: 40px; height: 40px; }

      .hero-headline { margin-bottom: 2rem; }

      .hero-data { gap: 1rem; }

      .hero-data-item {
        font-size: 0.7rem;
        flex-direction: column;
        gap: 0.2rem;
      }

      .hero-data-item .separator { display: none; }

      section { padding: 4rem 1.25rem; }

      .section-title { font-size: 1.5rem; }

      .founder { flex-direction: column; text-align: center; }

      .vision-quote { font-size: 1.1rem; }

      .counter-value { font-size: 1.5rem; }
    }
  </style>
</head>
<body>

  <!-- Scan-line overlay -->
  <div class="scanlines" aria-hidden="true"></div>

  <!-- NAV -->
  <nav class="nav">
    <a href="/#hero" class="nav-logo">Neo<span>volt</span></a>
    <ul class="nav-links">
      <li><a href="/#hero">Start</a></li>
      <li><a href="/#stationen">Stationen</a></li>
      <li><a href="/#vision">Vision</a></li>
    </ul>
    <button class="nav-hamburger" aria-label="Menu" onclick="document.querySelector('.mobile-menu').classList.toggle('active')">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu">
    <a href="/#hero" onclick="document.querySelector('.mobile-menu').classList.remove('active')">Start</a>
