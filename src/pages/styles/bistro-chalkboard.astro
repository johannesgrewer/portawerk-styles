---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Le Tableau — Bistro Français | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400;1,500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --board:      #161E15;
      --board-2:    #1A2419;
      --board-3:    #1F2B1E;
      --chalk:      #EAE5D4;
      --chalk-dim:  rgba(234,229,212,0.55);
      --chalk-faint:rgba(234,229,212,0.15);
      --chalk-ghost:rgba(234,229,212,0.07);
      --amber:      #D8A84A;
      --amber-glow: rgba(216,168,74,0.12);
      --rose:       #C06850;
    }

    body {
      background: var(--board);
      color: var(--chalk);
      font-family: 'Cormorant Garamond', Georgia, serif;
      overflow-x: hidden;
    }

    /* Horizontal chalk ruling lines */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: repeating-linear-gradient(
        180deg,
        transparent,
        transparent 27px,
        rgba(234,229,212,0.025) 27px,
        rgba(234,229,212,0.025) 28px
      );
      pointer-events: none;
      z-index: 1;
    }

    /* SVG grain overlay */
    .grain {
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.78' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)' opacity='0.12'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 220px 220px;
      pointer-events: none;
      z-index: 999;
      mix-blend-mode: overlay;
      opacity: 0.5;
    }

    /* Scroll reveal */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.85s ease, transform 0.85s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 500;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.2rem 3.5rem;
      border-bottom: 1px solid var(--chalk-faint);
      background: rgba(22,30,21,0.88);
      backdrop-filter: blur(10px);
    }
    .nav-logo {
      font-family: 'Caveat', cursive;
      font-size: 1.7rem;
      font-weight: 700;
      color: var(--chalk);
      letter-spacing: 0.01em;
    }
    .nav-logo em { color: var(--amber); font-style: normal; }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.68rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--chalk-dim);
      text-decoration: none;
      position: relative;
      transition: color 0.3s;
    }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -3px; left: 0; right: 0;
      height: 1px;
      background: var(--amber);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s ease;
    }
    .nav-links a:hover { color: var(--chalk); }
    .nav-links a:hover::after { transform: scaleX(1); }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1fr 420px;
      padding-top: 64px;
      max-width: 1600px;
      margin: 0 auto;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 5rem 4rem 5rem 5rem;
      gap: 2.5rem;
      border-right: 1px solid var(--chalk-faint);
    }

    .hero-eyebrow {
      display: flex;
      align-items: center;
      gap: 1rem;
      animation: fadeUp 0.8s ease 0.2s both;
    }
    .eyebrow-line { width: 2.5rem; height: 1px; background: var(--amber); opacity: 0.6; }
    .eyebrow-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.65rem;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--amber);
      opacity: 0.85;
    }

    .hero-headline {
      font-family: 'Caveat', cursive;
      font-weight: 700;
      font-size: clamp(4.2rem, 9vw, 9rem);
      line-height: 0.95;
      color: var(--chalk);
      text-shadow: 0 0 80px rgba(234,229,212,0.06);
      animation: fadeUp 0.9s ease 0.4s both;
    }
    .hero-headline .accent { color: var(--amber); }
    .chalk-u {
      display: inline-block;
      position: relative;
    }
    .chalk-u::after {
      content: '';
      position: absolute;
      bottom: 2px; left: -2%; right: -2%;
      height: 4px;
      background: var(--rose);
      opacity: 0.6;
      border-radius: 3px;
      transform: rotate(-1.2deg);
    }

    .hero-tagline {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem;
      font-weight: 300;
      font-style: italic;
      line-height: 1.85;
      color: var(--chalk-dim);
      max-width: 38ch;
      animation: fadeUp 0.8s ease 0.6s both;
    }

    /* Tagesmenü card */
    .menu-card {
      position: relative;
      border: 1px dashed rgba(234,229,212,0.22);
      padding: 1.75rem 2rem;
      max-width: 420px;
      animation: fadeUp 0.8s ease 0.75s both;
    }
    .menu-card::before {
      content: '';
      position: absolute;
      inset: 5px;
      border: 1px solid rgba(234,229,212,0.05);
      pointer-events: none;
    }
    .menu-card-label {
      position: absolute;
      top: -0.7rem; left: 1.5rem;
      background: var(--board);
      padding: 0 0.6rem;
      font-family: 'Caveat', cursive;
      font-size: 1rem;
      font-weight: 600;
      color: var(--amber);
    }
    .menu-card-date {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.62rem;
      font-weight: 300;
      font-style: italic;
      letter-spacing: 0.12em;
      color: var(--chalk-dim);
      margin-bottom: 1.1rem;
      padding-top: 0.2rem;
    }
    .menu-rows { display: flex; flex-direction: column; gap: 0.7rem; }
    .menu-row { display: flex; align-items: center; gap: 0; }
    .menu-row-info { flex-shrink: 0; }
    .menu-item-name {
      font-family: 'Caveat', cursive;
      font-size: 1rem;
      font-weight: 600;
      color: var(--chalk);
    }
    .menu-item-note {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.66rem;
      font-style: italic;
      color: var(--chalk-dim);
      margin-left: 0.4rem;
    }
    .menu-dots {
      flex: 1;
      border-bottom: 1px dotted rgba(234,229,212,0.18);
      margin: 0 0.6rem;
      position: relative;
      top: -2px;
      min-width: 1rem;
    }
    .menu-price {
      font-family: 'Caveat', cursive;
      font-size: 1rem;
      font-weight: 700;
      color: var(--amber);
      flex-shrink: 0;
    }

    .hero-cta {
      display: flex;
      align-items: center;
      gap: 2rem;
      animation: fadeUp 0.8s ease 0.9s both;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      background: transparent;
      border: 1px solid rgba(216,168,74,0.55);
      color: var(--chalk);
      text-decoration: none;
      font-family: 'Caveat', cursive;
      font-size: 1.1rem;
      font-weight: 700;
      padding: 0.7rem 2rem;
      letter-spacing: 0.03em;
      position: relative;
      overflow: hidden;
      transition: color 0.3s;
    }
    .btn-primary::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--amber);
      transform: translateX(-101%);
      transition: transform 0.32s ease;
    }
    .btn-primary:hover::before { transform: translateX(0); }
    .btn-primary:hover { color: var(--board); }
    .btn-primary span { position: relative; z-index: 1; }
    .btn-link {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.68rem;
      font-weight: 300;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--chalk-dim);
      text-decoration: none;
      transition: color 0.3s;
    }
    .btn-link:hover { color: var(--chalk); }

    /* Hero photos column */
    .hero-photos {
      display: flex;
      flex-direction: column;
      padding: 2rem 2rem 2rem 1.5rem;
      gap: 0.75rem;
    }
    .hero-photo-main {
      flex: 1;
      position: relative;
      overflow: hidden;
      min-height: 280px;
    }
    .hero-photo-main img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }
    .hero-photo-main:hover img { transform: scale(1.04); }
    .hero-photo-main::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent 45%, rgba(22,30,21,0.55) 100%);
      pointer-events: none;
    }
    .photo-tag {
      position: absolute;
      bottom: 1rem; left: 1rem;
      z-index: 5;
      background: rgba(22,30,21,0.82);
      border: 1px solid var(--chalk-faint);
      padding: 0.35rem 0.7rem;
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--chalk-dim);
    }
    .hero-photo-small {
      height: 170px;
      position: relative;
      overflow: hidden;
    }
    .hero-photo-small img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }
    .hero-photo-small:hover img { transform: scale(1.05); }

    /* ─── SECTION: LA CARTE ─── */
    .la-carte {
      position: relative;
      z-index: 2;
      background: var(--board-2);
      padding: 6rem 5rem;
      border-top: 1px solid var(--chalk-faint);
    }
    .la-carte-inner { max-width: 1200px; margin: 0 auto; }

    .section-header {
      text-align: center;
      margin-bottom: 4rem;
    }
    .section-label {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.62rem;
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 0.75rem;
    }
    .section-title {
      font-family: 'Caveat', cursive;
      font-size: clamp(2.8rem, 5vw, 4.5rem);
      font-weight: 700;
      color: var(--chalk);
      line-height: 1;
    }
    .section-divider {
      display: flex;
      align-items: center;
      gap: 1rem;
      justify-content: center;
      margin-top: 1.25rem;
    }
    .div-line { width: 3rem; height: 1px; background: rgba(234,229,212,0.18); }
    .div-orn {
      font-family: 'Caveat', cursive;
      font-size: 1.1rem;
      color: var(--amber);
      opacity: 0.65;
    }

    /* Menu two-column layout */
    .menu-cols {
      display: grid;
      grid-template-columns: 1fr 1px 1fr;
      gap: 0 3.5rem;
    }
    .col-divider { background: var(--chalk-faint); }

    .menu-cat { margin-bottom: 2.75rem; }
    .cat-title {
      font-family: 'Caveat', cursive;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--chalk);
      display: inline-block;
      position: relative;
      margin-bottom: 0.2rem;
    }
    .cat-title::after {
      content: '';
      display: block;
      width: 100%;
      height: 2px;
      background: var(--amber);
      opacity: 0.38;
      margin-top: 0.2rem;
      border-radius: 2px;
    }
    .cat-sub {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.62rem;
      font-weight: 300;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--chalk-dim);
      margin-bottom: 1.25rem;
    }

    .dish {
      display: flex;
      align-items: flex-start;
      gap: 0;
      margin-bottom: 1.15rem;
    }
    .dish-info { flex: 1; min-width: 0; }
    .dish-name {
      font-family: 'Caveat', cursive;
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--chalk);
      line-height: 1.2;
    }
    .dish-desc {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.7rem;
      font-weight: 300;
      font-style: italic;
      color: var(--chalk-dim);
      margin-top: 0.12rem;
      line-height: 1.45;
    }
    .dish-dots {
      flex: 0 0 auto;
      width: 1.5rem;
      border-bottom: 1px dotted rgba(234,229,212,0.14);
      position: relative;
      top: 0.55rem;
      margin: 0 0.5rem;
    }
    .dish-price {
      font-family: 'Caveat', cursive;
      font-size: 1rem;
      font-weight: 700;
      color: var(--amber);
      white-space: nowrap;
      flex-shrink: 0;
    }

    .vin-note {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.78rem;
      font-style: italic;
      color: var(--chalk-dim);
      line-height: 1.75;
      margin-top: 1.25rem;
      padding-top: 1.25rem;
      border-top: 1px dashed var(--chalk-faint);
      max-width: 38ch;
    }

    /* ─── SECTION: ATMOSPHÈRE ─── */
    .atmosphere { position: relative; z-index: 2; }
    .atmo-grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      grid-template-rows: 400px 280px;
      gap: 3px;
    }
    .atmo-big {
      grid-row: 1 / 3;
      position: relative;
      overflow: hidden;
    }
    .atmo-big img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }
    .atmo-big:hover img { transform: scale(1.04); }
    .atmo-big-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(22,30,21,0.9) 0%, rgba(22,30,21,0.3) 45%, transparent 100%);
    }
    .atmo-big-text {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 3rem;
      z-index: 2;
    }
    .atmo-quote {
      font-family: 'Caveat', cursive;
      font-size: clamp(1.6rem, 2.8vw, 2.4rem);
      font-weight: 700;
      color: var(--chalk);
      line-height: 1.3;
      margin-bottom: 0.75rem;
    }
    .atmo-body {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.82rem;
      font-weight: 300;
      font-style: italic;
      line-height: 1.8;
      color: rgba(234,229,212,0.65);
      max-width: 40ch;
    }
    .atmo-small {
      position: relative;
      overflow: hidden;
    }
    .atmo-small img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }
    .atmo-small:hover img { transform: scale(1.06); }

    /* ─── SECTION: RÉSERVATION ─── */
    .reservation {
      position: relative;
      z-index: 2;
      padding: 6rem 5rem;
      background: var(--board-3);
      border-top: 1px solid var(--chalk-faint);
    }
    .reservation-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }

    .res-left { display: flex; flex-direction: column; gap: 2.5rem; }
    .res-intro {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.92rem;
      font-weight: 300;
      font-style: italic;
      line-height: 1.85;
      color: var(--chalk-dim);
      max-width: 40ch;
    }

    .hours-block {
      border-top: 1px dashed var(--chalk-faint);
      padding-top: 1.75rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }
    .hour-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .hour-day {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.8rem;
      font-weight: 300;
      font-style: italic;
      color: var(--chalk-dim);
    }
    .hour-time {
      font-family: 'Caveat', cursive;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--chalk);
    }
    .hour-closed {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.72rem;
      font-style: italic;
      color: rgba(234,229,212,0.25);
    }

    .res-box {
      position: relative;
      border: 1px dashed rgba(234,229,212,0.22);
      padding: 2.5rem;
    }
    .res-box::before {
      content: '';
      position: absolute;
      inset: 6px;
      border: 1px solid rgba(234,229,212,0.05);
      pointer-events: none;
    }
    .res-box-title {
      font-family: 'Caveat', cursive;
      font-size: 1.9rem;
      font-weight: 700;
      color: var(--chalk);
      margin-bottom: 0.4rem;
    }
    .res-box-note {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.8rem;
      font-weight: 300;
      font-style: italic;
      color: var(--chalk-dim);
      line-height: 1.75;
      margin-bottom: 2rem;
    }
    .res-contacts {
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
      margin-bottom: 2rem;
    }
    .res-contact-row {
      display: flex;
      align-items: center;
      gap: 0.8rem;
    }
    .res-icon {
      font-family: 'Caveat', cursive;
      font-size: 1.1rem;
      color: var(--amber);
      width: 1.25rem;
      text-align: center;
      flex-shrink: 0;
    }
    .res-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.85rem;
      font-weight: 300;
      color: var(--chalk);
    }
    .res-text em {
      font-style: normal;
      font-weight: 400;
    }
    .btn-reserve {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      background: var(--amber);
      color: var(--board);
      text-decoration: none;
      font-family: 'Caveat', cursive;
      font-size: 1.2rem;
      font-weight: 700;
      padding: 0.9rem 2rem;
      letter-spacing: 0.02em;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-reserve:hover { background: #e8b84f; transform: translateY(-2px); }

    /* ─── FOOTER ─── */
    footer {
      position: relative;
      z-index: 2;
      padding: 2rem 3.5rem;
      border-top: 1px solid var(--chalk-faint);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .footer-logo {
      font-family: 'Caveat', cursive;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--chalk-dim);
    }
    .footer-copy {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.1em;
      color: rgba(234,229,212,0.22);
    }

    /* ─── KEYFRAMES ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(26px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 1100px) {
      nav { padding: 1.2rem 2rem; }
      .hero { grid-template-columns: 1fr; }
      .hero-photos { display: none; }
      .hero-content { padding: 4.5rem 2.5rem; border-right: none; }
      .la-carte { padding: 5rem 2.5rem; }
      .menu-cols { grid-template-columns: 1fr; }
      .col-divider { display: none; }
      .atmo-grid { grid-template-columns: 1fr; grid-template-rows: 420px 260px 260px; }
      .atmo-big { grid-row: auto; }
      .reservation { padding: 5rem 2.5rem; }
      .reservation-inner { grid-template-columns: 1fr; gap: 3rem; }
      footer { padding: 1.5rem 2.5rem; flex-direction: column; gap: 1rem; text-align: center; }
    }
    @media (max-width: 640px) {
      .hero-headline { font-size: 4rem; }
      .la-carte { padding: 4rem 1.5rem; }
      .reservation { padding: 4rem 1.5rem; }
      .res-box { padding: 1.75rem; }
      .atmo-grid { grid-template-rows: 360px 220px 220px; }
    }
  </style>
</head>
<body>
  <div class="grain"></div>

  <!-- ── NAV ── -->
  <nav>
    <div class="nav-logo">Le <em>Tableau</em></div>
    <ul class="nav-links">
      <li><a href="#carte">La Carte</a></li>
      <li><a href="#atmosphere">L'Atmosphère</a></li>
      <li><a href="#reservation">Réservation</a></li>
    </ul>
  </nav>

  <!-- ── HERO ── -->
  <section class="hero">
