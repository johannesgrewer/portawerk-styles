---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Druckluft — Siebdruck mit Haltung</title>
  <meta name="description" content="Druckluft ist eine Siebdruck-Werkstatt in Trier-Nord. Textildruck, Poster, Workshops. Seit 2020." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: #F5F5F0;
      color: #1A1A1A;
      line-height: 1.5;
      overflow-x: hidden;
    }

    img {
      max-width: 100%;
      display: block;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    /* ===== NAV ===== */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 2rem;
      background: rgba(26, 26, 26, 0.95);
      backdrop-filter: blur(8px);
    }

    .nav-logo {
      font-size: 1.5rem;
      font-weight: 700;
      color: #FF3D00;
      text-transform: uppercase;
      letter-spacing: 0.15em;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      color: #F5F5F0;
      font-weight: 600;
      font-size: 0.875rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: #FFD600;
    }

    .nav-burger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }

    .nav-burger span {
      display: block;
      width: 28px;
      height: 3px;
      background: #F5F5F0;
      transition: transform 0.3s, opacity 0.3s;
    }

    /* ===== HERO ===== */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(26, 26, 26, 0.92) 0%, rgba(26, 26, 26, 0.6) 100%);
    }

    .hero-geometric {
      position: absolute;
      z-index: 1;
    }

    .hero-geometric--1 {
      top: -80px;
      right: -60px;
      width: 400px;
      height: 400px;
      border: 8px solid #FF3D00;
      transform: rotate(15deg);
      opacity: 0.4;
    }

    .hero-geometric--2 {
      bottom: 60px;
      left: -40px;
      width: 200px;
      height: 200px;
      background: #FFD600;
      transform: rotate(-12deg);
      opacity: 0.15;
    }

    .hero-geometric--3 {
      top: 30%;
      right: 10%;
      width: 120px;
      height: 120px;
      border: 6px solid #FFD600;
      border-radius: 50%;
      opacity: 0.3;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      padding: 8rem 2rem 4rem;
      max-width: 900px;
      margin-left: 6%;
    }

    .hero-tagline {
      display: inline-block;
      font-size: 0.875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.25em;
      color: #FFD600;
      margin-bottom: 1.5rem;
      padding: 0.5rem 1rem;
      border: 2px solid #FFD600;
    }

    .hero-headline {
      font-size: clamp(3.5rem, 10vw, 8rem);
      font-weight: 700;
      line-height: 0.95;
      color: #F5F5F0;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }

    .hero-headline span {
      color: #FF3D00;
    }

    .hero-subtitle {
      font-size: clamp(1.1rem, 2vw, 1.5rem);
      color: rgba(245, 245, 240, 0.75);
      max-width: 520px;
      margin-bottom: 2.5rem;
      line-height: 1.6;
    }

    .btn-primary {
      display: inline-block;
      padding: 1.1rem 2.5rem;
      background: #FF3D00;
      color: #F5F5F0;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border: none;
      cursor: pointer;
      transition: background 0.2s, transform 0.2s;
    }

    .btn-primary:hover {
      background: #e03500;
      transform: translateY(-2px);
    }

    .hero-skew-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 80px;
      background: #F5F5F0;
      transform: skewY(-2deg);
      transform-origin: bottom left;
      z-index: 3;
    }

    /* ===== SERVICES ===== */
    .services {
      padding: 6rem 2rem 8rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      color: #FF3D00;
      margin-bottom: 1rem;
    }

    .section-headline {
      font-size: clamp(2.2rem, 5vw, 3.5rem);
      font-weight: 700;
      text-transform: uppercase;
      line-height: 1.05;
      margin-bottom: 4rem;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .service-card {
      position: relative;
      background: #1A1A1A;
      color: #F5F5F0;
      padding: 2.5rem 2rem;
      border: 3px solid #1A1A1A;
      transition: border-color 0.3s, transform 0.3s;
    }

    .service-card:hover {
      border-color: #FF3D00;
      transform: translateY(-4px);
    }

    .service-card:nth-child(2) {
      background: #FF3D00;
      border-color: #FF3D00;
    }

    .service-card:nth-child(2):hover {
      border-color: #FFD600;
    }

    .service-number {
      font-size: 4rem;
      font-weight: 700;
      line-height: 1;
      color: rgba(245, 245, 240, 0.15);
      margin-bottom: 1.5rem;
    }

    .service-card:nth-child(2) .service-number {
      color: rgba(26, 26, 26, 0.2);
    }

    .service-title {
      font-size: 1.5rem;
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 1rem;
      letter-spacing: 0.05em;
    }

    .service-desc {
      font-size: 0.95rem;
      line-height: 1.7;
      color: rgba(245, 245, 240, 0.7);
      margin-bottom: 2rem;
    }

    .service-card:nth-child(2) .service-desc {
      color: rgba(245, 245, 240, 0.85);
    }

    .service-price {
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      padding-top: 1.5rem;
      border-top: 2px solid rgba(245, 245, 240, 0.15);
    }

    .service-card:nth-child(2) .service-price {
      border-top-color: rgba(26, 26, 26, 0.2);
    }

    .service-price em {
      font-style: normal;
      color: #FFD600;
    }

    .service-card:nth-child(2) .service-price em {
      color: #1A1A1A;
    }

    /* ===== CONTACT ===== */
    .contact {
      background: #1A1A1A;
      color: #F5F5F0;
      padding: 6rem 2rem 4rem;
      position: relative;
    }

    .contact-skew-top {
      position: absolute;
      top: -40px;
      left: 0;
      right: 0;
      height: 80px;
      background: #1A1A1A;
      transform: skewY(2deg);
      z-index: 1;
    }

    .contact-inner {
      position: relative;
      z-index: 2;
      max-width: 1200px;
      margin: 0 auto;
    }

    .contact-manifesto {
      font-size: clamp(1.5rem, 3.5vw, 2.5rem);
      font-weight: 700;
      text-transform: uppercase;
      line-height: 1.2;
      margin-bottom: 4rem;
      max-width: 700px;
      border-left: 6px solid #FF3D00;
      padding-left: 1.5rem;
    }

    .contact-manifesto span {
      color: #FF3D00;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .form-group label {
      display: block;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: rgba(245, 245, 240, 0.5);
      margin-bottom: 0.5rem;
    }

    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 1rem;
      background: rgba(245, 245, 240, 0.08);
      border: 2px solid rgba(245, 245, 240, 0.12);
      color: #F5F5F0;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1rem;
      transition: border-color 0.2s;
      outline: none;
    }

    .form-group input:focus,
    .form-group textarea:focus {
      border-color: #FF3D00;
    }

    .form-group textarea {
      min-height: 140px;
      resize: vertical;
    }

    .contact-info {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .contact-block h3 {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #FFD600;
      margin-bottom: 0.75rem;
    }

    .contact-block p,
    .contact-block a {
      font-size: 1rem;
      line-height: 1.8;
      color: rgba(245, 245, 240, 0.7);
    }

    .contact-block a:hover {
      color: #FF3D00;
    }

    .hours-table {
      width: 100%;
      border-collapse: collapse;
    }

    .hours-table td {
      padding: 0.4rem 0;
      font-size: 0.95rem;
      color: rgba(245, 245, 240, 0.7);
      border-bottom: 1px solid rgba(245, 245, 240, 0.06);
    }

    .hours-table td:last-child {
      text-align: right;
      font-weight: 600;
      color: #F5F5F0;
    }

    /* ===== FOOTER ===== */
    .footer {
      background: #111;
      padding: 2rem;
      text-align: center;
    }

    .footer p {
      font-size: 0.8rem;
      color: rgba(245, 245, 240, 0.3);
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .footer span {
      color: #FF3D00;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 900px) {
      .services-grid {
        grid-template-columns: 1fr;
        max-width: 500px;
      }

      .contact-grid {
        grid-template-columns: 1fr;
        gap: 3rem;
      }
    }

    @media (max-width: 768px) {
      .nav-links {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: rgba(26, 26, 26, 0.98);
        flex-direction: column;
        padding: 1.5rem 2rem;
        gap: 1.25rem;
      }

      .nav-links.open {
        display: flex;
      }

      .nav-burger {
        display: flex;
      }

      .hero-content {
        margin-left: 0;
        padding: 7rem 1.5rem 4rem;
      }

      .hero-geometric--1 {
        width: 250px;
        height: 250px;
        top: -50px;
        right: -50px;
      }

      .hero-geometric--3 {
        display: none;
      }

      .services {
        padding: 4rem 1.5rem 5rem;
      }

      .contact {
        padding: 5rem 1.5rem 3rem;
      }
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav class="nav">
    <a href="#" class="nav-logo">Druckluft</a>
    <ul class="nav-links" id="navLinks">
      <li><a href="#leistungen">Leistungen</a></li>
      <li><a href="#kontakt">Kontakt</a></li>
    </ul>
    <button class="nav-burger" id="navBurger" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1565793298595-6a879b1d9492?w=1920&q=80&auto=format"
        alt="Siebdruck-Werkstatt mit Farbsieben"
        loading="eager"
      />
    </div>
    <div class="hero-geometric hero-geometric--1"></div>
    <div class="hero-geometric hero-geometric--2"></div>
    <div class="hero-geometric hero-geometric--3"></div>
    <div class="hero-content">
      <div class="hero-tagline">Siebdruck-Werkstatt / Trier-Nord</div>
      <h1 class="hero-headline">
        Druck.<br />
        Farbe.<br />
        <span>Haltung.</span>
      </h1>
      <p class="hero-subtitle">
        Wir drucken, was andere nicht trauen. Handgemachter Siebdruck
        fuer Leute mit Meinung. Seit 2020.
      </p>
      <a href="#kontakt" class="btn-primary">Projekt anfragen</a>
    </div>
    <div class="hero-skew-bar"></div>
  </section>

  <!-- SERVICES -->
  <section class="services" id="leistungen">
    <p class="section-label">Was wir machen</p>
    <h2 class="section-headline">
      Drei Wege,<br />deine Idee auf<br />Material zu bringen.
    </h2>
    <div class="services-grid">

      <div class="service-card">
        <div class="service-number">01</div>
        <h3 class="service-title">Textildruck</h3>
        <p class="service-desc">
          T-Shirts, Hoodies, Beutel. Vom Einzelstueck bis zur Kleinserie.
          Hochwertige Farben, die auch nach 50 Waeschen noch halten.
        </p>
        <p class="service-price">Ab <em>18 EUR</em> / Stueck</p>
      </div>

      <div class="service-card">
        <div class="service-number">02</div>
        <h3 class="service-title">Poster & Prints</h3>
        <p class="service-desc">
          Kunstdrucke, Plakate, limitierte Editionen. Handgezogen
          auf schwerem Papier. Jeder Druck ein Original.
        </p>
        <p class="service-price">Ab <em>35 EUR</em> / Druck</p>
      </div>

      <div class="service-card">
        <div class="service-number">03</div>
        <h3 class="service-title">Workshops</h3>
        <p class="service-desc">
          Siebdruck lernen in der Werkstatt. 4 Stunden, eigenes Motiv,
          alles inklusive. Fuer Anfaenger und Fortgeschrittene.
        </p>
        <p class="service-price">Ab <em>89 EUR</em> / Person</p>
      </div>

    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact" id="kontakt">
    <div class="contact-skew-top"></div>
    <div class="contact-inner">
      <p class="contact-manifesto">
        Kein Massenprodukt. Kein Algorithmus.<br />
        Nur <span>Farbe, Rakel und Haltung.</span>
      </p>
      <div class="contact-grid">

        <form class="contact-form" onsubmit="event.preventDefault()">
          <div class="form-group">
            <label for="contactName">Name</label>
            <input type="text" id="contactName" placeholder="Dein Name" required />
          </div>
          <div class="form-group">
            <label for="contactEmail">E-Mail</label>
            <input type="email" id="contactEmail" placeholder="name@beispiel.de" required />
          </div>
          <div class="form-group">
            <label for="contactMessage">Nachricht</label>
            <textarea id="contactMessage" placeholder="Was hast du vor?"></textarea>
          </div>
          <button type="submit" class="btn-primary">Abschicken</button>
        </form>

        <div class="contact-info">
          <div class="contact-block">
            <h3>Adresse</h3>
            <p>
              Druckluft Siebdruck-Werkstatt<br />
              Domfreihof 1a<br />
              54290 Trier
            </p>
          </div>
          <div class="contact-block">
            <h3>Kontakt</h3>
            <p>
              <a href="tel:+4906517105590">0651 — 710 55 90</a><br />
              <a href="mailto:hallo@druckluft-trier.de">hallo@druckluft-trier.de</a>
            </p>
          </div>
          <div class="contact-block">
            <h3>Oeffnungszeiten</h3>
            <table class="hours-table">
              <tr><td>Montag — Freitag</td><td>10 — 18 Uhr</td></tr>
              <tr><td>Samstag</td><td>11 — 15 Uhr</td></tr>
              <tr><td>Sonntag</td><td>Geschlossen</td></tr>
            </table>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <p>&copy; 2020 — 2026 <span>Druckluft</span>. Siebdruck mit Haltung.</p>
  </footer>

  <script>
    const burger = document.getElementById('navBurger');
    const navLinks = document.getElementById('navLinks');
    burger.addEventListener('click', () => {
      navLinks.classList.toggle('open');
    });
    // Close menu on link click
    navLinks.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('open');
      });
    });
  </script>

</body>
</html>
