---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Druckluft — Siebdruck mit Haltung | Trier-Nord</title>
  <meta name="description" content="Druckluft ist eine Siebdruck-Werkstatt in Trier-Nord. Handgemachter Textildruck, Poster, Branding. Seit 2020." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: #F5F5F0;
      color: #1A1A1A;
      line-height: 1.5;
      overflow-x: hidden;
    }

    img {
      max-width: 100%;
      display: block;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    /* ===== NAV ===== */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2rem;
      background: #1A1A1A;
      border-bottom: 4px solid #FF3D00;
    }

    .nav-logo {
      font-size: 1.6rem;
      font-weight: 700;
      color: #F5F5F0;
      text-transform: uppercase;
      letter-spacing: 0.2em;
    }

    .nav-logo span {
      color: #FF3D00;
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      color: #F5F5F0;
      font-weight: 700;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      transition: color 0.2s;
      position: relative;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 3px;
      background: #FF3D00;
      transition: width 0.3s;
    }

    .nav-links a:hover::after {
      width: 100%;
    }

    .nav-links a:hover {
      color: #FFD600;
    }

    .nav-burger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }

    .nav-burger span {
      display: block;
      width: 30px;
      height: 3px;
      background: #F5F5F0;
      transition: transform 0.3s, opacity 0.3s;
    }

    /* ===== HERO ===== */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      overflow: hidden;
      background: #F5F5F0;
      /* CSS paper noise texture */
      background-image:
        url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    }

    /* Registration marks — corner crosshairs */
    .hero-reg-mark {
      position: absolute;
      width: 30px;
      height: 30px;
      z-index: 5;
      pointer-events: none;
      opacity: 0.25;
    }

    .hero-reg-mark::before,
    .hero-reg-mark::after {
      content: '';
      position: absolute;
      background: #1A1A1A;
    }

    .hero-reg-mark::before {
      top: 50%;
      left: 0;
      width: 100%;
      height: 1.5px;
      transform: translateY(-50%);
    }

    .hero-reg-mark::after {
      left: 50%;
      top: 0;
      width: 1.5px;
      height: 100%;
      transform: translateX(-50%);
    }

    .hero-reg-mark--tl { top: 5rem; left: 2rem; }
    .hero-reg-mark--tr { top: 5rem; right: 2rem; }
    .hero-reg-mark--bl { bottom: 7rem; left: 2rem; }
    .hero-reg-mark--br { bottom: 7rem; right: 2rem; }

    /* Halftone dot pattern in corner */
    .hero-halftone {
      position: absolute;
      bottom: 10%;
      right: 0;
      width: clamp(150px, 20vw, 300px);
      height: clamp(150px, 20vw, 300px);
      background-image: radial-gradient(circle, #FF3D00 1.5px, transparent 1.5px);
      background-size: 10px 10px;
      opacity: 0.12;
      pointer-events: none;
      z-index: 1;
      mask-image: radial-gradient(ellipse at bottom right, black 0%, transparent 70%);
      -webkit-mask-image: radial-gradient(ellipse at bottom right, black 0%, transparent 70%);
    }

    /* Stripe container behind the text */
    .hero-stripes {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -55%);
      width: 92vw;
      max-width: 1400px;
      height: clamp(9rem, 22vw, 18rem);
      z-index: 1;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .hero-stripe {
      flex: 1;
      transform: translateX(-110%);
      animation: stripeSlideIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .hero-stripe:nth-child(1) { background: #FF3D00; animation-delay: 0.1s; }
    .hero-stripe:nth-child(2) { background: #FFD600; animation-delay: 0.2s; }
    .hero-stripe:nth-child(3) { background: #1A1A1A; animation-delay: 0.3s; }
    .hero-stripe:nth-child(4) { background: #FF3D00; animation-delay: 0.4s; }
    .hero-stripe:nth-child(5) { background: #FFD600; animation-delay: 0.5s; }

    @keyframes stripeSlideIn {
      to { transform: translateX(0); }
    }

    /* Main title — the type IS the hero */
    .hero-title-wrap {
      position: relative;
      z-index: 2;
      text-align: center;
      padding: 0 2rem;
      margin-top: clamp(6rem, 10vh, 10rem);
    }

    .hero-title {
      font-size: clamp(8rem, 20vw, 16rem);
      font-weight: 700;
      line-height: 0.85;
      text-transform: uppercase;
      letter-spacing: -0.04em;
      color: #F5F5F0;
      mix-blend-mode: difference;
      position: relative;
      cursor: default;
      transition: color 0.3s;
      opacity: 0;
      animation: titlePunch 0.4s cubic-bezier(0.22, 1, 0.36, 1) 0.65s forwards;
    }

    .hero-title:hover {
      color: #E8E8E0;
    }

    .hero-title .reg-symbol {
      font-size: 0.18em;
      vertical-align: super;
      margin-left: 0.05em;
      opacity: 0.6;
    }

    @keyframes titlePunch {
      0% {
        opacity: 0;
        transform: scale(1.08);
      }
      100% {
        opacity: 1;
        transform: scale(1);
      }
    }

    /* Subtitle — offset right */
    .hero-subtitle-wrap {
      position: relative;
      z-index: 3;
      max-width: 1400px;
      width: 92vw;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .hero-subtitle {
      font-size: clamp(1.4rem, 3vw, 2.4rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #1A1A1A;
      text-align: right;
      margin-top: clamp(0.5rem, 1.5vw, 1.5rem);
      padding-right: 5%;
      opacity: 0;
      animation: fadeUp 0.5s ease 0.9s forwards;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(15px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Stamp element — rotated square */
    .hero-stamp {
      position: absolute;
      top: clamp(5.5rem, 12vh, 9rem);
      right: clamp(1.5rem, 5vw, 5rem);
      z-index: 4;
      width: clamp(80px, 10vw, 120px);
      height: clamp(80px, 10vw, 120px);
      border: 3px solid #1A1A1A;
      transform: rotate(12deg);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      opacity: 0;
      animation: fadeUp 0.5s ease 1.1s forwards;
    }

    .hero-stamp-text {
      font-size: clamp(0.5rem, 1vw, 0.7rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      line-height: 1.5;
      color: #1A1A1A;
    }

    /* Bottom area: scattered stats + CTA */
    .hero-bottom {
      position: relative;
      z-index: 3;
      max-width: 1400px;
      width: 92vw;
      margin: 0 auto;
      padding: clamp(3rem, 6vh, 6rem) 2rem clamp(5rem, 8vh, 7rem);
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 2rem;
    }

    .hero-scattered-stats {
      display: flex;
      align-items: flex-end;
      gap: clamp(1.5rem, 4vw, 4rem);
      flex-wrap: wrap;
    }

    .hero-stat-huge {
      font-size: clamp(5rem, 12vw, 9rem);
      font-weight: 700;
      line-height: 0.85;
      color: #1A1A1A;
      opacity: 0.08;
      letter-spacing: -0.03em;
    }

    .hero-stat-side {
      display: flex;
      flex-direction: column;
      margin-bottom: 0.5rem;
    }

    .hero-stat-side-label {
      font-size: clamp(0.6rem, 1vw, 0.8rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #1A1A1A;
      opacity: 0.45;
    }

    .hero-stat-medium {
      font-size: clamp(0.9rem, 1.8vw, 1.3rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #FF3D00;
      margin-left: clamp(1rem, 3vw, 4rem);
      align-self: flex-end;
      margin-bottom: 0.6rem;
    }

    /* CTA link */
    .hero-cta {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(0.85rem, 1.2vw, 1.1rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #1A1A1A;
      text-decoration: none;
      padding: 1rem 2.5rem;
      border: 3px solid #1A1A1A;
      position: relative;
      overflow: hidden;
      transition: color 0.3s;
      z-index: 1;
      display: inline-block;
    }

    .hero-cta::before {
      content: '';
      position: absolute;
      inset: 0;
      background: #1A1A1A;
      transform: translateX(-101%);
      transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
      z-index: -1;
    }

    .hero-cta:hover {
      color: #F5F5F0;
    }

    .hero-cta:hover::before {
      transform: translateX(0);
    }

    /* Diagonal divider */
    .hero-divider {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 6;
      height: 100px;
      overflow: hidden;
    }

    .hero-divider::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: -5%;
      width: 110%;
      height: 100%;
      background: #F5F5F0;
      transform: skewY(-2.5deg);
      transform-origin: bottom left;
    }

    /* ===== PORTFOLIO / LETZTE ARBEITEN ===== */
    .portfolio {
      padding: 4rem 2rem 8rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      color: #FF3D00;
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .section-label::before {
      content: '';
      display: block;
      width: 30px;
      height: 3px;
      background: #FF3D00;
    }

    .section-headline {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 700;
      text-transform: uppercase;
      line-height: 0.95;
      margin-bottom: 4rem;
      letter-spacing: -0.02em;
    }

    .section-headline span {
      color: #FF3D00;
    }

    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: auto auto auto;
      gap: 1.25rem;
    }

    .portfolio-tile {
      position: relative;
      overflow: hidden;
      cursor: pointer;
      background: #1A1A1A;
    }

    .portfolio-tile:nth-child(1) {
      grid-column: 1 / 8;
      grid-row: 1 / 3;
    }

    .portfolio-tile:nth-child(2) {
      grid-column: 8 / 13;
      grid-row: 1 / 2;
    }

    .portfolio-tile:nth-child(3) {
      grid-column: 8 / 13;
      grid-row: 2 / 3;
    }

    .portfolio-tile:nth-child(4) {
      grid-column: 1 / 5;
      grid-row: 3 / 4;
    }

    .portfolio-tile:nth-child(5) {
      grid-column: 5 / 9;
      grid-row: 3 / 4;
    }

    .portfolio-tile:nth-child(6) {
      grid-column: 9 / 13;
      grid-row: 3 / 4;
    }

    .portfolio-tile img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s, filter 0.5s;
      display: block;
      min-height: 220px;
    }

    .portfolio-tile:nth-child(1) img {
      min-height: 460px;
    }

    .portfolio-tile:hover img {
      transform: scale(1.05);
      filter: brightness(0.5);
    }

    .portfolio-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 1.5rem;
      opacity: 0;
      transition: opacity 0.4s;
      background: linear-gradient(0deg, rgba(26, 26, 26, 0.9) 0%, transparent 60%);
    }

    .portfolio-tile:hover .portfolio-overlay {
      opacity: 1;
    }

    .portfolio-tag {
      display: inline-block;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #1A1A1A;
      background: #FFD600;
      padding: 0.3rem 0.75rem;
      margin-bottom: 0.75rem;
      align-self: flex-start;
    }

    .portfolio-title {
      font-size: 1.25rem;
      font-weight: 700;
      color: #F5F5F0;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .portfolio-meta {
      font-size: 0.8rem;
      color: rgba(245, 245, 240, 0.6);
      margin-top: 0.25rem;
    }

    .portfolio-number {
      position: absolute;
      top: 1rem;
      left: 1rem;
      font-size: 3.5rem;
      font-weight: 700;
      color: rgba(255, 61, 0, 0.35);
      line-height: 1;
      pointer-events: none;
    }

    .portfolio-tile:nth-child(1) .portfolio-number {
      font-size: 5rem;
    }

    /* ===== PROZESS ===== */
    .process {
      background: #1A1A1A;
      color: #F5F5F0;
      padding: 6rem 2rem 5rem;
      position: relative;
    }

    .process-skew-top {
      position: absolute;
      top: -50px;
      left: 0;
      right: 0;
      height: 100px;
      background: #1A1A1A;
      transform: skewY(2.5deg);
      z-index: 1;
    }

    .process-inner {
      position: relative;
      z-index: 2;
      max-width: 1200px;
      margin: 0 auto;
    }

    .process .section-label {
      color: #FFD600;
    }

    .process .section-label::before {
      background: #FFD600;
    }

    .process .section-headline {
      color: #F5F5F0;
      margin-bottom: 5rem;
    }

    .process .section-headline span {
      color: #FF3D00;
    }

    .process-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      position: relative;
    }

    .process-steps::before {
      content: '';
      position: absolute;
      top: 40px;
      left: 12.5%;
      right: 12.5%;
      height: 3px;
      background: repeating-linear-gradient(
        90deg,
        #FF3D00 0px,
        #FF3D00 12px,
        transparent 12px,
        transparent 20px
      );
      opacity: 0.4;
    }

    .process-step {
      text-align: center;
      padding: 0 1.5rem;
      position: relative;
    }

    .process-step-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 80px;
      height: 80px;
      font-size: 2rem;
      font-weight: 700;
      color: #1A1A1A;
      background: #FF3D00;
      margin-bottom: 1.5rem;
      position: relative;
      z-index: 2;
    }

    .process-step:nth-child(even) .process-step-number {
      background: #FFD600;
    }

    .process-step-title {
      font-size: 1.25rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.75rem;
      color: #F5F5F0;
    }

    .process-step-desc {
      font-size: 0.9rem;
      line-height: 1.7;
      color: rgba(245, 245, 240, 0.6);
    }

    /* CTA bar */
    .process-cta {
      margin-top: 5rem;
      padding-top: 3rem;
      border-top: 3px solid rgba(245, 245, 240, 0.08);
      text-align: center;
    }

    .process-cta-text {
      font-size: clamp(1.4rem, 3vw, 2.2rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      line-height: 1.3;
    }

    .process-cta-text span {
      color: #FF3D00;
    }

    .process-cta-text a {
      color: #FFD600;
      text-decoration: none;
      border-bottom: 3px solid #FFD600;
      transition: color 0.2s, border-color 0.2s;
    }

    .process-cta-text a:hover {
      color: #FF3D00;
      border-color: #FF3D00;
    }

    /* ===== FOOTER ===== */
    .footer {
      background: #111;
      padding: 2rem;
      text-align: center;
      border-top: 4px solid #FF3D00;
    }

    .footer p {
      font-size: 0.75rem;
      color: rgba(245, 245, 240, 0.3);
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .footer span {
      color: #FF3D00;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 1024px) {
      .process-steps {
        grid-template-columns: repeat(2, 1fr);
        gap: 3rem 1rem;
      }

      .process-steps::before {
        display: none;
      }

      .portfolio-tile:nth-child(1) img {
        min-height: 350px;
      }
    }

    @media (max-width: 768px) {
      .nav-links {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #1A1A1A;
        flex-direction: column;
        padding: 1.5rem 2rem;
        gap: 1.25rem;
        border-top: 2px solid #FF3D00;
      }

      .nav-links.open {
        display: flex;
      }

      .nav-burger {
        display: flex;
      }

      .hero-stamp {
        top: auto;
        bottom: auto;
        right: 1.5rem;
        top: 5.5rem;
        width: 70px;
        height: 70px;
      }

      .hero-reg-mark--tl,
      .hero-reg-mark--tr,
      .hero-reg-mark--bl,
      .hero-reg-mark--br {
        display: none;
      }

      .hero-halftone {
        opacity: 0.08;
      }

      .hero-bottom {
        flex-direction: column;
        align-items: flex-start;
        padding-left: 1.5rem;
        padding-right: 1.5rem;
      }

      .hero-stat-medium {
        margin-left: 0;
      }

      .portfolio {
        padding: 3rem 1.5rem 5rem;
      }

      .portfolio-grid {
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto;
      }

      .portfolio-tile:nth-child(1) {
        grid-column: 1 / 3;
        grid-row: auto;
      }

      .portfolio-tile:nth-child(2) {
        grid-column: 1 / 2;
        grid-row: auto;
      }

      .portfolio-tile:nth-child(3) {
        grid-column: 2 / 3;
        grid-row: auto;
      }

      .portfolio-tile:nth-child(4) {
        grid-column: 1 / 3;
        grid-row: auto;
      }

      .portfolio-tile:nth-child(5) {
        grid-column: 1 / 2;
        grid-row: auto;
      }

      .portfolio-tile:nth-child(6) {
        grid-column: 2 / 3;
        grid-row: auto;
      }

      .portfolio-tile:nth-child(1) img {
        min-height: 280px;
      }

      .portfolio-tile img {
        min-height: 180px;
      }

      .portfolio-overlay {
        opacity: 1;
      }

      .portfolio-number {
        font-size: 2.5rem;
      }

      .portfolio-tile:nth-child(1) .portfolio-number {
        font-size: 3rem;
      }

      .process {
        padding: 5rem 1.5rem 4rem;
      }

      .process-steps {
        grid-template-columns: 1fr;
        gap: 2.5rem;
      }

      .process-step {
        text-align: left;
        padding: 0;
        display: flex;
        gap: 1.25rem;
        align-items: flex-start;
      }

      .process-step-number {
        width: 60px;
        height: 60px;
        font-size: 1.5rem;
        flex-shrink: 0;
      }

      .process-step-content {
        flex: 1;
      }
    }

    @media (max-width: 480px) {
      .hero-stat-huge {
        font-size: 4rem;
      }

      .hero-subtitle {
        padding-right: 0;
        text-align: left;
      }

      .hero-stamp {
        width: 60px;
        height: 60px;
      }

      .portfolio-grid {
        grid-template-columns: 1fr;
      }

      .portfolio-tile:nth-child(1),
      .portfolio-tile:nth-child(2),
      .portfolio-tile:nth-child(3),
