---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Druckluft — Siebdruck mit Haltung | Trier-Nord</title>
  <meta name="description" content="Druckluft ist eine Siebdruck-Werkstatt in Trier-Nord. Handgemachter Textildruck, Poster, Branding. Seit 2020." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: #F5F5F0;
      color: #1A1A1A;
      line-height: 1.5;
      overflow-x: hidden;
    }

    img {
      max-width: 100%;
      display: block;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    /* ===== NAV ===== */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2rem;
      background: #1A1A1A;
      border-bottom: 4px solid #FF3D00;
    }

    .nav-logo {
      font-size: 1.6rem;
      font-weight: 700;
      color: #F5F5F0;
      text-transform: uppercase;
      letter-spacing: 0.2em;
    }

    .nav-logo span {
      color: #FF3D00;
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      color: #F5F5F0;
      font-weight: 700;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      transition: color 0.2s;
      position: relative;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 3px;
      background: #FF3D00;
      transition: width 0.3s;
    }

    .nav-links a:hover::after {
      width: 100%;
    }

    .nav-links a:hover {
      color: #FFD600;
    }

    .nav-burger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }

    .nav-burger span {
      display: block;
      width: 30px;
      height: 3px;
      background: #F5F5F0;
      transition: transform 0.3s, opacity 0.3s;
    }

    /* ===== HERO ===== */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
      background: #1A1A1A;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(40%) contrast(1.1);
    }

    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        160deg,
        rgba(26, 26, 26, 0.95) 0%,
        rgba(26, 26, 26, 0.85) 40%,
        rgba(255, 61, 0, 0.3) 100%
      );
    }

    /* Geometric shapes */
    .geo {
      position: absolute;
      z-index: 1;
      pointer-events: none;
    }

    .geo--rect-1 {
      top: 10%;
      right: -30px;
      width: 350px;
      height: 350px;
      border: 8px solid #FF3D00;
      transform: rotate(12deg);
      opacity: 0.25;
    }

    .geo--rect-2 {
      bottom: 15%;
      right: 8%;
      width: 180px;
      height: 180px;
      background: #FFD600;
      transform: rotate(-8deg);
      opacity: 0.12;
    }

    .geo--circle {
      top: 20%;
      right: 25%;
      width: 100px;
      height: 100px;
      border: 6px solid #FFD600;
      border-radius: 50%;
      opacity: 0.2;
    }

    .geo--line {
      top: 0;
      left: 50%;
      width: 4px;
      height: 200px;
      background: #FF3D00;
      opacity: 0.15;
      transform: rotate(25deg);
    }

    .geo--dot-grid {
      bottom: 25%;
      left: 3%;
      width: 120px;
      height: 120px;
      background-image: radial-gradient(circle, #FF3D00 2px, transparent 2px);
      background-size: 20px 20px;
      opacity: 0.2;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      padding: 10rem 2rem 5rem;
      max-width: 1100px;
      margin: 0 auto;
      width: 100%;
    }

    .hero-label {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      color: #FFD600;
      margin-bottom: 2rem;
    }

    .hero-label::before {
      content: '';
      display: block;
      width: 40px;
      height: 3px;
      background: #FFD600;
    }

    .hero-headline {
      font-size: clamp(4rem, 12vw, 10rem);
      font-weight: 700;
      line-height: 0.9;
      color: #F5F5F0;
      text-transform: uppercase;
      margin-bottom: 2rem;
      letter-spacing: -0.03em;
    }

    .hero-headline .line {
      display: block;
    }

    .hero-headline .line--accent {
      color: #FF3D00;
      -webkit-text-stroke: 0px;
    }

    .hero-headline .line--outline {
      color: transparent;
      -webkit-text-stroke: 3px #F5F5F0;
    }

    .hero-subtitle {
      font-size: clamp(1.1rem, 2.2vw, 1.6rem);
      color: rgba(245, 245, 240, 0.7);
      max-width: 560px;
      margin-bottom: 3rem;
      line-height: 1.5;
      font-weight: 400;
    }

    .hero-subtitle strong {
      color: #F5F5F0;
      font-weight: 600;
    }

    .btn-primary {
      display: inline-block;
      padding: 1.2rem 3rem;
      background: #FF3D00;
      color: #F5F5F0;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      border: none;
      cursor: pointer;
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
      position: relative;
    }

    .btn-primary::after {
      content: '';
      position: absolute;
      top: 6px;
      left: 6px;
      right: -6px;
      bottom: -6px;
      border: 3px solid #FFD600;
      z-index: -1;
      transition: transform 0.2s;
    }

    .btn-primary:hover {
      background: #e03500;
      transform: translate(-2px, -2px);
    }

    .btn-primary:hover::after {
      transform: translate(2px, 2px);
    }

    .hero-stats {
      display: flex;
      gap: 3rem;
      margin-top: 4rem;
      padding-top: 2.5rem;
      border-top: 2px solid rgba(245, 245, 240, 0.1);
    }

    .hero-stat {
      display: flex;
      flex-direction: column;
    }

    .hero-stat-number {
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      font-weight: 700;
      color: #FFD600;
      line-height: 1;
    }

    .hero-stat-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: rgba(245, 245, 240, 0.5);
      margin-top: 0.4rem;
    }

    /* Diagonal divider */
    .hero-divider {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 3;
      height: 100px;
      overflow: hidden;
    }

    .hero-divider::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: -5%;
      width: 110%;
      height: 100%;
      background: #F5F5F0;
      transform: skewY(-2.5deg);
      transform-origin: bottom left;
    }

    /* ===== PORTFOLIO / LETZTE ARBEITEN ===== */
    .portfolio {
      padding: 4rem 2rem 8rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      color: #FF3D00;
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .section-label::before {
      content: '';
      display: block;
      width: 30px;
      height: 3px;
      background: #FF3D00;
    }

    .section-headline {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 700;
      text-transform: uppercase;
      line-height: 0.95;
      margin-bottom: 4rem;
      letter-spacing: -0.02em;
    }

    .section-headline span {
      color: #FF3D00;
    }

    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: auto auto auto;
      gap: 1.25rem;
    }

    .portfolio-tile {
      position: relative;
      overflow: hidden;
      cursor: pointer;
      background: #1A1A1A;
    }

    .portfolio-tile:nth-child(1) {
      grid-column: 1 / 8;
      grid-row: 1 / 3;
    }

    .portfolio-tile:nth-child(2) {
      grid-column: 8 / 13;
      grid-row: 1 / 2;
    }

    .portfolio-tile:nth-child(3) {
      grid-column: 8 / 13;
      grid-row: 2 / 3;
    }

    .portfolio-tile:nth-child(4) {
      grid-column: 1 / 5;
      grid-row: 3 / 4;
    }

    .portfolio-tile:nth-child(5) {
      grid-column: 5 / 9;
      grid-row: 3 / 4;
    }

    .portfolio-tile:nth-child(6) {
      grid-column: 9 / 13;
      grid-row: 3 / 4;
    }

    .portfolio-tile img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s, filter 0.5s;
      display: block;
      min-height: 220px;
    }

    .portfolio-tile:nth-child(1) img {
      min-height: 460px;
    }

    .portfolio-tile:hover img {
      transform: scale(1.05);
      filter: brightness(0.5);
    }

    .portfolio-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 1.5rem;
      opacity: 0;
      transition: opacity 0.4s;
      background: linear-gradient(0deg, rgba(26, 26, 26, 0.9) 0%, transparent 60%);
    }

    .portfolio-tile:hover .portfolio-overlay {
      opacity: 1;
    }

    .portfolio-tag {
      display: inline-block;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: #1A1A1A;
      background: #FFD600;
      padding: 0.3rem 0.75rem;
      margin-bottom: 0.75rem;
      align-self: flex-start;
    }

    .portfolio-title {
      font-size: 1.25rem;
      font-weight: 700;
      color: #F5F5F0;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .portfolio-meta {
      font-size: 0.8rem;
      color: rgba(245, 245, 240, 0.6);
      margin-top: 0.25rem;
    }

    .portfolio-number {
      position: absolute;
      top: 1rem;
      left: 1rem;
      font-size: 3.5rem;
      font-weight: 700;
      color: rgba(255, 61, 0, 0.35);
      line-height: 1;
      pointer-events: none;
    }

    .portfolio-tile:nth-child(1) .portfolio-number {
      font-size: 5rem;
    }

    /* ===== PROZESS ===== */
    .process {
      background: #1A1A1A;
      color: #F5F5F0;
      padding: 6rem 2rem 5rem;
      position: relative;
    }

    .process-skew-top {
      position: absolute;
      top: -50px;
      left: 0;
      right: 0;
      height: 100px;
      background: #1A1A1A;
      transform: skewY(2.5deg);
      z-index: 1;
    }

    .process-inner {
      position: relative;
      z-index: 2;
      max-width: 1200px;
      margin: 0 auto;
    }

    .process .section-label {
      color: #FFD600;
    }

    .process .section-label::before {
      background: #FFD600;
    }

    .process .section-headline {
      color: #F5F5F0;
      margin-bottom: 5rem;
    }

    .process .section-headline span {
      color: #FF3D00;
    }

    .process-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      position: relative;
    }

    .process-steps::before {
      content: '';
      position: absolute;
      top: 40px;
      left: 12.5%;
      right: 12.5%;
      height: 3px;
      background: repeating-linear-gradient(
        90deg,
        #FF3D00 0px,
        #FF3D00 12px,
        transparent 12px,
        transparent 20px
      );
      opacity: 0.4;
    }

    .process-step {
      text-align: center;
      padding: 0 1.5rem;
      position: relative;
    }

    .process-step-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 80px;
      height: 80px;
      font-size: 2rem;
      font-weight: 700;
      color: #1A1A1A;
      background: #FF3D00;
      margin-bottom: 1.5rem;
      position: relative;
      z-index: 2;
    }

    .process-step:nth-child(even) .process-step-number {
      background: #FFD600;
    }

    .process-step-title {
      font-size: 1.25rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.75rem;
      color: #F5F5F0;
    }

    .process-step-desc {
      font-size: 0.9rem;
      line-height: 1.7;
      color: rgba(245, 245, 240, 0.6);
    }

    /* CTA bar */
    .process-cta {
      margin-top: 5rem;
      padding-top: 3rem;
      border-top: 3px solid rgba(245, 245, 240, 0.08);
      text-align: center;
    }

    .process-cta-text {
      font-size: clamp(1.4rem, 3vw, 2.2rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      line-height: 1.3;
    }

    .process-cta-text span {
      color: #FF3D00;
    }

    .process-cta-text a {
      color: #FFD600;
      text-decoration: none;
      border-bottom: 3px solid #FFD600;
      transition: color 0.2s, border-color 0.2s;
    }

    .process-cta-text a:hover {
      color: #FF3D00;
      border-color: #FF3D00;
    }

    /* ===== FOOTER ===== */
    .footer {
      background: #111;
      padding: 2rem;
      text-align: center;
      border-top: 4px solid #FF3D00;
    }

    .footer p {
      font-size: 0.75rem;
      color: rgba(245, 245, 240, 0.3);
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .footer span {
      color: #FF3D00;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 1024px) {
      .process-steps {
        grid-template-columns: repeat(2, 1fr);
        gap: 3rem 1rem;
      }

      .process-steps::before {
        display: none;
      }

      .portfolio-tile:nth-child(1) img {
        min-height: 350px;
      }
    }

    @media (max-width: 768px) {
      .nav-links {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #1A1A1A;
        flex-direction: column;
        padding: 1.5rem 2rem;
        gap: 1.25rem;
        border-top: 2px solid #FF3D00;
      }

      .nav-links.open {
        display: flex;
      }

      .nav-burger {
        display: flex;
      }

      .hero-content {
        padding: 8rem 1.5rem 5rem;
      }

      .hero-headline {
        font-size: clamp(3rem, 14vw, 5rem);
      }

      .hero-headline .line--outline {
        -webkit-text-stroke: 2px #F5F5F0;
      }

      .hero-stats {
        flex-wrap: wrap;
        gap: 2rem;
      }

      .geo--rect-1 {
        width: 200px;
        height: 200px;
        top: 5%;
        right: -50px;
      }

      .geo--rect-2,
      .geo--circle,
      .geo--line {
        display: none;
      }

      .portfolio {
        padding: 3rem 1.5rem 5rem;
      }

      .portfolio-grid {
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto;
      }

      .portfolio-tile:nth-child(1) {
        grid-column: 1 / 3;
        grid-row: auto;
      }

      .portfolio-tile:nth-child(2) {
        grid-column: 1 / 2;
        grid-row: auto;
      }

      .portfolio-tile:nth-child(3) {
        grid-column: 2 / 3;
        grid-row: auto;
      }

      .portfolio-tile:nth-child(4) {
        grid-column: 1 / 3;
        grid-row: auto;
      }

      .portfolio-tile:nth-child(5) {
        grid-column: 1 / 2;
        grid-row: auto;
      }

      .portfolio-tile:nth-child(6) {
        grid-column: 2 / 3;
        grid-row: auto;
      }

      .portfolio-tile:nth-child(1) img {
        min-height: 280px;
      }

      .portfolio-tile img {
        min-height: 180px;
      }

      .portfolio-overlay {
        opacity: 1;
      }

      .portfolio-number {
        font-size: 2.5rem;
      }

      .portfolio-tile:nth-child(1) .portfolio-number {
        font-size: 3rem;
      }

      .process {
        padding: 5rem 1.5rem 4rem;
      }

      .process-steps {
        grid-template-columns: 1fr;
        gap: 2.5rem;
      }

      .process-step {
        text-align: left;
        padding: 0;
        display: flex;
        gap: 1.25rem;
        align-items: flex-start;
      }

      .process-step-number {
        width: 60px;
        height: 60px;
        font-size: 1.5rem;
        flex-shrink: 0;
      }

      .process-step-content {
        flex: 1;
      }
    }

    @media (max-width: 480px) {
      .hero-stats {
        gap: 1.5rem;
      }

      .hero-stat-number {
        font-size: 1.5rem;
      }

      .portfolio-grid {
        grid-template-columns: 1fr;
      }

      .portfolio-tile:nth-child(1),
      .portfolio-tile:nth-child(2),
      .portfolio-tile:nth-child(3),
      .portfolio-tile:nth-child(4),
      .portfolio-tile:nth-child(5),
      .portfolio-tile:nth-child(6) {
        grid-column: 1 / -1;
      }

      .portfolio-tile img,
      .portfolio-tile:nth-child(1) img {
        min-height: 220px;
      }
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav class="nav">
    <a href="#" class="nav-logo">Druck<span>luft</span></a>
    <ul class="nav-links" id="navLinks">
      <li><a href="#arbeiten">Arbeiten</a></li>
      <li><a href="#prozess">Prozess</a></li>
    </ul>
    <button class="nav-burger" id="navBurger" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1565793298595-6a879b1d9492?w=1920&q=80&auto=format"
        alt="Siebdruck-Werkstatt mit Farben und Drucktisch"
        loading="eager"
      />
    </div>
    <div class="geo geo--rect-1"></div>
    <div class="geo geo--rect-2"></div>
    <div class="geo geo--circle"></div>
    <div class="geo geo--line"></div>
    <div class="geo geo--dot-grid"></div>
    <div class="hero-content">
      <div class="hero-label">Siebdruck-Werkstatt / Trier-Nord</div>
      <h1 class="hero-headline">
        <span class="line">Druck.</span>
        <span class="line line--accent">Farbe.</span>
        <span class="line line--outline">Haltung.</span>
      </h1>
      <p class="hero-subtitle">
        Wir drucken keine Massenware.<br />
        <strong>Wir drucken das, woran du glaubst.</strong>
      </p>
      <a href="#prozess" class="btn-primary">Projekt anfragen</a>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-number">847</span>
          <span class="hero-stat-label">Drucke in 2025</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-number">100%</span>
          <span class="hero-stat-label">Handarbeit</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-number">2020</span>
          <span class="hero-stat-label">Seit</span>
        </div>
      </div>
    </div>
    <div class="hero-divider"></div>
  </section>

  <!-- PORTFOLIO / LETZTE ARBEITEN -->
  <section class="portfolio" id="arbeiten">
    <p class="section-label">Siebdruck-Projekte</p>
    <h2 class="section-headline">
      Was zuletzt<br />vom Tisch <span>ging.</span>
    </h2>
    <div class="portfolio-grid">

      <div class="portfolio-tile">
        <span class="portfolio-number">01</span>
        <img
          src="https://images.unsplash.com/photo-1503342217505-b0a15ec3261c?w=800&q=80&auto=format"
          alt="Festival T-Shirts im Siebdruck"
          loading="lazy"
        />
        <div class="portfolio-overlay">
          <span class="portfolio-tag">Textildruck</span>
          <span class="portfolio-title">Moselrock Festival 2025</span>
          <span class="portfolio-meta">500 Festival-Shirts, 3 Farben</span>
        </div>
      </div>

      <div class="portfolio-tile">
        <span class="portfolio-number">02</span>
        <img
