---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Kammer 13 — Escape Room & Mystery Experience | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Inconsolata:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    /* ── RESET ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --bg:        #0D0B08;
      --bg2:       #120F0A;
      --bg3:       #181410;
      --gold:      #E8C547;
      --gold-dim:  rgba(232,197,71,0.18);
      --gold-glow: rgba(232,197,71,0.06);
      --red:       #CC1F1F;
      --red-dim:   rgba(204,31,31,0.15);
      --text:      #F0E8D0;
      --muted:     rgba(240,232,208,0.4);
      --faint:     rgba(240,232,208,0.1);
      --rule:      rgba(240,232,208,0.06);
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inconsolata', monospace;
      font-weight: 400;
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* Film grain via SVG noise */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.82' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: 0.55;
    }

    /* Vignette with breathing animation */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: radial-gradient(ellipse at center, transparent 42%, rgba(0,0,0,0.6) 100%);
      pointer-events: none;
      z-index: 9998;
      animation: vigBreath 10s ease-in-out infinite;
    }

    @keyframes vigBreath {
      0%, 100% { opacity: 0.75; }
      50%       { opacity: 1; }
    }

    img { display: block; max-width: 100%; }
    ::selection { background: var(--gold); color: var(--bg); }

    /* ── NAV ── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.1rem clamp(1.5rem, 5vw, 3.5rem);
      background: rgba(13,11,8,0.92);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--rule);
    }

    .nav-logo {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text);
      text-decoration: none;
    }
    .nav-logo em { font-style: normal; color: var(--gold); }

    .nav-links {
      display: flex;
      gap: 0;
      list-style: none;
    }
    .nav-links a {
      display: block;
      padding: 0.4rem 1.2rem;
      font-size: 0.52rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      border-right: 1px solid var(--rule);
      transition: color 0.2s;
    }
    .nav-links li:first-child a { border-left: 1px solid var(--rule); }
    .nav-links a:hover { color: var(--text); }

    .nav-cta {
      font-family: 'Oswald', sans-serif;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--gold);
      padding: 0.55rem 1.4rem;
      text-decoration: none;
      white-space: nowrap;
      position: relative;
      overflow: hidden;
      transition: background 0.2s;
    }
    .nav-cta::after {
      content: '';
      position: absolute;
      top: 0; left: -60%;
      width: 40%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
      transition: left 0.5s;
    }
    .nav-cta:hover { background: #fff; }
    .nav-cta:hover::after { left: 150%; }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }
    .nav-hamburger span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: var(--text);
    }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      padding-top: 56px;
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 380px;
      max-width: 1600px;
      margin: 0 auto;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
    }
    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.15;
      filter: saturate(0.35) sepia(0.3);
    }
    .hero-bg-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        100deg,
        rgba(13,11,8,0.25) 0%,
        transparent 45%,
        rgba(13,11,8,0.55) 100%
      );
    }

    /* Keyhole decorative motif — large, ghosted */
    .hero-keyhole {
      position: absolute;
      bottom: -60px;
      left: 38%;
      transform: translateX(-50%);
      width: 200px;
      opacity: 0.035;
      z-index: 0;
      pointer-events: none;
    }

    .hero-left {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(3rem, 6vw, 5rem) clamp(2rem, 4vw, 3.5rem) clamp(3rem, 6vw, 5rem) clamp(2.5rem, 5vw, 5rem);
      gap: 2.4rem;
      border-right: 1px solid var(--rule);
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.65rem;
      font-size: 0.52rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--red);
      width: fit-content;
    }
    .pulse-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--red);
      flex-shrink: 0;
      animation: pulseRed 1.4s ease-in-out infinite;
    }
    @keyframes pulseRed {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.25; }
    }

    .hero-headline {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: clamp(3rem, 7.5vw, 6rem);
      line-height: 0.88;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }
    .hl-gold   { color: var(--gold); }
    .hl-dim    { opacity: 0.1; }
    .hl-stroke {
      color: transparent;
      -webkit-text-stroke: 1px rgba(240,232,208,0.28);
    }

    .hero-sub {
      font-size: 0.82rem;
      font-weight: 300;
      line-height: 1.95;
      color: var(--muted);
      max-width: 44ch;
    }

    /* Room-list widget */
    .room-widget {
      border: 1px solid var(--rule);
      background: rgba(255,255,255,0.012);
    }
    .rw-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.45rem 0.9rem;
      border-bottom: 1px solid var(--rule);
      background: rgba(255,255,255,0.02);
    }
    .rw-title {
      font-size: 0.44rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .rw-sub {
      font-size: 0.42rem;
      letter-spacing: 0.14em;
      color: var(--gold);
      opacity: 0.65;
    }

    .rw-row {
      display: grid;
      grid-template-columns: 2.2rem 1fr auto;
      align-items: center;
      gap: 0.75rem;
      padding: 0.78rem 0.9rem;
      border-bottom: 1px solid var(--rule);
      cursor: default;
      transition: background 0.2s, padding-left 0.22s;
    }
    .rw-row:last-child { border-bottom: none; }
    .rw-row:hover { background: var(--gold-glow); padding-left: 1.15rem; }

    .rw-num {
      font-family: 'Oswald', sans-serif;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--gold);
      opacity: 0.3;
      text-align: right;
      transition: opacity 0.2s;
    }
    .rw-row:hover .rw-num { opacity: 0.9; }

    .rw-name {
      font-family: 'Oswald', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .rw-row:hover .rw-name { color: var(--gold); }
    .rw-meta {
      font-size: 0.54rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 1px;
    }

    .rw-dots {
      display: flex;
      gap: 3px;
    }
    .rd {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: rgba(240,232,208,0.1);
      transition: background 0.2s;
    }
    .rd.on { background: var(--red); }
    .rw-row:hover .rd.on { background: var(--gold); }

    .hero-cta-row {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .btn-primary {
      font-family: 'Oswald', sans-serif;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--gold);
      padding: 0.88rem 2rem;
      text-decoration: none;
      display: inline-block;
      transition: background 0.2s;
    }
    .btn-primary:hover { background: #fff; }

    .btn-ghost {
      font-size: 0.56rem;
      letter-spacing: 0.12em;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 2px;
      transition: color 0.2s, border-color 0.2s;
    }
    .btn-ghost:hover { color: var(--text); border-color: var(--muted); }

    /* ── HERO RIGHT PANEL ── */
    .hero-right {
      position: relative;
      z-index: 1;
      background: var(--bg2);
      border-left: 1px solid var(--rule);
      display: flex;
      flex-direction: column;
    }

    .timer-block {
      padding: 2.5rem 2rem;
      border-bottom: 1px solid var(--rule);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .timer-block::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(232,197,71,0.05) 0%, transparent 70%);
      pointer-events: none;
    }
    .tb-label {
      font-size: 0.46rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.8rem;
    }
    .tb-time {
      font-family: 'Oswald', sans-serif;
      font-size: 3.8rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: var(--gold);
      line-height: 1;
      animation: timerGlow 3s ease-in-out infinite;
    }
    .tb-colon { animation: colonBlink 1s step-end infinite; }
    .tb-sub {
      font-size: 0.5rem;
      color: rgba(240,232,208,0.2);
      margin-top: 0.5rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    @keyframes timerGlow {
      0%, 100% { text-shadow: 0 0 12px rgba(232,197,71,0.12); }
      50%       { text-shadow: 0 0 40px rgba(232,197,71,0.55), 0 0 80px rgba(232,197,71,0.12); }
    }
    @keyframes colonBlink {
      0%, 49%  { opacity: 1; }
      50%, 100%{ opacity: 0; }
    }

    .stats-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-bottom: 1px solid var(--rule);
    }
    .stat-cell {
      padding: 1.1rem 1.4rem;
      text-align: center;
      border-right: 1px solid var(--rule);
    }
    .stat-cell:nth-child(2) { border-right: none; }
    .stat-num {
      font-family: 'Oswald', sans-serif;
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1;
    }
    .stat-label {
      font-size: 0.48rem;
      color: var(--muted);
      letter-spacing: 0.1em;
      margin-top: 0.2rem;
    }

    .leaderboard {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding-top: 1.1rem;
    }
    .lb-label {
      font-size: 0.44rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--muted);
      padding: 0 1.4rem;
      margin-bottom: 0.6rem;
    }
    .lb-row {
      display: grid;
      grid-template-columns: 1.4rem 1fr auto;
      align-items: center;
      gap: 0.6rem;
      padding: 0.5rem 1.4rem;
      border-bottom: 1px solid var(--rule);
      cursor: default;
      transition: background 0.2s;
    }
    .lb-row:last-child { border-bottom: none; }
    .lb-row:hover { background: var(--gold-glow); }
    .lb-pos {
      font-size: 0.56rem;
      color: var(--muted);
    }
    .lb-pos.gold { color: var(--gold); }
    .lb-team {
      font-size: 0.68rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      transition: color 0.2s;
    }
    .lb-row:hover .lb-team { color: var(--gold); }
    .lb-time {
      font-family: 'Oswald', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--gold);
      letter-spacing: 0.04em;
      white-space: nowrap;
    }

    .lb-cta-block {
      padding: 1.1rem 1.4rem;
      border-top: 1px solid rgba(232,197,71,0.1);
      background: rgba(232,197,71,0.02);
    }
    .lb-cta-text {
      font-size: 0.58rem;
      color: var(--muted);
      line-height: 1.65;
      margin-bottom: 0.65rem;
    }
    .lb-cta-btn {
      font-family: 'Oswald', sans-serif;
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--gold);
      padding: 0.5rem 1.1rem;
      text-decoration: none;
      display: inline-block;
      transition: background 0.2s;
    }
    .lb-cta-btn:hover { background: #fff; }

    /* ── SECTION COMMON ── */
    .eyebrow {
      font-size: 0.46rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.45rem;
    }
    .section-title {
      font-family: 'Oswald', sans-serif;
      font-size: clamp(1.5rem, 2.8vw, 2.2rem);
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      line-height: 1.1;
    }
    .section-title em { font-style: normal; color: var(--gold); }
    .section-rule {
      width: 2rem;
      height: 1px;
      background: var(--gold);
      opacity: 0.45;
      margin-top: 1rem;
    }

    /* ── ROOMS SECTION ── */
    .rooms {
      padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 5vw, 5rem);
      background: var(--bg2);
      border-top: 1px solid var(--rule);
      position: relative;
      z-index: 1;
    }
    .rooms-inner { max-width: 1400px; margin: 0 auto; }
    .section-header { margin-bottom: 3rem; }

    .rooms-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .room-card {
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }
    .rc-photo {
      position: relative;
      height: clamp(260px, 32vw, 380px);
      overflow: hidden;
    }
    .rc-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.75s ease;
      filter: saturate(0.65) brightness(0.8);
    }
    .room-card:hover .rc-photo img { transform: scale(1.07); }

    .rc-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(13,11,8,0.95) 0%,
        rgba(13,11,8,0.45) 40%,
        transparent 70%
      );
    }

    .rc-hover-overlay {
      position: absolute;
      inset: 0;
      background: rgba(13,11,8,0.7);
      opacity: 0;
      transition: opacity 0.4s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .room-card:hover .rc-hover-overlay { opacity: 1; }

    .rc-hover-inner {
      text-align: center;
      padding: 2rem;
    }
    .rc-hover-desc {
      font-size: 0.8rem;
      line-height: 1.85;
      color: rgba(240,232,208,0.82);
      max-width: 28ch;
    }
    .rc-hover-cta {
      display: inline-block;
      margin-top: 1.25rem;
      font-family: 'Oswald', sans-serif;
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--gold);
      padding: 0.5rem 1.2rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .rc-hover-cta:hover { background: #fff; }

    .rc-info {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 1.2rem 1.4rem;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      z-index: 2;
    }
    .rc-name {
      font-family: 'Oswald', sans-serif;
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      line-height: 1;
    }
    .rc-meta {
      font-size: 0.52rem;
      color: var(--muted);
      margin-top: 0.3rem;
      letter-spacing: 0.08em;
    }
    .rc-badge {
      flex-shrink: 0;
      font-size: 0.46rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0.25rem 0.65rem;
      border: 1px solid rgba(232,197,71,0.3);
      color: var(--gold);
    }
    .rc-badge.hard    { border-color: rgba(204,31,31,0.4); color: var(--red); }
    .rc-badge.extreme { border-color: rgba(204,31,31,0.6); color: var(--red); }

    /* ── PROCESS SECTION ── */
    .process {
      position: relative;
      padding: clamp(5rem, 10vw, 8rem) clamp(1.5rem, 5vw, 5rem);
      background: var(--bg3);
      border-top: 1px solid var(--rule);
      overflow: hidden;
      z-index: 1;
    }
    .process-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .process-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.07;
      filter: saturate(0.15);
    }
    .process-bg-grad {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        var(--bg3) 0%,
        rgba(24,20,16,0.6) 50%,
        var(--bg3) 100%
      );
    }
    .process-inner {
      position: relative;
      z-index: 1;
      max-width: 1400px;
      margin: 0 auto;
    }

    .process-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      margin-top: 3rem;
      border: 1px solid var(--rule);
    }

    .step {
      padding: 2.5rem 1.8rem;
      border-right: 1px solid var(--rule);
      position: relative;
      transition: background 0.3s;
    }
    .step:last-child { border-right: none; }
    .step:hover { background: rgba(232,197,71,0.022); }

    .step-num {
      font-family: 'Oswald', sans-serif;
      font-size: 3.8rem;
      font-weight: 700;
      color: var(--gold);
      opacity: 0.1;
      line-height: 1;
      margin-bottom: 1.25rem;
      transition: opacity 0.3s;
    }
    .step:hover .step-num { opacity: 0.22; }

    /* Keyhole icon in step */
    .step-keyhole {
      width: 18px;
      height: 25px;
      margin-bottom: 0.85rem;
      opacity: 0.45;
      transition: opacity 0.3s;
    }
    .step:hover .step-keyhole { opacity: 1; }

    .step-label {
      font-size: 0.44rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--gold);
      opacity: 0.65;
      margin-bottom: 0.45rem;
    }
    .step-name {
      font-family: 'Oswald', sans-serif;
      font-size: 1.05rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      line-height: 1.2;
      margin-bottom: 0.65rem;
    }
    .step-desc {
      font-size: 0.72rem;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.85;
    }

    .step-connector {
      position: absolute;
      right: -12px;
      top: 50%;
      transform: translateY(-50%);
      z-index: 2;
      color: var(--gold);
      opacity: 0.18;
      font-size: 1rem;
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
    }
    .step:last-child .step-connector { display: none; }

    /* ── BOOKING SECTION ── */
    .booking {
      position: relative;
      border-top: 1px solid var(--rule);
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 600px;
    }

    .booking-photo {
      position: relative;
      overflow: hidden;
      min-height: 420px;
    }
    .booking-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(0.45) brightness(0.65);
      transition: transform 0.9s ease;
    }
    .booking:hover .booking-photo img { transform: scale(1.03); }
    .booking-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to right,
        transparent 40%,
        var(--bg) 100%
      );
    }

    .booking-content {
      background: var(--bg);
      padding: clamp(3rem, 6vw, 5rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 2.4rem;
    }

    .pricing-table {
      border: 1px solid var(--rule);
    }
    .pr-row {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--rule);
      transition: background 0.2s;
    }
    .pr-row:last-child { border-bottom: none; }
    .pr-row:hover { background: var(--gold-glow); }
    .pr-name {
      font-family: 'Oswald', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .pr-detail {
      font-size: 0.54rem;
      color: var(--muted);
      margin-top: 2px;
    }
    .pr-price {
      font-family: 'Oswald', sans-serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--gold);
      white-space: nowrap;
    }
    .pr-price small {
      font-size: 0.52rem;
      font-weight: 400;
      color: var(--muted);
    }

    .hours-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border: 1px solid var(--rule);
    }
    .hours-cell {
      padding: 0.85rem 1.25rem;
      border-right: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
    }
    .hours-cell:nth-child(even)         { border-right: none; }
    .hours-cell:nth-last-child(-n+2)    { border-bottom: none; }
    .hours-day {
      font-size: 0.46rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.2rem;
    }
    .hours-time {
      font-family: 'Oswald', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
    }

    .booking-cta-wrap {
      display: flex;
      align-items: center;
      gap: 1.6rem;
      flex-wrap: wrap;
    }
    .btn-book {
      font-family: 'Oswald', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--gold);
      padding: 1rem 2.5rem;
      text-decoration: none;
      display: inline-block;
      transition: background 0.2s;
    }
    .btn-book:hover { background: #fff; }
    .booking-note {
      font-size: 0.58rem;
      color: var(--muted);
      line-height: 1.75;
    }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--rule);
      padding: 2rem clamp(1.5rem, 5vw, 3.5rem);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      flex-wrap: wrap;
      position: relative;
      z-index: 1;
    }
    .footer-logo {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }
    .footer-logo em { font-style: normal; color: var(--gold); }
    .footer-info {
      font-size: 0.54rem;
      color: var(--muted);
      line-height: 1.75;
      text-align: center;
    }
    .footer-links {
      display: flex;
      gap: 1.5rem;
      list-style: none;
    }
    .footer-links a {
      font-size: 0.52rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--text); }

    /* ── RESPONSIVE ── */
    @media (max-width: 1100px) {
      .hero { grid-template-columns: 1fr; }
      .hero-right {
        border-left: none;
        border-top: 1px solid var(--rule);
        flex-direction: row;
        overflow-x: auto;
      }
      .timer-block {
        flex: 0 0 200px;
        border-bottom: none;
        border-right: 1px solid var(--rule);
      }
      .stats-grid {
        flex: 0 0 160px;
        grid-template-columns: 1fr;
        border-bottom: none;
        border-right: 1px solid var(--rule);
      }
      .stat-cell { border-right: none; border-bottom: 1px solid var(--rule); }
      .stat-cell:last-child { border-bottom: none; }
      .leaderboard { flex: 1 1 220px; min-width: 220px; }
      .lb-cta-block { display: none; }
      .hero-keyhole { display: none; }

      .process-steps { grid-template-columns: repeat(2, 1fr); }
      .step:nth-child(2) { border-right: none; }
      .step:nth-child(3) {
        border-top: 1px solid var(--rule);
        border-right: 1px solid var(--rule);
      }
      .step:nth-child(4) { border-top: 1px solid var(--rule); }
      .step:nth-child(2) .step-connector,
      .step:nth-child(4) .step-connector { display: none; }
    }

    @media (max-width: 768px) {
      .nav-links, .nav-cta { display: none; }
      .nav-hamburger { display: flex; }

      .hero { padding-top: 50px; }
      .hero-left { padding: 2.5rem 1.5rem; }

      .hero-right {
        flex-direction: column;
        overflow-x: visible;
      }
      .timer-block { flex: none; border-right: none; border-bottom: 1px solid var(--rule); }
      .stats-grid {
        flex: none;
        width: 100%;
        grid-template-columns: 1fr 1fr;
        border-right: none;
        border-bottom: 1px solid var(--rule);
      }
      .stat-cell { border-bottom: none; }
      .leaderboard { min-width: 0; }

      .rooms-grid { grid-template-columns: 1fr; gap: 1rem; }
      .rc-photo { height: 260px; }

      .process-steps { grid-template-columns: 1fr; }
      .step { border-right: none; border-bottom: 1px solid var(--rule); }
      .step:last-child { border-bottom: none; }
      .step .step-connector { display: none; }

      .booking {
        grid-template-columns: 1fr;
      }
      .booking-photo {
        min-height: 280px;
      }
      .booking-photo-overlay {
        background: linear-gradient(to bottom, transparent 40%, var(--bg) 100%);
      }

      footer { flex-direction: column; text-align: center; }
      .footer-links { justify-content: center; }
    }
  </style>
</head>
