---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Moselkorb — Regionale Spezialitaeten aus Trier &amp; der Mosel</title>
  <meta name="description" content="Moselkorb — Regionale Spezialitaeten von der Mosel direkt zu dir. Handverlesene Produkte von 42 Erzeugern aus der Region Trier." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&family=Prata&display=swap" rel="stylesheet" />

  <style>
    html { overflow-x: hidden; }
    body { overflow-x: hidden; max-width: 100%; }
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #2D5016;
      --secondary: #F9F5EC;
      --accent: #C4651A;
      --background: #FDFCF8;
      --text: #1A2E0A;
      --primary-light: #3a6a1d;
      --primary-dark: #1f3a0e;
      --accent-light: #d4782e;
      --border-subtle: #e5ddd0;
      --warm-shadow: rgba(26, 46, 10, 0.08);
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Open Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--text);
      background-color: var(--background);
      line-height: 1.7;
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
    }

    /* ============ NAVIGATION ============ */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: rgba(253, 252, 248, 0.95);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-subtle);
      transition: box-shadow 0.3s ease;
    }

    .nav.scrolled {
      box-shadow: 0 2px 20px var(--warm-shadow);
    }

    .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }

    .nav-logo {
      font-family: 'Prata', Georgia, serif;
      font-size: 1.5rem;
      color: var(--primary);
      text-decoration: none;
      letter-spacing: 0.01em;
    }

    .nav-logo span {
      color: var(--accent);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      text-decoration: none;
      color: var(--text);
      font-size: 0.9rem;
      font-weight: 500;
      transition: color 0.2s ease;
      letter-spacing: 0.02em;
    }

    .nav-links a:hover {
      color: var(--primary);
    }

    .nav-cart {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      background: var(--primary);
      color: #fff;
      padding: 0.5rem 1.1rem;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.2s ease;
    }

    .nav-cart:hover {
      background: var(--primary-dark);
    }

    .nav-cart-count {
      background: var(--accent);
      color: #fff;
      font-size: 0.7rem;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
    }

    .mobile-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
    }

    .mobile-toggle span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--text);
      margin: 5px 0;
      border-radius: 2px;
      transition: all 0.3s ease;
    }

    /* ============ HERO ============ */
    .hero {
      padding-top: 72px;
      min-height: 85vh;
      display: flex;
      align-items: center;
      background: var(--background);
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: -30%;
      right: -10%;
      width: 60%;
      height: 120%;
      background: radial-gradient(ellipse, rgba(45, 80, 22, 0.04) 0%, transparent 70%);
      pointer-events: none;
    }

    .hero-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 4rem 2rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
      width: 100%;
    }

    .hero-content {
      position: relative;
      z-index: 2;
    }

    .hero-badge {
      display: inline-block;
      background: var(--secondary);
      color: var(--accent);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.4rem 1rem;
      border-radius: 100px;
      border: 1px solid rgba(196, 101, 26, 0.15);
      margin-bottom: 1.5rem;
    }

    .hero-headline {
      font-family: 'Prata', Georgia, serif;
      font-size: clamp(2.5rem, 5vw, 3.8rem);
      line-height: 1.15;
      color: var(--text);
      margin-bottom: 1.2rem;
      font-weight: 400;
    }

    .hero-subtitle {
      font-size: 1.15rem;
      color: rgba(26, 46, 10, 0.7);
      line-height: 1.7;
      margin-bottom: 2rem;
      max-width: 420px;
    }

    .hero-trust {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1.5rem;
      margin-bottom: 2.5rem;
    }

    .hero-trust-item {
      font-size: 0.82rem;
      color: rgba(26, 46, 10, 0.6);
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-weight: 500;
    }

    .hero-trust-icon {
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: rgba(45, 80, 22, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .hero-trust-icon svg {
      width: 9px;
      height: 9px;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--primary);
      color: #fff;
      padding: 1rem 2.2rem;
      border-radius: 12px;
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s ease;
      box-shadow: 0 4px 16px rgba(45, 80, 22, 0.2);
    }

    .hero-cta:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(45, 80, 22, 0.3);
    }

    .hero-image-wrapper {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .hero-image-frame {
      position: relative;
      width: 100%;
      max-width: 480px;
      aspect-ratio: 4 / 5;
      border-radius: 24px;
      overflow: hidden;
      border: 3px solid rgba(196, 101, 26, 0.2);
      box-shadow: 0 20px 60px rgba(26, 46, 10, 0.12), 0 0 0 8px rgba(249, 245, 236, 0.6);
    }

    .hero-image-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .hero-image-accent {
      position: absolute;
      bottom: -16px;
      right: -16px;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: var(--secondary);
      border: 2px solid rgba(196, 101, 26, 0.12);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 3;
      box-shadow: 0 8px 24px var(--warm-shadow);
    }

    .hero-image-accent-number {
      font-family: 'Prata', Georgia, serif;
      font-size: 1.6rem;
      color: var(--primary);
      line-height: 1;
    }

    .hero-image-accent-label {
      font-size: 0.65rem;
      color: var(--accent);
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-top: 2px;
    }

    /* ============ BESTSELLER ============ */
    .bestseller {
      padding: 6rem 2rem;
      background: var(--secondary);
    }

    .bestseller-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    .section-label {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.8rem;
    }

    .section-title {
      font-family: 'Prata', Georgia, serif;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      color: var(--text);
      font-weight: 400;
      line-height: 1.2;
      margin-bottom: 0.8rem;
    }

    .section-subtitle {
      font-size: 1.05rem;
      color: rgba(26, 46, 10, 0.6);
      max-width: 480px;
      margin: 0 auto;
    }

    .product-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }

    .product-card {
      background: var(--background);
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid var(--border-subtle);
      transition: all 0.3s ease;
      position: relative;
      display: flex;
      flex-direction: column;
    }

    .product-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px var(--warm-shadow);
      border-color: rgba(45, 80, 22, 0.15);
    }

    .product-badge {
      position: absolute;
      top: 12px;
      left: 12px;
      background: var(--accent);
      color: #fff;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.3rem 0.8rem;
      border-radius: 100px;
      letter-spacing: 0.04em;
      z-index: 2;
    }

    .product-image {
      width: 100%;
      aspect-ratio: 1;
      overflow: hidden;
      background: var(--secondary);
    }

    .product-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.4s ease;
    }

    .product-card:hover .product-image img {
      transform: scale(1.05);
    }

    .product-info {
      padding: 1.2rem 1.2rem 1.4rem;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
    }

    .product-name {
      font-family: 'Prata', Georgia, serif;
      font-size: 1.05rem;
      color: var(--text);
      margin-bottom: 0.4rem;
      line-height: 1.3;
    }

    .product-desc {
      font-size: 0.82rem;
      color: rgba(26, 46, 10, 0.55);
      line-height: 1.5;
      margin-bottom: 1rem;
      flex-grow: 1;
    }

    .product-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
    }

    .product-price {
      font-family: 'Prata', Georgia, serif;
      font-size: 1.5rem;
      font-weight: 400;
      color: var(--primary);
      letter-spacing: -0.01em;
    }

    .product-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: var(--primary);
      color: #fff;
      padding: 0.55rem 1rem;
      border-radius: 8px;
      font-size: 0.8rem;
      font-weight: 600;
      border: none;
      cursor: pointer;
      transition: all 0.2s ease;
      white-space: nowrap;
    }

    .product-btn:hover {
      background: var(--primary-dark);
    }

    .product-btn svg {
      width: 14px;
      height: 14px;
    }

    /* ============ WARUM MOSELKORB ============ */
    .trust {
      padding: 6rem 2rem;
      background: var(--background);
      max-width: 1600px;
      margin: 0 auto;
    }

    .trust-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .trust-top {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
      margin-bottom: 4rem;
    }

    .trust-headline {
      font-family: 'Prata', Georgia, serif;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      color: var(--text);
      font-weight: 400;
      line-height: 1.25;
    }

    .trust-intro {
      font-size: 1.05rem;
      color: rgba(26, 46, 10, 0.65);
      line-height: 1.8;
    }

    .trust-elements {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-bottom: 4rem;
    }

    .trust-element {
      text-align: center;
      padding: 2.5rem 1.5rem;
      background: var(--secondary);
      border-radius: 16px;
      border: 1px solid var(--border-subtle);
      transition: all 0.3s ease;
    }

    .trust-element:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px var(--warm-shadow);
    }

    .trust-element-icon {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: rgba(45, 80, 22, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.2rem;
    }

    .trust-element-icon svg {
      width: 24px;
      height: 24px;
      color: var(--primary);
    }

    .trust-element-value {
      font-family: 'Prata', Georgia, serif;
      font-size: 2rem;
      color: var(--primary);
      margin-bottom: 0.3rem;
      letter-spacing: -0.02em;
    }

    .trust-element-label {
      font-size: 0.9rem;
      color: rgba(26, 46, 10, 0.6);
      font-weight: 500;
    }

    .trust-quote-section {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 3rem;
      align-items: center;
      background: var(--primary);
      border-radius: 20px;
      padding: 3.5rem;
      color: #fff;
    }

    .trust-quote {
      position: relative;
    }

    .trust-quote-mark {
      font-family: 'Prata', Georgia, serif;
      font-size: 4rem;
      color: rgba(255, 255, 255, 0.2);
      line-height: 1;
      margin-bottom: -1rem;
    }

    .trust-quote-text {
      font-family: 'Prata', Georgia, serif;
      font-size: 1.35rem;
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.95);
      margin-bottom: 1.5rem;
      font-style: italic;
    }

    .trust-quote-author {
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.6);
      font-weight: 500;
    }

    .trust-quote-author strong {
      color: rgba(255, 255, 255, 0.9);
      font-weight: 600;
    }

    .trust-contact {
      background: rgba(255, 255, 255, 0.08);
      border-radius: 14px;
      padding: 2rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .trust-contact-title {
      font-family: 'Prata', Georgia, serif;
      font-size: 1.15rem;
      color: #fff;
      margin-bottom: 1.2rem;
    }

    .trust-contact-item {
      display: flex;
      align-items: flex-start;
      gap: 0.8rem;
      margin-bottom: 1rem;
    }

    .trust-contact-item:last-child {
      margin-bottom: 0;
    }

    .trust-contact-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .trust-contact-icon svg {
      width: 15px;
      height: 15px;
      color: rgba(255, 255, 255, 0.7);
    }

    .trust-contact-label {
      font-size: 0.72rem;
      color: rgba(255, 255, 255, 0.45);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 600;
      margin-bottom: 0.15rem;
    }

    .trust-contact-value {
      font-size: 0.92rem;
      color: rgba(255, 255, 255, 0.85);
      line-height: 1.5;
    }

    /* ============ FOOTER ============ */
    .footer {
      padding: 3rem 2rem;
      background: var(--secondary);
      border-top: 1px solid var(--border-subtle);
      text-align: center;
    }

    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .footer-logo {
      font-family: 'Prata', Georgia, serif;
      font-size: 1.2rem;
      color: var(--primary);
      margin-bottom: 0.6rem;
    }

    .footer-text {
      font-size: 0.82rem;
      color: rgba(26, 46, 10, 0.45);
    }

    /* ============ RESPONSIVE ============ */
    @media (max-width: 1024px) {
      .product-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .trust-top {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .trust-quote-section {
        grid-template-columns: 1fr;
        padding: 2.5rem;
      }
    }

    @media (max-width: 768px) {
      .nav-links {
        display: none;
      }

      .mobile-toggle {
        display: block;
      }

      .nav-inner {
        height: 64px;
      }

      .hero {
        padding-top: 64px;
        min-height: auto;
      }

      .hero-inner {
        grid-template-columns: 1fr;
        gap: 2.5rem;
        padding: 3rem 1.5rem;
      }

      .hero-content {
        order: 1;
      }

      .hero-image-wrapper {
        order: 0;
      }

      .hero-image-frame {
        max-width: 360px;
        margin: 0 auto;
      }

      .hero-image-accent {
        width: 90px;
        height: 90px;
        bottom: -10px;
        right: -10px;
      }

      .hero-image-accent-number {
        font-size: 1.2rem;
      }

      .hero-image-accent-label {
        font-size: 0.55rem;
      }

      .hero-headline {
        font-size: 2.2rem;
      }

      .bestseller {
        padding: 4rem 1.5rem;
      }

      .product-grid {
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      .product-info {
        padding: 1rem;
      }

      .product-name {
        font-size: 0.95rem;
      }

      .product-footer {
        flex-direction: column;
        align-items: stretch;
        gap: 0.6rem;
      }

      .product-btn {
        justify-content: center;
        padding: 0.6rem;
      }

      .trust {
        padding: 4rem 1.5rem;
      }

      .trust-elements {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .trust-quote-section {
        padding: 2rem 1.5rem;
      }

      .trust-quote-text {
        font-size: 1.1rem;
      }
    }

    @media (max-width: 480px) {
      .product-grid {
        grid-template-columns: 1fr;
        max-width: 340px;
        margin: 0 auto;
      }

      .hero-trust {
        flex-direction: column;
        gap: 0.6rem;
      }
    }
  </style>
</head>

<body>

  <!-- NAVIGATION -->
  <nav class="nav" id="mainNav">
    <div class="nav-inner">
      <a href="#" class="nav-logo">Mosel<span>korb</span></a>
      <ul class="nav-links">
        <li><a href="#bestseller">Bestseller</a></li>
        <li><a href="#warum">Ueber uns</a></li>
        <li><a href="#kontakt">Kontakt</a></li>
        <li>
          <a href="#" class="nav-cart">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            Warenkorb
            <span class="nav-cart-count">3</span>
          </a>
        </li>
      </ul>
      <button class="mobile-toggle" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <span class="hero-badge">Neu: Fruehlingsbox 2026</span>
        <h1 class="hero-headline">Das Beste<br/>von hier.</h1>
        <p class="hero-subtitle">Regionale Spezialitaeten von der Mosel — direkt zu dir.</p>
        <div class="hero-trust">
          <span class="hero-trust-item">
            <span class="hero-trust-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#2D5016" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            Kostenloser Versand ab 49 EUR
          </span>
          <span class="hero-trust-item">
            <span class="hero-trust-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#2D5016" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            Lieferung in 2-3 Tagen
          </span>
          <span class="hero-trust-item">
            <span class="hero-trust-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#2D5016" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            100% Regional
          </span>
        </div>
        <a href="#bestseller" class="hero-cta">
          Jetzt stoebern
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <div class="hero-image-wrapper">
        <div class="hero-image-frame">
