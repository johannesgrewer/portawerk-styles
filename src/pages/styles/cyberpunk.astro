---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>NeuRoam — Digital Nomad Space & Co-Working | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@200;300;400;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --pink:  #FF0080;
      --green: #00FF41;
      --bg:    #0A000F;
      --text:  #E0FFE8;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Exo 2', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* CRT scanlines */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,255,65,0.025) 2px,
        rgba(0,255,65,0.025) 3px
      );
      pointer-events: none;
      z-index: 10;
    }

    /* Ambient glow */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 50% 40% at 10% 60%, rgba(255,0,128,0.08) 0%, transparent 60%),
        radial-gradient(ellipse 40% 50% at 90% 30%, rgba(0,255,65,0.06) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 2.5rem;
      background: rgba(10,0,15,0.92);
      border-bottom: 1px solid rgba(0,255,65,0.15);
    }
    .nav-logo {
      font-family: 'Share Tech Mono', monospace;
      font-size: 1.1rem;
      letter-spacing: 0.08em;
      color: var(--green);
      text-shadow: 0 0 10px rgba(0,255,65,0.5);
    }
    .nav-logo span { color: var(--pink); text-shadow: 0 0 10px rgba(255,0,128,0.5); }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(224,255,232,0.3);
      text-decoration: none;
      transition: color 0.15s, text-shadow 0.15s;
    }
    .nav-links a:hover {
      color: var(--green);
      text-shadow: 0 0 6px rgba(0,255,65,0.5);
    }
    .nav-access {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--green);
      padding: 0.5rem 1.2rem;
      text-decoration: none;
      box-shadow: 0 0 12px rgba(0,255,65,0.35);
      transition: box-shadow 0.2s;
    }
    .nav-access:hover { box-shadow: 0 0 24px rgba(0,255,65,0.6); }

    .hero {
      min-height: 100vh;
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      padding: 8rem 4rem 6rem;
      gap: 1.75rem;
    }

    /* Terminal prompt line */
    .terminal-line {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      color: var(--green);
      text-shadow: 0 0 6px rgba(0,255,65,0.4);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .terminal-line::before {
      content: '>';
      color: var(--pink);
      text-shadow: 0 0 6px rgba(255,0,128,0.5);
    }
    .cursor {
      display: inline-block;
      width: 8px;
      height: 14px;
      background: var(--green);
      animation: blink 1s step-end infinite;
      vertical-align: middle;
    }
    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

    .hero-headline {
      font-family: 'Share Tech Mono', monospace;
      font-size: clamp(2.8rem, 7vw, 6rem);
      line-height: 1.1;
      letter-spacing: -0.01em;
      max-width: 18ch;
    }
    .line-green {
      color: var(--green);
      text-shadow: 0 0 20px rgba(0,255,65,0.5), 0 0 40px rgba(0,255,65,0.2);
      display: block;
    }
    .line-pink {
      color: var(--pink);
      text-shadow: 0 0 20px rgba(255,0,128,0.5), 0 0 40px rgba(255,0,128,0.2);
      display: block;
    }
    .line-dim {
      color: rgba(224,255,232,0.2);
      display: block;
    }

    .hero-sub {
      font-size: 0.85rem;
      font-weight: 200;
      line-height: 1.9;
      color: rgba(224,255,232,0.4);
      max-width: 44ch;
      border-left: 2px solid rgba(0,255,65,0.2);
      padding-left: 1rem;
    }

    /* Tags */
    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .cp-tag {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.28rem 0.8rem;
      border: 1px solid;
    }
    .ct-green { color: var(--green); border-color: rgba(0,255,65,0.25); }
    .ct-pink  { color: var(--pink);  border-color: rgba(255,0,128,0.25); }
    .ct-dim   { color: rgba(224,255,232,0.3); border-color: rgba(224,255,232,0.08); }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 2rem;
    }
    .cta-btn {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--pink);
      text-decoration: none;
      padding: 0.85rem 2rem;
      box-shadow: 0 0 20px rgba(255,0,128,0.35);
      transition: box-shadow 0.2s;
    }
    .cta-btn:hover { box-shadow: 0 0 35px rgba(255,0,128,0.6); }
    .cta-link {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(224,255,232,0.25);
      text-decoration: none;
      transition: color 0.2s;
    }
    .cta-link:hover { color: var(--green); }

    /* Stats grid */
    .stats-grid {
      display: flex;
      gap: 2.5rem;
      margin-top: 0.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(0,255,65,0.08);
      width: 100%;
      max-width: 600px;
    }
    .sg-item {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .sg-num {
      font-family: 'Share Tech Mono', monospace;
      font-size: 1.5rem;
      line-height: 1;
      color: var(--green);
      text-shadow: 0 0 10px rgba(0,255,65,0.4);
    }
    .sg-label {
      font-size: 0.55rem;
      font-weight: 200;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(224,255,232,0.25);
    }

    /* Corner text */
    .corner {
      position: fixed;
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.42rem;
      letter-spacing: 0.15em;
      color: rgba(0,255,65,0.15);
      z-index: 5;
    }
    .corner.br { bottom: 1.5rem; right: 2rem; }
    .corner.bl { bottom: 1.5rem; left: 2rem; }

    /* Hero background photo */
    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
    }
    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.18;
      filter: saturate(0.4) hue-rotate(100deg);
    }
    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(10,0,15,0.85) 40%, rgba(10,0,15,0.4) 100%);
    }

    /* Photo container */
    .ph { position: relative; overflow: hidden; }
    .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
    .ph:hover img { transform: scale(1.05); }
    .ph-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(10,0,15,0.85) 0%, transparent 55%);
    }

    /* City grid section */
    .section-city {
      padding: 6rem 4rem;
      background: #0D0020;
      position: relative;
      z-index: 1;
    }
    .section-label {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.52rem;
      letter-spacing: 0.2em;
      color: var(--green);
      text-shadow: 0 0 6px rgba(0,255,65,0.35);
      margin-bottom: 0.5rem;
    }
    .section-label::before { content: '> '; color: var(--pink); }
    .section-title {
      font-family: 'Exo 2', sans-serif;
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 200;
      letter-spacing: -0.02em;
      color: var(--text);
      margin-bottom: 3rem;
    }
    .section-title em {
      font-style: normal;
      color: var(--pink);
      text-shadow: 0 0 15px rgba(255,0,128,0.4);
    }
    .city-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    .city-card {
      position: relative;
    }
    .city-card-body {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 1.25rem;
      z-index: 2;
    }
    .city-card-name {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      color: var(--green);
      text-shadow: 0 0 8px rgba(0,255,65,0.5);
      margin-bottom: 0.2rem;
    }
    .city-card-desc {
      font-size: 0.58rem;
      font-weight: 200;
      color: rgba(224,255,232,0.45);
      letter-spacing: 0.05em;
    }
    .city-card-tag {
      display: inline-block;
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.45rem;
      letter-spacing: 0.14em;
      color: var(--pink);
      border: 1px solid rgba(255,0,128,0.25);
      padding: 0.15rem 0.5rem;
      margin-top: 0.5rem;
    }

    /* Split section */
    .section-split {
      padding: 6rem 4rem;
      background: var(--bg);
      position: relative;
      z-index: 1;
    }
    .split-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
      max-width: 1400px;
      margin: 0 auto;
    }
    .split-body {
      font-size: 0.85rem;
      font-weight: 200;
      line-height: 1.9;
      color: rgba(224,255,232,0.4);
      max-width: 42ch;
      border-left: 2px solid rgba(0,255,65,0.15);
      padding-left: 1.25rem;
      margin-bottom: 2rem;
    }
    .split-features {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .sf-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(0,255,65,0.06);
    }
    .sf-dot {
      width: 6px; height: 6px;
      background: var(--pink);
      box-shadow: 0 0 6px rgba(255,0,128,0.5);
      flex-shrink: 0;
    }
    .sf-text {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.1em;
      color: rgba(224,255,232,0.35);
    }
  </style>
</head>
<body>
  <div class="corner br">SYS::TRIER-NODE-01</div>
  <div class="corner bl">UPTIME: 99.97% // NOMADS: 247</div>

  <nav>
    <div class="nav-logo">Neu<span>Roam</span></div>
    <ul class="nav-links">
      <li><a href="#">Workspace</a></li>
      <li><a href="#">Pläne</a></li>
      <li><a href="#">Community</a></li>
      <li><a href="#">Events</a></li>
    </ul>
    <a href="#" class="nav-access">Access beantragen</a>
  </nav>

  <section class="hero">
    <div class="hero-bg">
      <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1600&h=900&q=80" alt="Cyberpunk tech circuit board" loading="eager" />
    </div>
    <div class="terminal-line">
      NEUROAM_TRIER // CO-WORKING_SPACE // STATUS: ONLINE<span class="cursor"></span>
    </div>

    <h1 class="hero-headline">
      <span class="line-green">Plug in.</span>
      <span class="line-pink">Zone out.</span>
      <span class="line-dim">Ship it.</span>
    </h1>

    <p class="hero-sub">
      Kein Dresscode. Kein Bullshit-Office.<br>
      Nur schnelles Internet, guter Kaffee und<br>
      Menschen, die auch nachts noch liefern.
    </p>

    <div class="tag-row">
      <span class="cp-tag ct-green">24/7 Access</span>
      <span class="cp-tag ct-pink">10 Gbit/s</span>
      <span class="cp-tag ct-dim">Privat-Booths</span>
      <span class="cp-tag ct-green">Standing Desks</span>
      <span class="cp-tag ct-dim">Meetingräume</span>
    </div>

    <div class="cta-row">
      <a href="#" class="cta-btn">Jetzt einloggen →</a>
      <a href="#" class="cta-link">// Pläne & Preise</a>
    </div>

    <div class="stats-grid">
      <div class="sg-item">
        <div class="sg-num">247</div>
        <div class="sg-label">Aktive Nomads</div>
      </div>
      <div class="sg-item">
        <div class="sg-num">24/7</div>
        <div class="sg-label">Geöffnet</div>
      </div>
      <div class="sg-item">
        <div class="sg-num">10G</div>
        <div class="sg-label">Netzwerk</div>
      </div>
      <div class="sg-item">
        <div class="sg-num">ab 29€</div>
        <div class="sg-label">Pro Monat</div>
      </div>
    </div>
  </section>

  <!-- City grid section -->
  <section class="section-city">
    <div class="section-label">WORKSPACE_NODES // TRIER</div>
    <h2 class="section-title">Work in the <em>grid.</em></h2>
    <div class="city-grid">
      <div class="city-card">
        <div class="ph" style="height:320px;">
          <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&w=800&h=600&q=80" alt="Code on screen" />
          <div class="ph-overlay"></div>
        </div>
        <div class="city-card-body">
          <div class="city-card-name">// DEV_ZONE</div>
          <div class="city-card-desc">40 Dual-Monitor Plätze, 10 Gbit/s</div>
          <span class="city-card-tag">OPEN 24/7</span>
        </div>
      </div>
      <div class="city-card">
        <div class="ph" style="height:320px;">
          <img src="https://images.unsplash.com/photo-1461749280684-dccba630e2f6?auto=format&fit=crop&w=800&h=600&q=80" alt="Programming workspace" />
          <div class="ph-overlay"></div>
        </div>
        <div class="city-card-body">
          <div class="city-card-name">// FOCUS_POD</div>
          <div class="city-card-desc">8 schallisolierte Einzelkabinen</div>
          <span class="city-card-tag">BUCHBAR</span>
        </div>
      </div>
      <div class="city-card">
        <div class="ph" style="height:320px;">
          <img src="https://images.unsplash.com/photo-1550745165-9bc0b252726f?auto=format&fit=crop&w=800&h=600&q=80" alt="Neon gaming setup" />
          <div class="ph-overlay"></div>
        </div>
        <div class="city-card-body">
          <div class="city-card-name">// COLLAB_HUB</div>
          <div class="city-card-desc">Meetingraum, Beamer, Whiteboard</div>
          <span class="city-card-tag">4–12 PERSONEN</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Split section -->
  <section class="section-split">
    <div class="split-inner">
      <div>
        <div class="section-label">ABOUT_US // PROTOCOL</div>
        <h2 class="section-title">Kein <em>Bullshit.</em><br>Nur Speed.</h2>
        <p class="split-body">
          NeuRoam ist kein Office-Park mit Snackbar und Tischtennisplatte.
          Es ist eine Infrastruktur für Menschen, die Dinge bauen —
          schnell, fokussiert, ohne Ablenkung.
        </p>
        <div class="split-features">
          <div class="sf-row"><div class="sf-dot"></div><span class="sf-text">10 GBIT SYMETRISCH // KEIN TRAFFIC SHAPING</span></div>
          <div class="sf-row"><div class="sf-dot"></div><span class="sf-text">NFC-ZUGANGSKARTE // 24/7 ENTRY</span></div>
          <div class="sf-row"><div class="sf-dot"></div><span class="sf-text">STANDING DESKS + ERGOSTUHL INKLUSIVE</span></div>
          <div class="sf-row"><div class="sf-dot"></div><span class="sf-text">KAFFEE & GETRÄNKE FLATRATE</span></div>
          <div class="sf-row"><div class="sf-dot"></div><span class="sf-text">COMMUNITY // 200+ AKTIVE NOMADS</span></div>
        </div>
      </div>
      <div class="ph" style="height:480px;">
        <img src="https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?auto=format&fit=crop&w=800&h=1000&q=80" alt="Matrix digital rain" />
        <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(10,0,15,0.3) 0%,transparent 60%);"></div>
      </div>
    </div>
  </section>
</body>
</html>
