---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Rohbau — Ateliergemeinschaft & Kreativraum | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Karla:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --dark:  #2A2520;
      --rust:  #C4651A;
      --bg:    #F2EDE5;
      --warm:  #EAE3D8;
      --muted: rgba(42,37,32,0.45);
      --rule:  rgba(42,37,32,0.1);
    }

    body {
      background: var(--bg);
      color: var(--dark);
      font-family: 'Karla', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Concrete texture via gradient */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: repeating-linear-gradient(
        45deg,
        transparent 0px,
        transparent 40px,
        rgba(42,37,32,0.012) 40px,
        rgba(42,37,32,0.012) 41px
      );
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0;
      background: var(--dark);
      height: 56px;
    }
    .nav-logo-area {
      display: flex;
      align-items: center;
      height: 100%;
      padding: 0 2.5rem;
      border-right: 1px solid rgba(242,237,229,0.08);
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 0.18em;
      color: var(--bg);
    }
    .nav-logo span { color: var(--rust); }
    .nav-links {
      display: flex;
      gap: 0;
      list-style: none;
      flex: 1;
      height: 100%;
    }
    .nav-links li {
      height: 100%;
      border-right: 1px solid rgba(242,237,229,0.05);
    }
    .nav-links a {
      display: flex;
      align-items: center;
      height: 100%;
      padding: 0 1.5rem;
      font-size: 0.58rem;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(242,237,229,0.3);
      text-decoration: none;
      transition: color 0.2s, background 0.2s;
    }
    .nav-links a:hover { color: var(--bg); background: rgba(242,237,229,0.04); }
    .nav-cta {
      display: flex;
      align-items: center;
      height: 100%;
      padding: 0 2rem;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--dark);
      background: var(--rust);
      text-decoration: none;
      transition: background 0.2s;
    }
    .nav-cta:hover { background: var(--bg); }

    .hero {
      min-height: 100vh;
      padding-top: 56px;
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    /* LEFT */
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 3.5rem 4rem 4.5rem;
      gap: 2.5rem;
      border-right: 2px solid rgba(42,37,32,0.1);
    }

    .tag-row {
      display: flex;
      gap: 0.4rem;
    }
    .tag {
      font-size: 0.52rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.22rem 0.65rem;
      border: 1px solid rgba(42,37,32,0.15);
      color: var(--muted);
    }
    .tag.active { background: var(--dark); color: var(--bg); border-color: var(--dark); }

    .hero-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(4rem, 9vw, 8rem);
      line-height: 0.88;
      letter-spacing: 0.04em;
      color: var(--dark);
    }
    .hero-headline .rust { color: var(--rust); }
    .hero-headline .light { color: rgba(42,37,32,0.18); }

    .hero-body {
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 1.9;
      color: var(--muted);
      max-width: 44ch;
    }

    /* Studio spaces */
    .space-list {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--rule);
      background: #fff;
    }
    .sl-header {
      background: var(--dark);
      padding: 0.4rem 1rem;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      color: rgba(242,237,229,0.4);
    }
    .space-row {
      display: flex;
      align-items: center;
      padding: 0.85rem 1rem;
      gap: 1rem;
      border-bottom: 1px solid var(--rule);
    }
    .space-row:last-child { border-bottom: none; }
    .sr-size {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      letter-spacing: 0.06em;
      color: var(--rust);
      width: 4rem;
      flex-shrink: 0;
    }
    .sr-info { flex: 1; }
    .sr-name {
      font-size: 0.88rem;
      font-weight: 500;
      color: var(--dark);
    }
    .sr-desc {
      font-size: 0.62rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 0.05rem;
    }
    .sr-status {
      font-size: 0.52rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.2rem 0.55rem;
    }
    .s-free { background: rgba(42,37,32,0.06); color: var(--dark); }
    .s-taken { background: rgba(196,101,26,0.1); color: var(--rust); }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .cta-btn {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--dark);
      padding: 0.85rem 2rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .cta-btn:hover { background: var(--rust); }
    .cta-link {
      font-size: 0.62rem;
      font-weight: 400;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 1px;
    }

    /* RIGHT */
    .hero-right {
      background: var(--warm);
      display: flex;
      flex-direction: column;
      padding: 4rem 3.5rem;
      gap: 2.5rem;
    }

    .right-label {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      color: rgba(42,37,32,0.3);
    }

    /* Resident cards */
    .resident-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.6rem;
    }
    .resident-card {
      background: #fff;
      border: 1px solid var(--rule);
      padding: 1.1rem;
      border-left: 3px solid var(--rust);
    }
    .rc-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1rem;
      letter-spacing: 0.08em;
      color: var(--dark);
    }
    .rc-craft {
      font-size: 0.62rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 0.15rem;
    }

    /* Building facts */
    .facts-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      border: 1px solid var(--rule);
      background: #fff;
    }
    .fact-cell {
      padding: 1.25rem;
      border-right: 1px solid var(--rule);
      text-align: center;
    }
    .fact-cell:last-child { border-right: none; }
    .fc-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      letter-spacing: 0.04em;
      color: var(--rust);
      line-height: 1;
    }
    .fc-label {
      font-size: 0.58rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 0.2rem;
    }

    /* Info */
    .info-block {
      background: var(--dark);
      padding: 1.5rem;
      margin-top: auto;
    }
    .ib-label {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      color: rgba(242,237,229,0.25);
      margin-bottom: 0.4rem;
    }
    .ib-value {
      font-size: 0.85rem;
      font-weight: 300;
      color: rgba(242,237,229,0.75);
      line-height: 1.6;
    }
    /* === Animations & Micro-interactions === */
    @keyframes factPulse {
      0%, 100% { transform: scale(1); }
      50%       { transform: scale(1.04); }
    }

    .resident-card {
      transition: transform 0.2s, box-shadow 0.2s;
      cursor: default;
    }
    .resident-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(42,37,32,0.1);
    }
    .rc-name { transition: color 0.2s; }
    .resident-card:hover .rc-name { color: var(--rust); }

    .space-row {
      border-left: 3px solid transparent;
      transition: background 0.2s, border-left-color 0.25s, padding-left 0.25s;
    }
    .space-row:hover {
      background: rgba(196,101,26,0.04);
      border-left-color: var(--rust);
      padding-left: calc(1rem - 3px);
    }
    .sr-name { transition: color 0.2s; }
    .space-row:hover .sr-name { color: var(--rust); }

    .fact-cell {
      transition: background 0.2s;
      cursor: default;
    }
    .fact-cell:hover { background: rgba(196,101,26,0.05); }
    .fc-num { transition: transform 0.3s; }
    .fact-cell:hover .fc-num { animation: factPulse 0.4s ease-in-out; }

    .tag {
      transition: background 0.2s, color 0.2s, border-color 0.2s;
      cursor: default;
    }
    .tag:not(.active):hover {
      background: rgba(42,37,32,0.06);
      color: var(--dark);
    }

    .cta-btn {
      position: relative;
      overflow: hidden;
    }
    .cta-btn::after {
      content: '';
      position: absolute;
      top: 0; left: -60%;
      width: 40%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
      transition: left 0.5s;
    }
    .cta-btn:hover::after { left: 150%; }

  </style>
</head>
<body>
  <nav>
    <div class="nav-logo-area">
      <div class="nav-logo">ROH<span>BAU</span></div>
    </div>
    <ul class="nav-links">
      <li><a href="#">Ateliers</a></li>
      <li><a href="#">Residenten</a></li>
      <li><a href="#">Events</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <a href="#" class="nav-cta">Atelier anfragen</a>
  </nav>

  <section class="hero">
    <div class="hero-left">
      <div class="tag-row">
        <span class="tag active">Kreativraum</span>
        <span class="tag">Trier-Nord</span>
        <span class="tag">Seit 2019</span>
      </div>

      <h1 class="hero-headline">
        <span class="light">UN</span>FER<br>
        <span class="rust">TIG.</span><br>
        ABS.
      </h1>

      <p class="hero-body">
        Eine ehemalige Fabrikhalle, 14 Ateliers, über
        30 Kreative. Rohbau ist kein fertiger Ort —
        das ist das Konzept.
      </p>

      <div class="space-list">
        <div class="sl-header">Verfügbare Ateliers</div>
        <div class="space-row">
          <div class="sr-size">18 m²</div>
          <div class="sr-info">
            <div class="sr-name">Kleinatelier B-3</div>
            <div class="sr-desc">Naturlicht · Einzelperson</div>
          </div>
          <span class="sr-status s-free">Frei</span>
        </div>
        <div class="space-row">
          <div class="sr-size">34 m²</div>
          <div class="sr-info">
            <div class="sr-name">Atelier OG-1</div>
            <div class="sr-desc">Dachfenster · 2 Personen</div>
          </div>
          <span class="sr-status s-free">Frei</span>
        </div>
        <div class="space-row">
          <div class="sr-size">60 m²</div>
          <div class="sr-info">
            <div class="sr-name">Großatelier Halle</div>
            <div class="sr-desc">Hohe Decken · Gruppe</div>
          </div>
          <span class="sr-status s-taken">Belegt</span>
        </div>
      </div>

      <div class="cta-row">
        <a href="#" class="cta-btn">Atelier anfragen →</a>
        <a href="#" class="cta-link">Alle Räume ansehen</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="right-label">Unsere Residenten</div>

      <div class="resident-grid">
        <div class="resident-card">
          <div class="rc-name">Marta Voss</div>
          <div class="rc-craft">Malerei · Großformat</div>
        </div>
        <div class="resident-card">
          <div class="rc-name">Studio Kien</div>
          <div class="rc-craft">Keramik & Objekt</div>
        </div>
        <div class="resident-card">
          <div class="rc-name">Tom Ehrlich</div>
          <div class="rc-craft">Illustration · Print</div>
        </div>
        <div class="resident-card">
          <div class="rc-name">Raum 12</div>
          <div class="rc-craft">Fotografie · Studio</div>
        </div>
        <div class="resident-card">
          <div class="rc-name">Ines Walther</div>
          <div class="rc-craft">Textil & Installation</div>
        </div>
        <div class="resident-card">
          <div class="rc-name">+27 weitere</div>
          <div class="rc-craft">Alle Disziplinen</div>
        </div>
      </div>

      <div class="facts-row">
        <div class="fact-cell">
          <div class="fc-num">32</div>
          <div class="fc-label">Kreative</div>
        </div>
        <div class="fact-cell">
          <div class="fc-num">1.200</div>
          <div class="fc-label">m² Fläche</div>
        </div>
        <div class="fact-cell">
          <div class="fc-num">1962</div>
          <div class="fc-label">Baujahr</div>
        </div>
      </div>

      <div class="info-block">
        <div class="ib-label">Besichtigung & Kontakt</div>
        <div class="ib-value">Di + Do 14 – 18 Uhr · offene Tür<br>rohbau-trier.de · hallo@rohbau-trier.de</div>
      </div>
    </div>
  </section>
</body>
</html>
