---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>KELLER B3 — Techno Club Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --acid:  #BCFF00;
      --red:   #FF2200;
      --white: #FFFFFF;
      --black: #000000;
    }

    body {
      background: var(--black);
      color: var(--white);
      font-family: 'Space Mono', monospace;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Scanlines */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(188,255,0,0.012) 3px,
        rgba(188,255,0,0.012) 4px
      );
      pointer-events: none;
      z-index: 999;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 3rem;
      height: 56px;
      background: rgba(0,0,0,0.94);
      border-bottom: 1px solid rgba(188,255,0,0.1);
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.45rem;
      letter-spacing: 0.14em;
      color: var(--white);
    }
    .nav-logo span { color: var(--acid); }
    .nav-links {
      display: flex;
      list-style: none;
    }
    .nav-links a {
      display: block;
      padding: 0 1.2rem;
      height: 56px;
      line-height: 56px;
      font-size: 0.5rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.22);
      text-decoration: none;
      border-right: 1px solid rgba(255,255,255,0.05);
      transition: color 0.2s;
    }
    .nav-links li:first-child a { border-left: 1px solid rgba(255,255,255,0.05); }
    .nav-links a:hover { color: var(--acid); }
    .nav-tickets {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.9rem;
      letter-spacing: 0.15em;
      color: var(--black);
      background: var(--acid);
      padding: 0.45rem 1.5rem;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .nav-tickets:hover { opacity: 0.85; }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 100vh;
      padding-top: 56px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .hero-bg img {
      width: 100%; height: 100%;
      object-fit: cover;
      opacity: 0.2;
      filter: grayscale(0.8) contrast(1.4);
    }
    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom,
        rgba(0,0,0,0.55) 0%,
        rgba(0,0,0,0.25) 45%,
        rgba(0,0,0,0.9) 100%
      );
    }

    /* Rotating acid ring */
    .acid-ring {
      position: absolute;
      right: -10vw;
      top: 50%;
      transform: translateY(-55%);
      width: 58vw;
      height: 58vw;
      border-radius: 50%;
      border: 1px solid rgba(188,255,0,0.07);
      animation: ringRotate 35s linear infinite;
      z-index: 1;
      pointer-events: none;
    }
    .acid-ring::before {
      content: '';
      position: absolute;
      inset: 10%;
      border-radius: 50%;
      border: 1px solid rgba(188,255,0,0.04);
    }
    .acid-ring::after {
      content: '';
      position: absolute;
      inset: 22%;
      border-radius: 50%;
      border: 2px solid rgba(188,255,0,0.11);
    }
    @keyframes ringRotate {
      to { transform: translateY(-55%) rotate(360deg); }
    }

    /* Cross-hair decoration */
    .acid-cross {
      position: absolute;
      right: 8vw;
      top: 50%;
      width: 24px;
      height: 24px;
      transform: translateY(-50%);
      z-index: 2;
      pointer-events: none;
    }
    .acid-cross::before {
      content: '';
      position: absolute;
      left: 50%; top: 0;
      width: 1px; height: 100%;
      background: rgba(188,255,0,0.3);
    }
    .acid-cross::after {
      content: '';
      position: absolute;
      top: 50%; left: 0;
      width: 100%; height: 1px;
      background: rgba(188,255,0,0.3);
    }

    .hero-content {
      position: relative;
      z-index: 2;
      padding: 3.5rem 3.5rem 2.5rem;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 2rem;
    }

    .hero-overline {
      font-size: 0.48rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--acid);
      display: flex;
      align-items: center;
      gap: 0.9rem;
    }
    .hero-overline::before {
      content: '';
      display: block;
      width: 36px;
      height: 1px;
      background: var(--acid);
      flex-shrink: 0;
    }

    /* Glitch headline */
    .hero-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5.5rem, 15vw, 13.5rem);
      line-height: 0.86;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      color: var(--white);
    }
    .gw {
      display: block;
      position: relative;
    }
    .gw[data-t]::before,
    .gw[data-t]::after {
      content: attr(data-t);
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
    }
    .gw[data-t]::before {
      color: var(--acid);
      animation: gb 5s infinite linear;
    }
    .gw[data-t]::after {
      color: var(--red);
      animation: ga 5s infinite linear;
    }
    @keyframes gb {
      0%,87%,100% { opacity:0; clip-path:inset(0 0 100% 0); }
      88% { opacity:1; clip-path:inset(28% 0 42% 0); transform:translateX(-5px); }
      89% { clip-path:inset(58% 0 18% 0); transform:translateX(-7px); }
      90% { opacity:0; }
    }
    @keyframes ga {
      0%,81%,100% { opacity:0; clip-path:inset(0 0 100% 0); }
      82% { opacity:1; clip-path:inset(52% 0 22% 0); transform:translateX(4px); }
      83% { clip-path:inset(18% 0 62% 0); transform:translateX(6px); }
      84% { opacity:0; }
    }

    .hero-headline .acid-w { color: var(--acid); }
    .hero-headline .outline-w {
      -webkit-text-stroke: 1.5px rgba(255,255,255,0.18);
      color: transparent;
    }

    .hero-sub {
      font-size: 0.65rem;
      line-height: 1.95;
      color: rgba(255,255,255,0.28);
      max-width: 40ch;
      border-left: 2px solid rgba(188,255,0,0.18);
      padding-left: 1rem;
    }

    /* Ticker */
    .hero-ticker {
      position: relative;
      z-index: 2;
      border-top: 1px solid rgba(188,255,0,0.1);
      background: rgba(0,0,0,0.75);
      display: flex;
      align-items: stretch;
      overflow: hidden;
    }
    .ticker-label {
      padding: 0.8rem 1.5rem;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.82rem;
      letter-spacing: 0.1em;
      background: var(--acid);
      color: var(--black);
      white-space: nowrap;
      display: flex;
      align-items: center;
      flex-shrink: 0;
    }
    .ticker-track {
      flex: 1;
      overflow: hidden;
      display: flex;
      align-items: center;
      padding: 0;
    }
    .ticker-inner {
      display: flex;
      gap: 0;
      animation: tickScroll 22s linear infinite;
      white-space: nowrap;
    }
    .ti {
      font-size: 0.48rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.18);
      padding: 0.8rem 1.5rem;
      border-right: 1px solid rgba(255,255,255,0.04);
    }
    .ti strong { color: rgba(255,255,255,0.75); }
    @keyframes tickScroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ── EVENTS ── */
    .events {
      padding: 6rem 3.5rem;
      border-top: 1px solid rgba(255,255,255,0.04);
    }

    .section-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 3rem;
      gap: 2rem;
    }
    .s-tag {
      font-size: 0.46rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--acid);
      margin-bottom: 0.55rem;
    }
    .s-tag::before { content: '— '; }
    .s-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.4rem, 4.5vw, 4rem);
      line-height: 0.9;
      letter-spacing: 0.04em;
      color: var(--white);
    }
    .s-link {
      font-size: 0.48rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.18);
      text-decoration: none;
      white-space: nowrap;
      transition: color 0.2s;
    }
    .s-link::after { content: ' →'; }
    .s-link:hover { color: var(--acid); }

    .event-list {
      border-top: 1px solid rgba(255,255,255,0.05);
    }
    .event-item {
      display: grid;
      grid-template-columns: 110px 1fr auto auto;
      align-items: center;
      gap: 2.5rem;
      padding: 1.5rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      transition: background 0.25s;
      cursor: default;
    }
    .event-item:hover { background: rgba(188,255,0,0.025); }
    .ev-date {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.45rem;
      letter-spacing: 0.08em;
      color: var(--acid);
      line-height: 1;
    }
    .ev-date small {
      display: block;
      font-family: 'Space Mono', monospace;
      font-size: 0.42rem;
      letter-spacing: 0.2em;
      color: rgba(255,255,255,0.18);
      margin-top: 0.18rem;
    }
    .ev-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      letter-spacing: 0.05em;
      color: var(--white);
      line-height: 1;
      margin-bottom: 0.28rem;
    }
    .ev-artists {
      font-size: 0.52rem;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.28);
    }
    .ev-tags {
      display: flex;
      gap: 0.35rem;
    }
    .ev-tag {
      font-size: 0.4rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.2rem 0.5rem;
      border: 1px solid rgba(188,255,0,0.15);
      color: rgba(188,255,0,0.45);
    }
    .ev-btn {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      color: var(--black);
      background: var(--white);
      padding: 0.5rem 1.2rem;
      text-decoration: none;
      white-space: nowrap;
      transition: background 0.2s;
    }
    .ev-btn:hover { background: var(--acid); }
    .ev-btn.sold {
      background: transparent;
      color: rgba(255,255,255,0.14);
      border: 1px solid rgba(255,255,255,0.07);
      cursor: not-allowed;
    }

    /* ── ARTISTS ── */
    .artists {
      padding: 6rem 3.5rem;
      background: #050505;
      border-top: 1px solid rgba(255,255,255,0.04);
    }
    .artist-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      margin-top: 3rem;
    }
    .artist-card {
      position: relative;
      overflow: hidden;
    }

    /* Photo container */
    .ph { position: relative; overflow: hidden; }
    .ph img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease, filter 0.4s;
      filter: grayscale(0.65);
    }
    .ph:hover img { transform: scale(1.05); filter: grayscale(0.1); }

    .artist-grad {
      position: absolute; inset: 0;
      background: linear-gradient(to top,
        rgba(0,0,0,0.92) 0%,
        rgba(0,0,0,0.25) 55%,
        transparent 100%
      );
      z-index: 1;
    }
    .artist-body {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 1.5rem 1.5rem 1.75rem;
      z-index: 2;
    }
    .artist-origin {
      font-size: 0.4rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--acid);
      margin-bottom: 0.3rem;
    }
    .artist-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.7rem;
      letter-spacing: 0.04em;
      color: var(--white);
      line-height: 0.95;
      margin-bottom: 0.45rem;
    }
    .artist-genre {
      font-size: 0.46rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.22);
    }
    .artist-dot {
      position: absolute;
      top: 1rem; right: 1rem;
      width: 7px; height: 7px;
      background: var(--acid);
      z-index: 2;
      animation: dotPulse 2s ease-in-out infinite;
    }
    @keyframes dotPulse {
      0%,100% { opacity: 1; }
      50% { opacity: 0.25; }
    }

    /* ── LOCATION ── */
    .location {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 520px;
      border-top: 1px solid rgba(255,255,255,0.04);
    }
    .loc-img {
      position: relative;
      overflow: hidden;
    }
    .loc-img img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: grayscale(0.5);
      transition: filter 0.4s;
    }
    .loc-img:hover img { filter: grayscale(0.1); }
    .loc-img::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to right, transparent 55%, #000 100%);
    }
    .loc-content {
      padding: 5rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 2rem;
      background: #000;
      border-left: 1px solid rgba(255,255,255,0.04);
    }
    .loc-tag {
      font-size: 0.46rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--acid);
    }
    .loc-tag::before { content: '— '; }
    .loc-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.4rem, 3.8vw, 3.8rem);
      line-height: 0.9;
      letter-spacing: 0.03em;
      color: var(--white);
    }
    .loc-body {
      font-size: 0.62rem;
      line-height: 1.95;
      color: rgba(255,255,255,0.22);
      max-width: 38ch;
    }
    .loc-specs { display: flex; flex-direction: column; }
    .spec-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.7rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .spec-k {
      font-size: 0.5rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.18);
    }
    .spec-v {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.9rem;
      letter-spacing: 0.08em;
      color: var(--white);
    }
    .spec-v.acid { color: var(--acid); }

    /* ── FOOTER BAR ── */
    .footer-bar {
      padding: 1.4rem 3.5rem;
      background: #000;
      border-top: 1px solid rgba(188,255,0,0.07);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .footer-left {
      font-size: 0.44rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.1);
    }
    .footer-right {
      display: flex;
      gap: 2rem;
    }
    .footer-right a {
      font-size: 0.44rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.1);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-right a:hover { color: var(--acid); }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      nav { padding: 0 1.5rem; }
      .nav-links { display: none; }
      .hero-content { padding: 2.5rem 1.5rem 2rem; }
      .hero-ticker { flex-direction: column; }
      .ticker-label { justify-content: center; }
      .events, .artists { padding: 4rem 1.5rem; }
      .event-item {
        grid-template-columns: 80px 1fr;
        grid-template-rows: auto auto;
        gap: 0.75rem 1.25rem;
      }
      .ev-tags { grid-column: 2; }
      .ev-btn  { grid-column: 1 / -1; text-align: center; }
      .artist-grid { grid-template-columns: 1fr 1fr; gap: 1px; }
      .artist-grid .artist-card:nth-child(3) { display: none; }
      .location { grid-template-columns: 1fr; }
      .loc-img { min-height: 280px; }
      .loc-img::after { background: linear-gradient(to bottom, transparent 50%, #000 100%); }
      .loc-content { padding: 3rem 1.5rem; }
      .footer-bar { flex-direction: column; text-align: center; }
    }
    @media (max-width: 480px) {
      .artist-grid { grid-template-columns: 1fr; }
      .artist-grid .artist-card:nth-child(3) { display: block; }
      .section-head { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>

  <nav>
    <div class="nav-logo">KELL<span>ER</span></div>
    <ul class="nav-links">
      <li><a href="#">Events</a></li>
      <li><a href="#">Artists</a></li>
      <li><a href="#">Location</a></li>
      <li><a href="#">Booking</a></li>
    </ul>
    <a href="#" class="nav-tickets">Tickets →</a>
  </nav>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?auto=format&fit=crop&w=1800&h=1000&q=80"
        alt="Underground Rave Crowd"
        loading="eager"
      />
    </div>
    <div class="acid-ring"></div>
    <div class="acid-cross"></div>

    <div class="hero-content">
      <div class="hero-overline">Trier Hafen &nbsp;·&nbsp; Underground Collective &nbsp;·&nbsp; Seit 2019</div>

      <h1 class="hero-headline">
        <span class="gw" data-t="KELLER">KELLER</span>
        <span class="outline-w">UNTER</span>
        <span class="acid-w">GRUND</span>
      </h1>

      <p class="hero-sub">
        Kein VIP. Kein Dresscode. Kein Ende.<br>
        Techno, Acid und Noise aus dem Untergeschoss<br>
        des Trierer Hafenviertels.
      </p>
    </div>

    <div class="hero-ticker">
      <div class="ticker-label">Next Events</div>
      <div class="ticker-track">
        <div class="ticker-inner">
          <span class="ti"><strong>Fr 14.03.</strong> — Tekk Nacht Vol. 9</span>
          <span class="ti"><strong>Sa 22.03.</strong> — Acid Rain w/ Klaudia Kraft</span>
          <span class="ti"><strong>Fr 04.04.</strong> — Black Room · Members Only</span>
          <span class="ti"><strong>Sa 12.04.</strong> — Transmission 08 · Phase Fatale</span>
          <!-- duplicate for seamless loop -->
          <span class="ti"><strong>Fr 14.03.</strong> — Tekk Nacht Vol. 9</span>
          <span class="ti"><strong>Sa 22.03.</strong> — Acid Rain w/ Klaudia Kraft</span>
          <span class="ti"><strong>Fr 04.04.</strong> — Black Room · Members Only</span>
          <span class="ti"><strong>Sa 12.04.</strong> — Transmission 08 · Phase Fatale</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── EVENTS ── -->
  <section class="events" id="events">
    <div class="section-head">
      <div>
        <div class="s-tag">Upcoming</div>
        <h2 class="s-title">Events &amp;<br>Programme</h2>
      </div>
      <a href="#" class="s-link">Alle Events anzeigen</a>
    </div>

    <div class="event-list">
      <div class="event-item">
        <div class="ev-date">14.03<small>Freitag · 23:00</small></div>
        <div>
          <div class="ev-name">Tekk Nacht Vol. 9</div>
          <div class="ev-artists">Kobayashi b2b Renate &nbsp;·&nbsp; DJ Messer &nbsp;·&nbsp; Koda</div>
        </div>
        <div class="ev-tags">
          <span class="ev-tag">Techno</span>
          <span class="ev-tag">Industrial</span>
        </div>
        <a href="#" class="ev-btn">Ticket →</a>
      </div>

      <div class="event-item">
        <div class="ev-date">22.03<small>Samstag · 22:00</small></div>
        <div>
          <div class="ev-name">Acid Rain</div>
          <div class="ev-artists">Klaudia Kraft &nbsp;·&nbsp; Lützenkirchen &nbsp;·&nbsp; Roland 303</div>
        </div>
        <div class="ev-tags">
          <span class="ev-tag">Acid</span>
          <span class="ev-tag">303</span>
          <span class="ev-tag">Trance</span>
        </div>
        <a href="#" class="ev-btn">Ticket →</a>
      </div>

      <div class="event-item">
        <div class="ev-date">04.04<small>Freitag · 23:00</small></div>
        <div>
          <div class="ev-name">Black Room</div>
