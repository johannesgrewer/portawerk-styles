---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>KORN — Fotografisches Atelier | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=IBM+Plex+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --ink: #080808;
      --paper: #f7f7f5;
      --ink-50: rgba(8,8,8,0.5);
      --ink-30: rgba(8,8,8,0.3);
      --ink-15: rgba(8,8,8,0.15);
      --ink-08: rgba(8,8,8,0.08);
    }

    body {
      background: var(--paper);
      color: var(--ink);
      font-family: 'IBM Plex Mono', monospace;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Subtle grain overlay */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 250 250' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)' opacity='0.025'/%3E%3C/svg%3E");
      background-size: 250px;
      pointer-events: none;
      z-index: 9999;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 4rem;
      background: var(--paper);
      border-bottom: 1px solid var(--ink);
    }
    .nav-logo {
      font-family: 'IBM Plex Mono', monospace;
      font-weight: 400;
      font-size: 1rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--ink);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.52rem;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink-50);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--ink); }
    .nav-cta {
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--paper);
      background: var(--ink);
      padding: 0.55rem 1.4rem;
      text-decoration: none;
      border: 1px solid var(--ink);
      transition: background 0.15s, color 0.15s;
    }
    .nav-cta:hover { background: transparent; color: var(--ink); }

    /* HERO */
    .hero {
      min-height: 100vh;
      padding-top: 60px;
      display: grid;
      grid-template-columns: 42% 1px 1fr;
    }
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 4.5rem 4rem 4rem 5rem;
    }
    .hero-meta {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .meta-line {
      font-size: 0.46rem;
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--ink-30);
    }
    .hero-center {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 2rem 0;
    }
    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-weight: 300;
      font-size: clamp(4.5rem, 10vw, 9rem);
      line-height: 0.88;
      letter-spacing: -0.01em;
      color: var(--ink);
      margin-bottom: 2.5rem;
    }
    h1 .stroke {
      font-style: normal;
      font-weight: 300;
      -webkit-text-stroke: 1.5px var(--ink);
      color: transparent;
    }
    .hero-body {
      font-size: 0.68rem;
      font-weight: 300;
      line-height: 1.95;
      color: var(--ink-50);
      max-width: 40ch;
    }
    .hero-bottom {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      padding-top: 2rem;
      border-top: 1px solid var(--ink-15);
    }
    .cta-group {
      display: flex;
      align-items: center;
      gap: 1.8rem;
    }
    .btn-primary {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--paper);
      background: var(--ink);
      padding: 0.8rem 1.8rem;
      text-decoration: none;
      border: 1px solid var(--ink);
      transition: background 0.15s, color 0.15s;
    }
    .btn-primary:hover { background: transparent; color: var(--ink); }
    .btn-ghost {
      font-size: 0.46rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-30);
      text-decoration: none;
      transition: color 0.2s;
    }
    .btn-ghost:hover { color: var(--ink); }
    .hero-est {
      font-size: 0.42rem;
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--ink-30);
    }

    .v-rule { background: var(--ink); }

    .hero-photo {
      position: relative;
      overflow: hidden;
    }
    .hero-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(100%) contrast(1.1);
    }
    .hero-photo::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(8,8,8,0.3) 0%, transparent 35%);
      pointer-events: none;
    }
    .photo-tag {
      position: absolute;
      bottom: 1.5rem;
      right: 1.5rem;
      font-size: 0.4rem;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(247,247,245,0.35);
      z-index: 2;
    }

    /* STATS STRIP */
    .stats-strip {
      background: var(--ink);
      display: flex;
      border-top: 1px solid var(--ink);
    }
    .stat-item {
      flex: 1;
      padding: 2rem 3rem;
      border-right: 1px solid rgba(247,247,245,0.08);
      text-align: center;
    }
    .stat-item:last-child { border-right: none; }
    .stat-num {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: clamp(2rem, 3.5vw, 2.8rem);
      line-height: 1;
      letter-spacing: -0.02em;
      color: rgba(247,247,245,0.88);
    }
    .stat-label {
      font-size: 0.42rem;
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(247,247,245,0.22);
      margin-top: 0.5rem;
    }

    /* Photo utility */
    .ph { position: relative; overflow: hidden; }
    .ph img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(100%) contrast(1.05);
      transition: transform 0.6s ease;
    }
    .ph:hover img { transform: scale(1.04); }

    /* PORTFOLIO */
    .portfolio-section { border-top: 1px solid var(--ink); }
    .section-header {
      padding: 4rem 5rem 3.5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: end;
      border-bottom: 1px solid var(--ink-08);
    }
    .s-num {
      font-size: 0.42rem;
      font-weight: 300;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--ink-30);
      margin-bottom: 1.2rem;
    }
    .s-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      line-height: 0.9;
      color: var(--ink);
    }
    .s-title em { font-style: italic; }
    .s-title .stroke {
      -webkit-text-stroke: 1px var(--ink);
      color: transparent;
    }
    .s-desc {
      font-size: 0.66rem;
      font-weight: 300;
      line-height: 1.95;
      color: var(--ink-50);
      max-width: 44ch;
    }
    .port-grid {
      display: grid;
      grid-template-columns: 1.3fr 1fr 1fr;
      gap: 2px;
      background: var(--ink);
    }
    .port-item { background: var(--paper); }
    .port-overlay {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 1.25rem;
      background: linear-gradient(to top, rgba(8,8,8,0.75) 0%, transparent 100%);
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      z-index: 2;
      opacity: 0;
      transition: opacity 0.35s ease;
    }
    .ph:hover .port-overlay { opacity: 1; }
    .po-cat {
      font-size: 0.4rem;
      font-weight: 300;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(247,247,245,0.55);
    }
    .po-title {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-weight: 300;
      font-size: 1rem;
      color: rgba(247,247,245,0.9);
    }

    /* FILMSTRIP */
    .filmstrip {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 2px;
      background: var(--ink);
      border-top: 3px solid var(--ink);
      border-bottom: 3px solid var(--ink);
    }
    .fs-item { position: relative; overflow: hidden; }
    .fs-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(100%) brightness(0.6);
      display: block;
      transition: filter 0.4s;
    }
    .fs-item:hover img { filter: grayscale(100%) brightness(0.9); }

    /* STUDIO */
    .studio-section { background: var(--ink); }
    .studio-grid { display: grid; grid-template-columns: 1fr 1fr; }
    .studio-text {
      padding: 6rem 5rem;
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
      justify-content: center;
    }
    .s-num-light {
      font-size: 0.42rem;
      font-weight: 300;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(247,247,245,0.2);
    }
    .studio-headline {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-weight: 300;
      font-size: clamp(2.5rem, 4.5vw, 4rem);
      line-height: 0.95;
      color: rgba(247,247,245,0.88);
    }
    .studio-headline .stroke {
      font-style: normal;
      -webkit-text-stroke: 1px rgba(247,247,245,0.3);
      color: transparent;
    }
    .studio-body {
      font-size: 0.66rem;
      font-weight: 300;
      line-height: 2;
      color: rgba(247,247,245,0.3);
      max-width: 40ch;
    }
    .spec-table {
      display: flex;
      flex-direction: column;
      border-top: 1px solid rgba(247,247,245,0.08);
    }
    .spec-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.7rem 0;
      border-bottom: 1px solid rgba(247,247,245,0.06);
    }
    .sp-label {
      font-size: 0.46rem;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(247,247,245,0.2);
    }
    .sp-value {
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.04em;
      color: rgba(247,247,245,0.55);
    }
    .btn-light {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--paper);
      padding: 0.8rem 1.8rem;
      text-decoration: none;
      border: 1px solid var(--paper);
      transition: background 0.15s, color 0.15s;
      width: fit-content;
    }
    .btn-light:hover { background: transparent; color: var(--paper); }
    .studio-photo {
      position: relative;
      overflow: hidden;
      min-height: 580px;
    }
    .studio-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(100%) brightness(0.68) contrast(1.1);
    }

    /* CONTACT */
    .contact-section {
      border-top: 1px solid var(--ink);
      padding: 6rem 5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
    .contact-headline {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: clamp(2.2rem, 4vw, 3.2rem);
      line-height: 1.05;
      color: var(--ink);
      margin-bottom: 2.5rem;
    }
    .contact-headline em { font-style: italic; }
    .services-list {
      list-style: none;
      display: flex;
      flex-direction: column;
    }
    .services-list li {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0;
      border-bottom: 1px solid var(--ink-08);
    }
    .svc-name {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: 1.15rem;
      color: var(--ink);
    }
    .svc-price {
      font-size: 0.42rem;
      font-weight: 300;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink-30);
    }
    .contact-details {
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
    }
    .cd-item {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .cd-label {
      font-size: 0.4rem;
      font-weight: 300;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--ink-30);
    }
    .cd-value {
      font-size: 0.66rem;
      font-weight: 300;
      letter-spacing: 0.04em;
      color: var(--ink-50);
    }

    /* FOOTER */
    footer {
      background: var(--ink);
      padding: 1.5rem 5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .footer-logo {
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: rgba(247,247,245,0.45);
    }
    .footer-meta {
      font-size: 0.4rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(247,247,245,0.18);
    }

    /* Corner marks */
    .corner {
      position: fixed;
      font-size: 0.38rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-15);
      z-index: 50;
    }
    .corner.bl { bottom: 1.5rem; left: 2rem; }
    .corner.br { bottom: 1.5rem; right: 2rem; }
  </style>
</head>
<body>
  <div class="corner bl">49°45'N · 06°38'E</div>
  <div class="corner br">KORN · Trier</div>

  <nav>
    <div class="nav-logo">KORN</div>
    <ul class="nav-links">
      <li><a href="#">Portfolio</a></li>
      <li><a href="#">Leistungen</a></li>
      <li><a href="#">Studio</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <a href="#" class="nav-cta">Shooting anfragen</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <div class="hero-meta">
        <span class="meta-line">Fotografisches Atelier · Trier</span>
        <span class="meta-line">f/2.8 · ISO 400 · 35mm Analog</span>
      </div>

      <div class="hero-center">
        <h1>
          Das<br>
          Bild<br>
          braucht<br>
          keine<br>
          <span class="stroke">Farbe.</span>
        </h1>
        <p class="hero-body">
          KORN ist ein fotografisches Atelier in Trier.
          Wir arbeiten in Schwarzweiß — nicht aus Nostalgie,
          sondern weil Reduktion die stärkste Form der Aussage ist.
        </p>
      </div>

      <div class="hero-bottom">
        <div class="cta-group">
          <a href="#" class="btn-primary">Shooting anfragen</a>
          <a href="#" class="btn-ghost">Portfolio ansehen →</a>
        </div>
        <span class="hero-est">Est. 2018 · Trier</span>
      </div>
    </div>

    <div class="v-rule"></div>

    <div class="hero-photo">
      <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?auto=format&fit=crop&w=1600&h=1400&q=85" alt="Portrait Fotografie" />
      <div class="photo-tag">Portrait · Trier · 2025</div>
    </div>
  </section>

  <!-- STATS STRIP -->
  <div class="stats-strip">
    <div class="stat-item">
      <div class="stat-num">800+</div>
      <div class="stat-label">Shootings</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">120m²</div>
      <div class="stat-label">Studiofläche</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">48h</div>
      <div class="stat-label">Lieferzeit</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">12</div>
      <div class="stat-label">Jahre Erfahrung</div>
    </div>
  </div>

  <!-- PORTFOLIO -->
  <section class="portfolio-section">
    <div class="section-header">
      <div>
        <div class="s-num">001 — Ausgewählte Arbeiten</div>
        <h2 class="s-title">
          Bilder<br>
          die <em>bleiben.</em><br>
          <span class="stroke">Immer.</span>
        </h2>
      </div>
      <p class="s-desc">
        Schwarzweiß zwingt zur Konzentration auf das Wesentliche —
        Form, Licht, Schatten, Ausdruck. Jedes unserer Bilder ist so gemacht,
        dass es auch in 30 Jahren noch funktioniert.
      </p>
    </div>
    <div class="port-grid">
      <div class="port-item">
        <div class="ph" style="height:420px;">
          <img src="https://images.unsplash.com/photo-1524504388940-b1c1722653e0?auto=format&fit=crop&w=1400&h=1000&q=80" alt="Editorial Portrait" loading="lazy" />
          <div class="port-overlay">
            <span class="po-cat">Editorial</span>
            <span class="po-title">Zeichen der Zeit</span>
          </div>
        </div>
      </div>
      <div class="port-item">
        <div class="ph" style="height:420px;">
          <img src="https://images.unsplash.com/photo-1503951914875-452162b0f3f1?auto=format&fit=crop&w=900&h=700&q=80" alt="Portrait Herr" loading="lazy" />
          <div class="port-overlay">
            <span class="po-cat">Portrait</span>
            <span class="po-title">Stille Stärke</span>
          </div>
        </div>
      </div>
      <div class="port-item">
        <div class="ph" style="height:420px;">
          <img src="https://images.unsplash.com/photo-1508214751196-bcfd4ca60f91?auto=format&fit=crop&w=900&h=700&q=80" alt="Frauenportrait" loading="lazy" />
          <div class="port-overlay">
            <span class="po-cat">Mode</span>
            <span class="po-title">In Bewegung</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FILMSTRIP -->
  <div class="filmstrip" style="height:150px;">
    <div class="fs-item">
      <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=400&h=280&q=70" alt="" loading="lazy" />
    </div>
    <div class="fs-item">
      <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=400&h=280&q=70" alt="" loading="lazy" />
    </div>
    <div class="fs-item">
      <img src="https://images.unsplash.com/photo-1552374196-1ab2a1c593e8?auto=format&fit=crop&w=400&h=280&q=70" alt="" loading="lazy" />
    </div>
    <div class="fs-item">
      <img src="https://images.unsplash.com/photo-1488426862026-3ee34a7d66df?auto=format&fit=crop&w=400&h=280&q=70" alt="" loading="lazy" />
    </div>
    <div class="fs-item">
      <img src="https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&w=400&h=280&q=70" alt="" loading="lazy" />
    </div>
  </div>

  <!-- STUDIO -->
  <section class="studio-section">
    <div class="studio-grid">
      <div class="studio-text">
        <div class="s-num-light">002 — Das Studio</div>
        <h2 class="studio-headline">
          120 m².<br>
          <span class="stroke">Stille.</span><br>
          Klarheit.
        </h2>
        <p class="studio-body">
          Kein Dekor. Keine Ablenkung. Ein Raum, der alles wegräumt —
          damit das Bild das einzige ist, was zählt.
        </p>
        <div class="spec-table">
          <div class="spec-row">
            <span class="sp-label">Fläche</span>
            <span class="sp-value">120 m² Gesamt</span>
          </div>
          <div class="spec-row">
            <span class="sp-label">Licht</span>
            <span class="sp-value">Daylight + Profoto D2</span>
          </div>
          <div class="spec-row">
            <span class="sp-label">Hintergründe</span>
            <span class="sp-value">Weiß · Grau · Schwarz · Cyclorama</span>
          </div>
