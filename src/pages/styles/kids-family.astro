  <script>
    // ── Scroll reveal ──
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ── Confetti burst on "Jetzt anfragen" ──
    function launchConfetti(x, y) {
      const colors = ['#FF6135','#3BB8F0','#FFD02E','#5DC870','#FF7EEA','#9B72F2'];
      for (let i = 0; i < 28; i++) {
        const el = document.createElement('div');
        el.className = 'cp';
        const angle    = (i / 28) * 360;
        const dist     = 55 + Math.random() * 90;
        const tx       = Math.cos(angle * Math.PI / 180) * dist;
        const ty       = Math.sin(angle * Math.PI / 180) * dist - 50;
        const color    = colors[Math.floor(Math.random() * colors.length)];
        const isCircle = Math.random() > 0.5;
        el.style.cssText = [
          `left:${x}px`,
          `top:${y}px`,
          `background:${color}`,
          `--tx:${tx}px`,
          `--ty:${ty}px`,
          `--rot:${Math.random() * 720 - 360}deg`,
          isCircle ? 'border-radius:50%' : '',
        ].join(';');
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 1600);
      }
    }

    const konfettiBtn = document.getElementById('konfetti-btn');
    if (konfettiBtn) {
      konfettiBtn.addEventListener('click', (e) => {
        e.preventDefault();
        const r = e.currentTarget.getBoundingClientRect();
        launchConfetti(r.left + r.width / 2, r.top + r.height / 2);
      });
    }
  </script>
