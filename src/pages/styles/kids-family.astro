  <script>
    // ===== CONFETTI SPARKLES ON PAGE LOAD =====
    (function launchSparkles() {
      const colors = ['#E8734A', '#5B8C5A', '#F5C85D', '#E8A87C', '#A8D5A2', '#F9E4B7'];
      const centerX = window.innerWidth / 2;
      const centerY = window.innerHeight / 2;
      const count = 20;

      for (let i = 0; i < count; i++) {
        const dot = document.createElement('div');
        dot.className = 'sparkle';

        const size = Math.random() * 12 + 6;
        const angle = (i / count) * 2 * Math.PI + Math.random() * 0.5;
        const distance = Math.random() * 220 + 80;
        const tx = Math.cos(angle) * distance;
        const ty = Math.sin(angle) * distance;
        const delay = Math.random() * 0.3;
        const color = colors[Math.floor(Math.random() * colors.length)];

        dot.style.cssText = `
          width: ${size}px;
          height: ${size}px;
          background: ${color};
          left: ${centerX - size / 2}px;
          top: ${centerY - size / 2}px;
          --tx: ${tx}px;
          --ty: ${ty}px;
          animation-delay: ${delay}s;
          animation-duration: ${0.9 + Math.random() * 0.5}s;
        `;

        document.body.appendChild(dot);

        dot.addEventListener('animationend', () => dot.remove());
      }
    })();

    // ===== INTERSECTION OBSERVER — BOUNCE-IN WITH STAGGER =====
    (function initBounceIn() {
      const elements = document.querySelectorAll('.bounce-in');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          // Group siblings for stagger: find index among visible .bounce-in in same parent
          const parent = entry.target.parentElement;
          const siblings = Array.from(parent.querySelectorAll('.bounce-in'));
          const index = siblings.indexOf(entry.target);
          const staggerDelay = index * 80; // ms per sibling

          setTimeout(() => {
            entry.target.classList.add('visible');
          }, staggerDelay);

          observer.unobserve(entry.target);
        });
      }, {
        threshold: 0.15,
        rootMargin: '0px 0px -40px 0px'
      });

      elements.forEach((el) => observer.observe(el));
    })();
  </script>

