---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Wunderwelt Trier — Indoor-Spielplatz & Kreativwerkstatt</title>
  <meta name="description" content="Wunderwelt Trier — Indoor-Abenteuer für Kinder von 1–12 Jahren. Klettern, Bauen, Malen & unvergessliche Kindergeburtstage." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --coral:   #FF6135;
      --sky:     #3BB8F0;
      --yellow:  #FFD02E;
      --green:   #5DC870;
      --pink:    #FF7EEA;
      --purple:  #9B72F2;
      --bg:      #FFFBF0;
      --dark:    #2B1551;
      --dark60:  rgba(43,21,81,0.58);
      --white:   #ffffff;
    }

    body {
      font-family: 'Nunito', sans-serif;
      background: var(--bg);
      color: var(--dark);
      overflow-x: hidden;
      line-height: 1.7;
    }

    img { max-width: 100%; height: auto; display: block; }
    a { text-decoration: none; color: inherit; }
    h1, h2, h3, h4 { font-family: 'Baloo 2', cursive; line-height: 1.2; }

    /* ===== FLOATING BG SHAPES ===== */
    .bg-shapes {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    .shape {
      position: absolute;
      border-radius: 50%;
      opacity: 0.07;
    }
    .shape-1 { width: 520px; height: 520px; background: var(--coral);  top: -160px; right: -160px; animation: float-a 9s ease-in-out infinite; }
    .shape-2 { width: 380px; height: 380px; background: var(--sky);    bottom: 5%;  left: -110px; animation: float-b 11s ease-in-out infinite; }
    .shape-3 { width: 220px; height: 220px; background: var(--yellow); top: 38%;   right: 4%;   animation: float-a 8s ease-in-out infinite 1s; }
    .shape-4 { width: 160px; height: 160px; background: var(--green);  top: 58%;   left: 18%;   animation: float-b 10s ease-in-out infinite 2s; }
    .shape-5 { width: 260px; height: 260px; background: var(--pink);   top: 22%;   left: 12%;   animation: float-a 12s ease-in-out infinite 0.5s; }

    @keyframes float-a {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50%       { transform: translateY(-28px) rotate(4deg); }
    }
    @keyframes float-b {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50%       { transform: translateY(24px) rotate(-4deg); }
    }

    /* ===== CSS STAR SHAPES ===== */
    .deco-star {
      position: fixed;
      pointer-events: none;
      z-index: 0;
      font-size: 1.4rem;
      animation: twinkle 4s ease-in-out infinite;
      opacity: 0;
    }
    .deco-star:nth-child(1) { top: 8%;  left: 6%;  animation-delay: 0s; }
    .deco-star:nth-child(2) { top: 15%; right: 8%; animation-delay: 1.2s; }
    .deco-star:nth-child(3) { top: 55%; left: 3%;  animation-delay: 0.6s; }
    .deco-star:nth-child(4) { top: 70%; right: 5%; animation-delay: 2s; }
    .deco-star:nth-child(5) { top: 45%; left: 50%; animation-delay: 1.6s; }

    @keyframes twinkle {
      0%, 100% { opacity: 0;   transform: scale(0.6) rotate(0deg); }
      50%       { opacity: 0.55; transform: scale(1.1) rotate(20deg); }
    }

    /* ===== NAV ===== */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 2.5rem;
      background: rgba(255,251,240,0.92);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 2px solid rgba(255,97,53,0.1);
    }

    .nav-logo {
      font-family: 'Baloo 2', cursive;
      font-weight: 800;
      font-size: 1.5rem;
      color: var(--coral);
      letter-spacing: -0.01em;
    }
    .nav-logo span { color: var(--dark); }

    .nav-links {
      display: flex;
      gap: 0.25rem;
      list-style: none;
      align-items: center;
    }
    .nav-links a {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--dark);
      padding: 0.45rem 1.1rem;
      border-radius: 50px;
      transition: background 0.2s, color 0.2s;
    }
    .nav-links a:hover { background: rgba(255,97,53,0.1); color: var(--coral); }
    .nav-cta {
      background: var(--coral) !important;
      color: #fff !important;
      box-shadow: 0 4px 16px rgba(255,97,53,0.32);
      transition: transform 0.2s, box-shadow 0.2s !important;
    }
    .nav-cta:hover {
      transform: translateY(-2px) !important;
      box-shadow: 0 8px 24px rgba(255,97,53,0.44) !important;
    }

    /* ===== HERO ===== */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 8rem 3rem 5rem;
      gap: 3.5rem;
      position: relative;
      z-index: 1;
    }

    .hero-content {
      flex: 1;
      max-width: 560px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(255,97,53,0.1);
      border: 2px solid rgba(255,97,53,0.2);
      border-radius: 50px;
      padding: 0.45rem 1.2rem;
      font-size: 0.76rem;
      font-weight: 800;
      color: var(--coral);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 1.6rem;
    }

    .hero-title {
      font-size: clamp(3rem, 5.5vw, 5.8rem);
      font-weight: 800;
      line-height: 1.05;
      margin-bottom: 1.5rem;
      color: var(--dark);
    }
    .hero-title .w-coral   { color: var(--coral); }
    .hero-title .w-sky     { color: var(--white); background: var(--sky);    padding: 0 0.12em; border-radius: 8px; display: inline-block; }
    .hero-title .w-yellow  { color: var(--dark);  background: var(--yellow); padding: 0 0.12em; border-radius: 8px; display: inline-block; }

    .hero-sub {
      font-size: 1.03rem;
      color: var(--dark60);
      max-width: 45ch;
      line-height: 1.85;
      margin-bottom: 2rem;
    }

    .hero-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-bottom: 2.4rem;
    }
    .tag {
      font-size: 0.78rem;
      font-weight: 700;
      padding: 0.38rem 0.95rem;
      border-radius: 50px;
      border: 2px solid;
    }
    .tag-coral  { color: var(--coral);  border-color: rgba(255,97,53,0.3);   background: rgba(255,97,53,0.07); }
    .tag-sky    { color: #0278B0;       border-color: rgba(59,184,240,0.35); background: rgba(59,184,240,0.08); }
    .tag-green  { color: #18874E;       border-color: rgba(93,200,112,0.35); background: rgba(93,200,112,0.08); }
    .tag-purple { color: #6B3FD4;       border-color: rgba(155,114,242,0.35);background: rgba(155,114,242,0.08); }

    .hero-btns {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--coral);
      color: #fff;
      font-family: 'Baloo 2', cursive;
      font-size: 1rem;
      font-weight: 700;
      padding: 0.85rem 2.1rem;
      border-radius: 50px;
      box-shadow: 0 8px 24px rgba(255,97,53,0.38);
      transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.25s ease;
    }
    .btn-primary:hover {
      transform: translateY(-4px) scale(1.03);
      box-shadow: 0 16px 36px rgba(255,97,53,0.48);
    }
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--white);
      color: var(--dark);
      font-family: 'Baloo 2', cursive;
      font-size: 1rem;
      font-weight: 700;
      padding: 0.85rem 2.1rem;
      border-radius: 50px;
      border: 2px solid rgba(43,21,81,0.14);
      transition: border-color 0.2s, background 0.2s;
    }
    .btn-secondary:hover {
      border-color: var(--coral);
      background: rgba(255,97,53,0.04);
    }

    /* HERO VISUAL */
    .hero-visual {
      flex: 1;
      max-width: 520px;
      position: relative;
      z-index: 2;
    }

    .photo-frame {
      width: 100%;
      border-radius: 32px;
      overflow: hidden;
      box-shadow: 0 24px 64px rgba(43,21,81,0.2);
      position: relative;
      aspect-ratio: 5/4;
    }
    .photo-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .photo-frame:hover img { transform: scale(1.05); }
    .photo-frame::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent 45%, rgba(43,21,81,0.28) 100%);
      pointer-events: none;
    }

    /* Floating bubble badges around hero photo */
    .float-badge {
      position: absolute;
      background: var(--white);
      border-radius: 18px;
      padding: 0.6rem 1rem;
      box-shadow: 0 8px 28px rgba(43,21,81,0.14);
      font-size: 0.8rem;
      font-weight: 700;
      white-space: nowrap;
      z-index: 4;
    }
    .float-badge--tr {
      top: -18px; right: 20px;
      color: var(--coral);
      animation: bob 3.5s ease-in-out infinite;
    }
    .float-badge--bl {
      bottom: -18px; left: 20px;
      color: var(--sky);
      animation: bob 4.2s ease-in-out infinite reverse;
    }
    .float-badge--ml {
      top: 38%; left: -20px;
      color: var(--green);
      animation: bob 3.1s ease-in-out infinite 0.8s;
    }

    @keyframes bob {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(-9px); }
    }

    /* ===== WAVE ===== */
    .wave-wrap {
      position: relative;
      z-index: 1;
      line-height: 0;
      overflow: hidden;
    }

    /* ===== SHARED SECTION STYLES ===== */
    section { position: relative; z-index: 1; }

    .section-label {
      font-size: 0.72rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--coral);
      margin-bottom: 0.65rem;
    }
    .section-title {
      font-size: clamp(1.8rem, 3.2vw, 2.8rem);
      font-weight: 800;
      color: var(--dark);
      margin-bottom: 0.9rem;
      line-height: 1.2;
    }
    .section-sub {
      font-size: 0.95rem;
      color: var(--dark60);
      max-width: 54ch;
      line-height: 1.85;
    }

    /* ===== ACTIVITIES ===== */
    .activities {
      padding: 6rem 3rem;
      background: var(--white);
    }
    .activities-inner { max-width: 1180px; margin: 0 auto; }
    .activities-header { text-align: center; margin-bottom: 3.5rem; }
    .activities-header .section-sub { margin: 0 auto; }

    .activities-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.6rem;
    }

    .act-card {
      border-radius: 24px;
      overflow: hidden;
      background: var(--bg);
      box-shadow: 0 4px 20px rgba(43,21,81,0.07);
      transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.35s ease;
      cursor: default;
    }
    .act-card:hover                { transform: translateY(-10px) rotate(-0.6deg); box-shadow: 0 20px 48px rgba(43,21,81,0.14); }
    .act-card:nth-child(2):hover   { transform: translateY(-10px) rotate(0.6deg); }
    .act-card:nth-child(3):hover   { transform: translateY(-10px) rotate(-0.4deg); }

    .act-photo {
      position: relative;
      height: 230px;
      overflow: hidden;
    }
    .act-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.55s ease;
    }
    .act-card:hover .act-photo img { transform: scale(1.09); }
    .act-photo-ov {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(43,21,81,0.52) 0%, transparent 55%);
    }
    .act-icon {
      position: absolute;
      bottom: 14px; right: 14px;
      width: 50px; height: 50px;
      border-radius: 50%;
      background: var(--white);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.45rem;
      box-shadow: 0 4px 14px rgba(43,21,81,0.2);
      z-index: 1;
    }

    .act-body { padding: 1.5rem; }
    .act-age {
      display: inline-block;
      font-size: 0.68rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 0.28rem 0.8rem;
      border-radius: 50px;
      margin-bottom: 0.7rem;
    }
    .age-c { background: rgba(255,97,53,0.1);  color: var(--coral); }
    .age-s { background: rgba(59,184,240,0.12); color: #0278B0; }
    .age-g { background: rgba(93,200,112,0.12); color: #18874E; }

    .act-name {
      font-family: 'Baloo 2', cursive;
      font-size: 1.22rem;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 0.35rem;
    }
    .act-desc {
      font-size: 0.86rem;
      color: var(--dark60);
      line-height: 1.75;
    }

    /* ===== BIRTHDAY ===== */
    .birthday {
      padding: 6rem 3rem;
      background: var(--bg);
    }
    .birthday-inner {
      max-width: 1180px;
      margin: 0 auto;
      display: flex;
      gap: 4.5rem;
      align-items: center;
    }

    .bday-photo-wrap {
      flex: 1;
      position: relative;
      border-radius: 32px;
      overflow: hidden;
      min-height: 520px;
    }
    .bday-photo-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .bday-photo-wrap:hover img { transform: scale(1.04); }

    /* Confetti dots overlaid on birthday photo */
    .bday-dots {
      position: absolute;
      top: 20px; left: 20px;
      display: flex;
      gap: 7px;
      z-index: 1;
    }
    .dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      animation: pulse-dot 2.4s ease-in-out infinite;
    }
    .dot:nth-child(1) { background: var(--coral);  animation-delay: 0s; }
    .dot:nth-child(2) { background: var(--sky);    animation-delay: 0.3s; }
    .dot:nth-child(3) { background: var(--yellow); animation-delay: 0.6s; }
    .dot:nth-child(4) { background: var(--green);  animation-delay: 0.9s; }
    .dot:nth-child(5) { background: var(--pink);   animation-delay: 1.2s; }
    @keyframes pulse-dot {
      0%, 100% { transform: scale(1); }
      50%       { transform: scale(1.5); }
    }

    .bday-content { flex: 1; }
    .bday-pkgs {
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
      margin-top: 2rem;
    }
    .bday-pkg {
      background: var(--white);
      border-radius: 20px;
      padding: 1.4rem 1.6rem;
      border: 2px solid transparent;
      display: flex;
      align-items: center;
      gap: 1.2rem;
      transition:
        border-color 0.25s,
        transform 0.32s cubic-bezier(0.34,1.56,0.64,1),
        box-shadow 0.25s;
    }
    .bday-pkg:hover {
      border-color: var(--coral);
      transform: translateX(10px);
      box-shadow: 0 10px 28px rgba(255,97,53,0.13);
    }
    .pkg-ico {
      width: 52px; height: 52px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.55rem;
      flex-shrink: 0;
    }
    .ico-c { background: rgba(255,97,53,0.1); }
    .ico-s { background: rgba(59,184,240,0.12); }
    .ico-p { background: rgba(155,114,242,0.12); }

    .pkg-info h4 {
      font-family: 'Baloo 2', cursive;
      font-size: 1rem;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 0.2rem;
    }
    .pkg-info p { font-size: 0.79rem; color: var(--dark60); line-height: 1.6; }
    .pkg-price {
      margin-left: auto;
      font-family: 'Baloo 2', cursive;
      font-size: 1.2rem;
      font-weight: 800;
      color: var(--coral);
      white-space: nowrap;
    }

    .bday-cta { margin-top: 2rem; }

    /* ===== PRICING & HOURS ===== */
    .pricing {
      padding: 6rem 3rem;
      background: var(--dark);
      position: relative;
      overflow: hidden;
    }
    .pricing::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        radial-gradient(circle, rgba(255,97,53,0.18) 1px, transparent 1px),
        radial-gradient(circle, rgba(59,184,240,0.14) 1px, transparent 1px);
      background-size: 42px 42px, 65px 65px;
      background-position: 0 0, 21px 21px;
      pointer-events: none;
    }
    .pricing-inner {
      max-width: 1100px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .pricing-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }
    .pricing-header .section-label { color: var(--yellow); }
    .pricing-header .section-title { color: var(--white); }
    .pricing-header .section-sub   { color: rgba(255,255,255,0.58); margin: 0 auto; }

    .pricing-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 2rem;
      align-items: start;
    }

    .ticket-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .ticket {
      background: rgba(255,255,255,0.07);
      backdrop-filter: blur(8px);
      border: 1.5px solid rgba(255,255,255,0.1);
      border-radius: 20px;
      padding: 1.6rem;
      transition:
        background 0.3s,
        transform 0.3s cubic-bezier(0.34,1.56,0.64,1),
        border-color 0.3s;
    }
    .ticket:hover {
      background: rgba(255,255,255,0.12);
      border-color: rgba(255,255,255,0.24);
      transform: translateY(-5px);
    }
    .ticket.featured {
      background: var(--coral);
      border-color: var(--coral);
      grid-column: span 2;
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .ticket.featured:hover {
      background: #ff7446;
      border-color: #ff7446;
    }
    .ticket-emo  { font-size: 2rem;   margin-bottom: 0.7rem; }
    .ticket-name { font-family: 'Baloo 2', cursive; font-size: 0.82rem; font-weight: 700; color: rgba(255,255,255,0.65); text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 0.25rem; }
    .ticket-price{ font-family: 'Baloo 2', cursive; font-size: 2rem; font-weight: 800; color: var(--white); line-height: 1; margin-bottom: 0.35rem; }
    .ticket-note { font-size: 0.77rem; color: rgba(255,255,255,0.48); line-height: 1.55; }
    .ticket.featured .ticket-emo   { font-size: 2.5rem; margin-bottom: 0; flex-shrink: 0; }
    .ticket.featured .ticket-name  { color: rgba(255,255,255,0.78); }
    .ticket.featured .ticket-note  { color: rgba(255,255,255,0.68); }

    .hours-box {
      background: rgba(255,255,255,0.07);
      backdrop-filter: blur(8px);
      border: 1.5px solid rgba(255,255,255,0.1);
      border-radius: 20px;
      padding: 1.8rem;
    }
    .hours-head {
      font-family: 'Baloo 2', cursive;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--yellow);
      margin-bottom: 1.2rem;
    }
    .hours-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.58rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      font-size: 0.85rem;
    }
    .hours-row:last-child { border-bottom: none; }
    .h-day    { color: rgba(255,255,255,0.58); font-weight: 500; }
    .h-time   { color: var(--white); font-weight: 700; }
    .h-closed { color: rgba(255,97,53,0.75); font-weight: 600; }
    .addr-block {
      margin-top: 1.4rem;
      padding-top: 1.4rem;
      border-top: 1px solid rgba(255,255,255,0.09);
    }
    .addr-line { font-size: 0.82rem; color: rgba(255,255,255,0.52); line-height: 1.85; }
    .addr-line strong { color: rgba(255,255,255,0.88); }

    /* ===== FOOTER ===== */
    .footer {
      background: #17082A;
      color: rgba(255,255,255,0.45);
      text-align: center;
      padding: 2.5rem 2rem;
      font-size: 0.84rem;
    }
    .footer strong { color: var(--coral); }

    /* ===== SCROLL REVEAL ===== */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.34,1.56,0.64,1);
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-d1 { transition-delay: 0.1s; }
    .reveal-d2 { transition-delay: 0.2s; }
    .reveal-d3 { transition-delay: 0.3s; }

    /* ===== CONFETTI PIECES (JS) ===== */
