---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Brenner & Partner — Rechtsanwälte & Notare | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --navy:     #0D1B34;
      --navy-mid: #162444;
      --gold:     #B8983A;
      --gold-lt:  #D4B86A;
      --cream:    #FAF8F4;
      --warm:     #F2EEE7;
      --muted:    rgba(13,27,52,0.42);
      --border:   rgba(13,27,52,0.1);
      --serif:    'Playfair Display', Georgia, serif;
      --sans:     'Inter', system-ui, sans-serif;
    }

    body {
      background: var(--cream);
      color: var(--navy);
      font-family: var(--sans);
      font-weight: 300;
      -webkit-font-smoothing: antialiased;
    }

    ::selection { background: var(--gold); color: #fff; }

    /* ─────────────────────────────────
       NAV
    ───────────────────────────────── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: stretch;
      background: var(--navy);
      height: 64px;
    }

    .nav-brand {
      display: flex;
      align-items: center;
      padding: 0 2.5rem;
      gap: 0.85rem;
      border-right: 1px solid rgba(255,255,255,0.07);
      text-decoration: none;
      flex-shrink: 0;
    }
    .nav-seal {
      width: 32px; height: 32px;
      border: 1.5px solid var(--gold);
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-family: var(--serif);
      font-size: 0.75rem;
      color: var(--gold);
      flex-shrink: 0;
    }
    .nav-wordmark {
      font-family: var(--serif);
      font-size: 0.9rem;
      color: #fff;
      line-height: 1.3;
    }
    .nav-wordmark span {
      display: block;
      font-family: var(--sans);
      font-size: 0.48rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      margin-top: 0.1rem;
    }

    .nav-links {
      display: flex;
      list-style: none;
      flex: 1;
      padding: 0 1rem;
    }
    .nav-links a {
      display: flex;
      align-items: center;
      padding: 0 1.1rem;
      font-size: 0.57rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.38);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: rgba(255,255,255,0.82); }

    .nav-cta {
      display: flex;
      align-items: center;
      padding: 0 2.25rem;
      font-size: 0.57rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      background: var(--gold);
      color: #fff;
      text-decoration: none;
      transition: background 0.2s;
      flex-shrink: 0;
    }
    .nav-cta:hover { background: var(--gold-lt); }

    /* ─────────────────────────────────
       HERO
    ───────────────────────────────── */
    .hero {
      min-height: 100vh;
      padding-top: 64px;
      display: grid;
      grid-template-columns: 1fr 420px;
    }

    /* LEFT */
    .hero-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(3rem, 6vw, 6rem) clamp(2.5rem, 5vw, 5rem);
      gap: 2.25rem;
      border-right: 1px solid var(--border);
      background: var(--cream);
    }

    .eyebrow {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.57rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
    }
    .eyebrow::before {
      content: '';
      display: block;
      width: 22px; height: 1px;
      background: var(--gold);
      flex-shrink: 0;
    }

    .hero-headline {
      font-family: var(--serif);
      font-size: clamp(2.6rem, 4.5vw, 4.2rem);
      font-weight: 700;
      line-height: 1.15;
      color: var(--navy);
      letter-spacing: -0.01em;
    }
    .hero-headline em {
      font-style: italic;
      font-weight: 400;
      color: var(--gold);
    }

    .hero-divider {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .hd-line { flex: 1; height: 1px; background: var(--border); }
    .hd-ornament { font-size: 0.55rem; color: var(--gold); letter-spacing: 0.3em; }

    .hero-lead {
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 1.9;
      color: var(--muted);
      max-width: 42ch;
    }

    .practice-list {
      border: 1px solid var(--border);
      overflow: hidden;
    }
    .pl-head {
      background: var(--navy);
      padding: 0.55rem 1.25rem;
      font-size: 0.5rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
    }
    .pl-item {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      padding: 0.9rem 1.25rem;
      border-bottom: 1px solid var(--border);
      cursor: default;
      transition: background 0.18s, padding-left 0.18s;
    }
    .pl-item:last-child { border-bottom: none; }
    .pl-item:hover { background: var(--warm); padding-left: 1.75rem; }
    .pl-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
    }
    .pl-name {
      font-family: var(--serif);
      font-size: 0.92rem;
      color: var(--navy);
    }
    .pl-arrow { margin-left: auto; font-size: 0.6rem; color: rgba(13,27,52,0.2); }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .btn-primary {
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #fff;
      background: var(--navy);
      padding: 1rem 2.25rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .btn-primary:hover { background: var(--gold); }

    .tel-link {
      text-decoration: none;
    }
    .tel-link small {
      display: block;
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.15rem;
    }
    .tel-link strong {
      font-family: var(--serif);
      font-size: 0.95rem;
      font-weight: 400;
      color: var(--navy);
    }

    /* RIGHT — photo column */
    .hero-photo {
      position: relative;
      overflow: hidden;
      background: var(--navy);
    }
    .hero-photo img {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      opacity: 0.65;
      transition: transform 0.8s ease;
    }
    .hero-photo:hover img { transform: scale(1.03); }
    .hero-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        160deg,
        rgba(13,27,52,0.5) 0%,
        rgba(13,27,52,0.15) 50%,
        rgba(13,27,52,0.75) 100%
      );
    }
    .hero-photo-stats {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 2.5rem;
      background: linear-gradient(to top, rgba(13,27,52,0.95) 0%, transparent 100%);
      display: flex;
      gap: 2.5rem;
    }
    .stat {}
    .stat-num {
      font-family: var(--serif);
      font-size: 2rem;
      font-weight: 700;
      color: var(--gold);
      line-height: 1;
    }
    .stat-label {
      font-size: 0.58rem;
      font-weight: 300;
      color: rgba(255,255,255,0.45);
      letter-spacing: 0.06em;
      margin-top: 0.2rem;
    }

    .hero-photo-badge {
      position: absolute;
      top: 2.5rem; right: 2.5rem;
      border: 1px solid rgba(184,152,58,0.4);
      padding: 0.75rem 1.25rem;
      text-align: center;
      background: rgba(13,27,52,0.5);
      backdrop-filter: blur(8px);
    }
    .badge-year {
      font-family: var(--serif);
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--gold);
      line-height: 1;
    }
    .badge-label {
      font-size: 0.48rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-top: 0.25rem;
    }

    /* ─────────────────────────────────
       PHOTO UTIL
    ───────────────────────────────── */
    .ph { position: relative; overflow: hidden; }
    .ph img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .ph:hover img { transform: scale(1.05); }

    /* ─────────────────────────────────
       SECTION 2 — FACHGEBIETE
    ───────────────────────────────── */
    .fachgebiete {
      background: var(--navy-mid);
      padding: clamp(4rem, 7vw, 6.5rem) clamp(2rem, 5vw, 5rem);
    }
    .fg-inner { max-width: 1500px; margin: 0 auto; }

    .section-eyebrow {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.57rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.9rem;
    }
    .section-eyebrow::before {
      content: '';
      display: block;
      width: 22px; height: 1px;
      background: var(--gold);
      flex-shrink: 0;
    }

    .fg-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 2rem;
      margin-bottom: 3.5rem;
      flex-wrap: wrap;
    }
    .fg-title {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 700;
      color: #fff;
      line-height: 1.2;
    }
    .fg-lead {
      font-size: 0.85rem;
      font-weight: 300;
      line-height: 1.8;
      color: rgba(255,255,255,0.38);
      max-width: 36ch;
    }

    .fg-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: rgba(255,255,255,0.07);
    }
    .fg-card {
      background: var(--navy-mid);
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      transition: background 0.2s;
      cursor: default;
    }
    .fg-card:hover { background: #1a2d50; }
    .fg-num {
      font-family: var(--serif);
      font-size: 2.5rem;
      font-weight: 700;
      color: rgba(184,152,58,0.25);
      line-height: 1;
    }
    .fg-rule {
      width: 28px; height: 1px;
      background: var(--gold);
      opacity: 0.6;
    }
    .fg-name {
      font-family: var(--serif);
      font-size: 1.05rem;
      font-weight: 500;
      color: #fff;
      line-height: 1.35;
    }
    .fg-desc {
      font-size: 0.8rem;
      font-weight: 300;
      line-height: 1.75;
      color: rgba(255,255,255,0.38);
      flex: 1;
    }
    .fg-more {
      font-size: 0.57rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      margin-top: 0.5rem;
      transition: color 0.2s;
    }
    .fg-more:hover { color: var(--gold-lt); }

    /* ─────────────────────────────────
       SECTION 3 — TEAM
    ───────────────────────────────── */
    .team {
      padding: clamp(4rem, 7vw, 6.5rem) clamp(2rem, 5vw, 5rem);
      background: var(--cream);
      border-top: 1px solid var(--border);
    }
    .team-inner { max-width: 1500px; margin: 0 auto; }

    .team-header {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      align-items: end;
      margin-bottom: 3.5rem;
    }
    .team-title {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 700;
      color: var(--navy);
      line-height: 1.2;
    }
    .team-lead {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.85;
      color: var(--muted);
    }

    .team-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .team-card {
      background: var(--warm);
      border: 1px solid var(--border);
      overflow: hidden;
    }
    .team-card-photo {
      height: 320px;
      background: var(--navy);
    }
    .team-card-photo img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center top;
      transition: transform 0.6s ease;
      filter: grayscale(25%);
    }
    .team-card-photo:hover img { transform: scale(1.04); }
    .team-card-photo-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(13,27,52,0.45) 0%, transparent 55%);
    }
    .team-card-body {
      padding: 1.5rem 1.75rem;
      border-top: 2px solid var(--gold);
    }
    .tc-name {
      font-family: var(--serif);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--navy);
    }
    .tc-role {
      font-size: 0.72rem;
      font-weight: 400;
      color: var(--muted);
      margin-top: 0.25rem;
      letter-spacing: 0.04em;
    }
    .tc-areas {
      margin-top: 1rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .tc-area {
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(184,152,58,0.35);
      padding: 0.25rem 0.65rem;
    }

    /* ─────────────────────────────────
       SECTION 4 — KONTAKT
    ───────────────────────────────── */
    .kontakt {
      background: var(--navy);
      padding: clamp(4rem, 7vw, 6.5rem) clamp(2rem, 5vw, 5rem);
    }
    .kontakt-inner {
      max-width: 1500px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .kontakt-content {
      display: flex;
      flex-direction: column;
      gap: 2.25rem;
    }
    .kontakt-eyebrow {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.57rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
    }
    .kontakt-eyebrow::before {
      content: '';
      display: block;
      width: 22px; height: 1px;
      background: var(--gold);
      flex-shrink: 0;
    }
    .kontakt-title {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      font-weight: 700;
      color: #fff;
      line-height: 1.2;
    }
    .kontakt-lead {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.9;
      color: rgba(255,255,255,0.4);
      max-width: 40ch;
    }
    .kontakt-details {
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 1px solid rgba(255,255,255,0.08);
    }
    .kd-row {
      display: flex;
      gap: 1.5rem;
      align-items: baseline;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .kd-row:last-child { border-bottom: none; }
    .kd-label {
      font-size: 0.5rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      min-width: 72px;
      flex-shrink: 0;
    }
    .kd-value {
      font-family: var(--serif);
      font-size: 0.88rem;
      font-weight: 400;
      color: rgba(255,255,255,0.65);
      line-height: 1.5;
    }

    .kontakt-cta {
      display: flex;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .btn-gold {
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--navy);
      background: var(--gold);
      padding: 1rem 2.25rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .btn-gold:hover { background: var(--gold-lt); }

    .kontakt-tel {
      text-decoration: none;
    }
    .kontakt-tel small {
      display: block;
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      margin-bottom: 0.15rem;
    }
    .kontakt-tel strong {
      font-family: var(--serif);
      font-size: 0.95rem;
      font-weight: 400;
      color: rgba(255,255,255,0.7);
    }

    /* Kontakt photo */
    .kontakt-photo-wrap {
      position: relative;
    }
    .kontakt-photo-frame {
      position: relative;
      overflow: hidden;
      height: 520px;
    }
    .kontakt-photo-frame img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
      filter: brightness(0.7) saturate(0.8);
    }
    .kontakt-photo-frame:hover img { transform: scale(1.03); }
    .kontakt-photo-frame::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(13,27,52,0.4) 0%, transparent 70%);
    }
    .kontakt-photo-accent {
      position: absolute;
      top: -1.5rem; left: -1.5rem;
      width: 80px; height: 80px;
      border: 2px solid var(--gold);
      z-index: 2;
    }
    .kontakt-photo-caption {
      position: absolute;
      bottom: -1.5rem; right: -1.5rem;
      background: var(--gold);
      padding: 1.25rem 1.75rem;
      z-index: 2;
    }
    .kpc-name {
      font-family: var(--serif);
      font-size: 1rem;
      font-weight: 700;
      color: #fff;
      line-height: 1.2;
    }
    .kpc-role {
      font-size: 0.55rem;
      font-weight: 400;
      color: rgba(255,255,255,0.7);
      letter-spacing: 0.08em;
      margin-top: 0.2rem;
    }

    /* ─────────────────────────────────
       RESPONSIVE
    ───────────────────────────────── */
    @media (max-width: 1100px) {
      .hero { grid-template-columns: 1fr; }
      .hero-photo { min-height: 320px; }
      .fg-grid { grid-template-columns: repeat(2, 1fr); }
      .team-grid { grid-template-columns: repeat(2, 1fr); }
      .kontakt-inner { grid-template-columns: 1fr; gap: 3rem; }
      .kontakt-photo-accent,
      .kontakt-photo-caption { display: none; }
    }
    @media (max-width: 700px) {
      .fg-grid { grid-template-columns: 1fr; }
      .team-grid { grid-template-columns: 1fr; }
      .team-header { grid-template-columns: 1fr; }
      .fg-header { flex-direction: column; align-items: flex-start; }
      .nav-links { display: none; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <a href="#" class="nav-brand">
      <div class="nav-seal">B</div>
      <div class="nav-wordmark">
        Brenner &amp; Partner
        <span>Rechtsanwälte · Notare · Trier</span>
      </div>
    </a>
    <ul class="nav-links">
      <li><a href="#">Leistungen</a></li>
      <li><a href="#">Kanzlei</a></li>
      <li><a href="#">Team</a></li>
      <li><a href="#">Aktuelles</a></li>
    </ul>
    <a href="#" class="nav-cta">Beratungsgespräch</a>
  </nav>

  <!-- HERO -->
  <section class="hero">

    <!-- Left: Content -->
    <div class="hero-content">
      <div class="eyebrow">Rechtsanwälte &amp; Notare · Gegründet 1998</div>

      <h1 class="hero-headline">
        Ihr Recht.<br>
        <em>Unser</em><br>
        Auftrag.
      </h1>

      <div class="hero-divider">
        <div class="hd-line"></div>
        <div class="hd-ornament">✦ &nbsp; ✦ &nbsp; ✦</div>
        <div class="hd-line"></div>
      </div>

      <p class="hero-lead">
        Seit 1998 vertreten wir unsere Mandanten mit Präzision, Diskretion
        und echtem Engagement. Rechtssicherheit ist kein Zufall — sie ist
        handwerkliche Arbeit auf höchstem Niveau.
      </p>

      <div class="practice-list">
        <div class="pl-head">Schwerpunkte</div>
        <div class="pl-item">
          <span class="pl-dot"></span>
          <span class="pl-name">Gesellschafts- &amp; Unternehmensrecht</span>
          <span class="pl-arrow">→</span>
        </div>
        <div class="pl-item">
          <span class="pl-dot"></span>
          <span class="pl-name">Arbeitsrecht</span>
          <span class="pl-arrow">→</span>
        </div>
        <div class="pl-item">
          <span class="pl-dot"></span>
