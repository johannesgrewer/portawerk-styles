---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Brenner & Partner — Rechtsanwälte & Notare | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Mulish:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --navy:  #1B2A4A;
      --gold:  #B8960C;
      --bg:    #FFFFFF;
      --warm:  #F8F5F0;
      --muted: rgba(27,42,74,0.45);
      --rule:  rgba(27,42,74,0.1);
    }

    body {
      background: var(--bg);
      color: var(--navy);
      font-family: 'Mulish', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: stretch;
      background: var(--navy);
    }
    .nav-brand {
      display: flex;
      align-items: center;
      padding: 1.1rem 3rem;
      border-right: 1px solid rgba(255,255,255,0.08);
      gap: 0.75rem;
    }
    .nav-emblem {
      width: 28px;
      height: 28px;
      border: 2px solid var(--gold);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Libre Baskerville', serif;
      font-size: 0.7rem;
      color: var(--gold);
      flex-shrink: 0;
    }
    .nav-logo {
      font-family: 'Libre Baskerville', serif;
      font-size: 0.85rem;
      color: #fff;
      line-height: 1.3;
    }
    .nav-logo small {
      display: block;
      font-size: 0.5rem;
      font-family: 'Mulish', sans-serif;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
    }
    .nav-links {
      display: flex;
      gap: 0;
      list-style: none;
      flex: 1;
      padding: 0 1.5rem;
    }
    .nav-links a {
      display: flex;
      align-items: center;
      padding: 0 1.25rem;
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: rgba(255,255,255,0.85); }
    .nav-contact {
      display: flex;
      align-items: center;
      padding: 0 2.5rem;
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--navy);
      background: var(--gold);
      text-decoration: none;
      transition: background 0.2s;
    }
    .nav-contact:hover { background: #9a7d0a; }

    .hero {
      min-height: 100vh;
      padding-top: 62px;
      display: grid;
      grid-template-columns: 1fr 380px;
    }

    /* LEFT */
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 5rem 4rem 5rem 5rem;
      gap: 2.5rem;
      border-right: 1px solid var(--rule);
    }

    .eyebrow {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
    }
    .eyebrow::before {
      content: '';
      display: block;
      width: 24px;
      height: 1px;
      background: var(--gold);
    }

    .hero-headline {
      font-family: 'Libre Baskerville', serif;
      font-weight: 700;
      font-size: clamp(2.5rem, 4.5vw, 4rem);
      line-height: 1.2;
      letter-spacing: 0.01em;
      color: var(--navy);
    }
    .hero-headline em {
      font-style: italic;
      color: var(--gold);
      font-weight: 400;
    }

    .hero-divider {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .hd-line { flex: 1; height: 1px; background: var(--rule); }
    .hd-ornament {
      font-size: 0.65rem;
      color: var(--gold);
      letter-spacing: 0.1em;
    }

    .hero-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 2;
      color: var(--muted);
      max-width: 44ch;
    }

    /* Practice areas */
    .practice-list {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--rule);
    }
    .pl-header {
      background: var(--navy);
      padding: 0.5rem 1.25rem;
      font-size: 0.52rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
    }
    .pl-row {
      display: flex;
      align-items: center;
      padding: 0.85rem 1.25rem;
      border-bottom: 1px solid var(--rule);
      gap: 0.75rem;
      transition: background 0.2s, padding-left 0.2s;
      cursor: default;
    }
    .pl-row:last-child { border-bottom: none; }
    .pl-row:hover { background: var(--warm); padding-left: 1.75rem; }
    .pl-bullet {
      width: 4px; height: 4px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
    }
    .pl-name {
      font-family: 'Libre Baskerville', serif;
      font-size: 0.9rem;
      color: var(--navy);
    }
    .pl-arrow {
      margin-left: auto;
      font-size: 0.65rem;
      color: rgba(27,42,74,0.2);
    }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 1.75rem;
    }
    .cta-btn {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #fff;
      background: var(--navy);
      padding: 0.95rem 2.2rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .cta-btn:hover { background: var(--gold); }
    .cta-tel {
      font-family: 'Libre Baskerville', serif;
      font-size: 0.9rem;
      color: var(--navy);
      text-decoration: none;
    }
    .cta-tel small {
      display: block;
      font-family: 'Mulish', sans-serif;
      font-size: 0.52rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* RIGHT */
    .hero-right {
      background: var(--warm);
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .right-block {
      padding: 2rem 2.5rem;
      border-bottom: 1px solid var(--rule);
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }
    .right-block:last-child { border-bottom: none; }
    .rb-label {
      font-size: 0.52rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
    }
    .rb-value {
      font-family: 'Libre Baskerville', serif;
      font-size: 1.05rem;
      color: var(--navy);
      line-height: 1.5;
    }
    .rb-sub {
      font-size: 0.72rem;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.6;
    }

    /* Team block */
    .team-block {
      padding: 2rem 2.5rem;
      border-bottom: 1px solid var(--rule);
    }
    .tb-label {
      font-size: 0.52rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }
    .tb-persons {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .tb-person {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .tp-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--navy);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Libre Baskerville', serif;
      font-size: 0.75rem;
      color: var(--gold);
      flex-shrink: 0;
    }
    .tp-name {
      font-family: 'Libre Baskerville', serif;
      font-size: 0.88rem;
      color: var(--navy);
    }
    .tp-role {
      font-size: 0.62rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 0.05rem;
    }

    /* Award bar */
    .award-block {
      padding: 1.5rem 2.5rem;
      background: var(--navy);
    }
    .ab-label {
      font-size: 0.52rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      margin-bottom: 0.6rem;
    }
    .ab-stats {
      display: flex;
      gap: 2rem;
    }
    .ab-stat {}
    .abs-num {
      font-family: 'Libre Baskerville', serif;
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--gold);
      line-height: 1;
    }
    .abs-label {
      font-size: 0.58rem;
      font-weight: 300;
      color: rgba(255,255,255,0.35);
      margin-top: 0.15rem;
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-brand">
      <div class="nav-emblem">B</div>
      <div class="nav-logo">
        Brenner & Partner
        <small>Rechtsanwälte · Notare</small>
      </div>
    </div>
    <ul class="nav-links">
      <li><a href="#">Leistungen</a></li>
      <li><a href="#">Kanzlei</a></li>
      <li><a href="#">Team</a></li>
      <li><a href="#">Aktuelles</a></li>
    </ul>
    <a href="#" class="nav-contact">Beratungsgespräch</a>
  </nav>

  <section class="hero">
    <div class="hero-left">
      <div class="eyebrow">Rechtsanwälte & Notare · Trier</div>

      <h1 class="hero-headline">
        Ihr Recht.<br>
        <em>Unser</em><br>
        Auftrag.
      </h1>

      <div class="hero-divider">
        <div class="hd-line"></div>
        <div class="hd-ornament">✦ ✦ ✦</div>
        <div class="hd-line"></div>
      </div>

      <p class="hero-body">
        Seit 1998 vertreten wir unsere Mandanten mit Präzision,
        Diskretion und echtem Engagement. Rechtssicherheit ist
        kein Zufall — sie ist handwerkliche Arbeit.
      </p>

      <div class="practice-list">
        <div class="pl-header">Schwerpunkte</div>
        <div class="pl-row">
          <span class="pl-bullet"></span>
          <span class="pl-name">Gesellschafts- & Unternehmensrecht</span>
          <span class="pl-arrow">→</span>
        </div>
        <div class="pl-row">
          <span class="pl-bullet"></span>
          <span class="pl-name">Arbeitsrecht</span>
          <span class="pl-arrow">→</span>
        </div>
        <div class="pl-row">
          <span class="pl-bullet"></span>
          <span class="pl-name">Immobilien & Erbrecht</span>
          <span class="pl-arrow">→</span>
        </div>
        <div class="pl-row">
          <span class="pl-bullet"></span>
          <span class="pl-name">Notariat & Beurkundungen</span>
          <span class="pl-arrow">→</span>
        </div>
      </div>

      <div class="cta-row">
        <a href="#" class="cta-btn">Termin vereinbaren</a>
        <a href="#" class="cta-tel">
          <small>Direktwahl</small>
          0651 / 97 43 0
        </a>
      </div>
    </div>

    <div class="hero-right">
      <div class="right-block">
        <div class="rb-label">Standort</div>
        <div class="rb-value">Paulinstraße 18, Trier</div>
        <div class="rb-sub">Mo – Fr: 8:30 – 18:00 Uhr<br>Termine nach Vereinbarung</div>
      </div>

      <div class="team-block">
        <div class="tb-label">Das Team</div>
        <div class="tb-persons">
          <div class="tb-person">
            <div class="tp-avatar">HB</div>
            <div>
              <div class="tp-name">Dr. Hans Brenner</div>
              <div class="tp-role">Fachanwalt für Gesellschaftsrecht</div>
            </div>
          </div>
          <div class="tb-person">
            <div class="tp-avatar">SP</div>
            <div>
              <div class="tp-name">Sandra Pohl</div>
              <div class="tp-role">Fachanwältin für Arbeitsrecht</div>
            </div>
          </div>
          <div class="tb-person">
            <div class="tp-avatar">MK</div>
            <div>
              <div class="tp-name">Markus Kern</div>
              <div class="tp-role">Notar</div>
            </div>
          </div>
        </div>
      </div>

      <div class="award-block">
        <div class="ab-label">Kanzlei in Zahlen</div>
        <div class="ab-stats">
          <div class="ab-stat">
            <div class="abs-num">26</div>
            <div class="abs-label">Jahre Erfahrung</div>
          </div>
          <div class="ab-stat">
            <div class="abs-num">1.400+</div>
            <div class="abs-label">Mandate / Jahr</div>
          </div>
          <div class="ab-stat">
            <div class="abs-num">8</div>
            <div class="abs-label">Anwälte</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</body>
</html>
