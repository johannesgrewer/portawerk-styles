---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Kosmos — Planetarium & Wissenschaftszentrum Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --gold:   #FFD878;
      --purple: #6B2FA0;
      --bg:     #03050E;
      --surface:#070B18;
      --text:   #E8E0F8;
      --dim:    rgba(232,224,248,0.4);
      --border: rgba(107,47,160,0.18);
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Space Grotesk', sans-serif;
      overflow-x: hidden;
    }

    /* ─── Fixed starfield ─────────────────────────────── */
    .starfield {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
    }
    .s {
      position: absolute; border-radius: 50%; background: #fff;
      animation: tw var(--d,3s) ease-in-out infinite;
      animation-delay: var(--dl,0s);
    }
    @keyframes tw { 0%,100%{opacity:var(--hi,.8)} 50%{opacity:var(--lo,.1)} }

    .nebula {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(ellipse 55% 45% at 72% 22%, rgba(107,47,160,.22) 0%, transparent 60%),
        radial-gradient(ellipse 40% 55% at 18% 78%, rgba(30,60,122,.16) 0%, transparent 60%),
        radial-gradient(ellipse 35% 35% at 48% 52%, rgba(107,47,160,.06) 0%, transparent 65%);
    }

    /* ─── Nav ──────────────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 3.5rem; height: 62px;
      background: rgba(3,5,14,.92); backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .nav-brand { display: flex; align-items: center; gap: .8rem; }
    .nav-mark {
      width: 30px; height: 30px; border-radius: 50%;
      border: 1.5px solid rgba(255,216,120,.6);
      display: flex; align-items: center; justify-content: center;
      position: relative;
    }
    .nav-mark::before {
      content: ''; width: 8px; height: 8px; border-radius: 50%;
      background: var(--gold); box-shadow: 0 0 10px var(--gold);
    }
    .nav-mark::after {
      content: ''; position: absolute;
      width: 48px; height: 1px; left: 50%; transform: translateX(-50%);
      background: linear-gradient(to right, transparent, rgba(255,216,120,.35), transparent);
    }
    .nav-name { display: flex; flex-direction: column; gap: 1px; }
    .nav-title {
      font-weight: 700; font-size: .9rem; letter-spacing: .12em;
      text-transform: uppercase; color: var(--gold); line-height: 1;
    }
    .nav-sub {
      font-family: 'Space Mono', monospace; font-size: .4rem;
      letter-spacing: .22em; text-transform: uppercase;
      color: rgba(255,216,120,.35); line-height: 1;
    }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      font-family: 'Space Mono', monospace; font-size: .55rem;
      letter-spacing: .14em; text-transform: uppercase;
      color: var(--dim); text-decoration: none; transition: color .2s;
    }
    .nav-links a:hover { color: var(--gold); }
    .nav-ticket {
      font-family: 'Space Mono', monospace; font-size: .55rem;
      letter-spacing: .12em; text-transform: uppercase;
      color: var(--bg); background: var(--gold);
      padding: .65rem 1.6rem; text-decoration: none; transition: background .2s;
    }
    .nav-ticket:hover { background: #fff; }

    /* ─── Hero ─────────────────────────────────────────── */
    .hero {
      min-height: 100vh; position: relative; z-index: 1;
      display: grid; grid-template-columns: 1fr 500px;
      padding-top: 62px;
    }

    .hero-left {
      display: flex; flex-direction: column; justify-content: center;
      padding: 5rem 3rem 5rem 5rem; gap: 2.4rem;
    }

    .eyebrow {
      display: flex; align-items: center; gap: .9rem;
    }
    .eyebrow-bar { width: 28px; height: 1px; background: rgba(107,47,160,.6); }
    .eyebrow-text {
      font-family: 'Space Mono', monospace; font-size: .5rem;
      letter-spacing: .22em; text-transform: uppercase;
      color: rgba(107,47,160,.85);
    }

    .hero-h1 {
      font-weight: 700; font-size: clamp(2.6rem,5.2vw,4.75rem);
      line-height: 1.0; letter-spacing: -.025em;
    }
    .hero-h1 .gold { color: var(--gold); }
    .hero-h1 .dim  { font-weight: 300; color: rgba(232,224,248,.32); }

    .hero-p {
      font-size: .875rem; font-weight: 300; line-height: 1.9;
      color: rgba(232,224,248,.48); max-width: 46ch;
      border-left: 2px solid rgba(107,47,160,.35); padding-left: 1.25rem;
    }

    /* Upcoming list */
    .upcoming { display: flex; flex-direction: column; }
    .upc-header {
      font-family: 'Space Mono', monospace; font-size: .48rem;
      letter-spacing: .22em; text-transform: uppercase;
      color: rgba(232,224,248,.18); padding-bottom: .7rem;
      border-bottom: 1px solid rgba(107,47,160,.22);
    }
    .upc-row {
      display: grid; grid-template-columns: 2.2rem 1fr auto;
      align-items: center; gap: 1rem; padding: .75rem 0;
      border-bottom: 1px solid rgba(107,47,160,.08);
      transition: background .2s;
    }
    .upc-row:hover { background: rgba(107,47,160,.06); padding-left: .5rem; padding-right: .5rem; margin: 0 -.5rem; }
    .upc-n {
      font-family: 'Space Mono', monospace; font-size: .5rem;
      color: rgba(107,47,160,.55);
    }
    .upc-name { font-size: .82rem; font-weight: 500; color: var(--text); }
    .upc-date {
      font-family: 'Space Mono', monospace; font-size: .5rem;
      color: var(--gold); text-align: right; display: block;
    }
    .upc-time {
      font-family: 'Space Mono', monospace; font-size: .44rem;
      color: var(--dim); text-align: right;
    }

    .cta-row { display: flex; align-items: center; gap: 1.75rem; }
    .btn-prim {
      font-family: 'Space Mono', monospace; font-size: .58rem;
      font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
      color: var(--bg); background: var(--gold);
      text-decoration: none; padding: 1rem 2.4rem; transition: background .2s;
    }
    .btn-prim:hover { background: #fff; }
    .btn-ghost {
      font-family: 'Space Mono', monospace; font-size: .52rem;
      letter-spacing: .14em; text-transform: uppercase;
      color: rgba(232,224,248,.3); text-decoration: none; transition: color .2s;
    }
    .btn-ghost:hover { color: var(--text); }

    /* ─── Dome visual ──────────────────────────────────── */
    .hero-right {
      display: flex; align-items: center; justify-content: center;
      padding: 3rem 4rem 3rem 2rem; position: relative;
    }

    .dome-stage { position: relative; width: 420px; height: 420px; }

    .dome-ring-outer {
      position: absolute; inset: -28px; border-radius: 50%;
      border: 1px solid rgba(107,47,160,.1);
      animation: spin 140s linear infinite;
    }
    .dome-ring-outer::before {
      content: ''; position: absolute; top: -4px; left: 50%;
      transform: translateX(-50%); width: 8px; height: 8px;
      border-radius: 50%; background: rgba(107,47,160,.5);
      box-shadow: 0 0 8px rgba(107,47,160,.7);
    }
    .dome-ring-mid {
      position: absolute; inset: -10px; border-radius: 50%;
      border: 1px dashed rgba(107,47,160,.08);
      animation: spin 90s linear infinite reverse;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .dome {
      width: 420px; height: 420px; border-radius: 50%;
      position: relative; overflow: hidden;
      background: radial-gradient(ellipse 75% 70% at 42% 38%,
        rgba(28,42,95,.95) 0%, rgba(12,18,48,.97) 45%, #03050E 100%);
      border: 1px solid rgba(107,47,160,.28);
      box-shadow:
        inset 0 0 90px rgba(107,47,160,.18),
        inset 0 0 200px rgba(3,5,14,.85),
        0 0 80px rgba(107,47,160,.14);
    }

    /* Projection glow */
    .dome-proj {
      position: absolute; width: 200px; height: 200px; border-radius: 50%;
      top: 50%; left: 50%; transform: translate(-50%,-46%);
      background: radial-gradient(circle,
        rgba(107,47,160,.2) 0%, rgba(30,60,130,.1) 40%, transparent 70%);
      animation: projPulse 5s ease-in-out infinite;
    }
    @keyframes projPulse {
      0%,100%{ opacity:1; transform:translate(-50%,-46%) scale(1); }
      50%{ opacity:.65; transform:translate(-50%,-46%) scale(1.1); }
    }

    /* Scanning sweep */
    .dome-sweep {
      position: absolute; inset: 0; border-radius: 50%; overflow: hidden;
    }
    .dome-sweep::after {
      content: ''; position: absolute; top: 0; left: 50%; right: 0; height: 50%;
      background: conic-gradient(from 0deg, transparent 354deg,
        rgba(255,216,120,.04) 357deg, rgba(255,216,120,.1) 360deg);
      transform-origin: bottom center;
      animation: sweep 10s linear infinite;
    }
    @keyframes sweep { to { transform: rotate(360deg); } }

    /* Stars in dome */
    .ds { position: absolute; border-radius: 50%; background: #fff; animation: tw var(--d,3s) ease-in-out infinite; animation-delay:var(--dl,0s); }

    /* Constellation lines (Orion) */
    .cl {
      position: absolute; height: 1px; background: rgba(255,216,120,.18);
      transform-origin: left center;
    }

    /* Constellation star nodes */
    .cn {
      position: absolute; border-radius: 50%; transform: translate(-50%,-50%);
    }
    .cn.bright { background: rgba(255,216,120,.9); box-shadow: 0 0 5px rgba(255,216,120,.6); }
    .cn.mid    { background: rgba(200,190,240,.7); }
    .cn.dim    { background: rgba(200,190,240,.45); }

    /* Live tag */
    .dome-live {
      position: absolute; bottom: 26px; left: 50%; transform: translateX(-50%);
      display: flex; align-items: center; gap: .45rem;
    }
    .live-dot {
      width: 6px; height: 6px; border-radius: 50%; background: #4ade80;
      box-shadow: 0 0 6px #4ade80; animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
    .live-text {
      font-family: 'Space Mono', monospace; font-size: .44rem;
      letter-spacing: .18em; text-transform: uppercase;
      color: rgba(232,224,248,.45);
    }

    /* Cardinal labels */
    .dc {
      position: absolute; font-family: 'Space Mono', monospace;
      font-size: .4rem; letter-spacing: .14em;
      color: rgba(107,47,160,.45);
    }
    .dc.n { top: -20px; left: 50%; transform: translateX(-50%); }
    .dc.s { bottom: -20px; left: 50%; transform: translateX(-50%); }
    .dc.e { right: -32px; top: 50%; transform: translateY(-50%) rotate(90deg); }
    .dc.w { left: -32px; top: 50%; transform: translateY(-50%) rotate(-90deg); }

    /* ─── Section 2 — Shows ───────────────────────────── */
    .shows {
      position: relative; z-index: 1;
      padding: 7rem 5rem;
      background: var(--surface);
      border-top: 1px solid var(--border);
    }
    .sec-head {
      display: flex; align-items: flex-end; justify-content: space-between;
      margin-bottom: 3.5rem;
    }
    .sec-eyebrow {
      font-family: 'Space Mono', monospace; font-size: .5rem;
      letter-spacing: .22em; text-transform: uppercase;
      color: rgba(107,47,160,.75); margin-bottom: .55rem;
      display: flex; align-items: center; gap: .6rem;
    }
    .sec-eyebrow::before { content: ''; width: 22px; height: 1px; background: rgba(107,47,160,.6); }
    .sec-title {
      font-weight: 700; font-size: 2.25rem; letter-spacing: -.022em;
      color: var(--text);
    }
    .sec-link {
      font-family: 'Space Mono', monospace; font-size: .52rem;
      letter-spacing: .14em; text-transform: uppercase;
      color: var(--gold); text-decoration: none;
    }

    .shows-grid {
      display: grid; grid-template-columns: repeat(4,1fr);
      gap: 1px; background: var(--border);
      border: 1px solid var(--border);
    }

    .sc {
      background: var(--surface); display: flex; flex-direction: column;
      transition: background .3s;
    }
    .sc:hover { background: rgba(107,47,160,.08); }

    /* Show art containers */
    .sc-art {
      height: 176px; position: relative; overflow: hidden;
      background: var(--bg); border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
    }

    /* Black hole */
    .bh-wrap { position: relative; display: flex; align-items: center; justify-content: center; }
    .bh-glow {
      position: absolute; width: 130px; height: 130px; border-radius: 50%;
      background: radial-gradient(circle, rgba(255,100,20,.16) 0%, transparent 65%);
    }
    .bh-ring { position: absolute; border-radius: 50%; border: 0 solid transparent; }
    .bh-r1 { width: 88px; height: 28px; border: 2.5px solid rgba(255,140,20,.55); box-shadow: 0 0 14px rgba(255,110,0,.35); }
    .bh-r2 { width: 124px; height: 40px; border: 1.5px solid rgba(255,100,0,.25); }
    .bh-r3 { width: 162px; height: 52px; border: 1px solid rgba(255,80,0,.1); }
    .bh-core {
      width: 34px; height: 34px; border-radius: 50%; background: #000;
      box-shadow: 0 0 0 10px rgba(255,130,20,.2), 0 0 0 20px rgba(255,80,0,.08);
      z-index: 2;
      animation: bhPulse 3s ease-in-out infinite;
    }
    @keyframes bhPulse {
      0%,100%{ box-shadow: 0 0 0 10px rgba(255,130,20,.2), 0 0 0 20px rgba(255,80,0,.08); }
      50%{ box-shadow: 0 0 0 14px rgba(255,130,20,.28), 0 0 0 28px rgba(255,80,0,.12); }
    }

    /* Saturn */
    .sat-wrap { position: relative; display: flex; align-items: center; justify-content: center; }
    .sat-ball {
      width: 72px; height: 72px; border-radius: 50%; z-index: 2;
      background: radial-gradient(circle at 38% 36%, #7BA8D8, #2A5898 55%, #122848);
      box-shadow: -6px -5px 18px rgba(255,255,255,.12) inset, 0 0 28px rgba(40,100,200,.3);
    }
    .sat-ring {
      position: absolute; border-radius: 50%;
      border: 7px solid rgba(180,155,90,.42);
      width: 140px; height: 28px;
      box-shadow: 0 0 14px rgba(180,155,90,.12);
      z-index: 1;
    }
    .sat-ring-shadow {
      position: absolute; bottom: 28px;
      width: 72px; height: 12px;
      background: rgba(0,0,0,.5); border-radius: 50%; z-index: 3;
    }

    /* Moon phases */
    .moon-row {
      display: flex; align-items: center; gap: 12px;
    }
    .mp {
      width: 30px; height: 30px; border-radius: 50%; position: relative; overflow: hidden;
    }
    .mp-new  { background: #080816; border: 1px solid rgba(232,224,248,.2); }
    .mp-cres { background: #C8C0E0; box-shadow: -9px 0 0 5px #080816 inset; }
    .mp-half { background: linear-gradient(90deg, #080816 50%, #C8C0E0 50%); }
    .mp-full { background: #D0C8EC; box-shadow: 0 0 16px rgba(208,200,236,.45); }

    /* Nebula */
    .neb-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 58% 52% at 38% 52%, rgba(107,47,160,.65) 0%, transparent 60%),
        radial-gradient(ellipse 48% 60% at 65% 42%, rgba(30,120,188,.42) 0%, transparent 55%),
        radial-gradient(ellipse 42% 42% at 55% 58%, rgba(200,60,110,.32) 0%, transparent 50%);
    }
    .neb-s { position: absolute; border-radius: 50%; background: #fff; }

    /* Show card body */
    .sc-body {
      padding: 1.5rem 1.75rem; flex: 1;
      display: flex; flex-direction: column; gap: .7rem;
    }
    .sc-tag {
      font-family: 'Space Mono', monospace; font-size: .44rem;
      letter-spacing: .2em; text-transform: uppercase;
      color: rgba(107,47,160,.75);
    }
    .sc-name {
      font-weight: 700; font-size: 1rem; letter-spacing: -.01em;
      color: var(--text); line-height: 1.2;
    }
    .sc-desc {
      font-size: .74rem; font-weight: 300; color: var(--dim);
      line-height: 1.75; flex: 1;
    }
    .sc-foot {
      display: flex; align-items: center; justify-content: space-between;
      padding-top: .7rem; border-top: 1px solid var(--border);
    }
    .sc-details { display: flex; gap: 1.2rem; }
    .sc-dl { display: flex; flex-direction: column; gap: 1px; }
    .sc-dl-label {
      font-family: 'Space Mono', monospace; font-size: .4rem;
      letter-spacing: .14em; text-transform: uppercase;
      color: rgba(232,224,248,.18);
    }
    .sc-dl-val {
      font-family: 'Space Mono', monospace; font-size: .58rem; color: var(--text);
    }
    .sc-book {
      font-family: 'Space Mono', monospace; font-size: .5rem;
      letter-spacing: .1em; text-transform: uppercase;
      color: var(--gold); text-decoration: none; transition: color .2s;
    }
    .sc-book:hover { color: #fff; }

    /* ─── Section 3 — Die Kuppel ──────────────────────── */
    .kuppel {
      position: relative; z-index: 1;
      padding: 7rem 5rem;
      border-top: 1px solid var(--border);
      display: grid; grid-template-columns: 1fr 480px;
      gap: 6rem; align-items: center;
    }

    .kup-eyebrow {
      font-family: 'Space Mono', monospace; font-size: .5rem;
      letter-spacing: .22em; text-transform: uppercase;
      color: rgba(107,47,160,.75); margin-bottom: 1rem;
      display: flex; align-items: center; gap: .6rem;
    }
    .kup-eyebrow::before { content: ''; width: 22px; height: 1px; background: rgba(107,47,160,.6); }
    .kup-h2 {
      font-weight: 700; font-size: 2.5rem; letter-spacing: -.025em;
      color: var(--text); line-height: 1.05; margin-bottom: .9rem;
    }
    .kup-h2 .gold { color: var(--gold); }
    .kup-p {
      font-size: .82rem; font-weight: 300; line-height: 1.85;
      color: var(--dim); max-width: 50ch; margin-bottom: 3rem;
    }
    .spec-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 0; border-top: 1px solid var(--border);
    }
    .spec-cell {
      padding: 1.6rem 2rem 1.6rem 0;
      border-bottom: 1px solid var(--border);
    }
    .spec-cell:nth-child(even) {
      padding-left: 2rem; padding-right: 0;
      border-left: 1px solid var(--border);
    }
    .spec-num {
      font-weight: 700; font-size: 2.4rem; letter-spacing: -.03em;
      color: var(--gold); line-height: 1; margin-bottom: .3rem;
    }
    .spec-unit {
      font-family: 'Space Mono', monospace; font-size: .65rem;
      color: rgba(255,216,120,.45); margin-left: .2rem;
    }
    .spec-name {
      font-size: .8rem; font-weight: 600; color: var(--text); margin-bottom: .15rem;
    }
    .spec-desc {
      font-family: 'Space Mono', monospace; font-size: .48rem;
      letter-spacing: .08em; text-transform: uppercase; color: var(--dim);
    }

    /* Orrery */
    .orrery-wrap {
      display: flex; align-items: center; justify-content: center;
      height: 440px; position: relative;
    }
    .orrery { position: relative; width: 400px; height: 400px; }

    .sun {
      position: absolute; width: 36px; height: 36px; border-radius: 50%;
      top: 50%; left: 50%; transform: translate(-50%,-50%); z-index: 10;
      background: radial-gradient(circle at 38% 38%, #fff9e0, #ffcc00 42%, #ff8800);
      box-shadow: 0 0 0 5px rgba(255,200,0,.12), 0 0 28px rgba(255,160,0,.45), 0 0 60px rgba(255,100,0,.18);
      animation: sunPulse 4s ease-in-out infinite;
    }
    @keyframes sunPulse {
      0%,100%{ box-shadow: 0 0 0 5px rgba(255,200,0,.12), 0 0 28px rgba(255,160,0,.45), 0 0 60px rgba(255,100,0,.18); }
      50%    { box-shadow: 0 0 0 9px rgba(255,200,0,.1),  0 0 40px rgba(255,160,0,.55), 0 0 80px rgba(255,100,0,.22); }
    }

    .orbit {
      position: absolute; border-radius: 50%;
      top: 50%; left: 50%;
      transform: translate(-50%,-50%) rotate(var(--start,0deg));
      animation: orb var(--period,10s) linear infinite;
      border: 1px solid;
    }
    @keyframes orb {
      to { transform: translate(-50%,-50%) rotate(calc(var(--start,0deg) + 360deg)); }
    }
    .o1 { width:  80px; height:  80px; border-color:rgba(200,200,220,.18); --period:5s;  --start:20deg; }
    .o2 { width: 128px; height: 128px; border-color:rgba(200,200,220,.14); --period:9s;  --start:75deg; }
    .o3 { width: 186px; height: 186px; border-color:rgba(200,200,220,.11); --period:15s; --start:130deg;}
    .o4 { width: 254px; height: 254px; border-color:rgba(200,200,220,.08); --period:26s; --start:200deg;}
    .o5 { width: 336px; height: 336px; border-color:rgba(200,200,220,.05); --period:48s; --start:310deg;}

    .orbit::after {
      content: ''; position: absolute;
      top: -1px; left: 50%; transform: translateX(-50%);
      border-radius: 50%;
      width: var(--ps,8px); height: var(--ps,8px);
      background: var(--pc,#888);
      box-shadow: 0 0 var(--pg,0px) var(--pc,transparent);
    }
    .o1::after { --ps:5px; --pc:#C0B8D0; --pg:0px; margin-top:-1px; }
    .o2::after { --ps:8px; --pc:#E8A060; --pg:8px; margin-top:-3px; }
    .o3::after { --ps:9px; --pc:#5080C8; --pg:10px; margin-top:-3px; }
    .o4::after { --ps:7px; --pc:#C07838; --pg:6px; margin-top:-2px; }
    .o5::after { --ps:15px; --pc:#D8A840; --pg:14px; margin-top:-6px; }

    .orrery-label {
      position: absolute; bottom: -32px; left: 50%; transform: translateX(-50%);
