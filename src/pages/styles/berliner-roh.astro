      .rc:first-child .rc-img-wrap { height: auto; min-height: auto; padding-bottom: 65%; }
      .raume-top { flex-direction: column; align-items: flex-start; }

      .manifest-inner { grid-template-columns: 1fr; }

      .pricing-grid { grid-template-columns: 1fr; }
      .mitglied-top { grid-template-columns: 1fr; }
      .mitglied-note { text-align: left; }

      footer { flex-direction: column; align-items: flex-start; gap: 1.2rem; }
