---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>ROHBAU — Coworking & Galerie | Trier-Euren</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --black:    #0C0B0A;
      --black-2:  #161412;
      --black-3:  #211E1B;
      --border:   #333030;
      --border-l: #4A4540;
      --white:    #EDE7DC;
      --muted:    #6A6258;
      --muted-2:  #9A9088;
      --rust:     #C4603A;
      --rust-l:   #DE7B52;
      --fd: 'Barlow Condensed', sans-serif;
      --fm: 'IBM Plex Mono', monospace;
      --fb: 'IBM Plex Sans', sans-serif;
    }

    body {
      background: var(--black);
      color: var(--white);
      font-family: var(--fb);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* Grain */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 9999;
      pointer-events: none;
      opacity: 1;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.88' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.038'/%3E%3C/svg%3E");
      background-size: 220px 220px;
    }

    a { text-decoration: none; color: inherit; }
    img { display: block; width: 100%; }

    /* ── REVEAL ── */
    .reveal {
      opacity: 0;
      transform: translateY(36px);
      transition: opacity 0.85s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal.in { opacity: 1; transform: none; }
    .d1 { transition-delay: 0.08s; }
    .d2 { transition-delay: 0.2s; }
    .d3 { transition-delay: 0.34s; }
    .d4 { transition-delay: 0.48s; }
    .d5 { transition-delay: 0.62s; }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 clamp(1.5rem, 4vw, 3rem);
      background: rgba(12, 11, 10, 0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: var(--fm);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--white);
    }
    .nav-logo b { color: var(--rust); font-weight: 700; }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-family: var(--fm);
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted-2);
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--white); }

    .nav-cta {
      font-family: var(--fm);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--rust);
      border: 1px solid var(--rust);
      padding: 0.38rem 1.1rem;
      transition: background 0.2s, color 0.2s;
    }
    .nav-cta:hover { background: var(--rust); color: var(--black); }

    .nav-burger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }
    .nav-burger span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: var(--white);
      transition: all 0.3s;
    }

    /* ── HERO ── */
    .hero {
      display: grid;
      grid-template-columns: 55% 45%;
      min-height: 100vh;
      padding-top: 56px;
    }

    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(3rem, 5vw, 5rem) clamp(2rem, 5vw, 4.5rem);
      position: relative;
      border-right: 1px solid var(--border);
    }

    /* subtle vertical line accent */
    .hero-left::before {
      content: '';
      position: absolute;
      left: clamp(2rem, 5vw, 4.5rem);
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, transparent, var(--border) 20%, var(--border) 80%, transparent);
      pointer-events: none;
    }

    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      font-family: var(--fm);
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted-2);
      margin-bottom: 2.2rem;
      padding-left: 1.5rem;
    }
    .hero-tag::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--rust);
      flex-shrink: 0;
      animation: blink 2.4s ease-in-out infinite;
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    .hero-headline {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(5.5rem, 10vw, 10rem);
      line-height: 0.88;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      padding-left: 1.5rem;
      margin-bottom: 2.8rem;
    }
    .hero-headline .stroke {
      -webkit-text-stroke: 2.5px var(--white);
      color: transparent;
      display: block;
    }
    .hero-headline .solid { display: block; }
    .hero-headline .accent { display: block; color: var(--rust); }

    .hero-body {
      font-family: var(--fb);
      font-size: clamp(0.85rem, 1.1vw, 0.95rem);
      font-weight: 300;
      line-height: 1.75;
      color: var(--muted-2);
      max-width: 400px;
      padding-left: 1.5rem;
      margin-bottom: 2.8rem;
      border-left: 2px solid var(--border-l);
    }

    .hero-stats {
      display: flex;
      gap: clamp(1.5rem, 3vw, 3rem);
      padding: 2rem clamp(1.5rem, 5vw, 4.5rem);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      margin: 0 0 2.8rem;
    }
    .stat-n {
      font-family: var(--fm);
      font-size: clamp(1.2rem, 2vw, 1.7rem);
      font-weight: 700;
      color: var(--white);
      display: block;
      line-height: 1;
      margin-bottom: 0.28rem;
    }
    .stat-l {
      font-family: var(--fm);
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 2rem;
      padding-left: 1.5rem;
    }
    .btn-p {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-family: var(--fm);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--black);
      background: var(--rust);
      border: 2px solid var(--rust);
      padding: 0.85rem 1.8rem;
      transition: background 0.2s, color 0.2s;
      cursor: pointer;
    }
    .btn-p:hover { background: transparent; color: var(--rust); }

    .btn-s {
      font-family: var(--fm);
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      transition: color 0.2s;
    }
    .btn-s:hover { color: var(--white); }
    .btn-s::after { content: ' ↗'; }

    /* ── HERO RIGHT ── */
    .hero-right {
      position: relative;
      overflow: hidden;
      background: var(--black-3);
    }
    .hero-right-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 10s ease-out;
      filter: brightness(0.85) saturate(0.7);
    }
    .hero-right:hover .hero-right-img { transform: scale(1.04); }
    .hero-right::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to right, var(--black) 0%, transparent 25%),
        linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 45%);
    }

    .hero-badge {
      position: absolute;
      bottom: 2.5rem;
      right: 2rem;
      z-index: 2;
      background: rgba(12,11,10,0.88);
      border: 1px solid var(--border-l);
      backdrop-filter: blur(10px);
      padding: 0.9rem 1.3rem;
    }
    .badge-l {
      font-family: var(--fm);
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      display: block;
      margin-bottom: 0.25rem;
    }
    .badge-v {
      font-family: var(--fm);
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--white);
    }

    /* ── TICKER ── */
    .ticker {
      height: 42px;
      background: var(--rust);
      overflow: hidden;
      display: flex;
      align-items: center;
    }
    .ticker-track {
      display: flex;
      white-space: nowrap;
      animation: roll 32s linear infinite;
    }
    .ticker-item {
      font-family: var(--fm);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--black);
      padding: 0 2rem;
    }
    .ticker-sep {
      color: rgba(0,0,0,0.3);
      padding: 0 0.5rem;
    }
    @keyframes roll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ── SECTION HEADER ── */
    .sec-head {
      display: flex;
      align-items: baseline;
      gap: 1.2rem;
      margin-bottom: 3rem;
    }
    .sec-num {
      font-family: var(--fm);
      font-size: 0.65rem;
      font-weight: 600;
      color: var(--rust);
      letter-spacing: 0.15em;
      flex-shrink: 0;
    }
    .sec-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(2.8rem, 5vw, 5rem);
      font-weight: 900;
      text-transform: uppercase;
      line-height: 0.92;
      color: var(--white);
    }
    .sec-title .stroke {
      -webkit-text-stroke: 2px var(--white);
      color: transparent;
    }

    /* ── SECTION 01: RÄUME ── */
    .raume {
      padding: clamp(4rem, 7vw, 7rem) clamp(1.5rem, 4vw, 3rem);
      background: var(--black-2);
      border-top: 1px solid var(--border);
    }
    .raume-inner { max-width: 1400px; margin: 0 auto; }

    .raume-top {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 2rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 2.5rem;
    }
    .raume-desc {
      font-family: var(--fb);
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.75;
      color: var(--muted-2);
      max-width: 380px;
    }

    /* 3-col brutalist grid with 1.5px separator */
    .raume-grid {
      display: grid;
      grid-template-columns: 1.7fr 1fr 1fr;
      gap: 2px;
      background: var(--border);
    }

    .rc {
      position: relative;
      overflow: hidden;
      background: var(--black-3);
      cursor: pointer;
    }
    .rc:first-child { grid-row: span 2; }

    .rc-img-wrap {
      position: relative;
      width: 100%;
      padding-bottom: 68%;
      overflow: hidden;
    }
    .rc:first-child .rc-img-wrap {
      padding-bottom: 0;
      height: 100%;
      min-height: 560px;
    }

    .rc-img {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      filter: brightness(0.88) saturate(0.65);
    }
    .rc:hover .rc-img {
      transform: scale(1.06);
      filter: brightness(0.7) saturate(0.55);
    }

    .rc-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(12,11,10,0.9) 0%, transparent 55%);
      z-index: 1;
    }

    .rc-info {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 1.4rem 1.6rem;
      z-index: 2;
    }
    .rc-tag {
      display: inline-block;
      font-family: var(--fm);
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--rust-l);
      border: 1px solid rgba(196,96,58,0.5);
      padding: 0.18rem 0.55rem;
      margin-bottom: 0.55rem;
    }
    .rc-name {
      display: block;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(1.5rem, 2.8vw, 2.4rem);
      font-weight: 900;
      text-transform: uppercase;
      color: var(--white);
      line-height: 0.95;
    }
    .rc-meta {
      font-family: var(--fm);
      font-size: 0.6rem;
      color: var(--muted-2);
      margin-top: 0.35rem;
      letter-spacing: 0.08em;
    }

    /* ── SECTION 02: MANIFEST ── */
    .manifest {
      position: relative;
      min-height: 90vh;
      display: flex;
      align-items: center;
      overflow: hidden;
      border-top: 1px solid var(--border);
    }
    .manifest-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .manifest-bg img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: brightness(0.28) saturate(0.4);
    }
    .manifest-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(12,11,10,0.88) 35%, rgba(12,11,10,0.3) 100%);
    }

    .manifest-inner {
      position: relative;
      z-index: 2;
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
      padding: clamp(4rem, 7vw, 7rem) clamp(1.5rem, 4vw, 3rem);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(3rem, 6vw, 7rem);
      align-items: center;
    }

    .manifest-quote {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(3rem, 5.5vw, 5.5rem);
      text-transform: uppercase;
      line-height: 0.92;
      letter-spacing: -0.01em;
      margin-bottom: 2.5rem;
    }
    .manifest-quote .stroke {
      -webkit-text-stroke: 2.5px var(--white);
      color: transparent;
      display: block;
    }
    .manifest-quote .r { color: var(--rust); display: block; }

    .manifest-body {
      font-family: var(--fb);
      font-size: 0.92rem;
      font-weight: 300;
      color: var(--muted-2);
      line-height: 1.85;
      max-width: 440px;
    }

    .manifest-facts {
      display: flex;
      flex-direction: column;
      gap: 2px;
      background: var(--border);
    }
    .mf-row {
      background: rgba(12, 11, 10, 0.75);
      backdrop-filter: blur(6px);
      padding: 1.4rem 1.8rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      transition: background 0.2s;
    }
    .mf-row:hover { background: rgba(26, 23, 20, 0.92); }
    .mf-label {
      font-family: var(--fm);
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .mf-val {
      font-family: var(--fm);
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--white);
      text-align: right;
    }

    /* ── SECTION 03: MITGLIED ── */
    .mitglied {
      padding: clamp(4rem, 7vw, 7rem) clamp(1.5rem, 4vw, 3rem);
      background: var(--black);
      border-top: 1px solid var(--border);
    }
    .mitglied-inner { max-width: 1400px; margin: 0 auto; }

    .mitglied-top {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: end;
      gap: 2rem;
      margin-bottom: 0;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 2.5rem;
    }
    .mitglied-sub {
      font-family: var(--fb);
      font-size: 0.88rem;
      font-weight: 300;
      color: var(--muted-2);
      line-height: 1.75;
      max-width: 380px;
    }
    .mitglied-note {
      font-family: var(--fm);
      font-size: 0.62rem;
      color: var(--muted);
      letter-spacing: 0.1em;
      text-align: right;
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      background: var(--border);
    }

    .pc {
      background: var(--black-2);
      padding: 2.5rem;
      display: flex;
      flex-direction: column;
      gap: 1.4rem;
      position: relative;
      transition: background 0.2s;
    }
    .pc:hover { background: var(--black-3); }
    .pc.hot {
      background: var(--black-3);
      border-top: 3px solid var(--rust);
    }
    .pc-badge {
      position: absolute;
      top: -1px; right: 2.5rem;
      background: var(--rust);
      color: var(--black);
      font-family: var(--fm);
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 0.22rem 0.7rem;
    }

    .pc-tier {
      font-family: var(--fm);
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .pc-price {
      display: flex;
      align-items: baseline;
      gap: 0.25rem;
    }
    .pc-amt {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(3.5rem, 5vw, 5rem);
      font-weight: 900;
      color: var(--white);
      line-height: 1;
    }
    .pc-cur {
      font-family: var(--fm);
      font-size: 1rem;
      font-weight: 700;
      color: var(--muted-2);
      align-self: flex-start;
      margin-top: 0.3rem;
    }
    .pc-per {
      font-family: var(--fm);
      font-size: 0.62rem;
      color: var(--muted);
      letter-spacing: 0.1em;
    }

    .pc-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.9rem;
      font-weight: 800;
      text-transform: uppercase;
      color: var(--white);
      line-height: 1;
      padding-bottom: 1.4rem;
      border-bottom: 1px solid var(--border);
    }

    .pc-features {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      flex: 1;
    }
    .pc-feature {
      display: flex;
      align-items: flex-start;
      gap: 0.7rem;
      font-family: var(--fb);
      font-size: 0.82rem;
      color: var(--muted-2);
      line-height: 1.4;
    }
    .pc-feature::before {
      content: '—';
      color: var(--rust);
      font-family: var(--fm);
      font-size: 0.72rem;
      flex-shrink: 0;
      margin-top: 0.04em;
    }

    .pc-cta {
      display: block;
      text-align: center;
      font-family: var(--fm);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 0.85rem;
      border: 1px solid var(--border-l);
      color: var(--muted-2);
      transition: border-color 0.2s, color 0.2s;
      margin-top: auto;
    }
    .pc-cta:hover { border-color: var(--white); color: var(--white); }
    .pc.hot .pc-cta {
      background: var(--rust);
      border-color: var(--rust);
      color: var(--black);
    }
    .pc.hot .pc-cta:hover { background: var(--rust-l); border-color: var(--rust-l); }

    /* ── FOOTER ── */
    footer {
      padding: 2.5rem clamp(1.5rem, 4vw, 3rem);
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .ft-logo {
      font-family: var(--fm);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    .ft-logo b { color: var(--rust); }
    .ft-meta {
      font-family: var(--fm);
      font-size: 0.6rem;
      color: var(--muted);
      letter-spacing: 0.1em;
      text-align: center;
    }
    .ft-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .ft-links a {
      font-family: var(--fm);
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      transition: color 0.2s;
    }
