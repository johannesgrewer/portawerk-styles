  <script>
    // ===== MOUSE PARALLAX ON HERO GRID =====
    const heroGridBg = document.querySelector('.hero-grid-bg');
    document.addEventListener('mousemove', (e) => {
      const x = (e.clientX / window.innerWidth - 0.5);
      const y = (e.clientY / window.innerHeight - 0.5);
      document.documentElement.style.setProperty('--mouse-x', x.toFixed(3));
      document.documentElement.style.setProperty('--mouse-y', y.toFixed(3));
    });

    // ===== TYPEWRITER EFFECT ON HERO HEADLINE =====
    const typewriterTarget = document.getElementById('typewriter-headline');
    const typewriterCursor = document.querySelector('.typewriter-cursor');
    const typewriterText = 'RAUM FUR';
    let typewriterIndex = 0;

    function typeNextChar() {
      if (typewriterIndex <= typewriterText.length) {
        typewriterTarget.textContent = typewriterText.slice(0, typewriterIndex);
        typewriterIndex++;
        // Slow start, speed up to feel mechanical
        const delay = typewriterIndex === 1 ? 600 : 90 + Math.random() * 40;
        setTimeout(typeNextChar, delay);
      }
      // Cursor keeps blinking via CSS after typing completes
    }

    // Start typewriter after a short page-load pause
    setTimeout(typeNextChar, 400);

    // ===== INTERSECTION OBSERVER: .reveal =====
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          // Also trigger quote-mark animation
          const quote = entry.target.querySelector('.member-quote');
          if (quote) quote.classList.add('visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // Trigger member quotes individually too
    document.querySelectorAll('.member-quote').forEach(el => revealObserver.observe(el));

    // ===== INTERSECTION OBSERVER: .stagger-in =====
    const staggerObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const delay = parseInt(entry.target.dataset.delay || '0', 10);
          setTimeout(() => {
            entry.target.classList.add('revealed');
          }, delay);
          staggerObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.stagger-in').forEach(el => staggerObserver.observe(el));

    // ===== COUNT-UP ANIMATION =====
    function animateCountUp(el) {
      const target = parseInt(el.dataset.target, 10);
      const isLarge = el.classList.contains('count-large');
      const duration = isLarge ? 1200 : 800;
      const startTime = performance.now();

      function tick(now) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        // Ease-out cubic
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(eased * target);
        if (progress < 1) requestAnimationFrame(tick);
        else el.textContent = target;
      }

      requestAnimationFrame(tick);
    }

    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCountUp(entry.target);
          countObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });

    document.querySelectorAll('.count-up').forEach(el => countObserver.observe(el));
  </script>

