      .hero-left { padding: 3rem 1.5rem; border-right: none; border-bottom: 1px solid var(--border); }
      .hero-left::before { display: none; }
      .hero-right { height: 55vw; min-height: 240px; }
      .hero-right::after { background: linear-gradient(to top, var(--black) 0%, transparent 50%); }
