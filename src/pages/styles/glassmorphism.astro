---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>CloudBase — IT & Cloud Services, Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    html { overflow-x: hidden; }
    body { overflow-x: hidden; max-width: 100%; }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --primary: #4F46E5;
      --secondary: #1E1B4B;
      --accent: #06B6D4;
      --bg: #0F0E1A;
      --bg-light: #161428;
      --text: #F1F0F9;
      --text-muted: #9B99B0;
      --glass-bg: rgba(255, 255, 255, 0.05);
      --glass-border: rgba(255, 255, 255, 0.1);
      --glass-hover: rgba(255, 255, 255, 0.1);
      --glow-primary: rgba(79, 70, 229, 0.4);
      --glow-accent: rgba(6, 182, 212, 0.4);
      --font: "Outfit", system-ui, -apple-system, sans-serif;
    }

    html {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      scroll-behavior: smooth;
    }

    body { overflow-x: hidden; }

    ::selection { background: var(--primary); color: #fff; }

    /* ═══════════════════════════════════════════
       NAV
    ═══════════════════════════════════════════ */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 100;
      padding: 1.25rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(15, 14, 26, 0.6);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--glass-border);
    }

    .nav-logo {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--text);
      text-decoration: none;
      letter-spacing: -0.02em;
    }

    .nav-logo span {
      background: linear-gradient(135deg, var(--primary), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 400;
      transition: color 0.3s ease;
    }

    .nav-links a:hover { color: var(--text); }

    .nav-cta {
      padding: 0.5rem 1.25rem;
      border-radius: 8px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      color: var(--text) !important;
      font-weight: 500 !important;
      transition: background 0.3s ease, border-color 0.3s ease !important;
    }

    .nav-cta:hover {
      background: var(--glass-hover) !important;
      border-color: rgba(255, 255, 255, 0.2) !important;
    }

    /* ═══════════════════════════════════════════
       HERO
    ═══════════════════════════════════════════ */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 8rem 2rem 6rem;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
    }

    .hero-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      opacity: 0.4;
    }

    .hero-orb--1 {
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, var(--primary), transparent 70%);
      top: -10%;
      left: -10%;
      animation: orbFloat1 15s ease-in-out infinite;
    }

    .hero-orb--2 {
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, var(--accent), transparent 70%);
      bottom: -15%;
      right: -10%;
      animation: orbFloat2 18s ease-in-out infinite;
    }

    .hero-orb--3 {
      width: 350px;
      height: 350px;
      background: radial-gradient(circle, var(--primary), transparent 70%);
      top: 40%;
      right: 20%;
      opacity: 0.2;
      animation: orbFloat3 20s ease-in-out infinite;
    }

    @keyframes orbFloat1 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(80px, 40px) scale(1.1); }
      66% { transform: translate(-30px, 80px) scale(0.95); }
    }

    @keyframes orbFloat2 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(-60px, -50px) scale(1.05); }
      66% { transform: translate(40px, -30px) scale(0.9); }
    }

    @keyframes orbFloat3 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50% { transform: translate(-50px, 60px) scale(1.15); }
    }

    .hero-content {
      position: relative;
      z-index: 1;
      text-align: center;
      max-width: 800px;
    }

    .hero-badge {
      display: inline-block;
      padding: 0.4rem 1rem;
      border-radius: 100px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--accent);
      letter-spacing: 0.05em;
      margin-bottom: 2rem;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .hero-title {
      font-size: clamp(2.8rem, 6vw, 4.5rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 1.25rem;
      color: var(--text);
    }

    .hero-subtitle {
      font-size: 1.15rem;
      font-weight: 300;
      color: var(--text-muted);
      line-height: 1.6;
      max-width: 520px;
      margin: 0 auto 3rem;
    }

    .hero-metrics {
      display: flex;
      gap: 1.25rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 3rem;
    }

    .metric-card {
      padding: 1.25rem 1.75rem;
      border-radius: 16px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      text-align: center;
      min-width: 160px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      transition: transform 0.3s ease, border-color 0.3s ease;
    }

    .metric-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 255, 255, 0.18);
    }

    .metric-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.25rem;
    }

    .metric-label {
      font-size: 0.8rem;
      font-weight: 400;
      color: var(--text-muted);
      letter-spacing: 0.02em;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 1rem 2.25rem;
      border-radius: 12px;
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      border: 2px solid transparent;
      background-image: linear-gradient(var(--bg), var(--bg)), linear-gradient(135deg, var(--primary), var(--accent));
      background-origin: border-box;
      background-clip: padding-box, border-box;
      box-shadow: 0 0 24px var(--glow-primary), 0 0 48px rgba(79, 70, 229, 0.15);
      transition: box-shadow 0.3s ease, transform 0.3s ease;
      cursor: pointer;
    }

    .hero-cta:hover {
      box-shadow: 0 0 32px var(--glow-primary), 0 0 64px var(--glow-accent);
      transform: translateY(-2px);
    }

    /* ═══════════════════════════════════════════
       SECTION: SERVICES
    ═══════════════════════════════════════════ */
    .section {
      position: relative;
      padding: 6rem 2rem;
    }

    .section-inner {
      max-width: 1100px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.75rem;
      text-align: center;
    }

    .section-title {
      font-size: clamp(2rem, 4vw, 2.75rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      text-align: center;
      margin-bottom: 3.5rem;
      color: var(--text);
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .service-card {
      padding: 2.25rem;
      border-radius: 20px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
      transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
    }

    .service-card:hover {
      background: var(--glass-hover);
      border-color: rgba(255, 255, 255, 0.18);
      transform: translateY(-4px);
    }

    .service-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: linear-gradient(135deg, rgba(79, 70, 229, 0.15), rgba(6, 182, 212, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.5rem;
    }

    .service-icon svg {
      width: 24px;
      height: 24px;
      stroke: var(--accent);
      fill: none;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .service-title {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: var(--text);
    }

    .service-desc {
      font-size: 0.95rem;
      font-weight: 300;
      color: var(--text-muted);
      line-height: 1.6;
    }

    /* ═══════════════════════════════════════════
       SECTION: TRUST / WHY CLOUDBASE
    ═══════════════════════════════════════════ */
    .trust-section {
      background: linear-gradient(180deg, var(--bg) 0%, var(--bg-light) 50%, var(--bg) 100%);
    }

    .trust-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
      margin-bottom: 4rem;
    }

    .trust-item {
      text-align: center;
      padding: 2rem 1.25rem;
      border-radius: 16px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      transition: border-color 0.3s ease;
    }

    .trust-item:hover {
      border-color: rgba(255, 255, 255, 0.18);
    }

    .trust-value {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.35rem;
    }

    .trust-label {
      font-size: 0.8rem;
      font-weight: 400;
      color: var(--text-muted);
    }

    .quote-block {
      max-width: 640px;
      margin: 0 auto 3.5rem;
      text-align: center;
    }

    .quote-text {
      font-size: 1.25rem;
      font-weight: 300;
      font-style: italic;
      color: var(--text);
      line-height: 1.7;
      margin-bottom: 1.25rem;
    }

    .quote-text::before { content: "\201E"; }
    .quote-text::after { content: "\201C"; }

    .quote-author {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text-muted);
    }

    .quote-role {
      font-size: 0.8rem;
      font-weight: 300;
      color: var(--text-muted);
      opacity: 0.7;
    }

    .contact-row {
      display: flex;
      justify-content: center;
      gap: 2.5rem;
      flex-wrap: wrap;
    }

    .contact-link {
      font-size: 1rem;
      font-weight: 500;
      color: var(--accent);
      text-decoration: none;
      transition: text-shadow 0.3s ease, color 0.3s ease;
      text-shadow: 0 0 8px transparent;
    }

    .contact-link:hover {
      color: #22D3EE;
      text-shadow: 0 0 16px var(--glow-accent), 0 0 32px rgba(6, 182, 212, 0.2);
    }

    /* ═══════════════════════════════════════════
       FOOTER
    ═══════════════════════════════════════════ */
    .footer {
      padding: 3rem 2rem;
      text-align: center;
      border-top: 1px solid var(--glass-border);
    }

    .footer p {
      font-size: 0.8rem;
      color: var(--text-muted);
      opacity: 0.6;
    }

    /* ═══════════════════════════════════════════
       DIVIDER LINE
    ═══════════════════════════════════════════ */
    .section-divider {
      max-width: 1100px;
      margin: 0 auto;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--glass-border), transparent);
    }

    /* ═══════════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════════ */
    @media (max-width: 900px) {
      .services-grid {
        grid-template-columns: 1fr;
        max-width: 480px;
        margin: 0 auto;
      }

      .trust-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .nav-links { display: none; }
    }

    @media (max-width: 600px) {
      .hero { padding: 7rem 1.25rem 4rem; }
      .section { padding: 4rem 1.25rem; }

      .hero-metrics {
        flex-direction: column;
        align-items: center;
      }

      .metric-card { min-width: 220px; }

      .trust-grid {
        grid-template-columns: 1fr;
        max-width: 320px;
        margin: 0 auto 3rem;
      }

      .contact-row {
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }

      .nav { padding: 1rem 1.25rem; }
    }

    /* ═══════════════════════════════════════════
       SCANLINE OVERLAY
    ═══════════════════════════════════════════ */
    .scanlines {
      position: fixed;
      inset: 0;
      z-index: 9999;
      pointer-events: none;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(255, 255, 255, 0.015) 2px,
        rgba(255, 255, 255, 0.015) 4px
      );
    }

    /* ═══════════════════════════════════════════
       FLOATING PARTICLES
    ═══════════════════════════════════════════ */
    .particles {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .particle {
      position: absolute;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.15);
      box-shadow: 0 0 6px rgba(79, 70, 229, 0.3);
      animation: particleFloat linear infinite;
    }

    .particle:nth-child(1) { left: 5%; top: 10%; animation-duration: 22s; animation-delay: 0s; }
    .particle:nth-child(2) { left: 15%; top: 80%; animation-duration: 18s; animation-delay: -3s; width: 2px; height: 2px; }
    .particle:nth-child(3) { left: 25%; top: 30%; animation-duration: 25s; animation-delay: -7s; }
    .particle:nth-child(4) { left: 35%; top: 60%; animation-duration: 20s; animation-delay: -2s; width: 4px; height: 4px; box-shadow: 0 0 8px rgba(6, 182, 212, 0.4); }
    .particle:nth-child(5) { left: 45%; top: 15%; animation-duration: 28s; animation-delay: -10s; width: 2px; height: 2px; }
    .particle:nth-child(6) { left: 55%; top: 70%; animation-duration: 19s; animation-delay: -5s; }
    .particle:nth-child(7) { left: 65%; top: 45%; animation-duration: 24s; animation-delay: -8s; width: 4px; height: 4px; }
    .particle:nth-child(8) { left: 75%; top: 20%; animation-duration: 21s; animation-delay: -1s; box-shadow: 0 0 8px rgba(6, 182, 212, 0.4); }
    .particle:nth-child(9) { left: 85%; top: 55%; animation-duration: 26s; animation-delay: -6s; width: 2px; height: 2px; }
    .particle:nth-child(10) { left: 92%; top: 35%; animation-duration: 23s; animation-delay: -4s; }
    .particle:nth-child(11) { left: 10%; top: 50%; animation-duration: 27s; animation-delay: -9s; width: 2px; height: 2px; }
    .particle:nth-child(12) { left: 50%; top: 90%; animation-duration: 17s; animation-delay: -12s; box-shadow: 0 0 8px rgba(79, 70, 229, 0.5); }

    @keyframes particleFloat {
      0% { transform: translateY(0) translateX(0); opacity: 0; }
      10% { opacity: 1; }
      45% { transform: translateY(-40vh) translateX(20px); }
      55% { transform: translateY(-50vh) translateX(-15px); }
      90% { opacity: 1; }
      100% { transform: translateY(-100vh) translateX(10px); opacity: 0; }
    }

    /* ═══════════════════════════════════════════
       CHROMATIC ABERRATION — HERO TITLE
    ═══════════════════════════════════════════ */
    .hero-title {
      text-shadow:
        -1.5px 0 rgba(79, 70, 229, 0.35),
        1.5px 0 rgba(6, 182, 212, 0.35);
    }

    /* ═══════════════════════════════════════════
       GLASS CARD HOVER — LIGHT SWEEP + BLUR INCREASE
    ═══════════════════════════════════════════ */
    .metric-card,
    .service-card,
    .trust-item {
      position: relative;
      overflow: hidden;
    }

    .metric-card::after,
    .service-card::after,
    .trust-item::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        105deg,
        transparent 40%,
        rgba(255, 255, 255, 0.06) 45%,
        rgba(255, 255, 255, 0.12) 50%,
        rgba(255, 255, 255, 0.06) 55%,
        transparent 60%
      );
      transform: translateX(-100%);
      transition: transform 0.6s ease;
      pointer-events: none;
      border-radius: inherit;
    }

    .metric-card:hover::after,
    .service-card:hover::after,
    .trust-item:hover::after {
      transform: translateX(100%);
    }

    .metric-card:hover,
    .service-card:hover,
    .trust-item:hover {
      backdrop-filter: blur(32px);
      -webkit-backdrop-filter: blur(32px);
    }

    /* ═══════════════════════════════════════════
       CTA — ROTATING CONIC GRADIENT BORDER
    ═══════════════════════════════════════════ */
    .hero-cta {
      position: relative;
      z-index: 1;
      background: var(--bg) !important;
      background-image: none !important;
      background-clip: unset !important;
      border: none !important;
    }

    .hero-cta::before {
      content: "";
      position: absolute;
      inset: -2px;
      border-radius: 14px;
      background: conic-gradient(
        from var(--cta-angle, 0deg),
        var(--primary),
        var(--accent),
        var(--primary),
        var(--accent),
        var(--primary)
      );
      z-index: -1;
      animation: rotateBorder 3s linear infinite;
    }

    .hero-cta::after {
      content: "";
      position: absolute;
      inset: 2px;
      border-radius: 10px;
      background: var(--bg);
      z-index: -1;
    }

    @property --cta-angle {
      syntax: "<angle>";
      initial-value: 0deg;
      inherits: false;
    }

    @keyframes rotateBorder {
      to { --cta-angle: 360deg; }
    }

    /* ═══════════════════════════════════════════
       SERVICE CARDS — STAGGERED ENTRANCE
    ═══════════════════════════════════════════ */
    .service-card {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                  background 0.3s ease,
                  border-color 0.3s ease;
    }

    .service-card.visible { opacity: 1; transform: translateY(0); }
    .service-card:nth-child(1) { transition-delay: 0s; }
    .service-card:nth-child(2) { transition-delay: 0.15s; }
    .service-card:nth-child(3) { transition-delay: 0.3s; }

    /* ═══════════════════════════════════════════
       SVG ICON — PULSE GLOW ON HOVER
    ═══════════════════════════════════════════ */
    .service-icon svg {
      transition: filter 0.3s ease, transform 0.3s ease;
    }

    .service-card:hover .service-icon svg {
      filter: drop-shadow(0 0 6px var(--glow-accent)) drop-shadow(0 0 12px rgba(6, 182, 212, 0.3));
      animation: iconPulse 1.5s ease-in-out infinite;
    }

    @keyframes iconPulse {
      0%, 100% { transform: scale(1); filter: drop-shadow(0 0 6px var(--glow-accent)); }
      50% { transform: scale(1.08); filter: drop-shadow(0 0 12px var(--glow-accent)) drop-shadow(0 0 20px rgba(6, 182, 212, 0.25)); }
    }

    /* ═══════════════════════════════════════════
       TRUST ITEMS — STAGGERED ENTRANCE
    ═══════════════════════════════════════════ */
    .trust-item {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                  border-color 0.3s ease;
    }

    .trust-item.visible { opacity: 1; transform: translateY(0); }
    .trust-item:nth-child(1) { transition-delay: 0s; }
    .trust-item:nth-child(2) { transition-delay: 0.1s; }
    .trust-item:nth-child(3) { transition-delay: 0.2s; }
    .trust-item:nth-child(4) { transition-delay: 0.3s; }

    /* ═══════════════════════════════════════════
       TYPING CURSOR — QUOTE
    ═══════════════════════════════════════════ */
    .quote-text::after {
      content: "\201C";
      /* cursor blinks after closing quote */
    }

    .quote-cursor {
      display: inline-block;
      width: 2px;
      height: 1.1em;
      background: var(--accent);
      margin-left: 4px;
      vertical-align: text-bottom;
      animation: cursorBlink 0.8s steps(2) infinite;
    }

    @keyframes cursorBlink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    /* ═══════════════════════════════════════════
       HERO CONTENT — FADE-IN
    ═══════════════════════════════════════════ */
    .hero-badge,
    .hero-title,
    .hero-subtitle,
    .hero-metrics,
    .hero-cta {
      opacity: 0;
      transform: translateY(20px);
      animation: heroFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .hero-badge { animation-delay: 0.1s; }
    .hero-title { animation-delay: 0.25s; }
    .hero-subtitle { animation-delay: 0.4s; }
    .hero-metrics { animation-delay: 0.55s; }
    .hero-cta { animation-delay: 0.7s; }

    @keyframes heroFadeIn {
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
