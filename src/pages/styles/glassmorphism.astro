---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Vitrum Analytics — Datenstrategie für wachsende Unternehmen | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; overflow-x: hidden; }

    :root {
      --bg:        #050A18;
      --bg2:       #080D1E;
      --sky:       #38BDF8;
      --violet:    #8B5CF6;
      --violet-lt: #A78BFA;
      --cyan:      #06B6D4;
      --pink:      #F0ABFC;
      --text:      #EEF2FF;
      --muted:     rgba(238,242,255,0.48);
      --glass:     rgba(255,255,255,0.055);
      --glass-hov: rgba(255,255,255,0.09);
      --border:    rgba(255,255,255,0.1);
      --font:      'Sora', system-ui, sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-weight: 400;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    ::selection { background: var(--violet); color: #fff; }

    /* ── ORB SYSTEM ── */
    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      pointer-events: none;
    }
    .orb-blue {
      width: 700px; height: 700px;
      background: radial-gradient(circle, #1E40AF 0%, transparent 70%);
      opacity: 0.42;
      animation: float1 18s ease-in-out infinite;
    }
    .orb-violet {
      width: 580px; height: 580px;
      background: radial-gradient(circle, #7C3AED 0%, transparent 70%);
      opacity: 0.32;
      animation: float2 22s ease-in-out infinite;
    }
    .orb-teal {
      width: 480px; height: 480px;
      background: radial-gradient(circle, #0EA5E9 0%, transparent 70%);
      opacity: 0.26;
      animation: float3 16s ease-in-out infinite;
    }
    @keyframes float1 {
      0%,100% { transform: translate(0,0) scale(1); }
      33%  { transform: translate(40px,-30px) scale(1.06); }
      66%  { transform: translate(-25px,20px) scale(0.97); }
    }
    @keyframes float2 {
      0%,100% { transform: translate(0,0) scale(1); }
      40%  { transform: translate(-35px,28px) scale(1.04); }
      70%  { transform: translate(22px,-18px) scale(0.98); }
    }
    @keyframes float3 {
      0%,100% { transform: translate(0,0) scale(1); }
      50%  { transform: translate(-28px,-22px) scale(1.08); }
    }
    @keyframes pulse {
      0%,100% { opacity:1; transform:scale(1); }
      50%     { opacity:0.45; transform:scale(0.75); }
    }
    @keyframes floatY {
      0%,100% { transform: translateY(0); }
      50%     { transform: translateY(-10px); }
    }

    /* ── NAV ── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 999;
      padding: 1.35rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(5,10,24,0.45);
      backdrop-filter: blur(24px) saturate(120%);
      -webkit-backdrop-filter: blur(24px) saturate(120%);
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .nav-logo {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text);
      text-decoration: none;
      letter-spacing: -0.03em;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .nav-logo-mark {
      width: 33px; height: 33px;
      border-radius: 9px;
      background: linear-gradient(135deg, var(--sky), var(--violet));
      display: flex; align-items: center; justify-content: center;
      font-size: 0.8rem;
      font-weight: 800;
      color: #fff;
      flex-shrink: 0;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.875rem;
      font-weight: 400;
      transition: color 0.22s;
    }
    .nav-links a:hover { color: var(--text); }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.65rem 1.5rem;
      background: linear-gradient(135deg, var(--sky), var(--violet));
      border-radius: 11px;
      color: #fff;
      font-size: 0.875rem;
      font-weight: 600;
      font-family: var(--font);
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: opacity 0.22s, transform 0.22s, box-shadow 0.22s;
      box-shadow: 0 0 28px rgba(56,189,248,0.28);
    }
    .btn-primary:hover {
      opacity: 0.88;
      transform: translateY(-2px);
      box-shadow: 0 0 44px rgba(56,189,248,0.42);
    }
    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.65rem 1.5rem;
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: 11px;
      color: var(--text);
      font-size: 0.875rem;
      font-weight: 500;
      font-family: var(--font);
      text-decoration: none;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transition: background 0.22s, border-color 0.22s, transform 0.22s;
    }
    .btn-ghost:hover {
      background: var(--glass-hov);
      border-color: rgba(255,255,255,0.2);
      transform: translateY(-2px);
    }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 8rem 3rem 6rem;
      overflow: hidden;
    }
    .hero-orbs { position: absolute; inset: 0; overflow: hidden; }
    .hero-inner {
      position: relative;
      z-index: 2;
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      padding: 0.38rem 1rem;
      background: rgba(56,189,248,0.1);
      border: 1px solid rgba(56,189,248,0.28);
      border-radius: 100px;
      font-size: 0.77rem;
      font-weight: 500;
      color: var(--sky);
      margin-bottom: 1.8rem;
      width: fit-content;
    }
    .badge-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--sky);
      box-shadow: 0 0 8px var(--sky);
      animation: pulse 2s ease-in-out infinite;
      flex-shrink: 0;
    }
    .hero-title {
      font-size: clamp(3rem, 5.5vw, 5.5rem);
      font-weight: 800;
      line-height: 1.0;
      letter-spacing: -0.045em;
      margin-bottom: 1.8rem;
    }
    .grad {
      background: linear-gradient(135deg, var(--sky) 0%, var(--violet-lt) 55%, var(--pink) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      font-size: 1.08rem;
      font-weight: 300;
      line-height: 1.75;
      color: var(--muted);
      max-width: 480px;
      margin-bottom: 2.75rem;
    }
    .hero-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
      flex-wrap: wrap;
    }

    /* Dashboard Mockup */
    .hero-visual { position: relative; }
    .db-card {
      position: relative;
      padding: 2rem;
      border-radius: 22px;
      background: rgba(255,255,255,0.042);
      backdrop-filter: blur(32px) saturate(140%);
      -webkit-backdrop-filter: blur(32px) saturate(140%);
      border: 1px solid rgba(255,255,255,0.1);
      box-shadow: 0 32px 80px rgba(0,0,0,0.55), inset 0 1px 0 rgba(255,255,255,0.08);
      overflow: hidden;
    }
    .db-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent 5%, rgba(56,189,248,0.6) 40%, rgba(139,92,246,0.6) 65%, transparent 95%);
    }
    .db-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
    }
    .db-label {
      font-size: 0.72rem;
      font-weight: 500;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .db-live {
      display: flex;
      align-items: center;
      gap: 0.38rem;
      font-size: 0.7rem;
      color: #4ADE80;
      font-weight: 500;
    }
    .db-live-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: #4ADE80;
      box-shadow: 0 0 6px #4ADE80;
      animation: pulse 1.6s ease-in-out infinite;
    }
    .db-metrics {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.9rem;
      margin-bottom: 1.65rem;
    }
    .db-metric {
      padding: 0.95rem;
      background: rgba(255,255,255,0.038);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 13px;
    }
    .db-metric-lbl {
      font-size: 0.65rem;
      color: var(--muted);
      margin-bottom: 0.3rem;
    }
    .db-metric-val {
      font-size: 1.35rem;
      font-weight: 700;
      letter-spacing: -0.04em;
    }
    .db-metric-delta {
      font-size: 0.65rem;
      color: #4ADE80;
      margin-top: 0.22rem;
    }
    .db-chart {
      height: 88px;
      display: flex;
      align-items: flex-end;
      gap: 6px;
    }
    .bar {
      flex: 1;
      border-radius: 4px 4px 0 0;
      opacity: 0.7;
      transition: opacity 0.3s;
    }
    .bar:hover { opacity: 1; }

    /* Floating badge */
    .float-badge {
      position: absolute;
      bottom: -1.5rem;
      right: -1.75rem;
      padding: 1rem 1.3rem;
      background: rgba(124,58,237,0.18);
      backdrop-filter: blur(20px) saturate(130%);
      -webkit-backdrop-filter: blur(20px) saturate(130%);
      border: 1px solid rgba(139,92,246,0.32);
      border-radius: 18px;
      animation: floatY 4s ease-in-out infinite;
      z-index: 3;
    }
    .float-badge-lbl {
      font-size: 0.67rem;
      color: var(--muted);
      margin-bottom: 0.18rem;
    }
    .float-badge-val {
      font-size: 1.35rem;
      font-weight: 700;
      background: linear-gradient(135deg, var(--violet-lt), var(--pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .float-badge-sub {
      font-size: 0.65rem;
      color: rgba(238,242,255,0.38);
      margin-top: 0.15rem;
    }

    /* ── TRUSTED ── */
    .trusted {
      position: relative;
      z-index: 2;
      padding: 2.75rem 3rem;
      border-top: 1px solid rgba(255,255,255,0.055);
      border-bottom: 1px solid rgba(255,255,255,0.055);
    }
    .trusted-inner {
      max-width: 1280px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 3rem;
    }
    .trusted-lbl {
      font-size: 0.7rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      white-space: nowrap;
    }
    .trusted-logos {
      display: flex;
      gap: 3rem;
      flex-wrap: wrap;
    }
    .trusted-logo {
      font-size: 0.88rem;
      font-weight: 600;
      color: rgba(238,242,255,0.28);
      letter-spacing: -0.02em;
      transition: color 0.3s;
    }
    .trusted-logo:hover { color: rgba(238,242,255,0.65); }

    /* ── SHARED SECTION STYLES ── */
    .section-inner {
      position: relative;
      z-index: 2;
      max-width: 1280px;
      margin: 0 auto;
    }
    .section-eyebrow {
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--sky);
      margin-bottom: 0.9rem;
    }
    .section-h2 {
      font-size: clamp(2rem, 3.5vw, 3.2rem);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.08;
      margin-bottom: 1.1rem;
    }
    .section-sub {
      font-size: 1.02rem;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.72;
      max-width: 560px;
    }

    /* ── FEATURES ── */
    .features {
      position: relative;
      padding: 8rem 3rem;
      overflow: hidden;
    }
    .features .section-sub { margin-bottom: 4rem; }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .feat-card {
      padding: 2.25rem;
      border-radius: 20px;
      background: var(--glass);
      backdrop-filter: blur(26px) saturate(130%);
      -webkit-backdrop-filter: blur(26px) saturate(130%);
      border: 1px solid var(--border);
      position: relative;
      overflow: hidden;
      transition: background 0.32s, border-color 0.32s, transform 0.32s;
    }
    .feat-card::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent 10%, rgba(255,255,255,0.14) 50%, transparent 90%);
    }
    .feat-card:hover {
      background: var(--glass-hov);
      border-color: rgba(56,189,248,0.32);
      transform: translateY(-6px);
    }
    .feat-icon {
      width: 48px; height: 48px;
      border-radius: 13px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.5rem;
    }
    .feat-title {
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: -0.025em;
      margin-bottom: 0.7rem;
    }
    .feat-text {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.72;
      color: var(--muted);
    }
    .feat-chip {
      margin-top: 1.5rem;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.7rem;
      font-weight: 500;
      padding: 0.28rem 0.7rem;
      border-radius: 100px;
    }

    /* ── SHOWCASE ── */
    .showcase {
      position: relative;
      padding: 8rem 3rem;
      overflow: hidden;
      background: linear-gradient(180deg, var(--bg) 0%, var(--bg2) 100%);
    }
    .showcase-grid {
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      gap: 5rem;
      align-items: center;
    }
    .showcase-photo {
      position: relative;
      border-radius: 24px;
      overflow: hidden;
      height: 520px;
    }
    .showcase-photo img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.65s ease;
    }
    .showcase-photo:hover img { transform: scale(1.04); }
    .showcase-photo-tint {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(30,58,138,0.48) 0%, rgba(124,58,237,0.28) 100%);
      pointer-events: none;
    }
    .showcase-photo-border {
      position: absolute; inset: 0;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 24px;
      pointer-events: none;
      z-index: 2;
    }
    /* glass overlay on photo */
    .photo-glass {
      position: absolute;
      bottom: 1.5rem; left: 1.5rem; right: 1.5rem;
      z-index: 3;
      padding: 1.25rem 1.5rem;
      background: rgba(255,255,255,0.1);
      backdrop-filter: blur(20px) saturate(130%);
      -webkit-backdrop-filter: blur(20px) saturate(130%);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 16px;
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }
    .pg-stat { flex: 1; text-align: center; }
    .pg-val {
      font-size: 1.55rem;
      font-weight: 800;
      letter-spacing: -0.045em;
    }
    .pg-lbl {
      font-size: 0.68rem;
      color: rgba(238,242,255,0.6);
      margin-top: 0.15rem;
    }
    .pg-div {
      width: 1px;
      height: 38px;
      background: rgba(255,255,255,0.18);
    }
    .showcase-steps { display: flex; flex-direction: column; gap: 1.5rem; }
    .step-card {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      padding: 1.4rem;
      background: var(--glass);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: 16px;
      transition: background 0.28s, border-color 0.28s;
    }
    .step-card:hover {
      background: var(--glass-hov);
      border-color: rgba(56,189,248,0.22);
    }
    .step-num {
      width: 32px; height: 32px;
      border-radius: 8px;
      background: linear-gradient(135deg, rgba(56,189,248,0.18), rgba(139,92,246,0.18));
      border: 1px solid rgba(56,189,248,0.28);
      flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--sky);
    }
    .step-title {
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: -0.018em;
      margin-bottom: 0.3rem;
    }
    .step-text {
      font-size: 0.83rem;
      font-weight: 300;
      color: var(--muted);
      line-height: 1.62;
    }

    /* ── STATS ── */
    .stats {
      position: relative;
      overflow: hidden;
    }
    .stats-photo {
      position: absolute; inset: 0;
    }
    .stats-photo img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: brightness(0.22) saturate(0.45);
    }
    .stats-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(5,10,24,0.88) 0%, rgba(30,58,138,0.55) 50%, rgba(5,10,24,0.92) 100%);
    }
    .stats-inner {
      position: relative;
      z-index: 2;
      max-width: 1280px;
      margin: 0 auto;
      padding: 8rem 3rem;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
      margin-bottom: 4rem;
    }
    .stat-card {
      padding: 2.5rem;
      background: rgba(255,255,255,0.058);
      backdrop-filter: blur(32px) saturate(130%);
      -webkit-backdrop-filter: blur(32px) saturate(130%);
      border: 1px solid rgba(255,255,255,0.11);
      border-radius: 20px;
      text-align: center;
      position: relative;
      overflow: hidden;
      transition: background 0.28s, transform 0.28s;
    }
    .stat-card::before {
      content: '';
      position: absolute;
      top: 0; left: 15%; right: 15%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(56,189,248,0.5), transparent);
    }
    .stat-card:hover { background: rgba(255,255,255,0.085); transform: translateY(-4px); }
    .stat-num {
      font-size: clamp(2.5rem, 4vw, 4rem);
      font-weight: 800;
      letter-spacing: -0.055em;
      background: linear-gradient(135deg, #fff 20%, var(--sky) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1;
      margin-bottom: 0.5rem;
    }
    .stat-lbl {
      font-size: 0.85rem;
      font-weight: 300;
      color: var(--muted);
    }
    .testimonial {
      padding: 2.5rem;
      background: rgba(124,58,237,0.1);
      backdrop-filter: blur(30px) saturate(130%);
      -webkit-backdrop-filter: blur(30px) saturate(130%);
      border: 1px solid rgba(139,92,246,0.24);
      border-radius: 20px;
      max-width: 720px;
      position: relative;
      overflow: hidden;
    }
    .testimonial::before {
      content: '"';
      position: absolute;
      top: -0.5rem; left: 1.5rem;
      font-size: 8rem;
      font-weight: 800;
      color: rgba(139,92,246,0.12);
      line-height: 1;
      font-family: Georgia, serif;
    }
    .testimonial-quote {
      font-size: 1.1rem;
      font-weight: 300;
      line-height: 1.78;
      color: rgba(238,242,255,0.88);
      margin-bottom: 1.5rem;
      font-style: italic;
      position: relative;
      z-index: 1;
    }
    .testimonial-author {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .author-av {
      width: 44px; height: 44px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--sky), var(--violet));
      display: flex; align-items: center; justify-content: center;
      font-weight: 700;
      font-size: 0.82rem;
      flex-shrink: 0;
    }
    .author-name { font-weight: 600; font-size: 0.9rem; }
    .author-role { font-size: 0.75rem; color: var(--muted); margin-top: 0.1rem; }

    /* ── CTA ── */
    .cta {
      position: relative;
      padding: 9rem 3rem;
      overflow: hidden;
    }
    .cta-orbs { position: absolute; inset: 0; overflow: hidden; }
    .cta-inner {
      position: relative;
      z-index: 2;
      max-width: 680px;
      margin: 0 auto;
      text-align: center;
    }
    .cta-card {
      padding: 3.75rem;
      background: rgba(255,255,255,0.052);
      backdrop-filter: blur(36px) saturate(145%);
