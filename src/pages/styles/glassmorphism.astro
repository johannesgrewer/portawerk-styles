  <script>
    // ═══════════════════════════════════════════
    // PARALLAX ORBS — respond to mouse movement
    // ═══════════════════════════════════════════
    (function() {
      var orbs = document.querySelectorAll('.hero-orb');
      var parallaxStrengths = [0.03, 0.02, 0.015];

      document.addEventListener('mousemove', function(event) {
        var centerX = window.innerWidth / 2;
        var centerY = window.innerHeight / 2;
        var deltaX = (event.clientX - centerX) / centerX;
        var deltaY = (event.clientY - centerY) / centerY;

        orbs.forEach(function(orb, index) {
          var strength = parallaxStrengths[index] || 0.02;
          var moveX = deltaX * strength * 100;
          var moveY = deltaY * strength * 100;
          orb.style.translate = moveX + 'px ' + moveY + 'px';
        });
      });
    })();

    // ═══════════════════════════════════════════
    // SCROLL-TRIGGERED VISIBILITY (service cards, trust items)
    // ═══════════════════════════════════════════
    (function() {
      var scrollTargets = document.querySelectorAll('.service-card, .trust-item');

      var scrollObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            scrollObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });

      scrollTargets.forEach(function(element) {
        scrollObserver.observe(element);
      });
    })();

    // ═══════════════════════════════════════════
    // COUNT-UP ANIMATION for metric values
    // ═══════════════════════════════════════════
    (function() {
      var metricValues = document.querySelectorAll('.metric-value');

      function animateCountUp(element) {
        var originalText = element.textContent.trim();
        var alreadyAnimated = element.getAttribute('data-animated');
        if (alreadyAnimated) return;
        element.setAttribute('data-animated', 'true');

        // "99.9%" — animate number from 0 to 99.9
        if (originalText.includes('99.9')) {
          var duration = 1800;
          var startTime = performance.now();
          function stepPercent(currentTime) {
            var elapsed = currentTime - startTime;
            var progress = Math.min(elapsed / duration, 1);
            var easedProgress = 1 - Math.pow(1 - progress, 3);
            var currentValue = (easedProgress * 99.9).toFixed(1);
            element.textContent = currentValue + '%';
            if (progress < 1) requestAnimationFrame(stepPercent);
          }
          requestAnimationFrame(stepPercent);
        }
        // "< 2h" — animate from 10 down to 2
        else if (originalText.includes('2h') || originalText.includes('2 h')) {
          var duration2 = 1200;
          var startTime2 = performance.now();
          function stepHours(currentTime) {
            var elapsed = currentTime - startTime2;
            var progress = Math.min(elapsed / duration2, 1);
            var easedProgress = 1 - Math.pow(1 - progress, 3);
            var currentVal = Math.round(10 - easedProgress * 8);
            element.textContent = '< ' + currentVal + 'h';
            if (progress < 1) requestAnimationFrame(stepHours);
            else element.textContent = '< 2h';
          }
          requestAnimationFrame(stepHours);
        }
        // "Seit 2019" — animate year from 2000 to 2019
        else if (originalText.includes('2019')) {
          var duration3 = 1500;
          var startTime3 = performance.now();
          function stepYear(currentTime) {
            var elapsed = currentTime - startTime3;
            var progress = Math.min(elapsed / duration3, 1);
            var easedProgress = 1 - Math.pow(1 - progress, 3);
            var currentYear = Math.round(2000 + easedProgress * 19);
            element.textContent = 'Seit ' + currentYear;
            if (progress < 1) requestAnimationFrame(stepYear);
          }
          requestAnimationFrame(stepYear);
        }
      }

      var metricObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            animateCountUp(entry.target);
            metricObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.5 });

      metricValues.forEach(function(element) {
        metricObserver.observe(element);
      });
    })();

    // ═══════════════════════════════════════════
    // TYPING EFFECT — Quote text
    // ═══════════════════════════════════════════
    (function() {
      var quoteText = document.querySelector('.quote-text');
      if (!quoteText) return;

      var cursor = quoteText.querySelector('.quote-cursor');
      var fullText = 'Wir glauben daran, dass gute IT unsichtbar ist. Sie soll einfach funktionieren \u2014 zuverl\u00e4ssig, sicher und ohne dass Sie dar\u00fcber nachdenken m\u00fcssen.';
      var charIndex = 0;

      // Clear text initially, keep cursor
      quoteText.textContent = '';
      quoteText.appendChild(cursor);

      var quoteObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            startTyping();
            quoteObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });

      quoteObserver.observe(quoteText);

      function startTyping() {
        function typeChar() {
          if (charIndex < fullText.length) {
            quoteText.textContent = fullText.substring(0, charIndex + 1);
            quoteText.appendChild(cursor);
            charIndex++;
            var delay = 18 + Math.random() * 22;
            setTimeout(typeChar, delay);
          }
        }
        typeChar();
      }
    })();
  </script>

