---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Iron Valley — CrossFit Box Trier-Sued</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    html { overflow-x: hidden; }
    /* ── RESET & BASE ── */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #111111;
      color: #FFFFFF;
      line-height: 1.6;
      overflow-x: hidden;
    }

    img {
      max-width: 100%;
      display: block;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    /* ── UTILITY ── */
    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .neon { color: #E8FF00; }
    .accent-red { color: #FF4136; }

    /* ── NAV ── */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 100;
      background: rgba(17, 17, 17, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(232, 255, 0, 0.15);
    }

    .nav-inner {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }

    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      letter-spacing: 3px;
      color: #E8FF00;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      gap: 32px;
      list-style: none;
    }

    .nav-links a {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.05rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #FFFFFF;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: #E8FF00;
    }

    .nav-burger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 4px;
    }

    .nav-burger span {
      display: block;
      width: 28px;
      height: 3px;
      background: #E8FF00;
      border-radius: 2px;
      transition: transform 0.3s, opacity 0.3s;
    }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: stretch;
      overflow: hidden;
      background: #111;
    }

    /* Dark left panel */
    .hero-dark {
      position: absolute;
      inset: 0;
      background: #111;
      clip-path: polygon(0 0, 58% 0, 38% 100%, 0 100%);
      z-index: 2;
      animation: heroClipReveal 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    @keyframes heroClipReveal {
      0% { clip-path: polygon(0 0, 0% 0, 0% 100%, 0 100%); }
      100% { clip-path: polygon(0 0, 58% 0, 38% 100%, 0 100%); }
    }

    /* IV monogram watermark */
    .hero-monogram {
      position: absolute;
      top: 50%;
      left: 12%;
      transform: translateY(-50%);
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(18rem, 28vw, 32rem);
      color: rgba(232, 255, 0, 0.04);
      letter-spacing: -10px;
      line-height: 0.8;
      z-index: 3;
      pointer-events: none;
      user-select: none;
    }

    /* Rotated side label */
    .hero-side-label {
      position: absolute;
      left: 20px;
      top: 50%;
      transform: translateY(-50%) rotate(-90deg);
      transform-origin: center center;
      font-family: 'Inter', sans-serif;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 5px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.25);
      white-space: nowrap;
      z-index: 10;
    }

    /* Image panel (right side) */
    .hero-image {
      position: absolute;
      inset: 0;
      z-index: 1;
      clip-path: polygon(55% 0, 100% 0, 100% 100%, 35% 100%);
      animation: heroImageReveal 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    @keyframes heroImageReveal {
      0% { clip-path: polygon(100% 0, 100% 0, 100% 100%, 100% 100%); }
      100% { clip-path: polygon(55% 0, 100% 0, 100% 100%, 35% 100%); }
    }

    .hero-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(0.15) contrast(1.4) brightness(0.55);
    }

    /* Scan lines over image */
    .hero-image::after {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.12) 2px,
        rgba(0, 0, 0, 0.12) 4px
      );
      pointer-events: none;
    }

    /* Hero content — sits on the diagonal boundary */
    .hero-content {
      position: relative;
      z-index: 5;
      display: flex;
      flex-direction: column;
      justify-content: center;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 160px 24px 140px 80px;
    }

    /* Headline group — positioned to straddle the diagonal */
    .hero-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5rem, 12vw, 11rem);
      line-height: 0.9;
      letter-spacing: 6px;
      text-transform: uppercase;
      margin-bottom: 0;
      opacity: 0;
      transform: translateX(-60px);
      animation: heroTextSlide 0.8s 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    @keyframes heroTextSlide {
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .hero-headline .line-neon {
      color: #E8FF00;
      display: block;
      text-shadow:
        0 0 40px rgba(232, 255, 0, 0.3),
        0 0 80px rgba(232, 255, 0, 0.1);
    }

    .hero-headline .line-white {
      color: #FFFFFF;
      display: block;
      padding-left: 0.15em;
    }

    /* Neon divider line */
    .hero-divider {
      width: 120px;
      height: 4px;
      background: #E8FF00;
      margin: 32px 0 28px;
      box-shadow: 0 0 16px rgba(232, 255, 0, 0.5), 0 0 40px rgba(232, 255, 0, 0.2);
      opacity: 0;
      animation: heroTextSlide 0.6s 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    /* Stats row */
    .hero-stats {
      display: flex;
      align-items: center;
      gap: 0;
      font-family: 'Inter', sans-serif;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.45);
      margin-bottom: 40px;
      opacity: 0;
      animation: heroTextSlide 0.6s 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .hero-stats span {
      white-space: nowrap;
    }

    .hero-stat-separator {
      margin: 0 16px;
      color: rgba(232, 255, 0, 0.4);
      font-size: 0.6rem;
    }

    /* CTA button — angular with cut corner */
    .hero-cta {
      display: inline-block;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.3rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      background: #E8FF00;
      color: #111111;
      padding: 20px 52px;
      clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 0 100%);
      cursor: pointer;
      border: none;
      font-weight: 400;
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 0 20px rgba(232, 255, 0, 0.25), 0 0 60px rgba(232, 255, 0, 0.1);
      align-self: flex-start;
      opacity: 0;
      animation: heroTextSlide 0.6s 1.25s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .hero-cta:hover {
      background: #d4eb00;
      transform: scale(1.03);
      box-shadow: 0 0 30px rgba(232, 255, 0, 0.4), 0 0 80px rgba(232, 255, 0, 0.15);
    }

    /* Hard angular bottom transition */
    .hero::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 80px;
      background: #1A1A1A;
      clip-path: polygon(0 70%, 100% 0, 100% 100%, 0 100%);
      z-index: 6;
    }

    /* ── SECTION 2: COMMUNITY ── */
    .community {
      padding: 100px 0 120px;
      position: relative;
      background: #1A1A1A;
    }

    .community::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: #E8FF00;
    }

    .section-label {
      font-family: 'Inter', sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 5px;
      text-transform: uppercase;
      color: #FF4136;
      margin-bottom: 12px;
    }

    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.8rem, 6vw, 4.5rem);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 56px;
      line-height: 1;
    }

    .member-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-bottom: 64px;
    }

    .member-card {
      background: #111111;
      border: 1px solid rgba(232, 255, 0, 0.08);
      position: relative;
      overflow: hidden;
      transition: border-color 0.3s, transform 0.3s;
      clip-path: polygon(0 0, 100% 0, 100% calc(100% - 24px), calc(100% - 24px) 100%, 0 100%);
    }

    .member-card:hover {
      border-color: rgba(232, 255, 0, 0.3);
      transform: translateY(-4px);
    }

    .member-card-img {
      width: 100%;
      height: 240px;
      object-fit: cover;
      filter: grayscale(30%) contrast(1.1);
      transition: filter 0.3s;
    }

    .member-card:hover .member-card-img {
      filter: grayscale(0%) contrast(1.05);
    }

    .member-card-body {
      padding: 28px 24px 32px;
      position: relative;
    }

    .member-card-body::before {
      content: '';
      position: absolute;
      top: 0;
      left: 24px;
      width: 40px;
      height: 3px;
      background: #E8FF00;
    }

    .member-card-quote {
      font-size: 1rem;
      color: rgba(255, 255, 255, 0.85);
      line-height: 1.6;
      margin-bottom: 20px;
      font-style: italic;
    }

    .member-card-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.3rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #E8FF00;
      margin-bottom: 4px;
    }

    .member-card-since {
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.35);
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    /* Community photo banner */
    .community-banner {
      position: relative;
      overflow: hidden;
      clip-path: polygon(0 8%, 100% 0, 100% 92%, 0 100%);
    }

    .community-banner img {
      width: 100%;
      height: 400px;
      object-fit: cover;
      filter: brightness(0.4) contrast(1.2);
    }

    .community-banner-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(17, 17, 17, 0.5);
    }

    .community-banner-text {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 6vw, 5rem);
      letter-spacing: 6px;
      text-transform: uppercase;
      text-align: center;
      color: #FFFFFF;
      text-shadow: 0 0 60px rgba(232, 255, 0, 0.2);
    }

    .community-banner-text span {
      color: #E8FF00;
    }

    /* ── SECTION 3: TAGESPLAN ── */
    .schedule {
      padding: 100px 0 120px;
      position: relative;
      background: #111111;
    }

    .schedule::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 80px;
      background: #1A1A1A;
      clip-path: polygon(0 0, 100% 0, 100% 40%, 0 100%);
    }

    /* WOD Preview */
    .wod-preview {
      background: linear-gradient(135deg, #1A1A1A 0%, rgba(232, 255, 0, 0.04) 100%);
      border: 2px solid rgba(232, 255, 0, 0.2);
      padding: 40px;
      margin-bottom: 56px;
      position: relative;
      clip-path: polygon(0 0, calc(100% - 32px) 0, 100% 32px, 100% 100%, 32px 100%, 0 calc(100% - 32px));
    }

    .wod-preview::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 4px;
      height: 100%;
      background: #FF4136;
    }

    .wod-label {
      display: inline-block;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.9rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      background: #FF4136;
      color: #FFFFFF;
      padding: 6px 16px;
      margin-bottom: 16px;
      clip-path: polygon(0 0, 100% 0, 95% 100%, 5% 100%);
    }

    .wod-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #E8FF00;
      margin-bottom: 12px;
    }

    .wod-description {
      font-size: 1.05rem;
      color: rgba(255, 255, 255, 0.75);
      line-height: 1.7;
      margin-bottom: 16px;
    }

    .wod-description strong {
      color: #FFFFFF;
    }

    .wod-coach {
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.4);
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    .wod-coach span {
      color: #E8FF00;
    }

    /* Schedule Grid */
    .schedule-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 2px;
      background: rgba(232, 255, 0, 0.08);
      border: 1px solid rgba(232, 255, 0, 0.12);
      margin-bottom: 48px;
    }

    .schedule-day {
      background: #1A1A1A;
    }

    .schedule-day-header {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.3rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      text-align: center;
      padding: 16px 8px;
      background: rgba(232, 255, 0, 0.06);
      color: #E8FF00;
      border-bottom: 2px solid rgba(232, 255, 0, 0.15);
    }

    .schedule-day-slots {
      padding: 12px 10px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      min-height: 200px;
    }

    .schedule-slot {
      display: flex;
      flex-direction: column;
      padding: 10px 8px;
      background: rgba(17, 17, 17, 0.6);
      border-left: 2px solid transparent;
      transition: border-color 0.2s, background 0.2s;
    }

    .schedule-slot:hover {
      border-left-color: #E8FF00;
      background: rgba(232, 255, 0, 0.04);
    }

    .schedule-slot-time {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.05rem;
      letter-spacing: 1px;
      color: #E8FF00;
      line-height: 1.2;
    }

    .schedule-slot-name {
      font-size: 0.72rem;
      color: rgba(255, 255, 255, 0.5);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-top: 2px;
    }

    /* Contact line */
    .schedule-contact {
      text-align: center;
      padding: 40px 24px;
      background: rgba(232, 255, 0, 0.03);
      border: 1px solid rgba(232, 255, 0, 0.08);
      clip-path: polygon(2% 0, 98% 0, 100% 50%, 98% 100%, 2% 100%, 0 50%);
    }

    .schedule-contact p {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(1.1rem, 2.5vw, 1.5rem);
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.7);
    }

    .schedule-contact p span {
      color: #E8FF00;
    }

    .schedule-contact p strong {
      color: #FFFFFF;
    }

    /* ── FOOTER ── */
    .footer {
      padding: 40px 0;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      text-align: center;
    }

    .footer-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 3px;
      color: #E8FF00;
      margin-bottom: 8px;
    }

    .footer p {
      font-size: 0.8rem;
      color: rgba(255, 255, 255, 0.3);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .schedule-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 900px) {
      .member-grid {
        grid-template-columns: 1fr;
        gap: 20px;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
      }

      .schedule-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .hero-content {
        padding: 140px 24px 120px 60px;
      }

      .community-banner img {
        height: 280px;
      }
    }

    @media (max-width: 680px) {
      .nav-links {
        display: none;
        position: absolute;
        top: 72px;
        left: 0;
        width: 100%;
        flex-direction: column;
        background: rgba(17, 17, 17, 0.97);
        padding: 24px;
        gap: 20px;
        border-bottom: 1px solid rgba(232, 255, 0, 0.15);
      }

      .nav-links.open {
        display: flex;
      }

      .nav-burger {
        display: flex;
      }

      /* Hero mobile: stack vertically, image as full background */
      .hero-dark {
        clip-path: none;
        position: absolute;
        inset: 0;
        background: rgba(17, 17, 17, 0.82);
        animation: none;
      }

      .hero-image {
        clip-path: none;
        animation: none;
      }

      .hero-monogram {
        font-size: 12rem;
        left: 5%;
        opacity: 0.6;
      }

      .hero-side-label {
        display: none;
      }

      .hero-content {
        padding: 130px 20px 110px;
      }

      .hero-headline {
        font-size: clamp(3.5rem, 15vw, 6rem);
        opacity: 1;
        transform: none;
        animation: none;
      }

      .hero-divider {
        opacity: 1;
        animation: none;
      }

      .hero-stats {
        flex-wrap: wrap;
        gap: 4px 0;
        opacity: 1;
        animation: none;
      }

      .hero-cta {
        opacity: 1;
        animation: none;
      }

      .hero::after {
        height: 40px;
      }

      .community,
      .schedule {
        padding: 80px 0;
      }

      .schedule-grid {
        grid-template-columns: 1fr 1fr;
      }

      .schedule-day-slots {
        min-height: auto;
      }

      .wod-preview {
        padding: 28px 20px;
        clip-path: none;
      }

      .community-banner {
        clip-path: none;
      }

      .community-banner img {
        height: 220px;
      }

      .community-banner-text {
        font-size: clamp(1.8rem, 8vw, 3rem);
        letter-spacing: 3px;
      }

      .schedule-contact {
        clip-path: none;
      }

      .hero-stat-separator {
        margin: 0 8px;
      }
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="#" class="nav-logo">Iron Valley</a>
      <ul class="nav-links" id="navLinks">
        <li><a href="#crew">Crew</a></li>
        <li><a href="#schedule">Tagesplan</a></li>
      </ul>
      <button class="nav-burger" id="navBurger" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-dark">
      <div class="hero-monogram">IV</div>
    </div>
    <div class="hero-image">
      <img
        src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1920&q=80&auto=format"
        alt="CrossFit Box Atmosphaere — Hanteln, Ketten, raue Waende"
        loading="eager"
      />
    </div>
    <div class="hero-side-label">CROSSFIT BOX &middot; TRIER-S&Uuml;D</div>
    <div class="hero-content">
      <h1 class="hero-headline">
        <span class="line-neon">KEIN</span>
        <span class="line-white">SCHÖNWETTER-<br>SPORT.</span>
      </h1>
      <div class="hero-divider"></div>
      <div class="hero-stats">
        <span>147 MITGLIEDER</span>
        <span class="hero-stat-separator">/</span>
        <span>6 CF-L2 COACHES</span>
        <span class="hero-stat-separator">/</span>
        <span>EST. 2021 · TRIER-SÜD</span>
      </div>
      <a href="#schedule" class="hero-cta">PROBETRAINING BUCHEN</a>
    </div>
  </section>

  <!-- COMMUNITY -->
  <section class="community" id="crew">
    <div class="container">
      <span class="section-label">Echte Menschen. Echte Ergebnisse.</span>
      <h2 class="section-title">Die Valley Crew</h2>
      <div class="member-grid">

        <div class="member-card">
          <img
            class="member-card-img"
            src="https://images.unsplash.com/photo-1609261251969-6a33c079c40f?w=600&q=80&auto=format&fit=crop"
            alt="Lisa — Mitglied seit 2022"
            loading="lazy"
          />
          <div class="member-card-body">
            <p class="member-card-quote">&bdquo;Vor Iron Valley: chronische R&uuml;ckenschmerzen, Physio alle zwei Wochen. Heute: Deadlift 122&thinsp;kg, keine Schmerzen mehr.&ldquo;</p>
            <div class="member-card-name">Lisa Brenner, 34</div>
