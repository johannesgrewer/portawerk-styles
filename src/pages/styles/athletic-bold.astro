---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Iron Valley — CrossFit Box Trier-Sued</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    /* ── RESET & BASE ── */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #111111;
      color: #FFFFFF;
      line-height: 1.6;
      overflow-x: hidden;
    }

    img {
      max-width: 100%;
      display: block;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    /* ── UTILITY ── */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .neon { color: #E8FF00; }
    .accent-red { color: #FF4136; }

    /* ── NAV ── */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 100;
      background: rgba(17, 17, 17, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(232, 255, 0, 0.15);
    }

    .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }

    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      letter-spacing: 3px;
      color: #E8FF00;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      gap: 32px;
      list-style: none;
    }

    .nav-links a {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.05rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #FFFFFF;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: #E8FF00;
    }

    .nav-burger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 4px;
    }

    .nav-burger span {
      display: block;
      width: 28px;
      height: 3px;
      background: #E8FF00;
      border-radius: 2px;
      transition: transform 0.3s, opacity 0.3s;
    }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: brightness(0.25) contrast(1.2) saturate(0.8);
    }

    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        160deg,
        rgba(17, 17, 17, 0.95) 0%,
        rgba(17, 17, 17, 0.4) 40%,
        rgba(17, 17, 17, 0.85) 100%
      );
    }

    /* Diagonal slash accents */
    .hero-slash {
      position: absolute;
      top: -10%;
      right: -5%;
      width: 45%;
      height: 130%;
      background: linear-gradient(135deg, rgba(232, 255, 0, 0.07) 0%, transparent 50%);
      transform: skewX(-12deg);
      z-index: 1;
      pointer-events: none;
    }

    .hero-slash-2 {
      position: absolute;
      bottom: -20%;
      left: -10%;
      width: 50%;
      height: 60%;
      background: linear-gradient(45deg, rgba(255, 65, 54, 0.05) 0%, transparent 40%);
      transform: skewX(8deg);
      z-index: 1;
      pointer-events: none;
    }

    /* Angular clip on hero bottom */
    .hero::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 80px;
      background: #1A1A1A;
      clip-path: polygon(0 60%, 100% 0, 100% 100%, 0 100%);
      z-index: 3;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 1200px;
      margin: 0 auto;
      padding: 140px 24px 120px;
      width: 100%;
    }

    .hero-label {
      font-family: 'Inter', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.5);
      margin-bottom: 20px;
      display: inline-block;
      border-left: 3px solid #FF4136;
      padding-left: 12px;
    }

    .hero-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(4.5rem, 11vw, 10rem);
      line-height: 0.92;
      letter-spacing: 4px;
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    .hero-headline .highlight {
      color: #E8FF00;
      position: relative;
      display: inline-block;
      text-shadow: 0 0 40px rgba(232, 255, 0, 0.25);
    }

    .hero-headline .highlight::after {
      content: '';
      position: absolute;
      bottom: 6px;
      left: 0;
      width: 100%;
      height: 6px;
      background: #FF4136;
      transform: skewX(-12deg);
    }

    .hero-sub {
      font-size: 1rem;
      color: rgba(255, 255, 255, 0.5);
      max-width: 480px;
      margin-bottom: 40px;
      line-height: 1.6;
      letter-spacing: 0.5px;
    }

    .hero-cta {
      display: inline-block;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.3rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      background: #E8FF00;
      color: #111111;
      padding: 20px 56px;
      clip-path: polygon(0 0, 100% 0, 96% 100%, 4% 100%);
      transition: background 0.2s, transform 0.2s;
      cursor: pointer;
      border: none;
      font-weight: 400;
    }

    .hero-cta:hover {
      background: #d4eb00;
      transform: scale(1.03);
    }

    .hero-stats {
      display: flex;
      gap: 40px;
      margin-top: 56px;
      padding-top: 32px;
      border-top: 1px solid rgba(232, 255, 0, 0.15);
    }

    .hero-stat {
      display: flex;
      align-items: baseline;
      gap: 8px;
    }

    .hero-stat-text {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #E8FF00;
    }

    .hero-stat-separator {
      color: rgba(255, 255, 255, 0.2);
      font-size: 1.2rem;
    }

    /* ── SECTION 2: COMMUNITY ── */
    .community {
      padding: 100px 0 120px;
      position: relative;
      background: #1A1A1A;
    }

    .community::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(90deg, #E8FF00 0%, #FF4136 50%, #E8FF00 100%);
    }

    .section-label {
      font-family: 'Inter', sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 5px;
      text-transform: uppercase;
      color: #FF4136;
      margin-bottom: 12px;
    }

    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.8rem, 6vw, 4.5rem);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 56px;
      line-height: 1;
    }

    .member-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-bottom: 64px;
    }

    .member-card {
      background: #111111;
      border: 1px solid rgba(232, 255, 0, 0.08);
      position: relative;
      overflow: hidden;
      transition: border-color 0.3s, transform 0.3s;
      clip-path: polygon(0 0, 100% 0, 100% calc(100% - 24px), calc(100% - 24px) 100%, 0 100%);
    }

    .member-card:hover {
      border-color: rgba(232, 255, 0, 0.3);
      transform: translateY(-4px);
    }

    .member-card-img {
      width: 100%;
      height: 240px;
      object-fit: cover;
      filter: grayscale(30%) contrast(1.1);
      transition: filter 0.3s;
    }

    .member-card:hover .member-card-img {
      filter: grayscale(0%) contrast(1.05);
    }

    .member-card-body {
      padding: 28px 24px 32px;
      position: relative;
    }

    .member-card-body::before {
      content: '';
      position: absolute;
      top: 0;
      left: 24px;
      width: 40px;
      height: 3px;
      background: #E8FF00;
    }

    .member-card-quote {
      font-size: 1rem;
      color: rgba(255, 255, 255, 0.85);
      line-height: 1.6;
      margin-bottom: 20px;
      font-style: italic;
    }

    .member-card-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.3rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #E8FF00;
      margin-bottom: 4px;
    }

    .member-card-since {
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.35);
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    /* Community photo banner */
    .community-banner {
      position: relative;
      overflow: hidden;
      clip-path: polygon(0 8%, 100% 0, 100% 92%, 0 100%);
    }

    .community-banner img {
      width: 100%;
      height: 400px;
      object-fit: cover;
      filter: brightness(0.4) contrast(1.2);
    }

    .community-banner-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(17, 17, 17, 0.5);
    }

    .community-banner-text {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 6vw, 5rem);
      letter-spacing: 6px;
      text-transform: uppercase;
      text-align: center;
      color: #FFFFFF;
      text-shadow: 0 0 60px rgba(232, 255, 0, 0.2);
    }

    .community-banner-text span {
      color: #E8FF00;
    }

    /* ── SECTION 3: TAGESPLAN ── */
    .schedule {
      padding: 100px 0 120px;
      position: relative;
      background: #111111;
    }

    .schedule::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 80px;
      background: #1A1A1A;
      clip-path: polygon(0 0, 100% 0, 100% 40%, 0 100%);
    }

    /* WOD Preview */
    .wod-preview {
      background: linear-gradient(135deg, #1A1A1A 0%, rgba(232, 255, 0, 0.04) 100%);
      border: 2px solid rgba(232, 255, 0, 0.2);
      padding: 40px;
      margin-bottom: 56px;
      position: relative;
      clip-path: polygon(0 0, calc(100% - 32px) 0, 100% 32px, 100% 100%, 32px 100%, 0 calc(100% - 32px));
    }

    .wod-preview::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 4px;
      height: 100%;
      background: #FF4136;
    }

    .wod-label {
      display: inline-block;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.9rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      background: #FF4136;
      color: #FFFFFF;
      padding: 6px 16px;
      margin-bottom: 16px;
      clip-path: polygon(0 0, 100% 0, 95% 100%, 5% 100%);
    }

    .wod-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #E8FF00;
      margin-bottom: 12px;
    }

    .wod-description {
      font-size: 1.05rem;
      color: rgba(255, 255, 255, 0.75);
      line-height: 1.7;
      margin-bottom: 16px;
    }

    .wod-description strong {
      color: #FFFFFF;
    }

    .wod-coach {
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.4);
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    .wod-coach span {
      color: #E8FF00;
    }

    /* Schedule Grid */
    .schedule-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 2px;
      background: rgba(232, 255, 0, 0.08);
      border: 1px solid rgba(232, 255, 0, 0.12);
      margin-bottom: 48px;
    }

    .schedule-day {
      background: #1A1A1A;
    }

    .schedule-day-header {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.3rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      text-align: center;
      padding: 16px 8px;
      background: rgba(232, 255, 0, 0.06);
      color: #E8FF00;
      border-bottom: 2px solid rgba(232, 255, 0, 0.15);
    }

    .schedule-day-slots {
      padding: 12px 10px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      min-height: 200px;
    }

    .schedule-slot {
      display: flex;
      flex-direction: column;
      padding: 10px 8px;
      background: rgba(17, 17, 17, 0.6);
      border-left: 2px solid transparent;
      transition: border-color 0.2s, background 0.2s;
    }

    .schedule-slot:hover {
      border-left-color: #E8FF00;
      background: rgba(232, 255, 0, 0.04);
    }

    .schedule-slot-time {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.05rem;
      letter-spacing: 1px;
      color: #E8FF00;
      line-height: 1.2;
    }

    .schedule-slot-name {
      font-size: 0.72rem;
      color: rgba(255, 255, 255, 0.5);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-top: 2px;
    }

    /* Contact line */
    .schedule-contact {
      text-align: center;
      padding: 40px 24px;
      background: rgba(232, 255, 0, 0.03);
      border: 1px solid rgba(232, 255, 0, 0.08);
      clip-path: polygon(2% 0, 98% 0, 100% 50%, 98% 100%, 2% 100%, 0 50%);
    }

    .schedule-contact p {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(1.1rem, 2.5vw, 1.5rem);
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.7);
    }

    .schedule-contact p span {
      color: #E8FF00;
    }

    .schedule-contact p strong {
      color: #FFFFFF;
    }

    /* ── FOOTER ── */
    .footer {
      padding: 40px 0;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      text-align: center;
    }

    .footer-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 3px;
      color: #E8FF00;
      margin-bottom: 8px;
    }

    .footer p {
      font-size: 0.8rem;
      color: rgba(255, 255, 255, 0.3);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .schedule-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 900px) {
      .member-grid {
        grid-template-columns: 1fr;
        gap: 20px;
        max-width: 500px;
      }

      .schedule-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .hero-stats {
        flex-wrap: wrap;
        gap: 12px 24px;
      }

      .hero-stat-text {
        font-size: 0.95rem;
      }

      .community-banner img {
        height: 280px;
      }
    }

    @media (max-width: 680px) {
      .nav-links {
        display: none;
        position: absolute;
        top: 72px;
        left: 0;
        width: 100%;
        flex-direction: column;
        background: rgba(17, 17, 17, 0.97);
        padding: 24px;
        gap: 20px;
        border-bottom: 1px solid rgba(232, 255, 0, 0.15);
      }

      .nav-links.open {
        display: flex;
      }

      .nav-burger {
        display: flex;
      }

      .hero-content {
        padding: 120px 20px 100px;
      }

      .hero-headline {
        font-size: clamp(3.2rem, 14vw, 5.5rem);
      }

      .hero::after {
        height: 40px;
      }

      .community,
      .schedule {
        padding: 80px 0;
      }

      .schedule-grid {
        grid-template-columns: 1fr 1fr;
      }

      .schedule-day-slots {
        min-height: auto;
      }

      .wod-preview {
        padding: 28px 20px;
        clip-path: none;
      }

      .community-banner {
        clip-path: none;
      }

      .community-banner img {
        height: 220px;
      }

      .community-banner-text {
        font-size: clamp(1.8rem, 8vw, 3rem);
        letter-spacing: 3px;
      }

      .schedule-contact {
        clip-path: none;
      }

      .hero-stats {
        flex-direction: column;
        gap: 8px;
      }

      .hero-stat-separator {
        display: none;
      }
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="#" class="nav-logo">Iron Valley</a>
      <ul class="nav-links" id="navLinks">
        <li><a href="#crew">Crew</a></li>
        <li><a href="#schedule">Tagesplan</a></li>
      </ul>
      <button class="nav-burger" id="navBurger" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1920&q=80&auto=format"
        alt="CrossFit Box Atmosphaere — Hanteln, Ketten, raue Waende"
        loading="eager"
      />
    </div>
    <div class="hero-slash"></div>
    <div class="hero-slash-2"></div>
    <div class="hero-content">
      <span class="hero-label">CrossFit Box seit 2021 &middot; Trier-Sued, Industriegebiet</span>
      <h1 class="hero-headline">
        <span class="highlight">St&auml;rker</span><br />
        als gestern.
      </h1>
      <p class="hero-sub">
        6 Tage die Woche. Kein Spiegel, kein Ego. Nur du, die Hantel und 147 Leute, die wollen, dass du durchziehst.
      </p>
      <a href="#schedule" class="hero-cta">Kostenloses Probetraining</a>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-text">147 Mitglieder</span>
        </div>
        <span class="hero-stat-separator">&middot;</span>
        <div class="hero-stat">
          <span class="hero-stat-text">6 Coaches</span>
        </div>
        <span class="hero-stat-separator">&middot;</span>
        <div class="hero-stat">
          <span class="hero-stat-text">6 Tage die Woche</span>
        </div>
      </div>
    </div>
  </section>

  <!-- COMMUNITY -->
  <section class="community" id="crew">
    <div class="container">
      <span class="section-label">Mehr als ein Gym</span>
      <h2 class="section-title">Die Valley Crew</h2>
      <div class="member-grid">

        <div class="member-card">
          <img
            class="member-card-img"
            src="https://images.unsplash.com/photo-1609899464926-209bc9a1506b?w=600&q=80&auto=format&fit=crop"
            alt="Lisa — Mitglied seit 2022"
            loading="lazy"
          />
          <div class="member-card-body">
            <p class="member-card-quote">&bdquo;Vor Iron Valley: R&uuml;ckenschmerzen. Jetzt: Deadlift 120kg.&ldquo;</p>
            <div class="member-card-name">Lisa, 34</div>
            <div class="member-card-since">Mitglied seit 2022</div>
          </div>
        </div>

        <div class="member-card">
          <img
            class="member-card-img"
            src="https://images.unsplash.com/photo-1567013127542-490d483063b2?w=600&q=80&auto=format&fit=crop"
            alt="Osman — Mitglied seit 2021"
            loading="lazy"
          />
          <div class="member-card-body">
            <p class="member-card-quote">&bdquo;Ich kam f&uuml;r den Sport. Ich bleibe f&uuml;r die Leute.&ldquo;</p>
            <div class="member-card-name">Osman, 28</div>
            <div class="member-card-since">Mitglied seit 2021</div>
          </div>
        </div>

        <div class="member-card">
          <img
            class="member-card-img"
            src="https://images.unsplash.com/photo-1595078475328-1ab05d0a6a0e?w=600&q=80&auto=format&fit=crop"
            alt="Petra — Mitglied seit 2023"
            loading="lazy"
          />
          <div class="member-card-body">
            <p class="member-card-quote">&bdquo;Mit 50 angefangen. Beste Entscheidung meines Lebens.&ldquo;</p>
            <div class="member-card-name">Petra, 52</div>
            <div class="member-card-since">Mitglied seit 2023</div>
          </div>
        </div>

      </div>

      <!-- Community banner -->
      <div class="community-banner">
        <img
          src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=1200&q=80&auto=format"
          alt="CrossFit Gruppe beim Training"
          loading="lazy"
        />
        <div class="community-banner-overlay">
          <div class="community-banner-text">Kein Ego. <span>Nur Einsatz.</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- TAGESPLAN -->
  <section class="schedule" id="schedule">
    <div class="container">
      <span class="section-label">Wochenplan</span>
      <h2 class="section-title">Heute im Valley</h2>

      <!-- WOD Preview -->
      <div class="wod-preview">
        <div class="wod-label">WOD des Tages</div>
        <div class="wod-title">AMRAP 20 Minuten</div>
        <p class="wod-description">
          <strong>10 Power Cleans</strong> (60/40kg) &middot;
