---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Doppel — Grafikdesign-Duo | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --y: #F5C842;
      --b: #0A0A0A;
      --w: #FFFFFF;
      --b40: rgba(10,10,10,0.40);
      --b20: rgba(10,10,10,0.20);
      --b10: rgba(10,10,10,0.10);
      --b06: rgba(10,10,10,0.06);
    }

    body {
      background: var(--w);
      color: var(--b);
      font-family: 'Inter', sans-serif;
      overflow-x: hidden;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      display: grid;
      grid-template-columns: 1fr 1fr;
      height: 58px;
    }
    .nav-l {
      display: flex;
      align-items: center;
      padding: 0 3.5rem;
      background: var(--w);
      border-bottom: 2px solid var(--b);
    }
    .nav-r {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 2.5rem;
      padding: 0 3.5rem;
      background: var(--y);
      border-bottom: 2px solid var(--b);
      border-left: 2px solid var(--b);
    }
    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.1rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--b);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--b40);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--b); }
    .nav-cta {
      font-family: 'Syne', sans-serif;
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--b);
      text-decoration: none;
      padding-bottom: 2px;
      border-bottom: 2px solid var(--b);
      transition: border-color 0.2s;
    }
    .nav-cta:hover { border-color: transparent; }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      padding-top: 58px;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    /* Left: white */
    .hero-l {
      background: var(--w);
      border-right: 2px solid var(--b);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 5rem 4rem 4.5rem 5rem;
      gap: 2.5rem;
    }
    .eyebrow {
      font-size: 0.52rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--b40);
    }
    .hero-h {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(3.2rem, 6.5vw, 6rem);
      line-height: 0.92;
      letter-spacing: -0.025em;
      color: var(--b);
    }
    .hero-h .out {
      -webkit-text-stroke: 2.5px var(--b);
      color: transparent;
    }
    .hero-body {
      font-size: 0.85rem;
      font-weight: 300;
      line-height: 2;
      color: var(--b40);
      max-width: 38ch;
    }
    .svc-list {
      display: flex;
      flex-direction: column;
      border-top: 1px solid var(--b10);
    }
    .svc-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.9rem 0;
      border-bottom: 1px solid var(--b06);
      cursor: default;
      transition: padding-left 0.3s ease;
    }
    .svc-row:hover { padding-left: 0.5rem; }
    .svc-name {
      font-family: 'Syne', sans-serif;
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--b);
    }
    .svc-tag {
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--b40);
      background: var(--b06);
      padding: 0.2rem 0.65rem;
    }
    .hero-cta {
      display: flex;
      align-items: center;
      gap: 1.75rem;
    }
    .btn-main {
      font-family: 'Syne', sans-serif;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--w);
      background: var(--b);
      padding: 1rem 2.2rem;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
    }
    .btn-main:hover { background: var(--y); color: var(--b); }
    .btn-ghost {
      font-size: 0.58rem;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--b40);
      text-decoration: none;
      padding-bottom: 1px;
      border-bottom: 1px solid var(--b20);
      transition: color 0.2s, border-color 0.2s;
    }
    .btn-ghost:hover { color: var(--b); border-color: var(--b); }

    /* Right: yellow + photo */
    .hero-r {
      background: var(--y);
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .hero-photo {
      position: absolute;
      inset: 0;
    }
    .hero-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      mix-blend-mode: multiply;
      opacity: 0.55;
      transition: transform 0.8s ease;
    }
    .hero-r:hover .hero-photo img { transform: scale(1.03); }
    .hero-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        transparent 30%,
        rgba(245,200,66,0.6) 100%
      );
    }

    /* Floating content over photo */
    .hero-r-content {
      position: relative;
      z-index: 2;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 4rem;
    }
    .hero-r-label {
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(10,10,10,0.55);
    }
    .hero-r-bottom {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .duo-block {
      display: flex;
      gap: 0;
      border: 2px solid var(--b);
    }
    .duo-person {
      flex: 1;
      padding: 1.25rem 1.5rem;
      background: var(--w);
    }
    .duo-person + .duo-person {
      border-left: 2px solid var(--b);
      background: var(--b);
    }
    .dp-name {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--b);
      margin-bottom: 0.2rem;
    }
    .duo-person + .duo-person .dp-name { color: var(--w); }
    .dp-role {
      font-size: 0.52rem;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--b40);
    }
    .duo-person + .duo-person .dp-role { color: rgba(255,255,255,0.4); }
    .stats-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      background: var(--b);
    }
    .stat-cell {
      padding: 1.1rem 1.25rem;
      border-right: 1px solid rgba(255,255,255,0.08);
    }
    .stat-cell:last-child { border-right: none; }
    .sc-n {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.5rem;
      line-height: 1;
      color: var(--y);
    }
    .sc-l {
      font-size: 0.46rem;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      margin-top: 0.2rem;
    }

    /* ─── SECTION 2: ARBEITEN ─── */
    .arbeiten {
      border-top: 2px solid var(--b);
    }
    .arb-header {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 220px;
    }
    .arb-h-l {
      padding: 3.5rem 4rem 3.5rem 5rem;
      background: var(--b);
      border-right: 2px solid var(--b);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    .arb-eyebrow {
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
    }
    .arb-h {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(2rem, 4vw, 3.2rem);
      line-height: 0.92;
      letter-spacing: -0.02em;
      color: var(--w);
    }
    .arb-h .out {
      -webkit-text-stroke: 2px var(--w);
      color: transparent;
    }
    .arb-h-r {
      padding: 3.5rem 4rem;
      background: var(--y);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      border-bottom: 2px solid var(--b);
    }
    .arb-count {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(3.5rem, 7vw, 6rem);
      line-height: 1;
      color: var(--b);
      letter-spacing: -0.04em;
    }
    .arb-count-l {
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--b40);
    }
    .arb-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
    .arb-card {
      border-right: 2px solid var(--b);
      border-bottom: 2px solid var(--b);
    }
    .arb-card:nth-child(3n) { border-right: none; }
    .arb-card:nth-last-child(-n+3) { border-bottom: none; }
    .arb-photo {
      position: relative;
      overflow: hidden;
      height: 240px;
      border-bottom: 2px solid var(--b);
    }
    .arb-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.55s ease;
    }
    .arb-photo:hover img { transform: scale(1.05); }
    .arb-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(10,10,10,0.45) 0%, transparent 55%);
      pointer-events: none;
    }
    .arb-body {
      padding: 1.5rem;
      background: var(--w);
    }
    .arb-card:nth-child(even) .arb-body { background: var(--y); }
    .arb-num {
      font-size: 0.5rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      color: var(--b40);
      margin-bottom: 0.4rem;
    }
    .arb-name {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--b);
      margin-bottom: 0.2rem;
    }
    .arb-type {
      font-size: 0.58rem;
      font-weight: 400;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--b40);
    }

    /* ─── SECTION 3: PROZESS ─── */
    .prozess {
      border-top: 2px solid var(--b);
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .proz-l {
      background: var(--b);
      padding: 5rem 4rem 5rem 5rem;
      display: flex;
      flex-direction: column;
      gap: 3rem;
      border-right: 2px solid var(--b);
    }
    .proz-eyebrow {
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.22);
    }
    .proz-h {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(2rem, 3.5vw, 3rem);
      line-height: 0.95;
      letter-spacing: -0.02em;
      color: var(--w);
    }
    .proz-h .out {
      -webkit-text-stroke: 1.5px rgba(255,255,255,0.35);
      color: transparent;
    }
    .proz-steps {
      display: flex;
      flex-direction: column;
      gap: 0;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .step-row {
      display: flex;
      gap: 1.5rem;
      align-items: flex-start;
      padding: 1.5rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .step-num {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.6rem;
      line-height: 1;
      color: var(--y);
      flex-shrink: 0;
      width: 2rem;
    }
    .step-body {}
    .step-title {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--w);
      margin-bottom: 0.3rem;
    }
    .step-desc {
      font-size: 0.72rem;
      font-weight: 300;
      line-height: 1.75;
      color: rgba(255,255,255,0.35);
    }
    .proz-r {
      position: relative;
      overflow: hidden;
      background: var(--y);
      min-height: 560px;
    }
    .proz-r img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      mix-blend-mode: multiply;
      opacity: 0.6;
      transition: transform 0.7s ease;
    }
    .proz-r:hover img { transform: scale(1.04); }
    .proz-r-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        rgba(245,200,66,0.3) 0%,
        transparent 60%
      );
      pointer-events: none;
    }
    .proz-tag {
      position: absolute;
      bottom: 2rem;
      right: 2rem;
      font-size: 0.44rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(10,10,10,0.45);
      z-index: 2;
    }

    /* ─── SECTION 4: STUDIO ─── */
    .studio {
      border-top: 2px solid var(--b);
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .studio-photo {
      position: relative;
      overflow: hidden;
      min-height: 600px;
      border-right: 2px solid var(--b);
    }
    .studio-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }
    .studio-photo:hover img { transform: scale(1.04); }
    .studio-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(10,10,10,0.5) 0%,
        transparent 50%
      );
      pointer-events: none;
    }
    .studio-photo-tag {
      position: absolute;
      bottom: 1.75rem;
      left: 2rem;
      font-size: 0.44rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      z-index: 2;
    }
    .studio-r {
      background: var(--y);
      padding: 5rem 4.5rem 5rem 4rem;
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
      justify-content: center;
    }
    .studio-eyebrow {
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--b40);
    }
    .studio-h {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(2rem, 3.5vw, 3rem);
      line-height: 0.95;
      letter-spacing: -0.02em;
      color: var(--b);
    }
    .studio-h .out {
      -webkit-text-stroke: 2px var(--b);
      color: transparent;
    }
    .studio-body {
      font-size: 0.85rem;
      font-weight: 300;
      line-height: 1.95;
      color: var(--b40);
      max-width: 40ch;
    }
    .facts {
      display: flex;
      flex-direction: column;
      border: 2px solid var(--b);
      background: var(--w);
    }
    .fact-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.85rem 1.25rem;
      border-bottom: 1px solid var(--b10);
    }
    .fact-row:last-child { border-bottom: none; }
    .fact-l {
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--b40);
    }
    .fact-r {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--b);
    }
    .studio-cta {
      display: flex;
      gap: 1.25rem;
      align-items: center;
    }

    /* ─── FOOTER ─── */
    footer {
      border-top: 2px solid var(--b);
      display: grid;
      grid-template-columns: 1fr 1fr;
      height: 56px;
    }
    .footer-l {
      display: flex;
      align-items: center;
      padding: 0 4rem 0 5rem;
      border-right: 2px solid var(--b);
      background: var(--w);
    }
    .footer-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--b);
    }
    .footer-r {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 3.5rem;
      background: var(--b);
    }
    .footer-meta {
      font-size: 0.46rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.2);
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 960px) {
      nav { grid-template-columns: 1fr; }
      .nav-r { display: none; }

      .hero { grid-template-columns: 1fr; }
      .hero-l { border-right: none; border-bottom: 2px solid var(--b); padding: 4rem 2.5rem; }
      .hero-r { min-height: 380px; }

      .arb-header { grid-template-columns: 1fr; }
      .arb-h-l { border-right: none; border-bottom: 2px solid var(--b); padding: 3rem 2.5rem; }
      .arb-h-r { padding: 2.5rem; }
      .arb-grid { grid-template-columns: 1fr 1fr; }
      .arb-card:nth-child(3n) { border-right: 2px solid var(--b); }
      .arb-card:nth-child(2n) { border-right: none; }
      .arb-card:nth-last-child(-n+3) { border-bottom: 2px solid var(--b); }
      .arb-card:last-child { border-bottom: none; }

      .prozess { grid-template-columns: 1fr; }
      .proz-l { border-right: none; border-bottom: 2px solid var(--b); padding: 4rem 2.5rem; }
      .proz-r { min-height: 320px; }

      .studio { grid-template-columns: 1fr; }
      .studio-photo { min-height: 340px; border-right: none; border-bottom: 2px solid var(--b); }
      .studio-r { padding: 3.5rem 2.5rem; }

      footer { grid-template-columns: 1fr; height: auto; }
      .footer-l { border-right: none; border-bottom: 1px solid var(--b10); padding: 1.25rem 2.5rem; }
      .footer-r { padding: 1.25rem 2.5rem; }
    }
  </style>
</head>
<body>

  <!-- ─── NAV ─── -->
  <nav>
    <div class="nav-l">
      <div class="nav-logo">Doppel</div>
    </div>
    <div class="nav-r">
      <ul class="nav-links">
        <li><a href="#">Projekte</a></li>
        <li><a href="#">Leistungen</a></li>
        <li><a href="#">Studio</a></li>
      </ul>
      <a href="#" class="nav-cta">Kontakt aufnehmen</a>
    </div>
  </nav>

  <!-- ─── HERO ─── -->
  <section class="hero">

    <!-- Left: white — text content -->
    <div class="hero-l">

      <div>
        <div class="eyebrow">Grafikdesign-Duo · Trier · seit 2021</div>
      </div>

      <h1 class="hero-h">
        Zwei<br>
        Köpfe.<br>
        <span class="out">Eine</span><br>
        Idee.
      </h1>

      <p class="hero-body">
        Anna & Paul. Wir entwerfen visuelle Identitäten,
        die bleiben — für Marken, die etwas zu sagen haben.
        Kein Account-Manager. Keine Zwischenebene.
      </p>

      <div class="svc-list">
        <div class="svc-row">
          <span class="svc-name">Brand Identity</span>
          <span class="svc-tag">Kernleistung</span>
        </div>
        <div class="svc-row">
          <span class="svc-name">Editorial Design</span>
          <span class="svc-tag">Print</span>
        </div>
        <div class="svc-row">
          <span class="svc-name">Digital Branding</span>
          <span class="svc-tag">Web & Social</span>
        </div>
        <div class="svc-row">
          <span class="svc-name">Verpackungsdesign</span>
          <span class="svc-tag">Produkt</span>
        </div>
      </div>

      <div class="hero-cta">
        <a href="#" class="btn-main">Projekt starten →</a>
        <a href="#" class="btn-ghost">Alle Arbeiten ansehen</a>
      </div>

    </div>

    <!-- Right: yellow + photo overlay -->
    <div class="hero-r">
      <div class="hero-photo">
        <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=1000&h=1200&q=85" alt="Grafikdesign Arbeit" />
        <div class="hero-photo-overlay"></div>
      </div>
      <div class="hero-r-content">
