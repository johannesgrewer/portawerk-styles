---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Klar — Coaching & Unternehmensberatung | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }
    body {
      overflow-x: hidden;
      background: #0D0D0D;
      color: #F5F3EF;
      font-family: 'DM Mono', monospace;
      min-height: 100vh;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      border-bottom: 1px solid rgba(245, 243, 239, 0.06);
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.6rem 3rem;
      max-width: 1600px;
      margin: 0 auto;
    }
    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.35rem;
      letter-spacing: -0.02em;
      color: #F5F3EF;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'DM Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      color: rgba(245, 243, 239, 0.45);
      text-decoration: none;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: #E85D04; }

    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
      overflow: hidden;
      max-width: 1600px;
      margin: 0 auto;
    }

    /* Diagonal accent line */
    .diagonal {
      position: absolute;
      top: 0; bottom: 0;
      left: 49%;
      width: 2px;
      background: #E85D04;
      transform: skewX(-4deg);
      transform-origin: top;
      opacity: 0;
      animation: drawLine 0.8s ease 0.2s forwards;
    }
    @keyframes drawLine {
      from { clip-path: inset(0 0 100% 0); opacity: 1; }
      to   { clip-path: inset(0 0 0% 0);   opacity: 1; }
    }

    /* LEFT column — big number + intro */
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 7rem 3rem 5rem 4rem;
      position: relative;
    }

    .big-number {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(8rem, 16vw, 18rem);
      line-height: 0.9;
      letter-spacing: -0.04em;
      color: transparent;
      -webkit-text-stroke: 1px rgba(245, 243, 239, 0.08);
      position: absolute;
      bottom: 10%;
      left: -0.02em;
      user-select: none;
      pointer-events: none;
    }

    .eyebrow {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      color: #E85D04;
      margin-bottom: 2rem;
      opacity: 0;
      animation: slideRight 0.7s ease 0.4s forwards;
    }

    .headline {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(3.5rem, 5.5vw, 7rem);
      line-height: 0.92;
      letter-spacing: -0.03em;
      text-transform: uppercase;
    }
    .headline .ln {
      display: block;
      overflow: hidden;
    }
    .headline .ln span {
      display: block;
      opacity: 0;
      animation: slideRight 0.7s ease forwards;
    }
    .headline .ln:nth-child(1) span { animation-delay: 0.5s; }
    .headline .ln:nth-child(2) span { animation-delay: 0.65s; }
    .headline .ln:nth-child(3) span {
      animation-delay: 0.8s;
      color: #E85D04;
    }

    /* Coach portrait */
    .coach-portrait {
      position: relative;
      overflow: hidden;
      border-radius: 2px;
      margin-bottom: 2.5rem;
      height: 220px;
    }
    .coach-portrait img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      filter: grayscale(30%) brightness(0.75);
      transition: transform 0.6s ease;
    }
    .coach-portrait:hover img { transform: scale(1.04); }
    .coach-portrait-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13,13,13,0.85) 0%, transparent 55%);
    }
    .coach-portrait-label {
      position: absolute;
      bottom: 1rem;
      left: 1.25rem;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      color: #E85D04;
      font-family: 'DM Mono', monospace;
    }

    /* RIGHT column — details */
    .hero-right {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 7rem 4rem 5rem 5rem;
      border-left: 1px solid rgba(245, 243, 239, 0.06);
    }

    .orange-rule {
      width: 0;
      height: 2px;
      background: #E85D04;
      margin-bottom: 2.5rem;
      animation: growRule 0.8s ease 1.1s forwards;
    }
    @keyframes growRule { to { width: 48px; } }

    .desc {
      font-family: 'DM Mono', monospace;
      font-size: 0.84rem;
      line-height: 1.9;
      color: rgba(245, 243, 239, 0.55);
      max-width: 360px;
      margin-bottom: 3rem;
      opacity: 0;
      animation: fadeUp 0.7s ease 1.2s forwards;
    }

    .stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem 2rem;
      margin-bottom: 3rem;
      opacity: 0;
      animation: fadeUp 0.7s ease 1.35s forwards;
    }
    .stat-item {}
    .stat-num {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 2.4rem;
      letter-spacing: -0.03em;
      color: #F5F3EF;
      line-height: 1;
    }
    .stat-num span {
      color: #E85D04;
      font-size: 1.6rem;
    }
    .stat-label {
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      color: rgba(245, 243, 239, 0.35);
      text-transform: uppercase;
      margin-top: 0.3rem;
    }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 2rem;
      opacity: 0;
      animation: fadeUp 0.7s ease 1.5s forwards;
    }
    .btn-main {
      background: #E85D04;
      color: #0D0D0D;
      border: none;
      padding: 0.85rem 2rem;
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      transition: background 0.3s;
    }
    .btn-main:hover { background: #ff7420; }
    .btn-link {
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      color: rgba(245, 243, 239, 0.4);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      padding-bottom: 2px;
      transition: all 0.3s;
    }
    .btn-link:hover {
      color: #F5F3EF;
      border-color: rgba(245, 243, 239, 0.3);
    }

    /* Grid texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(245,243,239,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(245,243,239,0.03) 1px, transparent 1px);
      background-size: 80px 80px;
      pointer-events: none;
      z-index: 0;
    }
    .hero { position: relative; z-index: 1; }

    @keyframes slideRight {
      from { opacity: 0; transform: translateX(-28px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ===== SECTION 2 — LEISTUNGEN ===== */
    .leistungen {
      padding: 6rem 5rem;
      background: #111;
      max-width: 1600px;
      margin: 0 auto;
    }
    .l-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 3rem;
      border-bottom: 1px solid rgba(245,243,239,0.08);
      padding-bottom: 2rem;
    }
    .l-eyebrow {
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      color: #FF6B35;
      margin-bottom: 0.6rem;
    }
    .l-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      color: #F5F3EF;
      line-height: 1.05;
    }
    .l-link {
      font-size: 0.6rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      color: rgba(245,243,239,0.3);
      text-decoration: none;
      border-bottom: 1px solid rgba(245,243,239,0.15);
      padding-bottom: 2px;
      white-space: nowrap;
      transition: color 0.2s;
    }
    .l-link:hover { color: #FF6B35; }

    .l-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    .l-card {
      position: relative;
      overflow: hidden;
    }
    .l-card img {
      width: 100%;
      height: 400px;
      object-fit: cover;
      display: block;
      transition: transform 0.55s ease;
      filter: grayscale(40%) brightness(0.75);
    }
    .l-card:hover img { transform: scale(1.05); filter: grayscale(0%) brightness(0.85); }
    .l-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13,13,13,0.92) 0%, transparent 55%);
    }
    .l-card-info {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 2rem;
    }
    .l-card-num {
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      color: #FF6B35;
      margin-bottom: 0.5rem;
    }
    .l-card-name {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.1rem;
      color: #F5F3EF;
    }
    .l-card-desc {
      font-size: 0.68rem;
      font-weight: 300;
      color: rgba(245,243,239,0.5);
      margin-top: 0.3rem;
      line-height: 1.5;
    }

    /* ===== SECTION 3 — ERGEBNISSE ===== */
    .ergebnisse {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 560px;
      max-width: 1600px;
      margin: 0 auto;
    }
    .erg-text {
      background: #0D0D0D;
      padding: 5rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.75rem;
      border-right: 1px solid rgba(245,243,239,0.06);
    }
    .erg-eyebrow {
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      color: #FF6B35;
    }
    .erg-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      color: #F5F3EF;
      line-height: 1.05;
    }
    .erg-quote {
      font-family: 'DM Mono', monospace;
      font-size: 0.95rem;
      font-style: italic;
      line-height: 1.7;
      color: rgba(245,243,239,0.6);
      padding-left: 1.25rem;
      border-left: 2px solid #FF6B35;
    }
    .erg-author {
      font-size: 0.65rem;
      font-weight: 400;
      letter-spacing: 0.12em;
      color: rgba(245,243,239,0.35);
    }
    .erg-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: 'Syne', sans-serif;
      font-size: 0.62rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #0D0D0D;
      background: #FF6B35;
      padding: 0.9rem 2rem;
      text-decoration: none;
      align-self: flex-start;
      transition: background 0.2s;
    }
    .erg-cta:hover { background: #e05820; }
    .erg-photo {
      position: relative;
      overflow: hidden;
    }
    .erg-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: grayscale(30%) brightness(0.7);
    }

    @media (max-width: 1024px) {
      .l-grid { grid-template-columns: 1fr 1fr; }
      .l-card:last-child { grid-column: 1 / -1; }
      .l-card:last-child img { height: 280px; }
      .ergebnisse { grid-template-columns: 1fr; }
      .erg-photo { height: 380px; position: relative; }
      .erg-photo img { position: absolute; }
    }
    @media (max-width: 768px) {
      .leistungen { padding: 4rem 2rem; }
      .l-grid { grid-template-columns: 1fr; }
      .l-card:last-child { grid-column: auto; }
      .l-card img, .l-card:last-child img { height: 280px; }
      .erg-text { padding: 3.5rem 2rem; }
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-inner">
      <span class="nav-logo">Klar_</span>
      <ul class="nav-links">
        <li><a href="#">Leistungen</a></li>
        <li><a href="#">Methode</a></li>
        <li><a href="#">Ergebnisse</a></li>
        <li><a href="#">Kontakt</a></li>
      </ul>
    </div>
  </nav>

  <section class="hero">
    <div class="diagonal"></div>

    <!-- LEFT -->
    <div class="hero-left">
      <div class="big-number" aria-hidden="true">07</div>

      <p class="eyebrow">// Coaching · Beratung · Trier</p>

      <h1 class="headline">
        <div class="ln"><span>Mehr</span></div>
        <div class="ln"><span>Klar-</span></div>
        <div class="ln"><span>heit.</span></div>
      </h1>
    </div>

    <!-- RIGHT -->
    <div class="hero-right">
      <div class="coach-portrait">
        <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&w=800&h=500&q=80"
             alt="Business Coach Portrait" loading="eager" />
        <div class="coach-portrait-overlay"></div>
        <div class="coach-portrait-label">// Klar_ · Inhaber & Coach</div>
      </div>
      <div class="orange-rule"></div>

      <p class="desc">
        Coaching ist kein Nice-to-have. Es ist die schnellste
        Route von hier nach da. Keine Umwege, keine
        Selbstberuhigung — nur was wirkt.
      </p>

      <div class="stats">
        <div class="stat-item">
          <div class="stat-num">94<span>%</span></div>
          <div class="stat-label">Kundenzufriedenheit</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">12<span>+</span></div>
          <div class="stat-label">Jahre Erfahrung</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">380<span>+</span></div>
          <div class="stat-label">Klienten begleitet</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">6<span>×</span></div>
          <div class="stat-label">Ø Wachstum</div>
        </div>
      </div>

      <div class="cta-row">
        <a href="#" class="btn-main">Erstgespräch buchen</a>
        <a href="#" class="btn-link">Methode ansehen →</a>
      </div>
    </div>
  </section>

  <!-- SECTION 2 — LEISTUNGEN -->
  <section class="leistungen" id="leistungen">
    <div class="l-head">
      <div>
        <p class="l-eyebrow">// LEISTUNGEN</p>
        <h2 class="l-title">Was wir<br>gemeinsam<br>angehen.</h2>
      </div>
      <a href="#" class="l-link">Alle Leistungen ansehen →</a>
    </div>

    <div class="l-grid">
      <div class="l-card">
        <img src="https://images.unsplash.com/photo-1573497620053-ea5300f94f21?auto=format&fit=crop&w=800&h=400&q=80"
             alt="Business Coaching Einzelgespräch" loading="lazy" />
        <div class="l-card-overlay"></div>
        <div class="l-card-info">
          <p class="l-card-num">01 — EINZELCOACHING</p>
          <h3 class="l-card-name">1:1 Coaching</h3>
          <p class="l-card-desc">Fokussierte Arbeit an deinen Themen — Klarheit, Entscheidungen, Wirkung.</p>
        </div>
      </div>

      <div class="l-card">
        <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=800&h=400&q=80"
             alt="Führungskräfte Workshop" loading="lazy" />
        <div class="l-card-overlay"></div>
        <div class="l-card-info">
          <p class="l-card-num">02 — FÜHRUNG</p>
          <h3 class="l-card-name">Leadership-Coaching</h3>
          <p class="l-card-desc">Für Führungskräfte, die besser führen wollen — sich selbst und andere.</p>
        </div>
      </div>

      <div class="l-card">
        <img src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?auto=format&fit=crop&w=800&h=400&q=80"
             alt="Teamworkshop und Strategie" loading="lazy" />
        <div class="l-card-overlay"></div>
        <div class="l-card-info">
          <p class="l-card-num">03 — TEAMS</p>
          <h3 class="l-card-name">Team-Workshops</h3>
          <p class="l-card-desc">Gemeinsam herausfinden, was das Team blockiert — und wie es wegkommt.</p>
        </div>
      </div>
      <div class="l-card">
        <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=800&h=400&q=80"
             alt="Strategiegespräch am Whiteboard" loading="lazy" />
        <div class="l-card-overlay"></div>
        <div class="l-card-info">
          <p class="l-card-num">04 — STRATEGIE</p>
          <h3 class="l-card-name">Strategieentwicklung</h3>
          <p class="l-card-desc">Von der Idee zur Entscheidung. Klarheit über Richtung, Prioritäten und nächste Schritte.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3 — ERGEBNISSE -->
  <section class="ergebnisse" id="ergebnisse">
    <div class="erg-text">
      <p class="erg-eyebrow">// ERGEBNISSE</p>
      <h2 class="erg-title">Weniger<br>Rauschen.<br>Mehr Wirkung.</h2>
      <blockquote class="erg-quote">
        "Nach sechs Monaten hatte ich nicht nur eine neue Strategie. Ich hatte
        wieder Vertrauen — in mich selbst und in das, was ich tue."
      </blockquote>
      <p class="erg-author">— Markus T., Geschäftsführer · Trier</p>
      <a href="#" class="erg-cta">Erstgespräch vereinbaren →</a>
    </div>

    <div class="erg-photo">
      <img src="https://images.unsplash.com/photo-1521791136064-7986c2920216?auto=format&fit=crop&w=900&h=600&q=80"
           alt="Coaching-Gespräch, Handshake nach erfolgreichem Meeting" loading="lazy" />
    </div>
  </section>

</body>
</html>
