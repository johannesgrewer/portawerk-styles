---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Klar — Coaching & Unternehmensberatung | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }
    body {
      overflow-x: hidden;
      background: #0D0D0D;
      color: #F5F3EF;
      font-family: 'DM Mono', monospace;
      min-height: 100vh;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.6rem 3rem;
      border-bottom: 1px solid rgba(245, 243, 239, 0.06);
    }
    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.35rem;
      letter-spacing: -0.02em;
      color: #F5F3EF;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'DM Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      color: rgba(245, 243, 239, 0.45);
      text-decoration: none;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: #E85D04; }

    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
      overflow: hidden;
    }

    /* Diagonal accent line */
    .diagonal {
      position: absolute;
      top: 0; bottom: 0;
      left: 49%;
      width: 2px;
      background: #E85D04;
      transform: skewX(-4deg);
      transform-origin: top;
      opacity: 0;
      animation: drawLine 0.8s ease 0.2s forwards;
    }
    @keyframes drawLine {
      from { clip-path: inset(0 0 100% 0); opacity: 1; }
      to   { clip-path: inset(0 0 0% 0);   opacity: 1; }
    }

    /* LEFT column — big number + intro */
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 7rem 3rem 5rem 4rem;
      position: relative;
    }

    .big-number {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(8rem, 16vw, 18rem);
      line-height: 0.9;
      letter-spacing: -0.04em;
      color: transparent;
      -webkit-text-stroke: 1px rgba(245, 243, 239, 0.08);
      position: absolute;
      bottom: 10%;
      left: -0.02em;
      user-select: none;
      pointer-events: none;
    }

    .eyebrow {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      color: #E85D04;
      margin-bottom: 2rem;
      opacity: 0;
      animation: slideRight 0.7s ease 0.4s forwards;
    }

    .headline {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(3.5rem, 5.5vw, 7rem);
      line-height: 0.92;
      letter-spacing: -0.03em;
      text-transform: uppercase;
    }
    .headline .ln {
      display: block;
      overflow: hidden;
    }
    .headline .ln span {
      display: block;
      opacity: 0;
      animation: slideRight 0.7s ease forwards;
    }
    .headline .ln:nth-child(1) span { animation-delay: 0.5s; }
    .headline .ln:nth-child(2) span { animation-delay: 0.65s; }
    .headline .ln:nth-child(3) span {
      animation-delay: 0.8s;
      color: #E85D04;
    }

    /* RIGHT column — details */
    .hero-right {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 7rem 4rem 5rem 5rem;
      border-left: 1px solid rgba(245, 243, 239, 0.06);
    }

    .orange-rule {
      width: 0;
      height: 2px;
      background: #E85D04;
      margin-bottom: 2.5rem;
      animation: growRule 0.8s ease 1.1s forwards;
    }
    @keyframes growRule { to { width: 48px; } }

    .desc {
      font-family: 'DM Mono', monospace;
      font-size: 0.84rem;
      line-height: 1.9;
      color: rgba(245, 243, 239, 0.55);
      max-width: 360px;
      margin-bottom: 3rem;
      opacity: 0;
      animation: fadeUp 0.7s ease 1.2s forwards;
    }

    .stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem 2rem;
      margin-bottom: 3rem;
      opacity: 0;
      animation: fadeUp 0.7s ease 1.35s forwards;
    }
    .stat-item {}
    .stat-num {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 2.4rem;
      letter-spacing: -0.03em;
      color: #F5F3EF;
      line-height: 1;
    }
    .stat-num span {
      color: #E85D04;
      font-size: 1.6rem;
    }
    .stat-label {
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      color: rgba(245, 243, 239, 0.35);
      text-transform: uppercase;
      margin-top: 0.3rem;
    }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 2rem;
      opacity: 0;
      animation: fadeUp 0.7s ease 1.5s forwards;
    }
    .btn-main {
      background: #E85D04;
      color: #0D0D0D;
      border: none;
      padding: 0.85rem 2rem;
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      transition: background 0.3s;
    }
    .btn-main:hover { background: #ff7420; }
    .btn-link {
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      color: rgba(245, 243, 239, 0.4);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      padding-bottom: 2px;
      transition: all 0.3s;
    }
    .btn-link:hover {
      color: #F5F3EF;
      border-color: rgba(245, 243, 239, 0.3);
    }

    /* Grid texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(245,243,239,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(245,243,239,0.03) 1px, transparent 1px);
      background-size: 80px 80px;
      pointer-events: none;
      z-index: 0;
    }
    .hero { position: relative; z-index: 1; }

    @keyframes slideRight {
      from { opacity: 0; transform: translateX(-28px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <nav>
    <span class="nav-logo">Klar_</span>
    <ul class="nav-links">
      <li><a href="#">Leistungen</a></li>
      <li><a href="#">Methode</a></li>
      <li><a href="#">Ergebnisse</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
  </nav>

  <section class="hero">
    <div class="diagonal"></div>

    <!-- LEFT -->
    <div class="hero-left">
      <div class="big-number" aria-hidden="true">07</div>

      <p class="eyebrow">// Coaching · Beratung · Trier</p>

      <h1 class="headline">
        <div class="ln"><span>Mehr</span></div>
        <div class="ln"><span>Klar-</span></div>
        <div class="ln"><span>heit.</span></div>
      </h1>
    </div>

    <!-- RIGHT -->
    <div class="hero-right">
      <div class="orange-rule"></div>

      <p class="desc">
        Coaching ist kein Nice-to-have. Es ist die schnellste
        Route von hier nach da. Keine Umwege, keine
        Selbstberuhigung — nur was wirkt.
      </p>

      <div class="stats">
        <div class="stat-item">
          <div class="stat-num">94<span>%</span></div>
          <div class="stat-label">Kundenzufriedenheit</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">12<span>+</span></div>
          <div class="stat-label">Jahre Erfahrung</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">380<span>+</span></div>
          <div class="stat-label">Klienten begleitet</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">6<span>×</span></div>
          <div class="stat-label">Ø Wachstum</div>
        </div>
      </div>

      <div class="cta-row">
        <a href="#" class="btn-main">Erstgespräch buchen</a>
        <a href="#" class="btn-link">Methode ansehen →</a>
      </div>
    </div>
  </section>
</body>
</html>
