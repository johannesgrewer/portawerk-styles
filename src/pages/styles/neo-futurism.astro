---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Nexum — Technologieberatung & Innovation | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;600;700&family=Plus+Jakarta+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --sky:    #0EA5E9;
      --violet: #8B5CF6;
      --bg:     #FAFAFA;
      --dark:   #0F172A;
      --muted:  rgba(15,23,42,0.45);
    }

    body {
      background: var(--bg);
      color: var(--dark);
      font-family: 'Plus Jakarta Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Subtle dot grid */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: radial-gradient(circle, rgba(14,165,233,0.08) 1px, transparent 1px);
      background-size: 32px 32px;
      pointer-events: none;
      z-index: 0;
    }

    /* Large background arc */
    body::after {
      content: '';
      position: fixed;
      top: -30vh;
      right: -20vw;
      width: 80vw;
      height: 80vw;
      border-radius: 50%;
      background: conic-gradient(from 180deg, rgba(14,165,233,0.06), rgba(139,92,246,0.06), transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 3.5rem;
      background: rgba(250,250,250,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(15,23,42,0.06);
    }
    .nav-logo {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 1.25rem;
      letter-spacing: -0.03em;
      color: var(--dark);
    }
    .nav-logo span {
      background: linear-gradient(90deg, var(--sky), var(--violet));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--sky); }
    .nav-cta {
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: #fff;
      background: linear-gradient(90deg, var(--sky), var(--violet));
      padding: 0.6rem 1.4rem;
      border-radius: 100px;
      text-decoration: none;
      transition: opacity 0.2s, box-shadow 0.2s;
      box-shadow: 0 2px 12px rgba(14,165,233,0.25);
    }
    .nav-cta:hover { opacity: 0.9; box-shadow: 0 4px 20px rgba(14,165,233,0.35); }

    .hero {
      min-height: 100vh;
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 400px;
      padding-top: 64px;
    }

    /* LEFT */
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 3.5rem 4rem 4.5rem;
      gap: 2rem;
    }

    .pill-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--sky);
      background: rgba(14,165,233,0.08);
      border: 1px solid rgba(14,165,233,0.2);
      padding: 0.3rem 0.9rem;
      border-radius: 100px;
      width: fit-content;
    }
    .pill-tag::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--sky);
    }

    .hero-headline {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: clamp(2.8rem, 5.5vw, 5rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--dark);
    }
    .hero-headline .grad {
      background: linear-gradient(90deg, var(--sky), var(--violet));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-body {
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 1.85;
      color: var(--muted);
      max-width: 44ch;
    }

    /* Service pills */
    .service-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .sp {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      padding: 0.35rem 0.9rem;
      border-radius: 100px;
      border: 1px solid rgba(15,23,42,0.1);
      color: var(--muted);
      background: #fff;
      box-shadow: 0 1px 4px rgba(15,23,42,0.04);
    }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: #fff;
      background: linear-gradient(90deg, var(--sky), var(--violet));
      text-decoration: none;
      padding: 0.85rem 2rem;
      border-radius: 100px;
      box-shadow: 0 4px 16px rgba(14,165,233,0.25);
      transition: box-shadow 0.2s, opacity 0.2s;
    }
    .cta-btn:hover { opacity: 0.9; box-shadow: 0 6px 24px rgba(14,165,233,0.35); }
    .cta-link {
      font-size: 0.62rem;
      font-weight: 400;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .cta-link:hover { color: var(--sky); }

    /* RIGHT — card stack */
    .hero-right {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 6rem 3.5rem 4rem 2rem;
      gap: 1rem;
    }

    .metric-card {
      background: #fff;
      border: 1px solid rgba(15,23,42,0.06);
      border-radius: 16px;
      padding: 1.5rem 2rem;
      box-shadow: 0 2px 12px rgba(15,23,42,0.04);
      display: flex;
      align-items: center;
      gap: 1.25rem;
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .metric-card:hover {
      box-shadow: 0 8px 24px rgba(15,23,42,0.08);
      transform: translateY(-2px);
    }
    .metric-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      flex-shrink: 0;
    }
    .mi-sky    { background: rgba(14,165,233,0.1); }
    .mi-violet { background: rgba(139,92,246,0.1); }
    .mi-dark   { background: rgba(15,23,42,0.06); }
    .metric-text {}
    .metric-num {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 1.6rem;
      line-height: 1;
      color: var(--dark);
      letter-spacing: -0.02em;
    }
    .metric-label {
      font-size: 0.62rem;
      font-weight: 400;
      color: var(--muted);
      margin-top: 0.15rem;
    }

    .contact-card {
      background: linear-gradient(135deg, rgba(14,165,233,0.08), rgba(139,92,246,0.08));
      border: 1px solid rgba(14,165,233,0.15);
      border-radius: 16px;
      padding: 1.5rem 2rem;
      margin-top: 0.5rem;
    }
    .cc-label {
      font-size: 0.55rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--sky);
      margin-bottom: 0.5rem;
    }
    .cc-value {
      font-family: 'Outfit', sans-serif;
      font-size: 0.9rem;
      font-weight: 400;
      color: var(--dark);
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Ne<span>xum</span></div>
    <ul class="nav-links">
      <li><a href="#">Leistungen</a></li>
      <li><a href="#">Referenzen</a></li>
      <li><a href="#">Team</a></li>
      <li><a href="#">Insights</a></li>
    </ul>
    <a href="#" class="nav-cta">Gespräch starten</a>
  </nav>

  <section class="hero">
    <div class="hero-left">
      <div class="pill-tag">Technologieberatung · Trier</div>

      <h1 class="hero-headline">
        Zukunft ist<br>
        eine <span class="grad">Entscheidung.</span>
      </h1>

      <p class="hero-body">
        Wir helfen Unternehmen, digitale Veränderung nicht
        zu erleiden, sondern zu gestalten. Strategisch,
        technisch, menschlich.
      </p>

      <div class="service-pills">
        <span class="sp">Digital Strategy</span>
        <span class="sp">Cloud Migration</span>
        <span class="sp">AI Integration</span>
        <span class="sp">Process Design</span>
        <span class="sp">Change Management</span>
      </div>

      <div class="cta-row">
        <a href="#" class="cta-btn">Erstgespräch buchen →</a>
        <a href="#" class="cta-link">Referenzen ansehen</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="metric-card">
        <div class="metric-icon mi-sky">🚀</div>
        <div class="metric-text">
          <div class="metric-num">120+</div>
          <div class="metric-label">Abgeschlossene Projekte</div>
        </div>
      </div>
      <div class="metric-card">
        <div class="metric-icon mi-violet">⚡</div>
        <div class="metric-text">
          <div class="metric-num">3× schneller</div>
          <div class="metric-label">Ø Digitalisierungsgeschwindigkeit</div>
        </div>
      </div>
      <div class="metric-card">
        <div class="metric-icon mi-dark">🏆</div>
        <div class="metric-text">
          <div class="metric-num">94%</div>
          <div class="metric-label">Kundenzufriedenheit</div>
        </div>
      </div>
      <div class="contact-card">
        <div class="cc-label">Nächste Verfügbarkeit</div>
        <div class="cc-value">Di, 25. März · 14:00 Uhr</div>
      </div>
    </div>
  </section>
</body>
</html>
