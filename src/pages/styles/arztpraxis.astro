---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Praxis Dr. Helene Voss — Allgemeinmedizin Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue-deep:   #0F2D4A;
      --blue-mid:    #1A4B6E;
      --blue-accent: #2E7DB5;
      --blue-light:  #E8F3FB;
      --green:       #2A8C6A;
      --green-light: #E6F5EF;
      --white:       #FFFFFF;
      --off-white:   #F7FAFB;
      --border:      #DCE9F0;
      --text-muted:  #6B8FA8;
      --text-body:   #2C4A5A;
      --ff-serif:    'DM Serif Display', Georgia, serif;
      --ff-sans:     'Inter', system-ui, sans-serif;
    }

    html {
      background: var(--white);
      color: var(--text-body);
      font-family: var(--ff-sans);
      font-size: 15px;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }

    img { display: block; max-width: 100%; }

    /* ── REVEAL ── */
    .reveal {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
                  transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }
    .reveal-delay-5 { transition-delay: 0.5s; }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 200;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 clamp(1.5rem, 4vw, 4rem);
      height: 68px;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      text-decoration: none;
    }

    .nav-cross {
      width: 36px;
      height: 36px;
      background: var(--blue-accent);
      border-radius: 10px;
      display: grid;
      place-items: center;
      flex-shrink: 0;
    }

    .nav-brand {
      font-family: var(--ff-sans);
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--blue-deep);
      line-height: 1.25;
    }
    .nav-brand span {
      display: block;
      font-size: 0.7rem;
      font-weight: 400;
      color: var(--text-muted);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--blue-deep); }

    .nav-tel {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--blue-deep) !important;
    }
    .nav-btn {
      background: var(--blue-accent);
      color: #fff !important;
      padding: 0.5rem 1.4rem;
      border-radius: 7px;
      font-weight: 600 !important;
      font-size: 0.78rem !important;
      transition: background 0.2s, transform 0.15s !important;
    }
    .nav-btn:hover { background: var(--blue-mid) !important; transform: translateY(-1px); }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 88vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      overflow: hidden;
    }

    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(3rem, 6vw, 6rem) clamp(2rem, 4vw, 4rem) clamp(3rem, 6vw, 6rem) clamp(2rem, 5vw, 5rem);
      background: var(--white);
      position: relative;
      z-index: 2;
    }

    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--blue-accent);
      margin-bottom: 1.75rem;
    }
    .hero-tag-dot {
      width: 7px;
      height: 7px;
      background: var(--green);
      border-radius: 50%;
      animation: pulse 2.5s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(42,140,106,0.5); }
      50% { box-shadow: 0 0 0 5px rgba(42,140,106,0); }
    }

    .hero-h1 {
      font-family: var(--ff-serif);
      font-size: clamp(2.6rem, 4.5vw, 4rem);
      font-weight: 400;
      color: var(--blue-deep);
      line-height: 1.15;
      letter-spacing: -0.01em;
      margin-bottom: 1.5rem;
    }
    .hero-h1 em {
      font-style: italic;
      color: var(--blue-accent);
    }

    .hero-sub {
      font-size: 0.9375rem;
      color: var(--text-muted);
      max-width: 420px;
      line-height: 1.8;
      margin-bottom: 2.75rem;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 3rem;
    }

    .btn-primary {
      background: var(--blue-deep);
      color: #fff;
      font-size: 0.82rem;
      font-weight: 600;
      padding: 0.8rem 1.875rem;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-primary:hover { background: var(--blue-mid); transform: translateY(-1px); }

    .btn-ghost {
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--blue-deep);
      text-decoration: none;
      padding: 0.8rem 1.5rem;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      transition: border-color 0.2s, background 0.2s;
    }
    .btn-ghost:hover { border-color: var(--blue-accent); background: var(--blue-light); }

    .hero-trust {
      display: flex;
      gap: 2rem;
    }
    .trust-item {
      display: flex;
      flex-direction: column;
    }
    .trust-num {
      font-family: var(--ff-serif);
      font-size: 1.6rem;
      color: var(--blue-deep);
      line-height: 1;
    }
    .trust-label {
      font-size: 0.7rem;
      color: var(--text-muted);
      margin-top: 0.2rem;
    }
    .trust-divider {
      width: 1px;
      background: var(--border);
      align-self: stretch;
    }

    /* Hero Right — full photo */
    .hero-right {
      position: relative;
      overflow: hidden;
    }
    .hero-right img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 8s ease;
    }
    .hero-right:hover img { transform: scale(1.04); }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, rgba(255,255,255,0.12) 0%, transparent 50%),
                  linear-gradient(to top, rgba(15,45,74,0.45) 0%, transparent 55%);
      pointer-events: none;
    }
    .hero-badge {
      position: absolute;
      bottom: 2.5rem;
      left: 2.5rem;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(8px);
      border-radius: 12px;
      padding: 1.125rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      box-shadow: 0 8px 32px rgba(15,45,74,0.15);
    }
    .badge-icon {
      width: 40px;
      height: 40px;
      background: var(--green-light);
      border-radius: 10px;
      display: grid;
      place-items: center;
      flex-shrink: 0;
    }
    .badge-text strong {
      display: block;
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--blue-deep);
    }
    .badge-text span {
      font-size: 0.7rem;
      color: var(--text-muted);
    }

    /* ── QUICK INFO BAR ── */
    .info-bar {
      background: var(--blue-deep);
      display: flex;
      justify-content: center;
      gap: 0;
    }
    .info-bar-item {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      padding: 1.25rem 3rem;
      border-right: 1px solid rgba(255,255,255,0.08);
      flex: 1;
      max-width: 320px;
    }
    .info-bar-item:last-child { border-right: none; }
    .info-bar-icon {
      width: 36px;
      height: 36px;
      background: rgba(255,255,255,0.07);
      border-radius: 8px;
      display: grid;
      place-items: center;
      flex-shrink: 0;
    }
    .info-bar-label {
      font-size: 0.68rem;
      color: rgba(255,255,255,0.45);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.15rem;
    }
    .info-bar-value {
      font-size: 0.82rem;
      font-weight: 500;
      color: #fff;
    }

    /* ── LEISTUNGEN ── */
    .leistungen {
      padding: clamp(4rem, 7vw, 7rem) clamp(1.5rem, 5vw, 5rem);
      background: var(--off-white);
    }

    .section-header {
      max-width: 560px;
      margin-bottom: 3.5rem;
    }
    .section-eyebrow {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--blue-accent);
      margin-bottom: 0.75rem;
    }
    .section-title {
      font-family: var(--ff-serif);
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      font-weight: 400;
      color: var(--blue-deep);
      line-height: 1.2;
      letter-spacing: -0.01em;
      margin-bottom: 1rem;
    }
    .section-desc {
      font-size: 0.9rem;
      color: var(--text-muted);
      line-height: 1.8;
    }

    .leistungen-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .leistung-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 2rem;
      position: relative;
      overflow: hidden;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    }
    .leistung-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: var(--blue-accent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.35s cubic-bezier(0.22,1,0.36,1);
    }
    .leistung-card:hover {
      border-color: transparent;
      box-shadow: 0 8px 40px rgba(15,45,74,0.1);
      transform: translateY(-3px);
    }
    .leistung-card:hover::before { transform: scaleX(1); }

    .leistung-icon-wrap {
      width: 48px;
      height: 48px;
      background: var(--blue-light);
      border-radius: 12px;
      display: grid;
      place-items: center;
      margin-bottom: 1.25rem;
      transition: background 0.2s;
    }
    .leistung-card:hover .leistung-icon-wrap { background: rgba(46,125,181,0.15); }

    .leistung-name {
      font-family: var(--ff-sans);
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--blue-deep);
      margin-bottom: 0.6rem;
    }
    .leistung-text {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.75;
    }

    /* ── TEAM ── */
    .team {
      padding: clamp(4rem, 7vw, 7rem) clamp(1.5rem, 5vw, 5rem);
      background: var(--white);
    }

    .team-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-top: 3.5rem;
    }

    .team-card {
      position: relative;
    }
    .team-photo-wrap {
      position: relative;
      overflow: hidden;
      border-radius: 14px;
      aspect-ratio: 4/5;
      margin-bottom: 1.5rem;
    }
    .team-photo-wrap img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .team-card:hover .team-photo-wrap img { transform: scale(1.05); }
    .team-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(15,45,74,0.5) 0%, transparent 50%);
      pointer-events: none;
    }
    .team-specialty {
      position: absolute;
      bottom: 1.25rem;
      left: 1.25rem;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(6px);
      border-radius: 20px;
      padding: 0.3rem 0.875rem;
      font-size: 0.68rem;
      font-weight: 500;
      color: var(--blue-accent);
    }
    .team-name {
      font-family: var(--ff-serif);
      font-size: 1.25rem;
      color: var(--blue-deep);
      margin-bottom: 0.2rem;
    }
    .team-role {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-bottom: 0.875rem;
    }
    .team-bio {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.75;
    }

    /* ── PRAXIS (SPLIT) ── */
    .praxis {
      background: var(--blue-deep);
      display: grid;
      grid-template-columns: 1fr 1fr;
      overflow: hidden;
    }

    .praxis-photo {
      position: relative;
      min-height: 520px;
    }
    .praxis-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 8s ease;
    }
    .praxis:hover .praxis-photo img { transform: scale(1.04); }
    .praxis-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, transparent 60%, rgba(15,45,74,0.5));
      pointer-events: none;
    }

    .praxis-content {
      padding: clamp(3rem, 5vw, 5rem) clamp(2.5rem, 4vw, 4.5rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .praxis-eyebrow {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(46,125,181,0.8);
      margin-bottom: 0.875rem;
    }
    .praxis-title {
      font-family: var(--ff-serif);
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      font-weight: 400;
      color: #fff;
      line-height: 1.25;
      letter-spacing: -0.01em;
      margin-bottom: 1.5rem;
    }
    .praxis-title em { font-style: italic; color: rgba(46,125,181,0.9); }
    .praxis-text {
      font-size: 0.875rem;
      color: rgba(255,255,255,0.55);
      line-height: 1.85;
      margin-bottom: 2.5rem;
    }

    .praxis-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: rgba(255,255,255,0.06);
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 2.5rem;
    }
    .praxis-stat {
      background: rgba(255,255,255,0.04);
      padding: 1.25rem 1.5rem;
      transition: background 0.2s;
    }
    .praxis-stat:hover { background: rgba(255,255,255,0.07); }
    .stat-num {
      font-family: var(--ff-serif);
      font-size: 1.8rem;
      color: #fff;
      line-height: 1;
      margin-bottom: 0.25rem;
    }
    .stat-label {
      font-size: 0.7rem;
      color: rgba(255,255,255,0.4);
    }

    .praxis-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--blue-accent);
      color: #fff;
      font-size: 0.82rem;
      font-weight: 600;
      padding: 0.875rem 2rem;
      border-radius: 8px;
      text-decoration: none;
      align-self: flex-start;
      transition: background 0.2s, transform 0.15s;
    }
    .praxis-btn:hover { background: #2569a0; transform: translateY(-1px); }

    /* ── FOTO GALERIE ── */
    .galerie {
      padding: clamp(4rem, 7vw, 7rem) clamp(1.5rem, 5vw, 5rem);
      background: var(--off-white);
    }

    .galerie-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 1rem;
      margin-top: 3rem;
    }

    .galerie-item {
      position: relative;
      overflow: hidden;
      border-radius: 12px;
    }
    .galerie-item:first-child {
      grid-row: 1 / 3;
    }
    .galerie-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
      display: block;
    }
    .galerie-item:first-child { aspect-ratio: auto; min-height: 420px; }
    .galerie-item:not(:first-child) { aspect-ratio: 4/3; }
    .galerie-item:hover img { transform: scale(1.06); }
    .galerie-item-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(15,45,74,0.3) 0%, transparent 50%);
      pointer-events: none;
    }

    /* ── KONTAKT ── */
    .kontakt {
      padding: clamp(4rem, 7vw, 7rem) clamp(1.5rem, 5vw, 5rem);
      background: var(--white);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }

    .kontakt-left { }

    .oeffnungszeiten {
      margin-top: 2.5rem;
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
    }
    .oz-header {
      background: var(--blue-light);
      padding: 1rem 1.5rem;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--blue-accent);
    }
    .oz-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.875rem 1.5rem;
      border-top: 1px solid var(--border);
      font-size: 0.82rem;
    }
    .oz-day { color: var(--text-body); font-weight: 500; }
    .oz-time { color: var(--text-muted); }
    .oz-closed { color: var(--border); font-style: italic; }
    .oz-row.today { background: var(--green-light); }
    .oz-row.today .oz-day { color: var(--green); }
    .oz-row.today .oz-time { color: var(--green); font-weight: 600; }

    .kontakt-right { }

    .kontakt-map {
      position: relative;
      overflow: hidden;
      border-radius: 14px;
      height: 260px;
      margin-bottom: 1.5rem;
      background: var(--blue-light);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .kontakt-map img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }
    .kontakt-map:hover img { transform: scale(1.04); }
    .map-label {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: rgba(255,255,255,0.95);
      border-radius: 10px;
      padding: 1rem 1.5rem;
      text-align: center;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--blue-deep);
      box-shadow: 0 4px 20px rgba(15,45,74,0.15);
    }
    .map-label span {
      display: block;
      font-weight: 400;
      color: var(--text-muted);
      font-size: 0.7rem;
      margin-top: 0.2rem;
    }

    .kontakt-info {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .ki-block {
      background: var(--off-white);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.25rem;
    }
    .ki-label {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 0.4rem;
    }
    .ki-value {
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--blue-deep);
      line-height: 1.5;
    }
    .ki-value a {
      color: var(--blue-accent);
      text-decoration: none;
    }
    .ki-value a:hover { text-decoration: underline; }

    /* ── FOOTER ── */
    footer {
      background: var(--blue-deep);
      padding: 2rem clamp(1.5rem, 5vw, 5rem);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }
    .footer-brand {
      font-family: var(--ff-serif);
      font-size: 1rem;
      color: #fff;
    }
    .footer-brand span {
      display: block;
      font-family: var(--ff-sans);
      font-size: 0.7rem;
      font-weight: 400;
      color: rgba(255,255,255,0.4);
      margin-top: 0.2rem;
    }
    .footer-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .footer-links a {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.4);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-links a:hover { color: rgba(255,255,255,0.8); }
    .footer-copy {
