---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Praxis Dr. Helene Voss — Allgemeinmedizin Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:    #1B3A4B;
      --mid:     #2E5E78;
      --cyan:    #4AADCF;
      --cyan-l:  #7ECDE8;
      --bg:      #F4F8FA;
      --white:   #FFFFFF;
      --muted:   #7A9AAB;
      --border:  #D8E8EF;
      --ff-disp: 'Plus Jakarta Sans', sans-serif;
      --ff-body: 'Inter', sans-serif;
    }

    html, body {
      background: var(--bg);
      color: var(--navy);
      font-family: var(--ff-body);
      font-size: 15px;
      line-height: 1.6;
    }

    /* ── NAV ── */
    nav {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 3rem;
      height: 64px;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-logo-wrap {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
    }

    .nav-logo-mark {
      width: 32px;
      height: 32px;
      background: var(--cyan);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .nav-logo-name {
      font-family: var(--ff-disp);
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--navy);
      line-height: 1.2;
    }

    .nav-logo-name span {
      display: block;
      font-size: 0.65rem;
      font-weight: 400;
      color: var(--muted);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--navy); }

    .nav-tel {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--navy) !important;
    }

    .nav-cta {
      background: var(--cyan);
      color: #fff !important;
      padding: 0.45rem 1.4rem;
      border-radius: 6px;
      font-weight: 600 !important;
      font-size: 0.78rem !important;
      transition: background 0.2s !important;
    }
    .nav-cta:hover { background: var(--mid) !important; }

    /* ── HERO ── */
    .hero {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 480px;
    }

    .hero-left {
      padding: 4.5rem 3.5rem 4.5rem 3rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      border-right: 1px solid var(--border);
    }

    .hero-eyebrow {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.7rem;
      font-weight: 500;
      color: var(--cyan);
      margin-bottom: 1.25rem;
      letter-spacing: 0.05em;
    }

    .eyebrow-dot {
      width: 6px;
      height: 6px;
      background: var(--cyan);
      border-radius: 50%;
      animation: dotPulse 2s ease-in-out infinite;
    }

    @keyframes dotPulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.4); opacity: 0.6; }
    }

    .hero-headline {
      font-family: var(--ff-disp);
      font-size: clamp(2rem, 3.5vw, 2.8rem);
      font-weight: 700;
      color: var(--navy);
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 1.25rem;
    }

    .hero-headline .cyan { color: var(--cyan); }

    .hero-desc {
      font-size: 0.875rem;
      color: var(--muted);
      max-width: 400px;
      line-height: 1.8;
      margin-bottom: 2.5rem;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
    }

    .btn-primary {
      background: var(--navy);
      color: #fff;
      font-size: 0.78rem;
      font-weight: 600;
      padding: 0.75rem 1.75rem;
      border-radius: 6px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-primary:hover { background: var(--mid); transform: translateY(-1px); }

    .btn-outline {
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--navy);
      text-decoration: none;
      padding: 0.75rem 1.5rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      transition: border-color 0.2s, background 0.2s;
    }
    .btn-outline:hover { border-color: var(--cyan); background: rgba(74,173,207,0.04); }

    /* Info cards right */
    .hero-right {
      padding: 3rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      align-content: center;
      background: var(--bg);
    }

    .info-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.25rem;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .info-card:hover {
      border-color: var(--cyan);
      box-shadow: 0 4px 16px rgba(74,173,207,0.1);
    }
    .info-card:first-child {
      grid-column: 1 / -1;
    }

    .info-icon {
      width: 36px;
      height: 36px;
      background: rgba(74,173,207,0.1);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 0.75rem;
    }

    .info-title {
      font-family: var(--ff-disp);
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 0.35rem;
    }

    .info-text {
      font-size: 0.75rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ── LEISTUNGEN ── */
    .leistungen-section {
      padding: 5rem 3rem;
      background: var(--bg);
    }

    .section-eyebrow {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--cyan);
      margin-bottom: 0.5rem;
    }

    .section-title {
      font-family: var(--ff-disp);
      font-size: clamp(1.6rem, 2.5vw, 2.2rem);
      font-weight: 700;
      color: var(--navy);
      letter-spacing: -0.02em;
      margin-bottom: 3rem;
    }

    .leistungen-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .leistung-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.75rem;
      transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    }
    .leistung-card:hover {
      border-color: var(--cyan);
      box-shadow: 0 6px 24px rgba(74,173,207,0.1);
      transform: translateY(-2px);
    }

    .leistung-icon {
      font-size: 1.6rem;
      margin-bottom: 1rem;
    }

    .leistung-name {
      font-family: var(--ff-disp);
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 0.5rem;
    }

    .leistung-desc {
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.7;
    }

    /* ── ÜBER DIE PRAXIS ── */
    .about-section {
      background: var(--navy);
      padding: 5rem 3rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .about-text { }

    .about-eyebrow {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--cyan);
      margin-bottom: 0.75rem;
    }

    .about-title {
      font-family: var(--ff-disp);
      font-size: clamp(1.6rem, 2.5vw, 2.2rem);
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.02em;
      line-height: 1.25;
      margin-bottom: 1.5rem;
    }

    .about-body {
      font-size: 0.875rem;
      color: rgba(255,255,255,0.55);
      line-height: 1.85;
      margin-bottom: 2rem;
    }

    .about-facts {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .fact-item {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px;
      padding: 1rem;
      transition: border-color 0.2s;
    }
    .fact-item:hover { border-color: rgba(74,173,207,0.4); }

    .fact-num {
      font-family: var(--ff-disp);
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--cyan);
      line-height: 1;
      margin-bottom: 0.25rem;
    }

    .fact-label {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.4);
    }

    /* Doctor profile */
    .doctor-profile {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px;
      padding: 2.5rem;
    }

    .doctor-avatar {
      width: 80px;
      height: 80px;
      background: linear-gradient(135deg, rgba(74,173,207,0.4), rgba(74,173,207,0.1));
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--ff-disp);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--cyan);
      margin-bottom: 1.25rem;
    }

    .doctor-name {
      font-family: var(--ff-disp);
      font-size: 1.1rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 0.25rem;
    }

    .doctor-title {
      font-size: 0.75rem;
      color: var(--cyan);
      margin-bottom: 1.5rem;
    }

    .doctor-bio {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.75;
      margin-bottom: 1.5rem;
    }

    .doctor-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .doctor-tag {
      font-size: 0.65rem;
      font-weight: 500;
      color: var(--cyan);
      background: rgba(74,173,207,0.1);
      border: 1px solid rgba(74,173,207,0.2);
      padding: 0.25rem 0.65rem;
      border-radius: 20px;
    }

    /* ── ANIMATIONS ── */
    /* Leistung cards already lift — add smooth icon glow */
    @keyframes iconGlow {
      0%, 100% { box-shadow: 0 0 0 0 rgba(74,173,207,0); }
      50%       { box-shadow: 0 0 12px 4px rgba(74,173,207,0.2); }
    }
    .leistung-card:hover .leistung-icon { animation: iconGlow 1.5s ease-in-out infinite; }

    /* Info cards border-color sweep */
    .info-card { transition: border-color 0.3s, box-shadow 0.3s; }

    /* Fact items count-up feel — scale on hover */
    .fact-item { transition: border-color 0.2s, transform 0.2s; }
    .fact-item:hover { transform: scale(1.03); }
    .fact-num { transition: color 0.2s; }
    .fact-item:hover .fact-num { color: var(--cyan-l); }

    /* Doctor profile hover lift */
    .doctor-profile { transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s; }
    .doctor-profile:hover {
      border-color: rgba(74,173,207,0.35);
      box-shadow: 0 8px 40px rgba(74,173,207,0.08);
      transform: translateY(-2px);
    }

    /* Nav logo mark spins subtly on hover */
    .nav-logo-wrap:hover .nav-logo-mark {
      transform: rotate(15deg);
      transition: transform 0.3s ease;
    }
    .nav-logo-mark { transition: transform 0.3s ease; }

    /* ── PHOTO ── */
    .img-wrap { display: block; }
    .img-wrap img { display: block; }
    .img-wrap:hover img { transform: scale(1.05); }

    /* ── FOOTER ── */
    footer {
      background: var(--white);
      border-top: 1px solid var(--border);
      padding: 2rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-logo {
      font-family: var(--ff-disp);
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--navy);
    }
    .footer-logo span {
      display: block;
      font-size: 0.65rem;
      font-weight: 400;
      color: var(--muted);
    }

    .footer-info {
      font-size: 0.72rem;
      color: var(--muted);
    }
  </style>
</head>
<body>

  <nav>
    <a class="nav-logo-wrap" href="#">
      <div class="nav-logo-mark">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </div>
      <div class="nav-logo-name">
        Dr. Helene Voss
        <span>Allgemeinmedizin & Prävention</span>
      </div>
    </a>
    <ul class="nav-links">
      <li><a href="#">Leistungen</a></li>
      <li><a href="#">Team</a></li>
      <li><a href="#">Praxis</a></li>
      <li><a class="nav-tel" href="#">0651 / 987 654</a></li>
      <li><a class="nav-cta" href="#">Termin buchen</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero" style="max-width:1600px;margin-left:auto;margin-right:auto;">
    <div class="hero-left">
      <div class="hero-eyebrow">
        <span class="eyebrow-dot"></span>
        Allgemeinmedizin · Trier-Nord · Jetzt Patienten annehmend
      </div>
      <h1 class="hero-headline">
        Medizin mit<br>
        <span class="cyan">Aufmerksamkeit.</span>
      </h1>
      <p class="hero-desc">Wir nehmen uns Zeit für Sie. Ganzheitliche Betreuung, ehrliche Kommunikation und eine Praxis, in der Sie sich willkommen fühlen — nicht wie eine Nummer.</p>
      <div class="hero-actions">
        <a class="btn-primary" href="#">Online-Termin buchen</a>
        <a class="btn-outline" href="#">Neue Patienten</a>
      </div>
    </div>

    <div class="hero-right">
      <!-- Photo 1: clinical/medical -->
      <div class="img-wrap" style="position:relative;overflow:hidden;height:200px;border-radius:4px;grid-column:1/-1;margin-bottom:0.25rem;">
        <img src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=1200&h=800&q=80"
             alt="Arztpraxis Konsultation" loading="lazy"
             style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform 0.55s ease;" />
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.5) 0%,transparent 60%);pointer-events:none;"></div>
      </div>

      <div class="info-card">
        <div class="info-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4AADCF" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <div class="info-title">Online-Terminbuchung</div>
        <p class="info-text">Buchen Sie Ihren Termin jederzeit online — ohne Warteschleife. Bestätigung per E-Mail in wenigen Minuten.</p>
      </div>
      <div class="info-card">
        <div class="info-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4AADCF" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.55a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <div class="info-title">Telefonsprechstunde</div>
        <p class="info-text">Mo–Fr 8–9 Uhr für Fragen ohne Termin.</p>
      </div>
      <div class="info-card">
        <div class="info-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4AADCF" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="info-title">Öffnungszeiten</div>
        <p class="info-text">Mo/Di/Do 8–18 Uhr · Mi/Fr 8–13 Uhr</p>
      </div>
    </div>
  </section>

  <!-- LEISTUNGEN -->
  <section class="leistungen-section" style="max-width:1600px;margin-left:auto;margin-right:auto;">
    <p class="section-eyebrow">Unser Angebot</p>
    <h2 class="section-title">Was wir für Sie tun</h2>

    <!-- Photo 2: medical setting -->
    <div class="img-wrap" style="position:relative;overflow:hidden;height:280px;border-radius:4px;margin-bottom:3rem;">
      <img src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?auto=format&fit=crop&w=1200&h=800&q=80"
           alt="Medizinische Behandlung in der Praxis" loading="lazy"
           style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform 0.55s ease;" />
      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.5) 0%,transparent 60%);pointer-events:none;"></div>
    </div>

    <div class="leistungen-grid">
      <div class="leistung-card">
        <div class="leistung-icon">🩺</div>
        <div class="leistung-name">Allgemeinmedizin</div>
        <p class="leistung-desc">Diagnose, Behandlung und Langzeitbetreuung bei akuten und chronischen Erkrankungen. Hausarztmodell mit langen Terminen auf Wunsch.</p>
      </div>
      <div class="leistung-card">
        <div class="leistung-icon">🔬</div>
        <div class="leistung-name">Vorsorge & Check-up</div>
        <p class="leistung-desc">Individuelles Gesundheitsprogramm: Blutbild, EKG, Blutdruckmessung, Krebsfrüherkennung und Impfberatung nach aktuellen RKI-Empfehlungen.</p>
      </div>
      <div class="leistung-card">
        <div class="leistung-icon">💊</div>
        <div class="leistung-name">Chronische Erkrankungen</div>
        <p class="leistung-desc">Strukturierte Langzeitbetreuung bei Diabetes, Bluthochdruck, Schilddrüsenerkrankungen und Herz-Kreislauf-Leiden.</p>
      </div>
      <div class="leistung-card">
        <div class="leistung-icon">✈️</div>
        <div class="leistung-name">Reisemedizin</div>
        <p class="leistung-desc">Impfberatung, Malariaprophy­laxe und individuelle Gesundheits­empfehlungen für Ihre Reisedestination.</p>
      </div>
      <div class="leistung-card">
        <div class="leistung-icon">🧠</div>
        <div class="leistung-name">Burnout & Stressmedizin</div>
        <p class="leistung-desc">Beratung und begleitende Behandlung bei arbeitsbedingtem Stress, Erschöpfung und psychosomatischen Beschwerden.</p>
      </div>
      <div class="leistung-card">
        <div class="leistung-icon">🏠</div>
        <div class="leistung-name">Hausbesuche</div>
        <p class="leistung-desc">Für Patienten, die nicht mobil sind. Hausbesuche auf Anfrage im Stadtgebiet Trier und Umgebung.</p>
      </div>
    </div>
  </section>

  <!-- ÜBER -->
  <section class="about-section" style="max-width:1600px;margin-left:auto;margin-right:auto;">
    <div class="about-text">
      <p class="about-eyebrow">Die Praxis</p>
      <h2 class="about-title">Medizin braucht<br>Zeit und Vertrauen.</h2>
      <p class="about-body">Seit 2014 sind wir eine feste Anlaufstelle für Patientinnen und Patienten aus Trier-Nord und Umgebung. Unsere Philosophie ist einfach: Wir hören zuerst zu. Ein gutes Gespräch ist oft der wichtigste Teil der Behandlung.</p>

      <div class="about-facts">
        <div class="fact-item">
          <div class="fact-num">11+</div>
          <div class="fact-label">Jahre in Trier</div>
        </div>
        <div class="fact-item">
          <div class="fact-num">2.400</div>
          <div class="fact-label">Aktive Patienten</div>
        </div>
        <div class="fact-item">
          <div class="fact-num">98%</div>
          <div class="fact-label">Weiterempfehlung</div>
        </div>
        <div class="fact-item">
          <div class="fact-num">≤48h</div>
          <div class="fact-label">Termin in der Regel</div>
        </div>
      </div>
    </div>

    <div class="doctor-profile">
      <!-- Photo 3: professional clinical -->
      <div class="img-wrap" style="position:relative;overflow:hidden;height:220px;border-radius:8px;margin-bottom:1.5rem;">
        <img src="https://images.unsplash.com/photo-1580136579312-94651dfd596d?auto=format&fit=crop&w=1200&h=800&q=80"
             alt="Dr. Helene Voss — Ärztin in Trier" loading="lazy"
             style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform 0.55s ease;" />
