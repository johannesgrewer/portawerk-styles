---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Brücke — Soziale Arbeit & Beratung Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,300;0,400;0,600;0,700;0,800;1,700&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --amber:  #D97706;
      --amber-light: #FEF3C7;
      --amber-mid:   #FDE68A;
      --green:  #059669;
      --green-light: rgba(5,150,105,0.08);
      --bg:     #FFFBEB;
      --surface:#FFFFFF;
      --dark:   #1C1917;
      --muted:  rgba(28,25,23,0.48);
      --border: rgba(28,25,23,0.07);
    }

    body {
      background: var(--bg);
      color: var(--dark);
      font-family: 'Source Sans 3', sans-serif;
      overflow-x: hidden;
    }

    /* ─── Nav ──────────────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 3.5rem; height: 60px;
      background: rgba(255,251,235,0.96); backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }
    .nav-brand { display: flex; align-items: center; gap: .7rem; }
    .nav-mark {
      width: 32px; height: 32px; border-radius: 50%;
      background: var(--amber);
      display: flex; align-items: center; justify-content: center;
    }
    .nav-mark svg { width: 16px; height: 16px; stroke: #fff; fill: none; stroke-width: 2.2; stroke-linecap: round; }
    .nav-name {
      font-family: 'Nunito', sans-serif; font-weight: 800;
      font-size: 1.05rem; color: var(--dark);
    }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      font-size: .65rem; font-weight: 600; letter-spacing: .1em;
      text-transform: uppercase; color: var(--muted);
      text-decoration: none; transition: color .2s;
    }
    .nav-links a:hover { color: var(--amber); }
    .nav-cta {
      font-size: .62rem; font-weight: 700; letter-spacing: .08em;
      text-transform: uppercase; color: #fff;
      background: var(--amber); padding: .65rem 1.5rem;
      border-radius: 100px; text-decoration: none; transition: background .2s;
    }
    .nav-cta:hover { background: var(--dark); }

    /* ─── Hero ─────────────────────────────────────────── */
    .hero {
      min-height: 100vh; padding-top: 60px;
      display: grid; grid-template-columns: 1fr 480px;
    }

    .hero-left {
      display: flex; flex-direction: column; justify-content: center;
      padding: 5rem 3.5rem 5rem 5rem; gap: 2.25rem;
    }

    .eyebrow {
      display: inline-flex; align-items: center; gap: .6rem;
      font-size: .6rem; font-weight: 700; letter-spacing: .18em;
      text-transform: uppercase; color: var(--green);
    }
    .eyebrow-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--green);
    }

    .hero-h1 {
      font-family: 'Nunito', sans-serif; font-weight: 800;
      font-size: clamp(2.8rem, 5.5vw, 5rem);
      line-height: 1.05; letter-spacing: -.02em; color: var(--dark);
    }
    .hero-h1 em {
      font-style: italic; color: var(--amber);
      position: relative; display: inline-block;
    }
    .hero-h1 em::after {
      content: '';
      position: absolute; bottom: 4px; left: 0; right: 0;
      height: 3px; background: var(--amber-mid); border-radius: 2px;
    }

    .hero-p {
      font-size: .92rem; font-weight: 300; line-height: 1.9;
      color: var(--muted); max-width: 46ch;
    }

    /* Angebots-Chips */
    .chips { display: flex; flex-direction: column; gap: .55rem; }
    .chip {
      display: flex; align-items: center; gap: 1rem;
      padding: .85rem 1.25rem;
      background: var(--surface); border: 1px solid var(--border);
      border-left: 3px solid var(--amber);
      transition: border-left-color .2s, transform .2s, box-shadow .2s;
    }
    .chip:hover {
      border-left-color: var(--green);
      transform: translateX(4px);
      box-shadow: 0 2px 12px rgba(28,25,23,0.06);
    }
    .chip-icon {
      width: 32px; height: 32px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .chip-icon svg { width: 16px; height: 16px; }
    .chip-text {}
    .chip-title {
      font-family: 'Nunito', sans-serif; font-weight: 700;
      font-size: .86rem; color: var(--dark);
    }
    .chip-sub {
      font-size: .68rem; font-weight: 300; color: var(--muted); margin-top: 1px;
    }
    .chip-badge {
      margin-left: auto; flex-shrink: 0;
      font-size: .52rem; font-weight: 700; letter-spacing: .1em;
      text-transform: uppercase; color: var(--green);
      background: var(--green-light);
      border: 1px solid rgba(5,150,105,.2);
      padding: .2rem .65rem; border-radius: 100px;
    }

    .cta-row { display: flex; align-items: center; gap: 1.5rem; }
    .btn-prim {
      font-size: .65rem; font-weight: 700; letter-spacing: .08em;
      text-transform: uppercase; color: #fff;
      background: var(--amber); text-decoration: none;
      padding: .9rem 2rem; border-radius: 100px; transition: background .2s;
    }
    .btn-prim:hover { background: var(--dark); }
    .btn-ghost {
      font-size: .62rem; font-weight: 400; color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid rgba(28,25,23,.15); padding-bottom: 1px;
    }

    /* ─── Hero Right: Menschen-Mosaik ─────────────────── */
    .hero-right {
      background: var(--amber-light); border-left: 1px solid var(--border);
      display: flex; flex-direction: column;
      padding: 5rem 3.5rem 3.5rem; gap: 2rem;
    }

    .mosaic-label {
      font-size: .55rem; font-weight: 700; letter-spacing: .2em;
      text-transform: uppercase; color: var(--amber);
    }

    .mosaic {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: .75rem;
    }
    .avatar {
      display: flex; flex-direction: column;
      align-items: center; gap: .4rem;
    }
    .avatar-circle {
      width: 64px; height: 64px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Nunito', sans-serif; font-weight: 800;
      font-size: 1.1rem; color: #fff;
      transition: transform .2s;
    }
    .avatar-circle:hover { transform: scale(1.08); }
    .avatar-name {
      font-size: .56rem; font-weight: 600; color: var(--dark);
      text-align: center; line-height: 1.2;
    }
    .avatar-role {
      font-size: .5rem; font-weight: 300; color: var(--muted);
      text-align: center;
    }

    /* Avatar colors */
    .av-1 { background: #D97706; }
    .av-2 { background: #059669; }
    .av-3 { background: #7C3AED; }
    .av-4 { background: #DC2626; }
    .av-5 { background: #0891B2; }
    .av-6 { background: #CA8A04; }
    .av-7 { background: #16A34A; }
    .av-8 { background: #9333EA; }

    /* Big stat */
    .hero-stat {
      padding: 1.5rem; background: var(--surface);
      border: 1px solid var(--border);
    }
    .hs-num {
      font-family: 'Nunito', sans-serif; font-weight: 800;
      font-size: 2.8rem; letter-spacing: -.03em; color: var(--amber);
      line-height: 1;
    }
    .hs-label {
      font-size: .72rem; font-weight: 300; color: var(--muted);
      margin-top: .3rem; line-height: 1.4;
    }
    .hs-note {
      font-size: .58rem; font-weight: 600; letter-spacing: .08em;
      text-transform: uppercase; color: var(--green);
      margin-top: .6rem; display: flex; align-items: center; gap: .4rem;
    }
    .hs-note::before {
      content: ''; width: 20px; height: 1px; background: var(--green);
    }

    /* ─── Section 2 — Angebote ────────────────────────── */
    .angebote {
      padding: 7rem 5rem;
      background: var(--surface);
      border-top: 1px solid var(--border);
    }
    .sec-head {
      display: flex; align-items: flex-end; justify-content: space-between;
      margin-bottom: 3.5rem;
    }
    .sec-eyebrow {
      font-size: .58rem; font-weight: 700; letter-spacing: .18em;
      text-transform: uppercase; color: var(--green);
      margin-bottom: .5rem; display: flex; align-items: center; gap: .55rem;
    }
    .sec-eyebrow::before { content: ''; width: 18px; height: 2px; background: var(--green); border-radius: 1px; }
    .sec-title {
      font-family: 'Nunito', sans-serif; font-weight: 800;
      font-size: 2.25rem; letter-spacing: -.02em; color: var(--dark);
    }
    .sec-link {
      font-size: .62rem; font-weight: 600; letter-spacing: .08em;
      text-transform: uppercase; color: var(--amber); text-decoration: none;
    }

    .ang-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
    }

    .ang-card {
      background: var(--bg); border: 1px solid var(--border);
      display: flex; flex-direction: column;
      transition: transform .2s, box-shadow .2s;
    }
    .ang-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(28,25,23,.08);
    }

    .ang-art {
      height: 160px; display: flex; align-items: center; justify-content: center;
      position: relative; overflow: hidden;
      border-bottom: 1px solid var(--border);
    }

    /* Art: Einzelberatung — two chairs facing each other */
    .art-chair {
      position: relative; display: flex; align-items: flex-end;
      gap: 24px;
    }
    .chair {
      display: flex; flex-direction: column; align-items: center; gap: 3px;
    }
    .chair-back {
      width: 24px; height: 32px; border-radius: 4px 4px 0 0;
    }
    .chair-seat {
      width: 32px; height: 10px; border-radius: 3px;
    }
    .chair-legs {
      display: flex; gap: 16px;
    }
    .chair-leg {
      width: 3px; height: 18px; border-radius: 2px;
    }
    .chair-r { transform: scaleX(-1); }
    .chair-line {
      position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
      width: 1px; height: 24px; background: rgba(28,25,23,.08);
    }

    /* Art: Familienbegleitung — family silhouettes */
    .art-family {
      display: flex; align-items: flex-end; gap: 10px;
    }
    .fig {
      display: flex; flex-direction: column; align-items: center; gap: 3px;
    }
    .fig-head { border-radius: 50%; }
    .fig-body { border-radius: 3px 3px 0 0; }

    /* Art: Krisenintervention — lifeline/heart */
    .art-heart {
      position: relative; width: 64px; height: 56px;
    }
    .art-heart::before, .art-heart::after {
      content: ''; position: absolute;
      width: 36px; height: 56px; border-radius: 36px 36px 0 0;
      background: #DC2626; opacity: .85;
      top: 0;
    }
    .art-heart::before { left: 14px; transform: rotate(-45deg); transform-origin: 0 100%; }
    .art-heart::after  { right: 14px; transform: rotate(45deg); transform-origin: 100% 100%; }

    /* Art: Gruppenangebote — circle of people */
    .art-group {
      position: relative; width: 120px; height: 120px;
    }
    .grp-dot {
      position: absolute; border-radius: 50%;
      transform: translate(-50%, -50%);
    }
    .grp-line {
      position: absolute; height: 1px;
      background: rgba(28,25,23,.08);
      transform-origin: left center;
    }

    .ang-body {
      padding: 1.5rem; flex: 1;
      display: flex; flex-direction: column; gap: .6rem;
    }
    .ang-tag {
      font-size: .52rem; font-weight: 700; letter-spacing: .16em;
      text-transform: uppercase; color: var(--amber);
    }
    .ang-name {
      font-family: 'Nunito', sans-serif; font-weight: 800;
      font-size: 1rem; color: var(--dark); line-height: 1.2;
    }
    .ang-desc {
      font-size: .74rem; font-weight: 300; color: var(--muted);
      line-height: 1.75; flex: 1;
    }
    .ang-foot {
      display: flex; align-items: center; justify-content: space-between;
      padding-top: .75rem; border-top: 1px solid var(--border);
      margin-top: auto;
    }
    .ang-badge {
      font-size: .52rem; font-weight: 700; letter-spacing: .1em;
      text-transform: uppercase; color: var(--green);
      background: var(--green-light);
      border: 1px solid rgba(5,150,105,.2);
      padding: .22rem .7rem; border-radius: 100px;
    }
    .ang-more {
      font-size: .6rem; font-weight: 600; color: var(--amber);
      text-decoration: none; transition: color .2s;
    }
    .ang-more:hover { color: var(--dark); }

    /* ─── Section 3 — Wirkung ─────────────────────────── */
    .wirkung {
      padding: 7rem 5rem;
      background: var(--bg);
      border-top: 1px solid var(--border);
    }

    /* Pull quote */
    .pullquote-wrap {
      max-width: 860px; margin: 0 auto 6rem;
      text-align: center; position: relative;
    }
    .pq-mark {
      font-family: 'Nunito', sans-serif; font-weight: 800;
      font-size: 8rem; line-height: .6; color: var(--amber-mid);
      display: block; margin-bottom: .5rem; user-select: none;
    }
    .pq-text {
      font-family: 'Nunito', sans-serif; font-weight: 700; font-style: italic;
      font-size: clamp(1.4rem, 2.5vw, 2rem); line-height: 1.45;
      color: var(--dark); letter-spacing: -.01em;
    }
    .pq-text em { font-style: normal; color: var(--amber); }
    .pq-author {
      margin-top: 1.5rem; display: flex; align-items: center;
      justify-content: center; gap: .75rem;
    }
    .pq-avatar {
      width: 40px; height: 40px; border-radius: 50%;
      background: var(--amber); display: flex; align-items: center;
      justify-content: center;
      font-family: 'Nunito', sans-serif; font-weight: 800;
      font-size: .9rem; color: #fff;
    }
    .pq-name {
      text-align: left;
    }
    .pq-n {
      font-size: .78rem; font-weight: 600; color: var(--dark);
    }
    .pq-sub {
      font-size: .62rem; font-weight: 300; color: var(--muted);
    }

    /* Impact grid */
    .impact-grid {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 1px; background: var(--border);
      border: 1px solid var(--border);
      margin-bottom: 5rem;
    }
    .impact-cell {
      background: var(--surface); padding: 2.5rem 2rem;
      display: flex; flex-direction: column; gap: .5rem;
      transition: background .2s;
    }
    .impact-cell:hover { background: var(--amber-light); }
    .impact-num {
      font-family: 'Nunito', sans-serif; font-weight: 800;
      font-size: 3rem; letter-spacing: -.03em; color: var(--amber);
      line-height: 1;
    }
    .impact-label {
      font-size: .82rem; font-weight: 600; color: var(--dark);
    }
    .impact-sub {
      font-size: .68rem; font-weight: 300; color: var(--muted); line-height: 1.5;
    }

    /* Team row */
    .team-head {
      font-size: .58rem; font-weight: 700; letter-spacing: .18em;
      text-transform: uppercase; color: var(--muted);
      margin-bottom: 1.5rem; display: flex; align-items: center; gap: .6rem;
    }
    .team-head::before { content: ''; width: 18px; height: 1px; background: var(--muted); }
    .team-row {
      display: flex; gap: 2rem; align-items: flex-start;
    }
    .team-member {
      display: flex; flex-direction: column; align-items: center; gap: .5rem;
      flex: 1;
    }
    .tm-circle {
      width: 72px; height: 72px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Nunito', sans-serif; font-weight: 800;
      font-size: 1.2rem; color: #fff;
      transition: transform .2s;
    }
    .tm-circle:hover { transform: scale(1.06); }
    .tm-name {
      font-family: 'Nunito', sans-serif; font-weight: 700;
      font-size: .78rem; color: var(--dark); text-align: center;
    }
    .tm-role {
      font-size: .62rem; font-weight: 300; color: var(--muted);
      text-align: center; line-height: 1.3;
    }

    /* ─── Animations ───────────────────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-left > * { animation: fadeUp .65s ease both; }
    .hero-left > *:nth-child(1){ animation-delay:.05s }
    .hero-left > *:nth-child(2){ animation-delay:.15s }
    .hero-left > *:nth-child(3){ animation-delay:.25s }
    .hero-left > *:nth-child(4){ animation-delay:.35s }
    .hero-left > *:nth-child(5){ animation-delay:.45s }

    @keyframes popIn {
      from { opacity: 0; transform: scale(.85); }
      to   { opacity: 1; transform: scale(1); }
    }
    .avatar-circle {
      animation: popIn .5s ease both;
    }
    .avatar:nth-child(1) .avatar-circle { animation-delay:.1s }
    .avatar:nth-child(2) .avatar-circle { animation-delay:.18s }
    .avatar:nth-child(3) .avatar-circle { animation-delay:.26s }
    .avatar:nth-child(4) .avatar-circle { animation-delay:.34s }
    .avatar:nth-child(5) .avatar-circle { animation-delay:.42s }
    .avatar:nth-child(6) .avatar-circle { animation-delay:.50s }
    .avatar:nth-child(7) .avatar-circle { animation-delay:.58s }
    .avatar:nth-child(8) .avatar-circle { animation-delay:.66s }

    .ang-card { animation: fadeUp .6s ease both; }
    .ang-card:nth-child(1){ animation-delay:.1s }
    .ang-card:nth-child(2){ animation-delay:.2s }
    .ang-card:nth-child(3){ animation-delay:.3s }
    .ang-card:nth-child(4){ animation-delay:.4s }
  </style>
</head>
<body>

<!-- Nav -->
<nav>
  <div class="nav-brand">
    <div class="nav-mark">
      <svg viewBox="0 0 24 24"><path d="M12 21C12 21 4 14 4 8.5a8 8 0 0 1 16 0C20 14 12 21 12 21z"/><circle cx="12" cy="9" r="2.5" fill="white" stroke="none"/></svg>
    </div>
    <span class="nav-name">Brücke</span>
  </div>
  <ul class="nav-links">
    <li><a href="#">Beratung</a></li>
    <li><a href="#">Angebote</a></li>
    <li><a href="#">Team</a></li>
    <li><a href="#">Über uns</a></li>
  </ul>
  <a href="#" class="nav-cta">Termin anfragen</a>
</nav>

<!-- Hero -->
<section class="hero">
  <div class="hero-left">
    <div class="eyebrow">
      <div class="eyebrow-dot"></div>
      Soziale Arbeit · Trier · seit 2009
    </div>

    <h1 class="hero-h1">
      Für jeden<br>
      ein <em>Ohr.</em>
    </h1>

    <p class="hero-p">
      Niemand muss alleine durch schwierige Zeiten.
      Wir hören zu, begleiten und helfen — kostenlos,
      vertraulich und ohne Bürokratie-Hürden.
    </p>

    <div class="chips">
      <div class="chip">
        <div class="chip-icon" style="background:#FEF3C7;">
          <svg viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" stroke-linecap="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
          </svg>
        </div>
        <div class="chip-text">
          <div class="chip-title">Einzelberatung</div>
          <div class="chip-sub">Persönlich · vertraulich · ohne Wartezeit</div>
        </div>
        <span class="chip-badge">Kostenlos</span>
      </div>
      <div class="chip">
        <div class="chip-icon" style="background:#ECFDF5;">
          <svg viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2" stroke-linecap="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <div class="chip-text">
          <div class="chip-title">Familienbegleitung</div>
          <div class="chip-sub">Unterstützung für Familien in Krisen</div>
        </div>
        <span class="chip-badge">Kostenlos</span>
      </div>
      <div class="chip">
        <div class="chip-icon" style="background:#FEF3C7;">
          <svg viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 12h8M12 8v8"/>
          </svg>
        </div>
        <div class="chip-text">
          <div class="chip-title">Gruppenangebote</div>
          <div class="chip-sub">Wöchentliche Treffen · Selbsthilfegruppen</div>
        </div>
        <span class="chip-badge">Offen</span>
      </div>
    </div>

    <div class="cta-row">
      <a href="#" class="btn-prim">Termin anfragen →</a>
      <a href="#" class="btn-ghost">Alle Angebote ansehen</a>
    </div>
  </div>

  <!-- Menschen-Mosaik -->
  <div class="hero-right">
    <div class="mosaic-label">Unser Team · 18 Mitarbeitende</div>

    <div class="mosaic">
      <div class="avatar">
        <div class="avatar-circle av-1">SK</div>
        <div class="avatar-name">Sarah K.</div>
        <div class="avatar-role">Beratung</div>
      </div>
      <div class="avatar">
        <div class="avatar-circle av-2">MT</div>
        <div class="avatar-name">Marc T.</div>
        <div class="avatar-role">Sozialarbeit</div>
      </div>
