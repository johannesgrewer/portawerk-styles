---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Chainforge — DeFi Infrastructure | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --bg:       #07050F;
      --bg2:      #0D0A1A;
      --surface:  rgba(255,255,255,0.04);
      --border:   rgba(255,255,255,0.08);
      --primary:  #8B5CF6;
      --primary-g:#A78BFA;
      --cyan:     #06B6D4;
      --cyan-g:   #22D3EE;
      --amber:    #F59E0B;
      --text:     #E2E8F0;
      --muted:    #64748B;
      --muted2:   #94A3B8;
      --glow-p:   rgba(139,92,246,0.4);
      --glow-c:   rgba(6,182,212,0.3);
      --font-h:   "Space Grotesk", sans-serif;
      --font-mono:"Space Mono", monospace;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-h);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    ::selection { background: var(--primary); color: #fff; }

    /* ── ATMOSPHERE ── */
    .orbs {
      position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden;
    }
    .orb {
      position: absolute; border-radius: 50%; filter: blur(120px); opacity: 0.32;
    }
    .orb-1 {
      width: 600px; height: 600px;
      background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
      top: -200px; left: -100px;
      animation: orbDrift1 20s ease-in-out infinite alternate;
    }
    .orb-2 {
      width: 500px; height: 500px;
      background: radial-gradient(circle, var(--cyan) 0%, transparent 70%);
      bottom: 80px; right: -80px;
      animation: orbDrift2 25s ease-in-out infinite alternate;
    }
    .orb-3 {
      width: 380px; height: 380px;
      background: radial-gradient(circle, var(--amber) 0%, transparent 70%);
      top: 45%; left: 50%; transform: translate(-50%,-50%);
      opacity: 0.10;
      animation: orbDrift3 18s ease-in-out infinite alternate;
    }
    @keyframes orbDrift1 {
      0%   { transform: translate(0,0) scale(1); }
      100% { transform: translate(80px,60px) scale(1.15); }
    }
    @keyframes orbDrift2 {
      0%   { transform: translate(0,0) scale(1); }
      100% { transform: translate(-60px,-80px) scale(1.1); }
    }
    @keyframes orbDrift3 {
      0%   { transform: translate(-50%,-50%) scale(1); }
      100% { transform: translate(-50%,-50%) scale(1.35); }
    }

    .grid-bg {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background-image:
        linear-gradient(rgba(139,92,246,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(139,92,246,0.04) 1px, transparent 1px);
      background-size: 80px 80px;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes shimmer {
      from { transform: translateX(-200%); }
      to   { transform: translateX(400%); }
    }
    @keyframes pulseDot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: 0.45; transform: scale(0.75); }
    }
    @keyframes tickerScroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @keyframes borderGlow {
      0%, 100% { box-shadow: 0 0 24px rgba(139,92,246,0.25), inset 0 0 24px rgba(139,92,246,0.04); }
      50%       { box-shadow: 0 0 40px rgba(6,182,212,0.22), inset 0 0 40px rgba(6,182,212,0.03); }
    }

    .reveal {
      opacity: 0;
      transform: translateY(32px);
      transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1),
                  transform 0.8s cubic-bezier(0.16,1,0.3,1);
    }
    .reveal.in { opacity: 1; transform: translateY(0); }

    /* ── NAV ── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 3rem; height: 68px;
      background: rgba(7,5,15,0.72);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: var(--font-mono); font-size: 0.88rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--text); text-decoration: none;
    }
    .nav-logo .ac { color: var(--cyan); }
    .nav-links { display: flex; align-items: center; gap: 2.5rem; list-style: none; }
    .nav-links a {
      font-size: 0.8rem; font-weight: 500; letter-spacing: 0.05em;
      color: var(--muted2); text-decoration: none; transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--text); }
    .nav-cta {
      font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: #fff; background: linear-gradient(135deg, var(--primary), var(--cyan));
      padding: 0.6rem 1.4rem; border-radius: 5px; text-decoration: none;
      transition: opacity 0.2s, transform 0.2s;
    }
    .nav-cta:hover { opacity: 0.82; transform: translateY(-1px); }

    /* ── HERO ── */
    .hero {
      position: relative; z-index: 1;
      display: grid; grid-template-columns: 1fr 1fr;
      align-items: center; gap: 4rem;
      min-height: 100vh; padding: 8rem 6rem 5rem;
      max-width: 1560px; margin: 0 auto;
    }
    .hero-left { display: flex; flex-direction: column; gap: 2rem; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.6rem;
      background: rgba(139,92,246,0.1); border: 1px solid rgba(139,92,246,0.25);
      border-radius: 100px; padding: 0.4rem 1rem 0.4rem 0.7rem;
      width: fit-content;
      animation: fadeUp 0.6s ease both;
    }
    .badge-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--primary); box-shadow: 0 0 8px var(--primary);
      animation: pulseDot 2s ease-in-out infinite;
    }
    .badge-text {
      font-family: var(--font-mono); font-size: 0.68rem;
      letter-spacing: 0.12em; text-transform: uppercase; color: var(--primary-g);
    }
    .hero-h1 {
      font-size: clamp(2.8rem, 4.8vw, 4.8rem);
      font-weight: 700; line-height: 1.05; letter-spacing: -0.03em;
      color: var(--text);
      animation: fadeUp 0.6s ease 0.1s both;
    }
    .hero-h1 .grad {
      background: linear-gradient(135deg, var(--primary-g) 0%, var(--cyan) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .hero-sub {
      font-size: 1.05rem; font-weight: 400; line-height: 1.78;
      color: var(--muted2); max-width: 48ch;
      animation: fadeUp 0.6s ease 0.2s both;
    }
    .hero-ctas {
      display: flex; align-items: center; gap: 1.25rem;
      animation: fadeUp 0.6s ease 0.3s both;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: var(--font-mono); font-size: 0.78rem; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: #fff; background: linear-gradient(135deg, var(--primary), var(--cyan));
      padding: 0.9rem 2rem; border-radius: 6px; text-decoration: none;
      position: relative; overflow: hidden;
      box-shadow: 0 0 32px rgba(139,92,246,0.35);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-primary::before {
      content: ''; position: absolute; top: 0; left: 0;
      width: 40%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transform: translateX(-200%);
      animation: shimmer 3.5s ease-in-out infinite 1.5s;
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 40px rgba(139,92,246,0.5); }
    .btn-ghost {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-size: 0.88rem; font-weight: 500;
      color: var(--muted2); text-decoration: none;
      transition: color 0.2s, gap 0.2s;
    }
    .btn-ghost:hover { color: var(--text); gap: 0.8rem; }

    .hero-stats {
      display: flex; gap: 2.5rem;
      padding-top: 1.25rem; border-top: 1px solid var(--border);
      animation: fadeUp 0.6s ease 0.4s both;
    }
    .stat-num {
      font-family: var(--font-mono); font-size: 1.8rem; font-weight: 700;
      line-height: 1;
      background: linear-gradient(135deg, #fff 0%, var(--muted2) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .stat-label {
      font-size: 0.72rem; font-weight: 500;
      color: var(--muted); letter-spacing: 0.06em; margin-top: 0.3rem;
    }

    /* Hero right card */
    .hero-right { position: relative; animation: fadeUp 0.8s ease 0.25s both; }
    .hero-card {
      position: relative;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px; overflow: hidden;
      backdrop-filter: blur(20px);
      animation: borderGlow 4s ease-in-out infinite;
    }
    .hero-card-img { position: relative; height: 260px; overflow: hidden; }
    .hero-card-img img {
      width: 100%; height: 100%; object-fit: cover;
      filter: brightness(0.55) saturate(0.65) hue-rotate(230deg);
      transition: transform 0.6s ease;
    }
    .hero-card:hover .hero-card-img img { transform: scale(1.05); }
    .hero-card-img-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, transparent 30%, rgba(13,10,26,1) 100%);
    }
    .hero-card-live {
      position: absolute; top: 1rem; right: 1rem;
      background: rgba(7,5,15,0.85); backdrop-filter: blur(12px);
      border: 1px solid var(--border); border-radius: 8px;
      padding: 0.5rem 0.75rem;
      display: flex; align-items: center; gap: 0.4rem;
    }
    .live-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: #10B981; box-shadow: 0 0 8px #10B981;
      animation: pulseDot 1.5s ease-in-out infinite;
    }
    .live-text {
      font-family: var(--font-mono); font-size: 0.62rem;
      letter-spacing: 0.12em; text-transform: uppercase; color: #10B981;
    }
    .hero-card-body { padding: 1.75rem; }
    .hero-card-ticker {
      font-family: var(--font-mono); font-size: 0.62rem;
      letter-spacing: 0.15em; color: var(--muted); text-transform: uppercase; margin-bottom: 0.5rem;
    }
    .hero-card-price {
      font-family: var(--font-mono); font-size: 2.4rem; font-weight: 700;
      color: var(--text); line-height: 1; margin-bottom: 0.6rem;
    }
    .hero-card-change {
      display: inline-flex; align-items: center; gap: 0.3rem;
      font-family: var(--font-mono); font-size: 0.78rem; font-weight: 700;
      color: #10B981; background: rgba(16,185,129,0.1);
      border: 1px solid rgba(16,185,129,0.25);
      padding: 0.3rem 0.75rem; border-radius: 100px; margin-bottom: 1.25rem;
    }
    .hero-card-metrics {
      display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;
    }
    .hero-metric {
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--border); border-radius: 8px; padding: 0.9rem;
    }
    .metric-lbl {
      font-size: 0.62rem; font-weight: 500; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 0.3rem;
    }
    .metric-val {
      font-family: var(--font-mono); font-size: 0.92rem; font-weight: 700; color: var(--text);
    }
    .metric-val.c { color: var(--cyan-g); }
    .metric-val.p { color: var(--primary-g); }

    /* ── TICKER ── */
    .ticker-wrap {
      position: relative; z-index: 1;
      background: rgba(7,5,15,0.85);
      border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
      overflow: hidden; padding: 0.8rem 0;
    }
    .ticker-track {
      display: flex; gap: 3rem; white-space: nowrap;
      animation: tickerScroll 28s linear infinite;
      width: max-content;
    }
    .ticker-item {
      font-family: var(--font-mono); font-size: 0.7rem;
      letter-spacing: 0.07em; color: var(--muted2);
      display: flex; align-items: center; gap: 0.55rem;
    }
    .t-name { color: var(--text); font-weight: 700; }
    .t-up   { color: #10B981; }
    .t-dn   { color: #EF4444; }
    .t-sep  { width: 4px; height: 4px; border-radius: 50%; background: var(--primary); opacity: 0.4; }

    /* ── LAYOUT ── */
    .container { position: relative; z-index: 1; max-width: 1280px; margin: 0 auto; padding: 0 4rem; }
    .section   { padding: 7rem 0; }

    .sec-eye {
      font-family: var(--font-mono); font-size: 0.67rem;
      letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--cyan); margin-bottom: 0.75rem;
    }
    .sec-h2 {
      font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 700;
      letter-spacing: -0.03em; line-height: 1.15; color: var(--text); margin-bottom: 1rem;
    }
    .sec-h2 .grad {
      background: linear-gradient(135deg, var(--primary-g), var(--cyan));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .sec-sub {
      font-size: 1rem; font-weight: 400; line-height: 1.78;
      color: var(--muted2); max-width: 56ch; margin-bottom: 4rem;
    }

    /* ── FEATURES ── */
    .feat-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 4rem;
    }
    .feat-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; padding: 2.25rem 2rem;
      position: relative; overflow: hidden;
      transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
    }
    .feat-card::after {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, var(--primary), transparent);
      opacity: 0; transition: opacity 0.3s;
    }
    .feat-card:hover { border-color: rgba(139,92,246,0.35); transform: translateY(-6px); box-shadow: 0 20px 60px rgba(139,92,246,0.15); }
    .feat-card:hover::after { opacity: 1; }
    .feat-icon {
      width: 46px; height: 46px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem; margin-bottom: 1.5rem;
    }
    .fi1 { background: rgba(139,92,246,0.14); }
    .fi2 { background: rgba(6,182,212,0.14); }
    .fi3 { background: rgba(245,158,11,0.14); }
    .fi4 { background: rgba(16,185,129,0.14); }
    .fi5 { background: rgba(236,72,153,0.14); }
    .fi6 { background: rgba(139,92,246,0.14); }
    .feat-num {
      font-family: var(--font-mono); font-size: 0.62rem;
      letter-spacing: 0.2em; color: var(--primary); margin-bottom: 0.55rem;
    }
    .feat-h3 { font-size: 1.1rem; font-weight: 600; color: var(--text); margin-bottom: 0.7rem; letter-spacing: -0.01em; }
    .feat-p  { font-size: 0.87rem; font-weight: 400; line-height: 1.72; color: var(--muted2); }

    .feat-banner {
      position: relative; height: 300px; border-radius: 12px; overflow: hidden;
      border: 1px solid var(--border);
    }
    .feat-banner img {
      width: 100%; height: 100%; object-fit: cover;
      filter: brightness(0.45) saturate(0.6) hue-rotate(200deg);
      transition: transform 0.6s ease;
    }
    .feat-banner:hover img { transform: scale(1.04); }
    .feat-banner-ov {
      position: absolute; inset: 0;
      background: linear-gradient(to right, rgba(7,5,15,0.9) 0%, transparent 55%);
    }
    .feat-banner-txt { position: absolute; left: 3rem; top: 50%; transform: translateY(-50%); }
    .feat-banner-lbl {
      font-family: var(--font-mono); font-size: 0.67rem; letter-spacing: 0.25em;
      text-transform: uppercase; color: var(--cyan); margin-bottom: 0.6rem;
    }
    .feat-banner-h { font-size: 2rem; font-weight: 700; letter-spacing: -0.02em; color: var(--text); line-height: 1.2; max-width: 16ch; }

    /* ── TOKENOMICS ── */
    .tok-section { background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .tok-layout  { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }

    .tok-ring { width: 280px; height: 280px; position: relative; margin: 0 auto 2rem; }
    .tok-ring svg { width: 100%; height: 100%; transform: rotate(-90deg); }
    .tok-ring-center {
      position: absolute; inset: 0;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
    }
    .ring-lbl  { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.25rem; }
    .ring-val  { font-family: var(--font-mono); font-size: 1.7rem; font-weight: 700; color: var(--text); }
    .ring-sub2 { font-size: 0.68rem; color: var(--muted); margin-top: 0.15rem; }

    .tok-legend { display: flex; flex-direction: column; gap: 1.1rem; }
    .leg-row    { display: flex; align-items: center; justify-content: space-between; }
    .leg-left   { display: flex; align-items: center; gap: 0.7rem; min-width: 200px; }
    .leg-dot    { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
    .leg-name   { font-size: 0.85rem; font-weight: 500; color: var(--muted2); }
    .leg-bar-w  { flex: 1; height: 3px; background: rgba(255,255,255,0.05); border-radius: 100px; overflow: hidden; margin: 0 1.5rem; }
    .leg-bar    { height: 100%; border-radius: 100px; }
    .leg-pct    { font-family: var(--font-mono); font-size: 0.78rem; font-weight: 700; color: var(--text); min-width: 3ch; text-align: right; }

    .tok-stats  { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; margin-bottom: 1.75rem; }
    .tok-stat   { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 1.2rem; }
    .tok-stat-lbl { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.45rem; }
    .tok-stat-val { font-family: var(--font-mono); font-size: 1.05rem; font-weight: 700; color: var(--text); }
    .tok-stat-val.c { color: var(--cyan-g); }
    .tok-stat-val.p { color: var(--primary-g); }

    /* ── ROADMAP ── */
    .rm-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: start; }

    .rm-track { position: relative; padding-left: 2.5rem; }
    .rm-track::before {
      content: ''; position: absolute; left: 0.5rem; top: 8px; bottom: 8px;
      width: 2px;
      background: linear-gradient(to bottom, var(--primary), var(--cyan), transparent);
    }
    .rm-item    { position: relative; padding-bottom: 2.75rem; }
    .rm-item:last-child { padding-bottom: 0; }
    .rm-dot     { position: absolute; left: -2rem; top: 6px; width: 14px; height: 14px; border-radius: 50%; border: 2px solid var(--border); background: var(--bg); }
    .rm-dot.done   { background: var(--primary); border-color: var(--primary); box-shadow: 0 0 12px var(--primary); }
    .rm-dot.active { background: var(--cyan); border-color: var(--cyan); box-shadow: 0 0 16px var(--cyan); animation: pulseDot 2s ease-in-out infinite; }
    .rm-q    { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.35rem; }
    .rm-h    { font-size: 1.15rem; font-weight: 600; color: var(--text); margin-bottom: 0.55rem; letter-spacing: -0.01em; }
    .rm-list { display: flex; flex-direction: column; gap: 0.35rem; }
    .rm-task { display: flex; align-items: center; gap: 0.55rem; font-size: 0.84rem; color: var(--muted2); }
    .rm-chk      { font-size: 0.7rem; flex-shrink: 0; color: var(--primary); }
    .rm-chk.cur  { color: var(--cyan); }
    .rm-chk.pend { color: var(--muted); }
    .rm-status {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 0.28rem 0.7rem; border-radius: 100px; margin-top: 0.7rem;
    }
    .rm-done { background: rgba(139,92,246,0.1); color: var(--primary-g); border: 1px solid rgba(139,92,246,0.25); }
    .rm-act  { background: rgba(6,182,212,0.1); color: var(--cyan-g); border: 1px solid rgba(6,182,212,0.25); }
    .rm-up   { background: rgba(255,255,255,0.04); color: var(--muted2); border: 1px solid var(--border); }

    .rm-photo { position: relative; height: 520px; border-radius: 12px; overflow: hidden; border: 1px solid var(--border); }
    .rm-photo img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.42) saturate(0.65) hue-rotate(200deg); transition: transform 0.6s ease; }
    .rm-photo:hover img { transform: scale(1.04); }
    .rm-photo-ov { position: absolute; inset: 0; background: linear-gradient(to top, rgba(7,5,15,0.8) 0%, transparent 50%), linear-gradient(to bottom, rgba(7,5,15,0.5) 0%, transparent 30%); }

    /* ── COMMUNITY ── */
    .comm-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .comm-photos {
      display: grid; grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto; gap: 1rem;
    }
    .comm-ph {
      position: relative; border-radius: 10px; overflow: hidden; border: 1px solid var(--border);
    }
    .comm-ph img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.58) saturate(0.7); transition: transform 0.6s ease, filter 0.4s; display: block; }
    .comm-ph:hover img { transform: scale(1.06); filter: brightness(0.75) saturate(0.85); }
    .comm-ph-ov { position: absolute; inset: 0; background: linear-gradient(to top, rgba(7,5,15,0.7) 0%, transparent 60%); }
    .comm-ph-wide { grid-column: 1 / -1; height: 210px; }
    .comm-ph-tall { height: 175px; }

    .comm-content { display: flex; flex-direction: column; gap: 2rem; }
    .comm-stat-list { display: flex; flex-direction: column; gap: 0.9rem; }
    .comm-stat {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.2rem 1.5rem; background: var(--surface);
      border: 1px solid var(--border); border-radius: 10px; transition: border-color 0.3s;
    }
    .comm-stat:hover { border-color: rgba(139,92,246,0.3); }
    .comm-stat-l { display: flex; align-items: center; gap: 0.9rem; }
    .comm-stat-icon { font-size: 1.2rem; }
    .comm-stat-lbl  { font-size: 0.85rem; font-weight: 500; color: var(--muted2); }
    .comm-stat-val  { font-family: var(--font-mono); font-size: 1.05rem; font-weight: 700; color: var(--text); }

    /* ── FOOTER ── */
    .footer { position: relative; z-index: 1; background: var(--bg2); border-top: 1px solid var(--border); padding: 4rem 0 2.5rem; }
    .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 4rem; margin-bottom: 3rem; }
    .footer-logo { font-family: var(--font-mono); font-size: 0.95rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text); margin-bottom: 0.9rem; }
    .footer-logo span { color: var(--cyan); }
    .footer-tag  { font-size: 0.85rem; font-weight: 400; line-height: 1.72; color: var(--muted); max-width: 32ch; margin-bottom: 1.25rem; }
    .footer-addr { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.07em; color: var(--muted); line-height: 1.9; }
    .footer-addr a { color: var(--cyan); text-decoration: none; }
    .footer-col-ttl { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem; }
    .footer-links { display: flex; flex-direction: column; gap: 0.55rem; list-style: none; }
    .footer-links a { font-size: 0.84rem; font-weight: 400; color: var(--muted2); text-decoration: none; transition: color 0.2s; }
    .footer-links a:hover { color: var(--text); }
    .footer-bottom { display: flex; align-items: center; justify-content: space-between; padding-top: 1.5rem; border-top: 1px solid var(--border); }
    .footer-copy { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.1em; color: var(--muted); }
    .footer-hash { font-family: var(--font-mono); font-size: 0.6rem; color: rgba(100,116,139,0.35); letter-spacing: 0.05em; }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .hero       { grid-template-columns: 1fr; padding: 7rem 3rem 4rem; gap: 3rem; }
      .hero-right { max-width: 480px; margin: 0 auto; }
      .tok-layout { grid-template-columns: 1fr; gap: 3rem; }
      .rm-layout  { grid-template-columns: 1fr; gap: 3rem; }
      .rm-photo   { height: 280px; }
      .comm-layout{ grid-template-columns: 1fr; gap: 3rem; }
      .footer-inner{ grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    }
    @media (max-width: 768px) {
      .nav        { padding: 0 1.5rem; }
      .nav-links  { display: none; }
      .hero       { padding: 6rem 1.5rem 3.5rem; }
      .hero-h1    { font-size: 2.6rem; }
      .hero-stats { gap: 1.5rem; }
      .container  { padding: 0 1.5rem; }
      .section    { padding: 5rem 0; }
      .feat-grid  { grid-template-columns: 1fr; }
      .tok-ring   { width: 220px; height: 220px; }
      .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
      .footer-bottom { flex-direction: column; gap: 0.6rem; align-items: flex-start; }
    }
  </style>
</head>
