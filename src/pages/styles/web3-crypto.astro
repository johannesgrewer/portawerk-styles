<script>
  // ===== INTERSECTION OBSERVER — CRYPTO-REVEAL WITH STAGGER =====
  (function initCryptoReveal() {
    const elements = document.querySelectorAll('.crypto-reveal');

    const observer = new IntersectionObserver((entries) => {
      // Sort by vertical position for natural top-to-bottom stagger
      const visible = entries.filter(e => e.isIntersecting);
      visible
        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)
        .forEach((entry, index) => {
          setTimeout(() => {
            entry.target.classList.add('visible');
          }, index * 100);
          observer.unobserve(entry.target);
        });
    }, {
      threshold: 0.12,
      rootMargin: '0px 0px -30px 0px'
    });

    elements.forEach(el => observer.observe(el));
  })();

  // ===== LIVE BLOCK HEIGHT COUNTER =====
  (function initBlockCounter() {
    const counterEl = document.getElementById('block-height-counter');
    if (!counterEl) return;

    let currentHeight = 19847321;

    function incrementBlock() {
      // Ethereum averages ~12s/block, simulate with occasional multi-block jumps
      const jump = Math.random() < 0.3 ? 2 : 1;
      currentHeight += jump;
      counterEl.textContent = currentHeight.toLocaleString('en-US').replace(/,/g, '_');

      // Flash color on update
      counterEl.classList.add('tick');
      setTimeout(() => counterEl.classList.remove('tick'), 300);
    }

    setInterval(incrementBlock, 2000);
  })();

  // ===== MATRIX RAIN CANVAS =====
  (function initMatrixRain() {
    const canvas = document.getElementById('matrix-canvas');
    if (!canvas) return;

    const ctx = canvas.getContext('2d');

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }
    resize();

    const chars = '01アイウエオカキクケコABCDEF0123456789<>{}[]|#';
    const fontSize = 10;
    const columns = Math.floor(canvas.width / fontSize);
    const drops = Array.from({ length: columns }, () => Math.random() * -50);

    function drawMatrix() {
      // Semi-transparent fade to create trail
      ctx.fillStyle = 'rgba(11, 7, 24, 0.08)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.font = `${fontSize}px "Space Mono", monospace`;

      drops.forEach((y, i) => {
        const char = chars[Math.floor(Math.random() * chars.length)];

        // Leading character is brighter (cyan), rest purple
        if (y * fontSize < canvas.height * 0.15) {
          ctx.fillStyle = '#22D3EE';
        } else {
          ctx.fillStyle = '#A855F7';
        }

        ctx.fillText(char, i * fontSize, y * fontSize);

        // Reset drop when it goes off screen, with random delay
        if (y * fontSize > canvas.height && Math.random() > 0.975) {
          drops[i] = 0;
        }
        drops[i] += 0.5;
      });
    }

    setInterval(drawMatrix, 50);
  })();
</script>

