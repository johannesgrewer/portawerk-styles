---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Chainforge — Blockchain Beratung, Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    html { overflow-x: hidden; }
    body { overflow-x: hidden; max-width: 100%; }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --primary: #A855F7;
      --secondary: #0F0B1E;
      --accent: #22D3EE;
      --bg: #0B0718;
      --bg-card: rgba(15, 11, 30, 0.6);
      --text: #E2E0F0;
      --text-muted: #8B85A8;
      --glow-purple: rgba(168, 85, 247, 0.5);
      --glow-cyan: rgba(34, 211, 238, 0.5);
      --font-display: "Space Mono", monospace;
      --font-body: "Inter Tight", sans-serif;
    }

    html {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      scroll-behavior: smooth;
    }

    body { overflow-x: hidden; }

    ::selection { background: var(--primary); color: var(--bg); }

    /* ═══════════════════════════════════════════
       CRYPTO-REVEAL ANIMATION
    ═══════════════════════════════════════════ */
    .crypto-reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s ease,
                  transform 0.7s ease,
                  box-shadow 0.7s ease;
    }

    .crypto-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Glow variant for cards on reveal */
    .crypto-reveal.glow-on-reveal.visible {
      box-shadow: 0 0 32px rgba(168, 85, 247, 0.15), 0 0 8px rgba(34, 211, 238, 0.08);
    }

    /* ═══════════════════════════════════════════
       MESH GRADIENT BACKGROUND
    ═══════════════════════════════════════════ */
    .mesh-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(ellipse 80% 60% at 20% 30%, rgba(168, 85, 247, 0.15) 0%, transparent 60%),
        radial-gradient(ellipse 60% 80% at 80% 70%, rgba(34, 211, 238, 0.1) 0%, transparent 60%),
        radial-gradient(ellipse 90% 50% at 50% 50%, rgba(168, 85, 247, 0.05) 0%, transparent 70%);
      animation: meshShift 12s ease-in-out infinite alternate;
    }

    @keyframes meshShift {
      0% {
        background:
          radial-gradient(ellipse 80% 60% at 20% 30%, rgba(168, 85, 247, 0.15) 0%, transparent 60%),
          radial-gradient(ellipse 60% 80% at 80% 70%, rgba(34, 211, 238, 0.1) 0%, transparent 60%),
          radial-gradient(ellipse 90% 50% at 50% 50%, rgba(168, 85, 247, 0.05) 0%, transparent 70%);
      }
      50% {
        background:
          radial-gradient(ellipse 70% 70% at 40% 60%, rgba(34, 211, 238, 0.12) 0%, transparent 60%),
          radial-gradient(ellipse 80% 60% at 60% 20%, rgba(168, 85, 247, 0.18) 0%, transparent 60%),
          radial-gradient(ellipse 60% 80% at 30% 80%, rgba(34, 211, 238, 0.08) 0%, transparent 70%);
      }
      100% {
        background:
          radial-gradient(ellipse 90% 50% at 70% 40%, rgba(168, 85, 247, 0.12) 0%, transparent 60%),
          radial-gradient(ellipse 50% 90% at 20% 60%, rgba(34, 211, 238, 0.15) 0%, transparent 60%),
          radial-gradient(ellipse 80% 60% at 60% 80%, rgba(168, 85, 247, 0.06) 0%, transparent 70%);
      }
    }

    /* ═══════════════════════════════════════════
       SCANLINE OVERLAY ON HERO
    ═══════════════════════════════════════════ */
    .hero-scanline {
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(168, 85, 247, 0.018) 3px,
        rgba(168, 85, 247, 0.018) 4px
      );
      pointer-events: none;
      z-index: 1;
      animation: scanlineScroll 8s linear infinite;
    }

    @keyframes scanlineScroll {
      0%   { background-position: 0 0; }
      100% { background-position: 0 400px; }
    }

    /* Subtle horizontal sweep gradient on hero */
    .hero-sweep {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        105deg,
        transparent 0%,
        rgba(168, 85, 247, 0.04) 30%,
        rgba(34, 211, 238, 0.04) 60%,
        transparent 100%
      );
      background-size: 200% 200%;
      pointer-events: none;
      z-index: 1;
      animation: sweepMove 6s ease-in-out infinite alternate;
    }

    @keyframes sweepMove {
      0%   { background-position: 0% 50%; }
      100% { background-position: 100% 50%; }
    }

    .content-wrapper {
      position: relative;
      z-index: 1;
    }

    /* ═══════════════════════════════════════════
       NAV
    ═══════════════════════════════════════════ */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.25rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(11, 7, 24, 0.8);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(168, 85, 247, 0.15);
    }

    .nav-logo {
      font-family: var(--font-display);
      font-size: 0.875rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text);
    }

    .nav-logo span {
      color: var(--accent);
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-family: var(--font-display);
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.3s;
    }

    .nav-links a:hover {
      color: var(--accent);
    }

    /* ═══════════════════════════════════════════
       HERO — TOKEN VISUALIZATION
    ═══════════════════════════════════════════ */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 6rem 2rem 4rem;
      position: relative;
      overflow: hidden;
    }

    /* Hex shape with glowing border */
    .hex-container {
      position: relative;
      width: 200px;
      height: 230px;
      margin-bottom: 3rem;
    }

    .hex-glow {
      position: absolute;
      inset: -4px;
      clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
      background: linear-gradient(135deg, var(--primary), var(--accent));
      animation: hexPulse 3s ease-in-out infinite;
    }

    @keyframes hexPulse {
      0%, 100% { opacity: 0.8; filter: blur(0px); }
      50% { opacity: 1; filter: blur(2px); }
    }

    .hex-inner {
      position: absolute;
      inset: 3px;
      clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
      background: var(--secondary);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hex-monogram {
      font-family: var(--font-display);
      font-size: 3.5rem;
      font-weight: 700;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Floating particles around hex */
    .hex-container::before,
    .hex-container::after {
      content: "";
      position: absolute;
      border-radius: 50%;
      animation: float 6s ease-in-out infinite;
    }

    .hex-container::before {
      width: 6px;
      height: 6px;
      background: var(--primary);
      top: -20px;
      right: -30px;
      box-shadow: 0 0 12px var(--glow-purple);
      animation-delay: 0s;
    }

    .hex-container::after {
      width: 4px;
      height: 4px;
      background: var(--accent);
      bottom: -15px;
      left: -25px;
      box-shadow: 0 0 10px var(--glow-cyan);
      animation-delay: -3s;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0) translateX(0); }
      25% { transform: translateY(-12px) translateX(8px); }
      50% { transform: translateY(-5px) translateX(-6px); }
      75% { transform: translateY(10px) translateX(4px); }
    }

    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 4vw, 2.5rem);
      font-weight: 700;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--text);
      text-align: center;
      margin-bottom: 1rem;
      position: relative;
      z-index: 2;
    }

    .hero-tagline {
      font-family: var(--font-body);
      font-size: 1.125rem;
      font-weight: 300;
      color: var(--text-muted);
      text-align: center;
      margin-bottom: 2.5rem;
      letter-spacing: 0.05em;
      position: relative;
      z-index: 2;
    }

    /* ═══════════════════════════════════════════
       BLOCK HEIGHT COUNTER
    ═══════════════════════════════════════════ */
    .block-height-display {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 2rem;
      padding: 0.6rem 1.25rem;
      border: 1px solid rgba(34, 211, 238, 0.25);
      border-radius: 4px;
      background: rgba(15, 11, 30, 0.6);
      position: relative;
      z-index: 2;
    }

    .block-height-label {
      font-family: var(--font-display);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .block-height-value {
      font-family: var(--font-display);
      font-size: 1rem;
      font-weight: 700;
      color: var(--accent);
      min-width: 7ch;
      text-align: right;
      transition: color 0.2s ease;
    }

    .block-height-value.tick {
      color: var(--primary);
    }

    .block-height-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--glow-cyan);
      animation: pulse-dot 2s ease-in-out infinite;
      flex-shrink: 0;
    }

    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.7); }
    }

    .hero-data {
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
      justify-content: center;
      margin-bottom: 3rem;
      position: relative;
      z-index: 2;
    }

    .data-point {
      font-family: var(--font-display);
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      padding: 0.5rem 1rem;
      border: 1px solid rgba(168, 85, 247, 0.2);
      border-radius: 2px;
      background: rgba(15, 11, 30, 0.5);
    }

    .data-point strong {
      color: var(--accent);
      font-weight: 700;
    }

    .cta-button {
      display: inline-block;
      font-family: var(--font-display);
      font-size: 0.875rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text);
      text-decoration: none;
      padding: 1rem 2.5rem;
      position: relative;
      background: transparent;
      border: none;
      cursor: pointer;
      transition: all 0.3s;
      z-index: 2;
    }

    .cta-button::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 4px;
      padding: 2px;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
    }

    .cta-button::after {
      content: "";
      position: absolute;
      inset: -4px;
      border-radius: 6px;
      background: linear-gradient(135deg, var(--glow-purple), var(--glow-cyan));
      filter: blur(12px);
      opacity: 0;
      transition: opacity 0.3s;
      z-index: -1;
    }

    .cta-button:hover::after {
      opacity: 0.6;
    }

    .cta-button:hover {
      color: #fff;
    }

    /* ═══════════════════════════════════════════
       SECTION SHARED
    ═══════════════════════════════════════════ */
    section {
      padding: 6rem 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .section-label {
      font-family: var(--font-display);
      font-size: 0.7rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(1.25rem, 3vw, 1.75rem);
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text);
      margin-bottom: 3rem;
    }

    /* ═══════════════════════════════════════════
       SERVICES — GLASS CARDS
    ═══════════════════════════════════════════ */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }

    .service-card {
      background: var(--bg-card);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(168, 85, 247, 0.1);
      border-radius: 4px;
      padding: 2rem 1.75rem;
      position: relative;
      overflow: hidden;
      transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
    }

    .service-card:hover {
      border-color: rgba(168, 85, 247, 0.4);
      transform: translateY(-4px);
      box-shadow: 0 8px 32px rgba(168, 85, 247, 0.2), 0 0 0 1px rgba(34, 211, 238, 0.08);
    }

    .service-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
    }

    .service-card:nth-child(1)::before {
      background: linear-gradient(90deg, var(--primary), transparent);
    }

    .service-card:nth-child(2)::before {
      background: linear-gradient(90deg, var(--accent), transparent);
    }

    .service-card:nth-child(3)::before {
      background: linear-gradient(90deg, var(--primary), var(--accent));
    }

    .service-label {
      font-family: var(--font-display);
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }

    .service-title {
      font-family: var(--font-display);
      font-size: 1.125rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.75rem;
      letter-spacing: 0.05em;
    }

    .service-desc {
      font-size: 0.9375rem;
      line-height: 1.6;
      color: var(--text-muted);
    }

    .services-note {
      font-family: var(--font-display);
      font-size: 0.75rem;
      color: var(--text-muted);
      letter-spacing: 0.1em;
      border-left: 2px solid var(--primary);
      padding-left: 1rem;
    }

    /* ═══════════════════════════════════════════
       TRACK RECORD — TERMINAL DISPLAY
    ═══════════════════════════════════════════ */
    .terminal {
      background: rgba(15, 11, 30, 0.8);
      border: 1px solid rgba(168, 85, 247, 0.2);
      border-radius: 4px;
      overflow: hidden;
      margin-bottom: 3rem;
    }

    .terminal-header {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.25rem;
      background: rgba(168, 85, 247, 0.08);
      border-bottom: 1px solid rgba(168, 85, 247, 0.15);
    }

    .terminal-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }

    .terminal-dot:nth-child(1) { background: #ff5f57; }
    .terminal-dot:nth-child(2) { background: #ffbd2e; }
    .terminal-dot:nth-child(3) { background: #28c840; }

    .terminal-title {
      font-family: var(--font-display);
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      color: var(--text-muted);
      margin-left: 0.75rem;
      text-transform: uppercase;
    }

    .terminal-body {
      padding: 1.5rem;
    }

    .block-entry {
      font-family: var(--font-display);
      font-size: 0.8125rem;
      line-height: 2.2;
      color: var(--text-muted);
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(168, 85, 247, 0.08);
    }

    .block-entry:last-child {
      border-bottom: none;
    }

    .block-hash {
      color: var(--primary);
      font-weight: 700;
    }

    .block-name {
      color: var(--text);
    }

    .block-chain {
      color: var(--accent);
    }

    .block-status {
      display: inline-block;
      font-size: 0.6875rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.2rem 0.6rem;
      border-radius: 2px;
      margin-left: 0.5rem;
    }

    .status-confirmed {
      background: rgba(34, 211, 238, 0.1);
      color: var(--accent);
      border: 1px solid rgba(34, 211, 238, 0.3);
    }

    .status-deployed {
      background: rgba(168, 85, 247, 0.1);
      color: var(--primary);
      border: 1px solid rgba(168, 85, 247, 0.3);
    }

    /* Founder */
    .founder {
      display: flex;
      align-items: flex-start;
      gap: 2rem;
      padding: 2rem;
      background: var(--bg-card);
      border: 1px solid rgba(168, 85, 247, 0.1);
      border-radius: 4px;
      transition: border-color 0.3s, box-shadow 0.3s;
    }

    .founder:hover {
      border-color: rgba(168, 85, 247, 0.3);
      box-shadow: 0 4px 24px rgba(168, 85, 247, 0.12);
    }

    .founder-avatar {
      width: 72px;
      height: 72px;
      clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
      background: linear-gradient(135deg, var(--primary), var(--accent));
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .founder-avatar-inner {
      width: calc(100% - 4px);
      height: calc(100% - 4px);
      clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
      background: var(--secondary);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .founder-initials {
      font-family: var(--font-display);
      font-size: 1.125rem;
      font-weight: 700;
      color: var(--primary);
    }

    .founder-name {
      font-family: var(--font-display);
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.25rem;
      letter-spacing: 0.05em;
    }

    .founder-role {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }

    .founder-contact {
      font-family: var(--font-display);
      font-size: 0.75rem;
      color: var(--text-muted);
      letter-spacing: 0.05em;
      line-height: 1.8;
    }

    .founder-contact a {
      color: var(--accent);
      text-decoration: none;
      transition: color 0.3s;
    }

    .founder-contact a:hover {
      color: var(--primary);
    }

    .pgp-note {
      font-family: var(--font-display);
      font-size: 0.6875rem;
      color: var(--text-muted);
      letter-spacing: 0.1em;
      opacity: 0.6;
      margin-top: 0.5rem;
    }

    /* ═══════════════════════════════════════════
       MATRIX CANVAS
    ═══════════════════════════════════════════ */
    #matrix-canvas {
      position: fixed;
      bottom: 0;
      right: 0;
      width: 180px;
      height: 240px;
      opacity: 0.18;
      pointer-events: none;
      z-index: 0;
      mask-image: linear-gradient(to top left, rgba(0,0,0,0.8) 0%, transparent 70%);
      -webkit-mask-image: linear-gradient(to top left, rgba(0,0,0,0.8) 0%, transparent 70%);
    }

    /* ═══════════════════════════════════════════
       FOOTER
    ═══════════════════════════════════════════ */
    .footer {
      text-align: center;
      padding: 3rem 2rem;
      border-top: 1px solid rgba(168, 85, 247, 0.1);
    }

    .footer-text {
      font-family: var(--font-display);
      font-size: 0.6875rem;
      letter-spacing: 0.2em;
      color: var(--text-muted);
      text-transform: uppercase;
    }

    .footer-hash {
      font-family: var(--font-display);
      font-size: 0.625rem;
      color: rgba(139, 133, 168, 0.4);
      letter-spacing: 0.05em;
      margin-top: 0.5rem;
    }

    /* ═══════════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════════ */
    @media (max-width: 768px) {
      .nav {
        padding: 1rem 1.25rem;
      }

      .nav-links {
        display: none;
      }

      .hero {
        padding: 5rem 1.5rem 3rem;
      }

      .hex-container {
        width: 150px;
        height: 173px;
        margin-bottom: 2rem;
      }

      .hex-monogram {
        font-size: 2.5rem;
      }

      .hero-data {
        gap: 0.75rem;
      }

      .data-point {
        font-size: 0.6875rem;
        padding: 0.4rem 0.75rem;
      }

      section {
        padding: 4rem 1.5rem;
      }

      .services-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .terminal-body {
        padding: 1rem;
      }

      .block-entry {
        font-size: 0.75rem;
        line-height: 1.8;
      }

      .block-status {
        display: block;
        margin-left: 0;
        margin-top: 0.25rem;
        width: fit-content;
      }

      .founder {
        flex-direction: column;
        align-items: center;
