---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Studio Haarwerk — Friseursalon Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@300;400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black:   #1A1A1A;
      --dark:    #111;
      --gold:    #D4A853;
      --gold-l:  #E8C97A;
      --off:     #F9F9F7;
      --warm:    #F3F2EE;
      --muted:   #888;
      --border:  #E4E4E0;
      --ff-disp: 'Unbounded', sans-serif;
      --ff-body: 'DM Sans', sans-serif;
    }

    html, body {
      background: var(--off);
      color: var(--black);
      font-family: var(--ff-body);
      font-size: 16px;
      line-height: 1.6;
    }

    /* ── NAV ── */
    nav {
      background: var(--black);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 3rem;
      height: 60px;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-logo {
      font-family: var(--ff-disp);
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: #fff;
      text-decoration: none;
    }

    .nav-logo span {
      color: var(--gold);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.45);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--gold); }

    .nav-cta {
      background: var(--gold);
      color: var(--black) !important;
      padding: 0.45rem 1.4rem;
      border-radius: 2px;
      font-weight: 600 !important;
      transition: background 0.2s !important;
    }
    .nav-cta:hover { background: var(--gold-l) !important; }

    /* ── HERO ── */
    .hero {
      min-height: 540px;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
    }

    .hero-left {
      background: var(--black);
      padding: 5rem 3rem 5rem 3rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    /* Hero background photo */
    .hero-left-photo {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .hero-left-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      filter: brightness(0.35);
    }
    .hero-left > *:not(.hero-left-photo) {
      position: relative;
      z-index: 1;
    }

    /* Gold accent line */
    .hero-left::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 3px;
      height: 100%;
      background: linear-gradient(180deg, transparent, var(--gold), transparent);
      animation: lineGlow 3s ease-in-out infinite;
    }

    @keyframes lineGlow {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 1; }
    }

    .hero-tag {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 2rem;
    }

    .hero-headline {
      font-family: var(--ff-disp);
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 700;
      line-height: 1.1;
      color: #fff;
      margin-bottom: 1.5rem;
      letter-spacing: -0.01em;
    }

    .hero-headline .accent { color: var(--gold); }

    .hero-desc {
      font-size: 0.875rem;
      font-weight: 300;
      color: rgba(255,255,255,0.5);
      max-width: 360px;
      line-height: 1.8;
      margin-bottom: 3rem;
    }

    .hero-ctas {
      display: flex;
      gap: 1rem;
      align-items: center;
    }

    .btn-gold {
      background: var(--gold);
      color: var(--black);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.8rem 2rem;
      border-radius: 2px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-gold:hover { background: var(--gold-l); transform: translateY(-1px); }

    .btn-ghost {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.4);
      text-decoration: none;
      border-bottom: 1px solid rgba(255,255,255,0.15);
      padding-bottom: 2px;
      transition: color 0.2s;
    }
    .btn-ghost:hover { color: #fff; }

    /* Right panel — availability */
    .hero-right {
      background: var(--warm);
      padding: 3rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .avail-title {
      font-family: var(--ff-disp);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }

    .avail-day {
      display: grid;
      grid-template-columns: 6rem 1fr auto;
      align-items: center;
      gap: 1rem;
      padding: 0.875rem 0;
      border-bottom: 1px solid var(--border);
    }
    .avail-day:last-child { border-bottom: none; }

    .day-name {
      font-family: var(--ff-disp);
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--black);
    }

    .day-slots {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }

    .slot {
      font-size: 0.65rem;
      font-weight: 500;
      padding: 0.2rem 0.5rem;
      border-radius: 2px;
      border: 1px solid var(--border);
      color: var(--muted);
      background: #fff;
    }

    .slot.free {
      border-color: var(--gold);
      color: var(--black);
      background: rgba(212,168,83,0.08);
    }

    .slot.busy {
      opacity: 0.3;
      text-decoration: line-through;
    }

    .day-status {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .st-free { color: #22C55E; }
    .st-busy { color: var(--muted); }

    .book-cta {
      margin-top: 1.5rem;
      background: var(--black);
      color: #fff;
      font-family: var(--ff-disp);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.9rem 1.5rem;
      border-radius: 2px;
      text-decoration: none;
      text-align: center;
      transition: background 0.2s;
    }
    .book-cta:hover { background: #333; }

    /* ── SERVICES ── */
    .services-section {
      background: var(--off);
      padding: 5rem 3rem;
    }

    .section-header {
      margin-bottom: 3rem;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
    }

    .section-eyebrow {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.5rem;
    }

    .section-title {
      font-family: var(--ff-disp);
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 700;
      color: var(--black);
      letter-spacing: -0.01em;
      line-height: 1.1;
    }

    .service-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }

    .service-item {
      background: #fff;
      padding: 1.75rem;
      transition: background 0.2s;
    }
    .service-item:hover { background: var(--warm); }
    .service-item:hover .service-name { color: var(--gold); }

    .service-cat {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.75rem;
    }

    .service-name {
      font-family: var(--ff-disp);
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--black);
      margin-bottom: 0.5rem;
      letter-spacing: -0.01em;
      transition: color 0.2s;
    }

    .service-desc {
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    .service-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .service-price {
      font-family: var(--ff-disp);
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--black);
    }

    .service-time {
      font-size: 0.65rem;
      color: var(--muted);
    }

    /* ── TEAM ── */
    .team-section {
      background: var(--black);
      padding: 5rem 3rem;
    }

    .team-header {
      margin-bottom: 3rem;
    }

    .team-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }

    .team-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 4px;
      padding: 1.5rem;
      transition: border-color 0.2s, background 0.2s, transform 0.2s;
    }
    .team-card:hover {
      border-color: rgba(212,168,83,0.4);
      background: rgba(212,168,83,0.05);
      transform: translateY(-2px);
    }

    .team-avatar {
      width: 56px;
      height: 56px;
      background: linear-gradient(135deg, rgba(212,168,83,0.3), rgba(212,168,83,0.1));
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--ff-disp);
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .team-name {
      font-family: var(--ff-disp);
      font-size: 0.8rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: 0.02em;
      margin-bottom: 0.25rem;
    }

    .team-role {
      font-size: 0.7rem;
      color: var(--gold);
      font-weight: 500;
      margin-bottom: 0.75rem;
    }

    .team-spec {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.4);
      line-height: 1.6;
    }

    /* ── TEAM PHOTO AVATAR ── */
    .team-avatar-photo {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      overflow: hidden;
      margin-bottom: 1rem;
      border: 2px solid rgba(212,168,83,0.3);
      flex-shrink: 0;
    }
    .team-avatar-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
    }

    /* ── FOTOGRID DIVIDER ── */
    .foto-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      background: var(--black);
    }
    .foto-grid-item {
      position: relative;
      overflow: hidden;
      height: 280px;
    }
    .foto-grid-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.55s ease;
      filter: brightness(0.8);
    }
    .foto-grid-item:hover img {
      transform: scale(1.05);
      filter: brightness(0.95);
    }
    .foto-grid-item-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(26,26,26,0.6) 0%, transparent 50%);
    }

    /* ── ANIMATIONS ── */
    /* Service items lift on hover */
    .service-item { transition: background 0.2s, transform 0.2s; }
    .service-item:hover { transform: translateY(-3px); }

    /* Gold line accent pulses on hero */
    @keyframes linePulse {
      0%, 100% { opacity: 0.4; height: 100%; }
      50%       { opacity: 1;   height: 60%; }
    }
    .hero-left::before { animation: linePulse 3s ease-in-out infinite; }

    /* Availability slots appear on hover */
    .slot.free {
      transition: background 0.2s, border-color 0.2s, transform 0.15s;
    }
    .slot.free:hover {
      transform: scale(1.08);
      background: rgba(212,168,83,0.18);
    }

    /* Team cards pop on hover */
    .team-card { transition: border-color 0.2s, background 0.2s, transform 0.2s, box-shadow 0.2s; }
    .team-card:hover { box-shadow: 0 8px 32px rgba(212,168,83,0.12); }

    /* Avatar ring pulse when card is hovered */
    .team-card:hover .team-avatar {
      box-shadow: 0 0 0 3px rgba(212,168,83,0.3);
      transition: box-shadow 0.2s;
    }

    /* Book CTA shimmer */
    @keyframes bookShimmer {
      0%   { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
    .book-cta {
      position: relative;
      overflow: hidden;
    }
    .book-cta::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.08) 50%, transparent 60%);
      background-size: 200% auto;
      animation: bookShimmer 3s linear infinite;
      pointer-events: none;
    }

    /* ── FOOTER ── */
    footer {
      background: var(--dark);
      border-top: 1px solid rgba(255,255,255,0.05);
      padding: 2rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-logo {
      font-family: var(--ff-disp);
      font-size: 0.8rem;
      font-weight: 700;
      color: #fff;
    }
    .footer-logo span { color: var(--gold); }

    .footer-info {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.3);
    }
  </style>
</head>
<body>

  <nav>
    <a class="nav-logo" href="#">STUDIO <span>HAARWERK</span></a>
    <ul class="nav-links">
      <li><a href="#">Leistungen</a></li>
      <li><a href="#">Team</a></li>
      <li><a href="#">Galerie</a></li>
      <li><a href="#">Preise</a></li>
      <li><a class="nav-cta" href="#">Termin buchen</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <div class="hero-left-photo">
        <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?auto=format&fit=crop&w=900&h=600&q=80"
             alt="Friseursalon Atmosphäre" loading="eager" />
      </div>
      <p class="hero-tag">Friseursalon · Trier-Mitte · Seit 2015</p>
      <h1 class="hero-headline">
        Dein Stil.<br>
        Dein <span class="accent">Ausdruck.</span>
      </h1>
      <p class="hero-desc">Wir hören zu, bevor wir schneiden. Moderne Schnitte, präzise Farbtechniken und Beratung, die ehrlich ist — nicht nur nett.</p>
      <div class="hero-ctas">
        <a class="btn-gold" href="#">Jetzt buchen</a>
        <a class="btn-ghost" href="#">Unsere Leistungen</a>
      </div>
    </div>

    <div class="hero-right">
      <p class="avail-title">Freie Termine diese Woche</p>

      <div class="avail-day">
        <span class="day-name">Di 25.03.</span>
        <div class="day-slots">
          <span class="slot busy">09:00</span>
          <span class="slot free">11:30</span>
          <span class="slot free">14:00</span>
          <span class="slot busy">16:30</span>
        </div>
        <span class="day-status st-free">2 frei</span>
      </div>

      <div class="avail-day">
        <span class="day-name">Mi 26.03.</span>
        <div class="day-slots">
          <span class="slot free">09:00</span>
          <span class="slot free">10:30</span>
          <span class="slot busy">12:00</span>
          <span class="slot free">15:30</span>
        </div>
        <span class="day-status st-free">3 frei</span>
      </div>

      <div class="avail-day">
        <span class="day-name">Do 27.03.</span>
        <div class="day-slots">
          <span class="slot busy">09:00</span>
          <span class="slot busy">11:00</span>
          <span class="slot busy">13:30</span>
          <span class="slot busy">16:00</span>
        </div>
        <span class="day-status st-busy">ausgebucht</span>
      </div>

      <div class="avail-day">
        <span class="day-name">Fr 28.03.</span>
        <div class="day-slots">
          <span class="slot free">09:30</span>
          <span class="slot free">11:30</span>
          <span class="slot free">14:00</span>
          <span class="slot free">16:00</span>
        </div>
        <span class="day-status st-free">4 frei</span>
      </div>

      <a class="book-cta" href="#">Termin online buchen</a>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services-section">
    <div class="section-header">
      <div>
        <p class="section-eyebrow">Preisliste</p>
        <h2 class="section-title">Unsere<br>Leistungen</h2>
      </div>
    </div>

    <div class="service-grid">
      <div class="service-item">
        <div class="service-cat">Schnitt</div>
        <div class="service-name">Damenschnitt inkl. Styling</div>
        <p class="service-desc">Waschen, Schneiden, Föhnen. Beratung inklusive.</p>
        <div class="service-meta">
          <span class="service-price">ab € 55</span>
          <span class="service-time">60–90 min</span>
        </div>
      </div>

      <div class="service-item">
        <div class="service-cat">Schnitt</div>
        <div class="service-name">Herrenschnitt</div>
        <p class="service-desc">Klassisch oder modern — Schneiden und Styling nach deinen Wünschen.</p>
        <div class="service-meta">
          <span class="service-price">ab € 38</span>
          <span class="service-time">45–60 min</span>
        </div>
      </div>

      <div class="service-item">
        <div class="service-cat">Farbe</div>
        <div class="service-name">Balayage / Highlights</div>
        <p class="service-desc">Natürlicher Farbübergang, handgemalt. Aufhellungsgrad nach Absprache.</p>
        <div class="service-meta">
          <span class="service-price">ab € 120</span>
          <span class="service-time">2–3 h</span>
        </div>
      </div>

      <div class="service-item">
        <div class="service-cat">Farbe</div>
        <div class="service-name">Vollcoloration</div>
        <p class="service-desc">Kompletteinfärbung mit Ammoniakfreien Farben auf Wunsch.</p>
        <div class="service-meta">
          <span class="service-price">ab € 75</span>
          <span class="service-time">90–120 min</span>
        </div>
      </div>

      <div class="service-item">
        <div class="service-cat">Pflege</div>
        <div class="service-name">Olaplex Behandlung</div>
        <p class="service-desc">Tiefenwirksame Haarpflege für beschädigtes oder gefärbtes Haar.</p>
        <div class="service-meta">
          <span class="service-price">€ 45</span>
          <span class="service-time">45 min</span>
        </div>
      </div>

      <div class="service-item">
        <div class="service-cat">Braut</div>
        <div class="service-name">Brautfrisur</div>
        <p class="service-desc">Probetermin + Hochzeitstagstermin. Inklusive Beratung und Probeschmuck-Anpassung.</p>
        <div class="service-meta">
          <span class="service-price">ab € 180</span>
          <span class="service-time">2 Termine</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FOTOGRID DIVIDER -->
  <div class="foto-grid">
    <div class="foto-grid-item">
      <img src="https://images.unsplash.com/photo-1560066984-138dadb4c035?auto=format&fit=crop&w=600&h=280&q=80"
           alt="Haarstyling im Salon" loading="lazy" />
      <div class="foto-grid-item-overlay"></div>
    </div>
    <div class="foto-grid-item">
      <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=600&h=280&q=80"
           alt="Colorationsarbeiten" loading="lazy" />
      <div class="foto-grid-item-overlay"></div>
    </div>
    <div class="foto-grid-item">
      <img src="https://images.unsplash.com/photo-1503951914875-452162b0f3f1?auto=format&fit=crop&w=600&h=280&q=80"
           alt="Professionelles Styling" loading="lazy" />
      <div class="foto-grid-item-overlay"></div>
    </div>
  </div>

  <!-- TEAM -->
  <section class="team-section">
    <div class="team-header">
      <p class="section-eyebrow" style="color:var(--gold);font-size:.65rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;margin-bottom:.5rem;">Das Team</p>
      <h2 style="font-family:var(--ff-disp);font-size:clamp(1.4rem,2.5vw,2rem);font-weight:700;color:#fff;letter-spacing:-.01em;">Vier Köpfe,<br>ein Anspruch.</h2>
    </div>

    <div class="team-grid">
      <div class="team-card">
        <div class="team-avatar-photo">
          <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=200&h=200&q=80" alt="Mia Haarwerk" loading="lazy" />
        </div>
        <div class="team-name">MIA HAARWERK</div>
        <div class="team-role">Inhaberin & Stylistin</div>
        <p class="team-spec">Colorationen, Schnitte, Balayage. 12 Jahre Erfahrung.</p>
      </div>
