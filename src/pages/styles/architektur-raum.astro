---
export const prerender = true;
---

<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Volumen Architekten — Trier</title>
  <meta name="description" content="Volumen Architekten. Architekturbuero in Trier. Form folgt Haltung. Seit 2014." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg:        #F8F7F4;
      --bg-alt:    #F2F1EE;
      --bg-dark:   #0C0C0A;
      --ink:       #0C0C0A;
      --ink-mid:   #5E5E58;
      --ink-light: #ADADAA;
      --rule:      rgba(12,12,10,0.09);
      --rule-faint:rgba(12,12,10,0.05);
      --accent:    #1B3FFF;
      --font-d:    'Syne', sans-serif;
      --font-b:    'DM Sans', sans-serif;
    }

    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; overflow-x:hidden; }
    body { font-family:var(--font-b); background:var(--bg); color:var(--ink); line-height:1.6; overflow-x:hidden; }
    a { text-decoration:none; color:inherit; }
    img { display:block; max-width:100%; }

    /* ===== NAV ===== */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 52px;
      height: 58px;
      background: rgba(248,247,244,0.9);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--rule);
    }

    .nav-logo {
      font-family: var(--font-d);
      font-weight: 800;
      font-size: 14px;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--ink);
    }

    .nav-links {
      display: flex;
      gap: 44px;
      list-style: none;
    }

    .nav-links li a {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-mid);
      transition: color 0.22s;
    }

    .nav-links li a:hover { color: var(--ink); }

    .nav-coord {
      font-size: 11px;
      font-weight: 300;
      color: var(--ink-light);
      letter-spacing: 0.06em;
    }

    /* ===== HERO ===== */
    .hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 100vh;
      padding-top: 58px;
      position: relative;
      overflow: hidden;
    }

    /* Blueprint grid — fades in */
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(var(--rule-faint) 1px, transparent 1px),
        linear-gradient(90deg, var(--rule-faint) 1px, transparent 1px);
      background-size: 52px 52px;
      pointer-events: none;
      opacity: 0;
      animation: gridFadeIn 1.6s ease 0.3s forwards;
    }

    @keyframes gridFadeIn { to { opacity: 1; } }

    /* Left — text */
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 88px 68px 88px 68px;
      position: relative;
      z-index: 1;
    }

    .hero-eyebrow {
      display: flex;
      align-items: center;
      gap: 14px;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--ink-light);
      margin-bottom: 44px;
      opacity: 0;
      animation: fadeUp 0.65s ease 0.5s forwards;
    }

    .hero-eyebrow::before {
      content: '';
      display: block;
      width: 28px;
      height: 1px;
      background: currentColor;
      flex-shrink: 0;
    }

    .hero-h1 {
      font-family: var(--font-d);
      font-size: clamp(46px, 5.8vw, 86px);
      font-weight: 700;
      line-height: 1.06;
      letter-spacing: -0.028em;
      color: var(--ink);
      margin-bottom: 36px;
      opacity: 0;
      animation: fadeUp 0.75s ease 0.7s forwards;
    }

    .hero-h1 em {
      font-style: normal;
      color: var(--ink-light);
    }

    .hero-desc {
      font-size: 16px;
      font-weight: 300;
      color: var(--ink-mid);
      line-height: 1.68;
      max-width: 340px;
      margin-bottom: 52px;
      opacity: 0;
      animation: fadeUp 0.7s ease 0.9s forwards;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 28px;
      opacity: 0;
      animation: fadeUp 0.65s ease 1.05s forwards;
    }

    .btn-filled {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-d);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--ink);
      padding: 15px 30px;
      transition: background 0.24s, transform 0.24s;
    }

    .btn-filled:hover {
      background: var(--accent);
      transform: translateY(-2px);
    }

    .btn-ghost {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-mid);
      display: flex;
      align-items: center;
      gap: 8px;
      transition: color 0.22s, gap 0.22s;
    }

    .btn-ghost:hover { color: var(--ink); gap: 14px; }

    /* Mini stats at bottom of left panel */
    .hero-stats {
      position: absolute;
      bottom: 48px;
      left: 68px;
      display: flex;
      gap: 40px;
      opacity: 0;
      animation: fadeUp 0.65s ease 1.2s forwards;
    }

    .h-stat { display: flex; flex-direction: column; gap: 3px; }

    .h-stat-n {
      font-family: var(--font-d);
      font-size: 20px;
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -0.02em;
      line-height: 1;
    }

    .h-stat-l {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-light);
    }

    @keyframes fadeUp {
      from { opacity:0; transform:translateY(18px); }
      to   { opacity:1; transform:translateY(0); }
    }

    /* Right — photo */
    .hero-right {
      position: relative;
      overflow: hidden;
    }

    .hero-photo {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(0.4) contrast(1.1);
      transform: scale(1.06);
      clip-path: inset(0 100% 0 0);
      animation: photoReveal 1.3s cubic-bezier(0.77,0,0.18,1) 0.25s forwards;
    }

    @keyframes photoReveal {
      to { clip-path: inset(0 0% 0 0); transform: scale(1.0); }
    }

    /* Blueprint corner markers */
    .photo-frame {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 2;
    }

    .ph-corner {
      position: absolute;
      width: 20px;
      height: 20px;
    }

    .ph-corner--tl { top:22px; left:22px; border-top:1.5px solid rgba(255,255,255,0.42); border-left:1.5px solid rgba(255,255,255,0.42); }
    .ph-corner--tr { top:22px; right:22px; border-top:1.5px solid rgba(255,255,255,0.42); border-right:1.5px solid rgba(255,255,255,0.42); }
    .ph-corner--bl { bottom:22px; left:22px; border-bottom:1.5px solid rgba(255,255,255,0.42); border-left:1.5px solid rgba(255,255,255,0.42); }
    .ph-corner--br { bottom:22px; right:22px; border-bottom:1.5px solid rgba(255,255,255,0.42); border-right:1.5px solid rgba(255,255,255,0.42); }

    .ph-ref {
      position: absolute;
      top: 30px;
      left: 30px;
      font-size: 10px;
      font-weight: 300;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.38);
    }

    .ph-loc {
      position: absolute;
      bottom: 30px;
      right: 30px;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }

    /* Vertical measuring line on photo */
    .ph-vline {
      position: absolute;
      top: 56px;
      bottom: 56px;
      right: 72px;
      width: 1px;
      background: rgba(255,255,255,0.12);
    }

    .ph-vline::before,
    .ph-vline::after {
      content: '';
      position: absolute;
      left: -4px;
      width: 9px;
      height: 1px;
      background: rgba(255,255,255,0.25);
    }
    .ph-vline::before { top: 0; }
    .ph-vline::after { bottom: 0; }

    /* Scroll hint */
    .scroll-hint {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      opacity: 0;
      animation: fadeUp 0.6s ease 1.5s forwards;
      z-index: 3;
      pointer-events: none;
    }

    .scroll-hint span {
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
    }

    .scroll-arrow {
      width: 1px;
      height: 32px;
      background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
      animation: scrollPulse 1.8s ease-in-out 2s infinite;
    }

    @keyframes scrollPulse {
      0%, 100% { opacity: 0.4; transform: scaleY(1); }
      50% { opacity: 1; transform: scaleY(1.15); }
    }

    /* ===== METRICS STRIP ===== */
    .metrics-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
    }

    .metric {
      display: flex;
      align-items: center;
      gap: 18px;
      padding: 28px 44px;
      border-right: 1px solid var(--rule);
    }

    .metric:last-child { border-right: none; }

    .metric-n {
      font-family: var(--font-d);
      font-size: clamp(26px, 2.8vw, 38px);
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -0.03em;
      line-height: 1;
    }

    .metric-l {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-light);
      line-height: 1.5;
    }

    /* ===== SHARED SECTION HEADER ===== */
    .sec-header {
      display: flex;
      align-items: baseline;
      gap: 18px;
      padding-bottom: 22px;
      border-bottom: 1px solid var(--rule);
      margin-bottom: 56px;
    }

    .sec-num {
      font-family: var(--font-d);
      font-size: 11px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.2em;
    }

    .sec-title {
      font-family: var(--font-d);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--ink-mid);
    }

    .sec-aside {
      margin-left: auto;
      font-size: 11px;
      font-weight: 300;
      color: var(--ink-light);
      letter-spacing: 0.05em;
    }

    .sec-wrap {
      padding: 100px 64px;
      max-width: 1600px;
      margin: 0 auto;
    }

    /* ===== PROJECTS GRID ===== */
    .proj-grid {
      display: grid;
      grid-template-columns: 1.45fr 1fr;
      grid-template-rows: 330px 330px;
      gap: 3px;
      background: var(--rule);
    }

    .proj-card {
      position: relative;
      overflow: hidden;
      background: var(--bg-alt);
    }

    .proj-card--featured { grid-row: 1 / 3; }

    .proj-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(0.5) contrast(1.06);
      transition: filter 0.5s ease, transform 0.6s cubic-bezier(0.4,0,0.2,1);
    }

    .proj-card:hover .proj-img {
      filter: saturate(0.78) contrast(1.05);
      transform: scale(1.04);
    }

    .proj-scrim {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(12,12,10,0.72) 0%, rgba(12,12,10,0.1) 45%, transparent 65%);
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .proj-card:hover .proj-scrim { opacity: 1; }

    .proj-meta-box {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 26px 30px;
      transform: translateY(10px);
      opacity: 0;
      transition: all 0.38s cubic-bezier(0.4,0,0.2,1);
    }

    .proj-card:hover .proj-meta-box {
      transform: translateY(0);
      opacity: 1;
    }

    .proj-card-name {
      font-family: var(--font-d);
      font-size: 15px;
      font-weight: 700;
      color: #F8F7F4;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      margin-bottom: 5px;
    }

    .proj-card-detail {
      font-size: 11px;
      color: rgba(248,247,244,0.6);
      letter-spacing: 0.1em;
    }

    /* Always-visible tag */
    .proj-tag {
      position: absolute;
      top: 18px;
      left: 18px;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(248,247,244,0.55);
      background: rgba(12,12,10,0.28);
      backdrop-filter: blur(6px);
      padding: 5px 10px;
    }

    /* ===== PHILOSOPHIE — DARK ===== */
    .phil-section {
      background: var(--bg-dark);
      color: #F8F7F4;
    }

    .phil-wrap {
      padding: 100px 64px;
      max-width: 1600px;
      margin: 0 auto;
    }

    .phil-section .sec-header {
      border-bottom-color: rgba(248,247,244,0.10);
    }

    .phil-section .sec-num { color: var(--accent); }
    .phil-section .sec-title { color: rgba(248,247,244,0.42); }
    .phil-section .sec-aside { color: rgba(248,247,244,0.22); }

    .phil-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 88px;
      align-items: start;
    }

    .phil-statement {
      font-family: var(--font-d);
      font-size: clamp(28px, 3vw, 44px);
      font-weight: 600;
      line-height: 1.28;
      letter-spacing: -0.022em;
      color: #F8F7F4;
    }

    .phil-statement em {
      font-style: normal;
      color: rgba(248,247,244,0.35);
    }

    .phil-sub {
      margin-top: 32px;
      font-size: 15px;
      font-weight: 300;
      color: rgba(248,247,244,0.52);
      line-height: 1.7;
      max-width: 380px;
    }

    .principles {
      list-style: none;
      margin-top: 4px;
    }

    .principle {
      display: grid;
      grid-template-columns: 30px 1fr;
      gap: 18px;
      padding: 22px 0;
      border-bottom: 1px solid rgba(248,247,244,0.07);
    }

    .principle:first-child { border-top: 1px solid rgba(248,247,244,0.07); }

    .pr-num {
      font-family: var(--font-d);
      font-size: 10px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.12em;
      padding-top: 3px;
    }

    .pr-body { color: rgba(248,247,244,0.72); font-size: 14px; line-height: 1.62; }
    .pr-body strong { display: block; color: #F8F7F4; font-weight: 500; font-size: 15px; margin-bottom: 3px; }

    /* ===== TEAM ===== */
    .team-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3px;
      background: var(--rule);
    }

    .team-card {
      background: var(--bg);
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 0;
      overflow: hidden;
    }

    .team-photo-col {
      position: relative;
      overflow: hidden;
    }

    .team-photo {
      width: 100%;
      height: 100%;
      min-height: 360px;
      object-fit: cover;
      object-position: top center;
      filter: saturate(0.35) contrast(1.12);
      transition: filter 0.45s ease;
    }

    .team-card:hover .team-photo { filter: saturate(0.6) contrast(1.06); }

    .team-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, transparent 75%, var(--bg) 100%);
    }

    .team-text {
      padding: 44px 44px 44px 40px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .team-role-tag {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 14px;
    }

    .team-name {
      font-family: var(--font-d);
      font-size: clamp(20px, 1.9vw, 27px);
      font-weight: 700;
      color: var(--ink);
      letter-spacing: -0.015em;
      line-height: 1.15;
      margin-bottom: 18px;
    }

    .team-bio {
      font-size: 14px;
      font-weight: 300;
      color: var(--ink-mid);
      line-height: 1.72;
      margin-bottom: 28px;
    }

    .team-skills {
      display: flex;
      flex-direction: column;
      gap: 9px;
    }

    .t-skill {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 12px;
      font-weight: 400;
      color: var(--ink-mid);
      letter-spacing: 0.04em;
    }

    .t-skill::before {
      content: '';
      display: block;
      width: 18px;
      height: 1px;
      background: var(--accent);
      flex-shrink: 0;
    }

    /* ===== FOOTER ===== */
    .footer {
      border-top: 1px solid var(--rule);
    }

    .footer-inner {
      max-width: 1600px;
      margin: 0 auto;
      padding: 56px 64px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .footer-brand {
      font-family: var(--font-d);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--ink);
      margin-bottom: 10px;
    }

    .footer-addr {
      font-size: 13px;
      font-weight: 300;
      color: var(--ink-mid);
      line-height: 1.75;
    }

    .footer-links {
      text-align: right;
    }

    .footer-links a {
      display: block;
      font-size: 13px;
      font-weight: 300;
      color: var(--ink-mid);
      line-height: 1.75;
      transition: color 0.22s;
    }

    .footer-links a:hover { color: var(--accent); }

    .footer-copy {
      margin-top: 10px;
      font-size: 11px;
      color: var(--ink-light);
      letter-spacing: 0.06em;
      text-align: right;
    }

    /* ===== REVEAL ===== */
    .reveal {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity 0.72s cubic-bezier(0.4,0,0.2,1), transform 0.72s cubic-bezier(0.4,0,0.2,1);
    }

    .reveal.vis { opacity:1; transform:translateY(0); }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 1100px) {
      .hero { grid-template-columns: 1fr; }
      .hero-right { height: 52vh; min-height: 380px; }
      .hero-photo { clip-path: none; animation: none; transform: scale(1); }
      .scroll-hint { display: none; }
      .nav-links, .nav-coord { display: none; }
      .nav { padding: 0 24px; }
      .metrics-strip { grid-template-columns: 1fr 1fr; }
      .metric { border-bottom: 1px solid var(--rule); }
      .metric:nth-child(2n) { border-right: none; }
      .sec-wrap, .phil-wrap { padding: 80px 32px; }
      .proj-grid { grid-template-columns: 1fr; grid-template-rows: auto; }
      .proj-card--featured { grid-row: auto; }
      .proj-card { height: 320px; }
      .proj-img { position: absolute; }
      .phil-grid { grid-template-columns: 1fr; gap: 52px; }
      .team-grid { grid-template-columns: 1fr; }
      .team-card { grid-template-columns: 200px 1fr; }
      .footer-inner { flex-direction: column; align-items: flex-start; gap: 28px; }
      .footer-links, .footer-copy { text-align: left; }
    }

    @media (max-width: 640px) {
      .hero-left { padding: 48px 24px; }
      .hero-stats { left: 24px; bottom: 28px; gap: 28px; }
      .sec-wrap, .phil-wrap { padding: 64px 24px; }
      .metrics-strip { grid-template-columns: 1fr 1fr; }
      .metric { padding: 22px 24px; }
      .team-card { grid-template-columns: 1fr; }
      .team-photo { min-height: 260px; height: 260px; }
      .team-photo-overlay { background: linear-gradient(to bottom, transparent 70%, var(--bg) 100%); }
      .sec-aside { display: none; }
      .footer-inner { padding: 48px 24px; }
    }
  </style>
</head>
<body>

  <!-- ===== NAV ===== -->
  <nav class="nav">
    <span class="nav-logo">Volumen</span>
    <ul class="nav-links">
      <li><a href="#projekte">Projekte</a></li>
      <li><a href="#philosophie">Philosophie</a></li>
      <li><a href="#team">Das Buero</a></li>
      <li><a href="#kontakt">Kontakt</a></li>
    </ul>
    <span class="nav-coord">49.7499&deg;&thinsp;N &mdash; 6.6371&deg;&thinsp;E</span>
  </nav>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <!-- Left: Text -->
    <div class="hero-left">
      <div class="hero-eyebrow">Architekturbuero &middot; Trier</div>

      <h1 class="hero-h1">
        Form<br />folgt<br /><em>Haltung.</em>
      </h1>

      <p class="hero-desc">
