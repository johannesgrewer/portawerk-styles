---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Eisenguss — Eventlocation & Kreativateliers | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Sans:wght@300;400;500&family=IBM+Plex+Mono:wght@400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --amber:  #E07A2F;
      --dark:   #141210;
      --mid:    #1C1A18;
      --steel:  #2E2C2A;
      --cream:  #F2EDE6;
    }

    body {
      background: var(--dark);
      color: var(--cream);
      font-family: 'IBM Plex Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Gritty texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      background-size: 200px;
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: stretch;
      height: 56px;
      border-bottom: 2px solid var(--steel);
      background: var(--dark);
    }
    .nav-logo {
      display: flex;
      align-items: center;
      padding: 0 2rem;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 0.1em;
      color: var(--amber);
      border-right: 2px solid var(--steel);
    }
    .nav-links {
      display: flex;
      list-style: none;
      height: 100%;
    }
    .nav-links li { border-right: 1px solid var(--steel); }
    .nav-links a {
      display: flex;
      align-items: center;
      padding: 0 1.5rem;
      height: 100%;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(242,237,230,0.35);
      text-decoration: none;
      transition: color 0.15s, background 0.15s;
    }
    .nav-links a:hover { color: var(--amber); background: rgba(224,122,47,0.05); }
    .nav-right {
      margin-left: auto;
      display: flex;
      align-items: center;
      padding: 0 1.5rem;
      border-left: 1px solid var(--steel);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.52rem;
      letter-spacing: 0.14em;
      color: rgba(242,237,230,0.2);
    }

    .hero {
      min-height: 100vh;
      padding-top: 56px;
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-rows: auto 1fr auto;
    }

    /* Top info bar */
    .info-bar {
      display: flex;
      border-bottom: 1px solid var(--steel);
    }
    .info-cell {
      flex: 1;
      padding: 1rem 2rem;
      border-right: 1px solid var(--steel);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.52rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(242,237,230,0.3);
    }
    .info-cell:last-child { border-right: none; }
    .info-cell.highlight {
      background: var(--amber);
      color: var(--dark);
    }

    /* Main content */
    .hero-main {
      display: grid;
      grid-template-columns: 1fr 320px;
    }

    .hero-left {
      padding: 3rem 3rem 3rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      border-right: 1px solid var(--steel);
    }

    .location-tag {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 2rem;
    }

    .hero-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5rem, 11vw, 9.5rem);
      line-height: 0.88;
      letter-spacing: 0.02em;
      color: var(--cream);
    }
    .hero-headline .outline {
      -webkit-text-stroke: 2px var(--cream);
      color: transparent;
    }
    .hero-headline .amber { color: var(--amber); }

    .hero-bottom {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-top: 3rem;
      gap: 2rem;
    }
    .hero-tagline {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.7;
      color: rgba(242,237,230,0.5);
      max-width: 36ch;
    }
    .cta-btn {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1rem;
      letter-spacing: 0.1em;
      color: var(--dark);
      background: var(--amber);
      text-decoration: none;
      padding: 0.8rem 2rem;
      white-space: nowrap;
      border: 2px solid var(--amber);
      transition: background 0.15s, color 0.15s;
    }
    .cta-btn:hover { background: transparent; color: var(--amber); }

    /* RIGHT column */
    .hero-right {
      display: flex;
      flex-direction: column;
    }
    .space-block {
      flex: 1;
      padding: 2rem;
      border-bottom: 1px solid var(--steel);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .space-block:last-of-type { border-bottom: none; }
    .sb-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(242,237,230,0.25);
      margin-bottom: 0.4rem;
    }
    .sb-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      letter-spacing: 0.04em;
      color: var(--cream);
      line-height: 1;
    }
    .sb-meta {
      font-size: 0.62rem;
      font-weight: 300;
      color: rgba(242,237,230,0.35);
      margin-top: 0.2rem;
    }
    .sb-meta span {
      color: var(--amber);
      margin-right: 0.5rem;
    }

    /* Bottom stats */
    .bottom-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 1px solid var(--steel);
    }
    .bot-cell {
      padding: 1.25rem 1.5rem;
      border-right: 1px solid var(--steel);
    }
    .bot-cell:last-child { border-right: none; }
    .bot-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      color: var(--cream);
      line-height: 1;
    }
    .bot-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(242,237,230,0.3);
      margin-top: 0.15rem;
    }
    .bot-cell.accent .bot-num { color: var(--amber); }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Eisenguss</div>
    <ul class="nav-links">
      <li><a href="#">Location</a></li>
      <li><a href="#">Ateliers</a></li>
      <li><a href="#">Events</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <div class="nav-right">Trier-Hafen · DE</div>
  </nav>

  <section class="hero">
    <div class="info-bar">
      <div class="info-cell">Eventlocation & Kreativateliers</div>
      <div class="info-cell highlight">Verfügbar — Jetzt buchen</div>
      <div class="info-cell">Trier-Hafen, Am Moselufer</div>
      <div class="info-cell">hallo@eisenguss-trier.de</div>
    </div>

    <div class="hero-main">
      <div class="hero-left">
        <div>
          <div class="location-tag">// Trier-Hafen · 2.400 m² Industriehalle</div>
          <h1 class="hero-headline">
            <span class="outline">Aus</span><br>
            <span>Stahl</span><br>
            wird <span class="amber">Kul</span>tur.
          </h1>
        </div>
        <div class="hero-bottom">
          <p class="hero-tagline">
            Eine ehemalige Gießerei. Rohe Wände, 8-Meter-Decken,
            Geschichte, die man anfassen kann.
            Der Ort für Events, die niemand vergisst.
          </p>
          <a href="#" class="cta-btn">Besichtigung →</a>
        </div>
      </div>

      <div class="hero-right">
        <div class="space-block">
          <div class="sb-label">Haupthalle</div>
          <div class="sb-name">Die Gießhalle</div>
          <div class="sb-meta"><span>1.200 m²</span>bis 800 Personen</div>
        </div>
        <div class="space-block">
          <div class="sb-label">Außenbereich</div>
          <div class="sb-name">Das Kesselhaus</div>
          <div class="sb-meta"><span>600 m²</span>bis 400 Personen</div>
        </div>
        <div class="space-block">
          <div class="sb-label">Ateliers</div>
          <div class="sb-name">12 Werkräume</div>
          <div class="sb-meta"><span>40–120 m²</span>Monatliche Miete</div>
        </div>
      </div>
    </div>

    <div class="bottom-row">
      <div class="bot-cell accent">
        <div class="bot-num">2.400</div>
        <div class="bot-label">m² Gesamt</div>
      </div>
      <div class="bot-cell">
        <div class="bot-num">1924</div>
        <div class="bot-label">Erbaut</div>
      </div>
      <div class="bot-cell">
        <div class="bot-num">800+</div>
        <div class="bot-label">Gäste max.</div>
      </div>
      <div class="bot-cell">
        <div class="bot-num">12</div>
        <div class="bot-label">Ateliers</div>
      </div>
    </div>
  </section>
</body>
</html>
