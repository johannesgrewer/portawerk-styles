---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Eisenguss — Eventlocation & Kreativateliers | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Sans:wght@300;400;500&family=IBM+Plex+Mono:wght@400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --amber:  #E07A2F;
      --dark:   #141210;
      --mid:    #1C1A18;
      --steel:  #2E2C2A;
      --cream:  #F2EDE6;
    }

    body {
      background: var(--dark);
      color: var(--cream);
      font-family: 'IBM Plex Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Gritty texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      background-size: 200px;
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: stretch;
      height: 56px;
      border-bottom: 2px solid var(--steel);
      background: var(--dark);
    }
    .nav-logo {
      display: flex;
      align-items: center;
      padding: 0 2rem;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 0.1em;
      color: var(--amber);
      border-right: 2px solid var(--steel);
    }
    .nav-links {
      display: flex;
      list-style: none;
      height: 100%;
    }
    .nav-links li { border-right: 1px solid var(--steel); }
    .nav-links a {
      display: flex;
      align-items: center;
      padding: 0 1.5rem;
      height: 100%;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(242,237,230,0.35);
      text-decoration: none;
      transition: color 0.15s, background 0.15s;
    }
    .nav-links a:hover { color: var(--amber); background: rgba(224,122,47,0.05); }
    .nav-right {
      margin-left: auto;
      display: flex;
      align-items: center;
      padding: 0 1.5rem;
      border-left: 1px solid var(--steel);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.52rem;
      letter-spacing: 0.14em;
      color: rgba(242,237,230,0.2);
    }

    .hero {
      min-height: 100vh;
      padding-top: 56px;
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-rows: auto 1fr auto;
    }

    /* Top info bar */
    .info-bar {
      display: flex;
      border-bottom: 1px solid var(--steel);
    }
    .info-cell {
      flex: 1;
      padding: 1rem 2rem;
      border-right: 1px solid var(--steel);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.52rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(242,237,230,0.3);
    }
    .info-cell:last-child { border-right: none; }
    .info-cell.highlight {
      background: var(--amber);
      color: var(--dark);
    }

    /* Main content */
    .hero-main {
      display: grid;
      grid-template-columns: 1fr 320px;
    }

    .hero-left {
      padding: 3rem 3rem 3rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      border-right: 1px solid var(--steel);
    }

    .location-tag {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 2rem;
    }

    .hero-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(5rem, 11vw, 9.5rem);
      line-height: 0.88;
      letter-spacing: 0.02em;
      color: var(--cream);
    }
    .hero-headline .outline {
      -webkit-text-stroke: 2px var(--cream);
      color: transparent;
    }
    .hero-headline .amber { color: var(--amber); }

    .hero-bottom {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-top: 3rem;
      gap: 2rem;
    }
    .hero-tagline {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.7;
      color: rgba(242,237,230,0.5);
      max-width: 36ch;
    }
    .cta-btn {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1rem;
      letter-spacing: 0.1em;
      color: var(--dark);
      background: var(--amber);
      text-decoration: none;
      padding: 0.8rem 2rem;
      white-space: nowrap;
      border: 2px solid var(--amber);
      transition: background 0.15s, color 0.15s;
    }
    .cta-btn:hover { background: transparent; color: var(--amber); }

    /* RIGHT column */
    .hero-right {
      display: flex;
      flex-direction: column;
    }
    .space-block {
      flex: 1;
      padding: 2rem;
      border-bottom: 1px solid var(--steel);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .space-block:last-of-type { border-bottom: none; }
    .sb-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(242,237,230,0.25);
      margin-bottom: 0.4rem;
    }
    .sb-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      letter-spacing: 0.04em;
      color: var(--cream);
      line-height: 1;
    }
    .sb-meta {
      font-size: 0.62rem;
      font-weight: 300;
      color: rgba(242,237,230,0.35);
      margin-top: 0.2rem;
    }
    .sb-meta span {
      color: var(--amber);
      margin-right: 0.5rem;
    }

    /* Bottom stats */
    .bottom-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 1px solid var(--steel);
    }
    .bot-cell {
      padding: 1.25rem 1.5rem;
      border-right: 1px solid var(--steel);
    }
    .bot-cell:last-child { border-right: none; }
    .bot-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      color: var(--cream);
      line-height: 1;
    }
    .bot-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(242,237,230,0.3);
      margin-top: 0.15rem;
    }
    .bot-cell.accent .bot-num { color: var(--amber); }

    /* ── PHOTO CONTAINERS ── */
    .ph { position: relative; overflow: hidden; }
    .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
    .ph:hover img { transform: scale(1.05); }

    /* ── SECTION 2 — RÄUME ── */
    .spaces-section {
      position: relative;
      z-index: 1;
      border-top: 2px solid var(--steel);
    }
    .spaces-header {
      max-width: 1600px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 2rem 4rem;
      border-bottom: 1px solid var(--steel);
    }
    .spaces-header-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(242,237,230,0.3);
    }
    .spaces-header-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.8rem;
      letter-spacing: 0.06em;
      color: var(--cream);
    }
    .spaces-grid {
      max-width: 1600px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
    .space-card {
      border-right: 1px solid var(--steel);
    }
    .space-card:last-child { border-right: none; }
    .space-card-info {
      padding: 1.5rem 2rem;
      border-top: 1px solid var(--steel);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .sc-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.3rem;
      letter-spacing: 0.04em;
      color: var(--cream);
    }
    .sc-meta {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.12em;
      color: var(--amber);
    }

    /* ── SECTION 3 — EVENTS ── */
    .events-section {
      position: relative;
      z-index: 1;
      border-top: 2px solid var(--steel);
    }
    .events-inner {
      max-width: 1600px;
      margin: 0 auto;
    }
    .events-header {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-bottom: 1px solid var(--steel);
    }
    .events-header-left {
      padding: 3rem 4rem;
      border-right: 1px solid var(--steel);
    }
    .events-header-right {
      padding: 3rem 4rem;
    }
    .ev-eyebrow {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.52rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 1rem;
    }
    .ev-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 4vw, 3.5rem);
      letter-spacing: 0.04em;
      color: var(--cream);
      line-height: 0.95;
      margin-bottom: 1.5rem;
    }
    .ev-body {
      font-size: 0.85rem;
      font-weight: 300;
      line-height: 1.8;
      color: rgba(242,237,230,0.5);
      max-width: 44ch;
    }
    .ev-details {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .ev-detail-row {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding-bottom: 1.25rem;
      border-bottom: 1px solid var(--steel);
    }
    .ev-detail-row:last-child { border-bottom: none; padding-bottom: 0; }
    .ev-detail-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.5rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(242,237,230,0.25);
      min-width: 80px;
      margin-top: 0.15rem;
    }
    .ev-detail-value {
      font-family: 'IBM Plex Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 300;
      color: var(--cream);
      line-height: 1.5;
    }
    .ev-detail-value strong {
      font-weight: 500;
      color: var(--amber);
    }
    .events-cta-bar {
      display: flex;
      align-items: center;
      gap: 2rem;
      padding: 2rem 4rem;
      border-top: 1px solid var(--steel);
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Eisenguss</div>
    <ul class="nav-links">
      <li><a href="#">Location</a></li>
      <li><a href="#">Ateliers</a></li>
      <li><a href="#">Events</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <div class="nav-right">Trier-Hafen · DE</div>
  </nav>

  <section class="hero" style="max-width:1600px;margin-left:auto;margin-right:auto;">
    <div class="info-bar">
      <div class="info-cell">Eventlocation & Kreativateliers</div>
      <div class="info-cell highlight">Verfügbar — Jetzt buchen</div>
      <div class="info-cell">Trier-Hafen, Am Moselufer</div>
      <div class="info-cell">hallo@eisenguss-trier.de</div>
    </div>

    <div class="hero-main">
      <div class="hero-left">
        <div>
          <div class="location-tag">// Trier-Hafen · 2.400 m² Industriehalle</div>
          <h1 class="hero-headline">
            <span class="outline">Aus</span><br>
            <span>Stahl</span><br>
            wird <span class="amber">Kul</span>tur.
          </h1>
        </div>
        <div class="hero-bottom">
          <p class="hero-tagline">
            Eine ehemalige Gießerei. Rohe Wände, 8-Meter-Decken,
            Geschichte, die man anfassen kann.
            Der Ort für Events, die niemand vergisst.
          </p>
          <a href="#" class="cta-btn">Besichtigung →</a>
        </div>
      </div>

      <div class="hero-right">
        <div class="ph" style="height:200px;">
          <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&h=400&q=80" alt="Eisenguss Gießhalle" loading="eager"/>
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.55) 0%,transparent 60%);pointer-events:none;"></div>
        </div>
        <div class="space-block">
          <div class="sb-label">Haupthalle</div>
          <div class="sb-name">Die Gießhalle</div>
          <div class="sb-meta"><span>1.200 m²</span>bis 800 Personen</div>
        </div>
        <div class="space-block">
          <div class="sb-label">Außenbereich</div>
          <div class="sb-name">Das Kesselhaus</div>
          <div class="sb-meta"><span>600 m²</span>bis 400 Personen</div>
        </div>
        <div class="space-block">
          <div class="sb-label">Ateliers</div>
          <div class="sb-name">12 Werkräume</div>
          <div class="sb-meta"><span>40–120 m²</span>Monatliche Miete</div>
        </div>
      </div>
    </div>

    <div class="bottom-row">
      <div class="bot-cell accent">
        <div class="bot-num">2.400</div>
        <div class="bot-label">m² Gesamt</div>
      </div>
      <div class="bot-cell">
        <div class="bot-num">1924</div>
        <div class="bot-label">Erbaut</div>
      </div>
      <div class="bot-cell">
        <div class="bot-num">800+</div>
        <div class="bot-label">Gäste max.</div>
      </div>
      <div class="bot-cell">
        <div class="bot-num">12</div>
        <div class="bot-label">Ateliers</div>
      </div>
    </div>
  </section>

  <!-- SECTION 2 — RÄUME & SPACES -->
  <section class="spaces-section">
    <div class="spaces-header">
      <div class="spaces-header-label">// Unsere Räume</div>
      <div class="spaces-header-title">Die Locations</div>
    </div>
    <div class="spaces-grid">
      <div class="space-card">
        <div class="ph" style="height:280px;">
          <img src="https://images.unsplash.com/photo-1521791136064-7986c2920216?auto=format&fit=crop&w=1200&h=800&q=80" alt="Die Gießhalle" loading="lazy"/>
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.4) 0%,transparent 60%);pointer-events:none;"></div>
        </div>
        <div class="space-card-info">
          <div>
            <div class="sc-name">Die Gießhalle</div>
            <div class="sc-meta">1.200 m² · bis 800 Personen</div>
          </div>
          <div class="sc-meta">Hauptlocation →</div>
        </div>
      </div>
      <div class="space-card">
        <div class="ph" style="height:280px;">
          <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?auto=format&fit=crop&w=1200&h=800&q=80" alt="Das Kesselhaus" loading="lazy"/>
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.4) 0%,transparent 60%);pointer-events:none;"></div>
        </div>
        <div class="space-card-info">
          <div>
            <div class="sc-name">Das Kesselhaus</div>
            <div class="sc-meta">600 m² · bis 400 Personen</div>
          </div>
          <div class="sc-meta">Außenbereich →</div>
        </div>
      </div>
      <div class="space-card">
        <div class="ph" style="height:280px;">
          <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=1200&h=800&q=80" alt="Kreativateliers Workshop" loading="lazy"/>
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.4) 0%,transparent 60%);pointer-events:none;"></div>
        </div>
        <div class="space-card-info">
          <div>
            <div class="sc-name">12 Werkräume</div>
            <div class="sc-meta">40–120 m² · Monatliche Miete</div>
          </div>
          <div class="sc-meta">Ateliers →</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3 — EVENTS & BUCHUNG -->
  <section class="events-section">
    <div class="events-inner">
      <div class="events-header">
        <div class="events-header-left">
          <div class="ev-eyebrow">// Events & Vermietung</div>
          <h2 class="ev-headline">Ihr Event.<br>Unser Raum.</h2>
          <p class="ev-body">
            Ob Firmenfeier, Produktlaunch, Kulturveranstaltung oder Ausstellung —
            die Eisenguss gibt jedem Event den Rahmen, den es verdient.
            Rohe Wände, 8-Meter-Decken, Geschichte, die man spürt.
          </p>
        </div>
        <div class="events-header-right">
          <div class="ev-details">
            <div class="ev-detail-row">
              <div class="ev-detail-label">Kapazität</div>
              <div class="ev-detail-value"><strong>bis 800 Gäste</strong> in der Gießhalle<br>bis 400 Gäste im Kesselhaus</div>
            </div>
            <div class="ev-detail-row">
              <div class="ev-detail-label">Catering</div>
              <div class="ev-detail-value">Freie Caterer-Wahl oder Vermittlung über unser Netzwerk. Profiküche vorhanden.</div>
            </div>
            <div class="ev-detail-row">
              <div class="ev-detail-label">Technik</div>
              <div class="ev-detail-value">PA-Anlage, Bühne, Beleuchtungsrig und Lastenlift inklusive.</div>
            </div>
            <div class="ev-detail-row">
              <div class="ev-detail-label">Buchung</div>
              <div class="ev-detail-value"><strong>hallo@eisenguss-trier.de</strong><br>0651 / 987 65 43</div>
            </div>
          </div>
        </div>
      </div>
      <div class="events-cta-bar">
        <a href="#" class="cta-btn">Besichtigung anfragen →</a>
        <span style="font-family:'IBM Plex Mono',monospace;font-size:0.52rem;letter-spacing:0.15em;color:rgba(242,237,230,0.2);">Verfügbarkeit auf Anfrage · Trier-Hafen · Am Moselufer</span>
      </div>
    </div>
  </section>

</body>
</html>
