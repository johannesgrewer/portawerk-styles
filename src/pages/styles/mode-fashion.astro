---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LINIE — Conceptstore & Modeatelier Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,700;1,6..96,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      overflow-x: hidden;
      height: 100%;
    }

    body {
      overflow-x: hidden;
      height: 100%;
      background: #F5F4F0;
      color: #1A1A1A;
      font-family: 'Jost', sans-serif;
    }

    .hero {
      display: flex;
      width: 100vw;
      height: 100vh;
      position: relative;
      overflow: hidden;
    }

    /* Vertical running text on far left edge */
    .hero__vertical-label {
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%) rotate(-90deg);
      transform-origin: center center;
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #1A1A1A;
      white-space: nowrap;
      z-index: 10;
      opacity: 0;
      animation: fadeIn 0.8s ease forwards 3.2s;
      writing-mode: vertical-rl;
      text-orientation: mixed;
      transform: rotate(180deg);
      width: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Left panel */
    .hero__left {
      width: 45%;
      height: 100%;
      background: #F5F4F0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 5vh 4vw 5vh 3.5rem;
      position: relative;
      z-index: 2;
    }

    .hero__season {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #1A1A1A;
      opacity: 0;
      transform: translateY(10px);
      animation: riseIn 0.6s ease forwards 0.3s;
      margin-bottom: 2.5rem;
    }

    .hero__brand {
      font-family: 'Bodoni Moda', serif;
      font-weight: 700;
      font-size: clamp(4.5rem, 9vw, 8.5rem);
      line-height: 0.92;
      letter-spacing: -0.02em;
      color: #1A1A1A;
      margin-bottom: 2rem;
      overflow: hidden;
    }

    .hero__brand .letter {
      display: inline-block;
      opacity: 0;
      transform: translateY(110%);
      animation: letterRise 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .hero__tagline {
      font-family: 'Bodoni Moda', serif;
      font-style: italic;
      font-size: clamp(1rem, 1.6vw, 1.35rem);
      font-weight: 400;
      color: #1A1A1A;
      opacity: 0;
      transform: translateY(8px);
      animation: riseIn 0.7s ease forwards 1.8s;
      margin-bottom: 2.5rem;
      letter-spacing: 0.01em;
    }

    .hero__divider {
      width: 100%;
      height: 1px;
      background: #1A1A1A;
      opacity: 0;
      transform: scaleX(0);
      transform-origin: left center;
      animation: expandLine 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards 2.2s;
      margin-bottom: 1.2rem;
    }

    .hero__atelier {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #1A1A1A;
      opacity: 0;
      transform: translateY(8px);
      animation: riseIn 0.6s ease forwards 2.6s;
    }

    .hero__accent-dot {
      display: inline-block;
      width: 4px;
      height: 4px;
      background: #8B0000;
      border-radius: 50%;
      margin: 0 0.6em;
      vertical-align: middle;
    }

    /* Right panel — image */
    .hero__right {
      width: 55%;
      height: 100%;
      position: relative;
      overflow: hidden;
    }

    .hero__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
      filter: grayscale(100%);
      animation: colorReveal 1.5s ease forwards 2s;
    }

    /* Thin left border/shadow between panels */
    .hero__right::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 2px;
      background: #F5F4F0;
      z-index: 3;
    }

    /* Vertical accent line on the right panel */
    .hero__image-label {
      position: absolute;
      right: 1.5rem;
      bottom: 3rem;
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.55rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(245, 244, 240, 0.75);
      z-index: 4;
      writing-mode: vertical-rl;
      opacity: 0;
      animation: fadeIn 0.8s ease forwards 3.4s;
    }

    /* Red accent mark */
    .hero__red-mark {
      position: absolute;
      top: 5vh;
      right: 0;
      width: 3px;
      height: 0;
      background: #8B0000;
      z-index: 5;
      animation: growDown 1s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.8s;
    }

    /* Issue number / editorial detail */
    .hero__issue {
      position: absolute;
      bottom: 3rem;
      left: 3.5rem;
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.35);
      opacity: 0;
      animation: fadeIn 0.8s ease forwards 3s;
    }

    /* ---- Keyframes ---- */

    @keyframes riseIn {
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeIn {
      to { opacity: 1; }
    }

    @keyframes letterRise {
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes expandLine {
      to { opacity: 1; transform: scaleX(1); }
    }

    @keyframes colorReveal {
      to { filter: grayscale(0%); }
    }

    @keyframes growDown {
      to { height: clamp(80px, 12vh, 140px); }
    }

    /* Photo containers */
    .ph { position: relative; overflow: hidden; }
    .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
    .ph:hover img { transform: scale(1.05); }

    .section-wrap { max-width: 1600px; margin-left: auto; margin-right: auto; }

    /* Collection section */
    .collection {
      padding: 6rem 4rem;
      background: #F5F4F0;
      border-top: 1px solid rgba(26,26,26,0.08);
    }
    .coll-eyebrow {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.62rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.4);
      margin-bottom: 0.6rem;
    }
    .coll-headline {
      font-family: 'Bodoni Moda', serif;
      font-weight: 700;
      font-size: clamp(2rem, 4vw, 3.5rem);
      letter-spacing: -0.01em;
      color: #1A1A1A;
      margin-bottom: 3rem;
      line-height: 1.05;
    }
    .coll-headline em {
      font-style: italic;
      font-weight: 400;
    }
    .coll-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr 1fr;
      gap: 1px;
      background: rgba(26,26,26,0.1);
    }
    .coll-item {
      background: #F5F4F0;
      overflow: hidden;
    }
    .coll-info {
      padding: 1rem 1.25rem 1.5rem;
    }
    .coll-name {
      font-family: 'Bodoni Moda', serif;
      font-size: 0.95rem;
      font-weight: 400;
      color: #1A1A1A;
    }
    .coll-material {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.4);
      margin-top: 0.2rem;
    }
    .coll-price {
      font-family: 'Jost', sans-serif;
      font-size: 0.85rem;
      font-weight: 400;
      color: #8B0000;
      margin-top: 0.5rem;
    }

    /* Lookbook / brand section */
    .lookbook {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 520px;
      border-top: 1px solid rgba(26,26,26,0.08);
    }
    .lookbook-image {}
    .lookbook-content {
      padding: 5rem 4rem;
      background: #1A1A1A;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.75rem;
    }
    .lb-eyebrow {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.62rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
    }
    .lb-headline {
      font-family: 'Bodoni Moda', serif;
      font-weight: 700;
      font-size: clamp(2rem, 3.5vw, 3.2rem);
      line-height: 1.0;
      letter-spacing: -0.01em;
      color: #F5F4F0;
    }
    .lb-headline em {
      font-style: italic;
      font-weight: 400;
      color: rgba(245,244,240,0.6);
    }
    .lb-body {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.9rem;
      line-height: 1.85;
      color: rgba(255,255,255,0.45);
      max-width: 42ch;
    }
    .lb-divider {
      width: 40px;
      height: 1px;
      background: #8B0000;
    }
    .lb-cta {
      font-family: 'Jost', sans-serif;
      font-weight: 400;
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #F5F4F0;
      text-decoration: none;
      border-bottom: 1px solid rgba(245,244,240,0.3);
      padding-bottom: 0.2rem;
      width: fit-content;
      transition: border-color 0.2s, color 0.2s;
    }
    .lb-cta:hover { color: #fff; border-color: #fff; }
  </style>
</head>
<body>
  <section class="hero">

    <!-- Far-left vertical label -->
    <div class="hero__vertical-label" aria-hidden="true">Conceptstore &amp; Modeatelier</div>

    <!-- Left content panel -->
    <div class="hero__left">
      <p class="hero__season">SS 26 <span class="hero__accent-dot"></span> Kollektion</p>

      <h1 class="hero__brand" aria-label="LINIE">
        <!-- Letters injected by JS for stagger -->
      </h1>

      <p class="hero__tagline">Weniger. Besser.</p>

      <div class="hero__divider"></div>

      <p class="hero__atelier">Atelier Trier</p>

      <p class="hero__issue">No. 08 — 2026</p>
    </div>

    <!-- Right image panel -->
    <div class="hero__right">
      <img
        class="hero__image"
        src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=900&q=80&auto=format"
        alt="Linie Modekollektion"
        loading="eager"
        decoding="async"
      />
      <div class="hero__red-mark"></div>
      <p class="hero__image-label" aria-hidden="true">Frühjahr / Sommer</p>
    </div>

  </section>

  <!-- SECTION 2: Kollektion SS 26 -->
  <section class="collection">
    <div class="section-wrap">
      <div class="coll-eyebrow">SS 26 — Kollektion</div>
      <h2 class="coll-headline">Weniger Stücke.<br><em>Mehr Haltung.</em></h2>
      <div class="coll-grid">
        <div class="coll-item">
          <div class="ph" style="height:380px;">
            <img src="https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&w=800&h=1000&q=80" alt="Mode Kollektion" loading="lazy"/>
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.35) 0%,transparent 55%);pointer-events:none;"></div>
          </div>
          <div class="coll-info">
            <div class="coll-name">Mantel No. 03</div>
            <div class="coll-material">Wollgemisch · Beige</div>
            <div class="coll-price">490 €</div>
          </div>
        </div>
        <div class="coll-item">
          <div class="ph" style="height:380px;">
            <img src="https://images.unsplash.com/photo-1547826039-a3e6db4c2527?auto=format&fit=crop&w=800&h=1000&q=80" alt="Modekollektion Detail" loading="lazy"/>
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.35) 0%,transparent 55%);pointer-events:none;"></div>
          </div>
          <div class="coll-info">
            <div class="coll-name">Kleid No. 07</div>
            <div class="coll-material">Leinen · Ecru</div>
            <div class="coll-price">285 €</div>
          </div>
        </div>
        <div class="coll-item">
          <div class="ph" style="height:380px;">
            <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=800&h=1000&q=80" alt="Fashion Editorial" loading="lazy"/>
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.35) 0%,transparent 55%);pointer-events:none;"></div>
          </div>
          <div class="coll-info">
            <div class="coll-name">Bluse No. 12</div>
            <div class="coll-material">Seide · Ivory</div>
            <div class="coll-price">195 €</div>
          </div>
        </div>
        <div class="coll-item">
          <div class="ph" style="height:380px;">
            <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&w=800&h=1000&q=80" alt="Fashion Portrait" loading="lazy"/>
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.35) 0%,transparent 55%);pointer-events:none;"></div>
          </div>
          <div class="coll-info">
            <div class="coll-name">Hose No. 02</div>
            <div class="coll-material">Baumwolle · Anthrazit</div>
            <div class="coll-price">165 €</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Atelier & Lookbook -->
  <section class="lookbook">
    <div class="section-wrap" style="display:grid;grid-template-columns:1fr 1fr;width:100%;">
      <div class="lookbook-image">
        <div class="ph" style="height:100%;min-height:520px;">
          <img src="https://images.unsplash.com/photo-1487958449943-2429e8be8625?auto=format&fit=crop&w=1200&h=800&q=80" alt="Atelier LINIE" loading="lazy"/>
          <div style="position:absolute;inset:0;background:linear-gradient(to right,transparent 55%,rgba(26,26,26,0.5) 100%);pointer-events:none;"></div>
        </div>
      </div>
      <div class="lookbook-content">
        <div class="lb-eyebrow">Das Atelier</div>
        <h2 class="lb-headline">Jedes Stück<br>ist eine <em>Entscheidung.</em></h2>
        <div class="lb-divider"></div>
        <p class="lb-body">
          LINIE entsteht in einem kleinen Atelier in der Trierer Innenstadt.
          Jedes Stück wird in limitierter Auflage produziert —
          aus natürlichen Materialien, mit Schneiderinnen aus der Region.
          Kein Fast Fashion. Keine Saison-Überproduktion.
        </p>
        <a href="#" class="lb-cta">Atelier besuchen &rarr;</a>
      </div>
    </div>
  </section>

  <script>
    // Stagger brand name letters
    const brand = 'LINIE';
    const brandEl = document.querySelector('.hero__brand');
    const delays = [0.6, 0.75, 0.9, 1.05, 1.2];

    brand.split('').forEach((char, i) => {
      const span = document.createElement('span');
      span.classList.add('letter');
      span.textContent = char;
      span.style.animationDelay = delays[i] + 's';
      brandEl.appendChild(span);
    });
  </script>
</body>
</html>
