---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LINIE — Conceptstore & Modeatelier Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,300;0,6..96,400;0,6..96,700;1,6..96,300;1,6..96,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }
    body {
      background: #F5F4F0;
      color: #1A1A1A;
      font-family: 'Jost', sans-serif;
      overflow-x: hidden;
    }

    /* ---- UTILITY ---- */
    .ph { position: relative; overflow: hidden; }
    .ph img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .ph:hover img { transform: scale(1.04); }

    /* ---- NAV ---- */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 3rem;
      mix-blend-mode: difference;
    }
    .nav-logo {
      font-family: 'Bodoni Moda', serif;
      font-weight: 700;
      font-size: 1.05rem;
      letter-spacing: 0.18em;
      color: #F5F4F0;
      text-decoration: none;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.58rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: #F5F4F0;
      text-decoration: none;
      opacity: 0.65;
      transition: opacity 0.2s;
    }
    .nav-links a:hover { opacity: 1; }

    /* ---- HERO ---- */
    .hero {
      position: relative;
      width: 100vw;
      height: 100vh;
      overflow: hidden;
      background: #111;
    }
    .hero-bg {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center 25%;
      filter: grayscale(100%) brightness(0.6);
      transform: scale(1.04);
      animation: heroBg 10s ease forwards, colorShift 2.5s ease forwards 1.8s;
    }
    @keyframes heroBg {
      to { transform: scale(1); }
    }
    @keyframes colorShift {
      to { filter: grayscale(15%) brightness(0.65); }
    }

    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(
        to top,
        rgba(0,0,0,0.82) 0%,
        rgba(0,0,0,0.15) 45%,
        transparent 70%
      );
      z-index: 1;
    }
    /* Top vignette */
    .hero-overlay-top {
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, transparent 25%);
      z-index: 1;
    }

    /* Red accent line */
    .hero-accent {
      position: absolute;
      top: 0;
      right: 5.5rem;
      width: 2px;
      height: 0;
      background: #8B0000;
      z-index: 3;
      animation: growDown 1.4s cubic-bezier(0.22, 1, 0.36, 1) forwards 1.2s;
    }
    @keyframes growDown { to { height: clamp(100px, 18vh, 170px); } }

    /* Right vertical label */
    .hero-issue {
      position: absolute;
      right: 3rem;
      bottom: 3.5rem;
      z-index: 4;
      writing-mode: vertical-rl;
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.55rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(245,244,240,0.3);
      opacity: 0;
      animation: fadeIn 0.8s ease forwards 3.5s;
    }

    .hero-content {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 4rem 4.5rem;
      z-index: 2;
    }
    .hero-season {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.58rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: rgba(245,244,240,0.45);
      margin-bottom: 0.8rem;
      display: flex;
      align-items: center;
      gap: 0.7em;
      opacity: 0;
      transform: translateY(8px);
      animation: riseIn 0.6s ease forwards 0.4s;
    }
    .hero-dot {
      display: inline-block;
      width: 4px; height: 4px;
      background: #8B0000;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .hero-title {
      font-family: 'Bodoni Moda', serif;
      font-weight: 700;
      font-size: clamp(7rem, 17vw, 17rem);
      line-height: 0.82;
      letter-spacing: -0.03em;
      color: #F5F4F0;
      margin-bottom: 2.5rem;
      overflow: hidden;
    }
    .hero-title .letter {
      display: inline-block;
      opacity: 0;
      transform: translateY(115%);
      animation: letterRise 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .hero-bottom {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      opacity: 0;
      animation: riseIn 0.7s ease forwards 2.8s;
    }
    .hero-tagline {
      font-family: 'Bodoni Moda', serif;
      font-style: italic;
      font-size: clamp(1rem, 1.8vw, 1.55rem);
      font-weight: 300;
      color: rgba(245,244,240,0.7);
      line-height: 1.5;
    }
    .hero-meta {
      text-align: right;
    }
    .hero-meta p {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.58rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(245,244,240,0.3);
      line-height: 2.2;
    }

    /* ---- KEYFRAMES ---- */
    @keyframes riseIn { to { opacity: 1; transform: translateY(0); } }
    @keyframes letterRise { to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeIn { to { opacity: 1; } }

    /* ---- SECTION 2: LOOKBOOK ---- */
    .lookbook {
      padding: 6.5rem 4rem 6rem;
      background: #F5F4F0;
    }
    .lookbook-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 2.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid rgba(26,26,26,0.1);
    }
    .section-eyebrow {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.58rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.32);
      margin-bottom: 0.45rem;
    }
    .section-headline {
      font-family: 'Bodoni Moda', serif;
      font-weight: 700;
      font-size: clamp(2.2rem, 3.8vw, 3.2rem);
      line-height: 1.0;
      letter-spacing: -0.01em;
      color: #1A1A1A;
    }
    .section-headline em { font-style: italic; font-weight: 400; }
    .section-sub {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.68rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.35);
      text-align: right;
      line-height: 1.9;
    }

    /* Asymmetric lookbook grid */
    .lookbook-grid {
      display: grid;
      grid-template-columns: 1.35fr 1fr 0.85fr;
      grid-template-rows: 460px 260px;
      gap: 4px;
    }
    .lb-cell { overflow: hidden; position: relative; }
    .lb-cell-1 { grid-column: 1; grid-row: 1 / 3; }
    .lb-cell-2 { grid-column: 2; grid-row: 1; }
    .lb-cell-3 { grid-column: 3; grid-row: 1; }
    .lb-cell-4 { grid-column: 2 / 4; grid-row: 2; }

    .lb-caption {
      position: absolute;
      bottom: 1rem;
      left: 1rem;
      z-index: 3;
      background: rgba(245,244,240,0.93);
      padding: 0.5rem 0.8rem;
    }
    .lb-caption-name {
      font-family: 'Bodoni Moda', serif;
      font-size: 0.78rem;
      font-weight: 400;
      color: #1A1A1A;
    }
    .lb-caption-price {
      font-family: 'Jost', sans-serif;
      font-size: 0.58rem;
      font-weight: 300;
      color: #8B0000;
      letter-spacing: 0.12em;
      margin-top: 0.15rem;
    }

    /* ---- SECTION 3: BRAND STORY ---- */
    .brand-story {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 580px;
    }
    .bs-text {
      background: #111;
      padding: 6.5rem 5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 2.25rem;
    }
    .bs-number {
      font-family: 'Bodoni Moda', serif;
      font-weight: 300;
      font-size: clamp(5rem, 10vw, 9rem);
      line-height: 1;
      color: rgba(255,255,255,0.05);
      letter-spacing: -0.04em;
      align-self: flex-start;
      margin-top: -1rem;
    }
    .bs-eyebrow {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.58rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.22);
    }
    .bs-quote {
      font-family: 'Bodoni Moda', serif;
      font-style: italic;
      font-weight: 300;
      font-size: clamp(1.4rem, 2.4vw, 2.1rem);
      line-height: 1.45;
      color: #F5F4F0;
      letter-spacing: 0.01em;
      position: relative;
      padding-left: 1.8rem;
    }
    .bs-quote::before {
      content: '"';
      font-family: 'Bodoni Moda', serif;
      font-size: 3.5rem;
      line-height: 0;
      color: #8B0000;
      position: absolute;
      top: 0.9rem;
      left: 0;
      font-style: normal;
    }
    .bs-divider {
      width: 36px;
      height: 1px;
      background: #8B0000;
    }
    .bs-body {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.83rem;
      line-height: 1.95;
      color: rgba(255,255,255,0.32);
      max-width: 44ch;
    }
    .bs-cta {
      display: inline-block;
      font-family: 'Jost', sans-serif;
      font-weight: 400;
      font-size: 0.58rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #F5F4F0;
      text-decoration: none;
      border-bottom: 1px solid rgba(255,255,255,0.2);
      padding-bottom: 0.3rem;
      width: fit-content;
      transition: border-color 0.2s;
    }
    .bs-cta:hover { border-color: #8B0000; }
    .bs-image {
      position: relative;
      overflow: hidden;
    }
    .bs-image img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center top;
      filter: grayscale(25%);
      transition: transform 0.8s ease;
    }
    .bs-image:hover img { transform: scale(1.04); }
    .bs-image::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(139,0,0,0.1) 0%, transparent 55%);
      z-index: 1;
      pointer-events: none;
    }

    /* ---- SECTION 4: STORE / KONTAKT ---- */
    .store {
      padding: 6.5rem 4rem;
      background: #F5F4F0;
      border-top: 1px solid rgba(26,26,26,0.08);
    }
    .store-inner {
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      gap: 5rem;
      align-items: start;
    }
    .store-info h2 {
      font-family: 'Bodoni Moda', serif;
      font-weight: 700;
      font-size: clamp(2.2rem, 3.8vw, 3.2rem);
      line-height: 1.0;
      letter-spacing: -0.01em;
      color: #1A1A1A;
      margin-bottom: 2.5rem;
    }
    .store-info h2 em { font-style: italic; font-weight: 400; }
    .store-detail { margin-bottom: 1.6rem; }
    .store-label {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.56rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: rgba(26,26,26,0.3);
      margin-bottom: 0.35rem;
    }
    .store-value {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.88rem;
      line-height: 1.75;
      color: #1A1A1A;
    }
    .store-accent {
      display: inline-block;
      width: 3px; height: 3px;
      background: #8B0000;
      border-radius: 50%;
      margin: 0 0.5em;
      vertical-align: middle;
    }
    .store-btn {
      display: inline-block;
      margin-top: 2.2rem;
      font-family: 'Jost', sans-serif;
      font-weight: 400;
      font-size: 0.58rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #F5F4F0;
      background: #1A1A1A;
      text-decoration: none;
      padding: 0.9rem 2.2rem;
      transition: background 0.2s;
    }
    .store-btn:hover { background: #8B0000; }

    /* Store photo grid */
    .store-photos {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 4px;
    }
    .store-photos .ph { height: 260px; }
    .store-photos .ph:first-child {
      grid-column: 1 / 3;
      height: 320px;
    }

    /* ---- FOOTER ---- */
    footer {
      padding: 1.75rem 4rem;
      background: #111;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .footer-brand {
      font-family: 'Bodoni Moda', serif;
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.18em;
      color: rgba(245,244,240,0.35);
    }
    .footer-note {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.52rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(245,244,240,0.18);
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <a href="#" class="nav-logo">LINIE</a>
    <ul class="nav-links">
      <li><a href="#">Kollektion</a></li>
      <li><a href="#">Atelier</a></li>
      <li><a href="#">Store</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <img
      class="hero-bg"
      src="https://images.unsplash.com/photo-1509631179647-0177331693ae?w=1600&q=85&auto=format"
      alt="LINIE Fashion"
      loading="eager"
      decoding="async"
    />
    <div class="hero-overlay"></div>
    <div class="hero-overlay-top"></div>
    <div class="hero-accent"></div>
    <p class="hero-issue" aria-hidden="true">No. 08 · SS 2026 · Trier</p>

    <div class="hero-content">
      <p class="hero-season">
        <span>SS 26</span>
        <span class="hero-dot"></span>
        <span>Neue Kollektion</span>
      </p>
      <h1 class="hero-title" aria-label="LINIE"></h1>
      <div class="hero-bottom">
        <p class="hero-tagline">Weniger. Besser.<br>Kleidung, die bleibt.</p>
        <div class="hero-meta">
          <p>Conceptstore &amp; Modeatelier</p>
          <p>Trier — Seit 2019</p>
          <p>8 Pieces · Natural Fibers</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: LOOKBOOK -->
  <section class="lookbook">
    <div class="lookbook-header">
      <div>
        <div class="section-eyebrow">SS 26 — Lookbook</div>
        <h2 class="section-headline">Frühjahr &amp;<br><em>Sommer.</em></h2>
      </div>
      <div class="section-sub">
        8 Pieces<br>
        Limitierte Edition<br>
        Natural Fibers Only
      </div>
    </div>

    <div class="lookbook-grid">
      <!-- Tall left -->
      <div class="lb-cell lb-cell-1">
        <div class="ph" style="height:100%;">
          <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=800&h=1200&q=80" alt="Lookbook Editorial" loading="lazy"/>
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.5) 0%,transparent 45%);pointer-events:none;"></div>
        </div>
        <div class="lb-caption">
          <div class="lb-caption-name">Kleid No. 04</div>
          <div class="lb-caption-price">295 € — Leinen · Ecru</div>
        </div>
      </div>

      <!-- Top mid -->
      <div class="lb-cell lb-cell-2">
        <div class="ph" style="height:100%;">
          <img src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&w=800&h=700&q=80" alt="Mode Editorial" loading="lazy"/>
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.4) 0%,transparent 50%);pointer-events:none;"></div>
        </div>
        <div class="lb-caption">
          <div class="lb-caption-name">Bluse No. 11</div>
          <div class="lb-caption-price">185 € — Seide · Ivory</div>
        </div>
      </div>

      <!-- Top right -->
      <div class="lb-cell lb-cell-3">
        <div class="ph" style="height:100%;">
          <img src="https://images.unsplash.com/photo-1539109136881-3be0616acf4b?auto=format&fit=crop&w=600&h=700&q=80" alt="Fashion Detail" loading="lazy"/>
        </div>
      </div>

      <!-- Bottom wide -->
      <div class="lb-cell lb-cell-4">
        <div class="ph" style="height:100%;">
          <img src="https://images.unsplash.com/photo-1469334031218-e382a71b716b?auto=format&fit=crop&w=1400&h=400&q=80" alt="Fashion Editorial" loading="lazy" style="object-position:center 25%;"/>
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.45) 0%,transparent 50%);pointer-events:none;"></div>
        </div>
        <div class="lb-caption" style="bottom:1rem;right:1rem;left:auto;">
          <div class="lb-caption-name">Mantel No. 02</div>
          <div class="lb-caption-price">540 € — Wollgemisch · Camel</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: BRAND STORY -->
  <section class="brand-story">
    <div class="bs-text">
      <div class="bs-number" aria-hidden="true">08</div>
      <div class="bs-eyebrow">Das Atelier · Trier</div>
      <blockquote class="bs-quote">
        Kleidung, die bleibt.<br>
        Materialien, die atmen.<br>
        Formen, die schweigen.
      </blockquote>
      <div class="bs-divider"></div>
      <p class="bs-body">
        LINIE entsteht in einem kleinen Atelier in der Trierer Altstadt.
        Acht bis zwölf Stücke pro Saison — nicht mehr.
        Jedes in limitierter Auflage, aus natürlichen Materialien,
        gefertigt mit Schneiderinnen aus der Region.
        Kein Fast Fashion. Keine Überproduktion.
        Nur das, was bleibt.
      </p>
      <a href="#" class="bs-cta">Atelier besuchen &rarr;</a>
    </div>
    <div class="bs-image">
      <img
        src="https://images.unsplash.com/photo-1566206091558-7f218b696731?auto=format&fit=crop&w=900&h=900&q=80"
        alt="LINIE Atelier"
        loading="lazy"
      />
    </div>
  </section>

  <!-- SECTION 4: STORE / KONTAKT -->
  <section class="store">
    <div class="store-inner">
      <div class="store-info">
        <h2>Store<br><em>&amp; Atelier.</em></h2>

        <div class="store-detail">
          <div class="store-label">Adresse</div>
          <div class="store-value">
            Simeonstraße 14<br>
            54290 Trier
          </div>
        </div>

        <div class="store-detail">
          <div class="store-label">Öffnungszeiten</div>
          <div class="store-value">
            Di–Fr <span class="store-accent"></span> 10–18 Uhr<br>
            Sa <span class="store-accent"></span> 10–16 Uhr
          </div>
        </div>

        <div class="store-detail">
          <div class="store-label">Kontakt</div>
          <div class="store-value">
            hallo@linie-trier.de<br>
            +49 651 123 45 67
          </div>
        </div>

        <a href="#" class="store-btn">Termin vereinbaren</a>
      </div>

      <div class="store-photos">
        <div class="ph">
          <img src="https://images.unsplash.com/photo-1581044777550-4cfa60707c03?auto=format&fit=crop&w=900&h=500&q=80" alt="LINIE Store" loading="lazy"/>
        </div>
        <div class="ph">
          <img src="https://images.unsplash.com/photo-1524504388940-b1c1722653e1?auto=format&fit=crop&w=500&h=400&q=80" alt="Mode Detail" loading="lazy"/>
        </div>
        <div class="ph">
          <img src="https://images.unsplash.com/photo-1564257577-c699af005a1c?auto=format&fit=crop&w=500&h=400&q=80" alt="Kollektion Detail" loading="lazy"/>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <span class="footer-brand">LINIE</span>
    <span class="footer-note">Conceptstore &amp; Modeatelier · Trier</span>
    <span class="footer-note">SS 26 · © 2026</span>
  </footer>

  <script>
    const brand = 'LINIE';
    const brandEl = document.querySelector('.hero-title');
    const delays = [0.5, 0.65, 0.8, 0.95, 1.1];
    brand.split('').forEach((char, i) => {
      const span = document.createElement('span');
      span.classList.add('letter');
      span.textContent = char;
      span.style.animationDelay = delays[i] + 's';
      brandEl.appendChild(span);
    });
  </script>
</body>
</html>
