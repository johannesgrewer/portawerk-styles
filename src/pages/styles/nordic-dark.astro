---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Kvällen — Nordic Spa & Saunarium | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300;1,9..144,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --sage:   #7A9E8E;
      --cream:  #D4C5A9;
      --bg:     #141618;
      --dark:   #0E1012;
      --mid:    #1E2226;
      --text:   #E8E4DC;
      --muted:  rgba(232,228,220,0.4);
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Subtle grain texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        radial-gradient(ellipse 80% 50% at 15% 40%, rgba(122,158,142,0.06) 0%, transparent 60%),
        radial-gradient(ellipse 50% 80% at 85% 70%, rgba(122,158,142,0.04) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 3.5rem;
      background: rgba(14,16,18,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(122,158,142,0.12);
    }
    .nav-logo {
      font-family: 'Fraunces', serif;
      font-weight: 300;
      font-style: italic;
      font-size: 1.2rem;
      letter-spacing: 0.08em;
      color: var(--cream);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.58rem;
      font-weight: 400;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(232,228,220,0.3);
      text-decoration: none;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: var(--sage); }
    .nav-book {
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--sage);
      padding: 0.65rem 1.5rem;
      text-decoration: none;
      transition: background 0.3s;
    }
    .nav-book:hover { background: var(--cream); color: var(--bg); }

    .hero {
      min-height: 100vh;
      padding-top: 60px;
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 360px;
    }

    /* LEFT */
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 5rem 4rem 5rem 4.5rem;
      gap: 3rem;
    }

    .eyebrow {
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--sage);
    }

    .hero-headline {
      font-family: 'Fraunces', serif;
      font-weight: 300;
      font-size: clamp(2.8rem, 5.5vw, 5rem);
      line-height: 1.15;
      color: var(--text);
      letter-spacing: 0.01em;
    }
    .hero-headline em {
      font-style: italic;
      color: var(--sage);
    }

    .sage-line {
      width: 2.5rem;
      height: 1px;
      background: var(--sage);
      opacity: 0.5;
    }

    .hero-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 2;
      color: var(--muted);
      max-width: 42ch;
    }

    /* Ritual list */
    .ritual-list {
      display: flex;
      flex-direction: column;
      border-top: 1px solid rgba(122,158,142,0.15);
    }
    .ritual-row {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(122,158,142,0.08);
    }
    .rr-num {
      font-family: 'Fraunces', serif;
      font-size: 0.7rem;
      font-weight: 300;
      color: rgba(122,158,142,0.4);
      width: 1.5rem;
      flex-shrink: 0;
    }
    .rr-info { flex: 1; }
    .rr-name {
      font-size: 0.9rem;
      font-weight: 400;
      color: var(--text);
    }
    .rr-detail {
      font-size: 0.65rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 0.1rem;
    }
    .rr-dur {
      font-family: 'Fraunces', serif;
      font-size: 0.8rem;
      font-weight: 300;
      color: var(--sage);
      flex-shrink: 0;
    }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 2rem;
    }
    .cta-btn {
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--sage);
      padding: 0.95rem 2.2rem;
      text-decoration: none;
      transition: background 0.3s;
    }
    .cta-btn:hover { background: var(--cream); }
    .cta-link {
      font-family: 'Fraunces', serif;
      font-size: 0.88rem;
      font-weight: 300;
      font-style: italic;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid rgba(232,228,220,0.15);
      padding-bottom: 1px;
    }

    /* RIGHT */
    .hero-right {
      border-left: 1px solid rgba(122,158,142,0.1);
      display: flex;
      flex-direction: column;
    }

    /* Temperature blocks */
    .temp-block {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 2rem 2.5rem;
      border-bottom: 1px solid rgba(122,158,142,0.08);
    }
    .temp-block:last-of-type { border-bottom: none; }
    .tb-label {
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(232,228,220,0.2);
      margin-bottom: 0.4rem;
    }
    .tb-temp {
      font-family: 'Fraunces', serif;
      font-size: 2.2rem;
      font-weight: 300;
      line-height: 1;
      color: var(--text);
    }
    .tb-temp .unit {
      font-size: 1rem;
      color: var(--sage);
    }
    .tb-name {
      font-size: 0.72rem;
      font-weight: 400;
      color: var(--sage);
      margin-top: 0.3rem;
    }
    .tb-note {
      font-size: 0.62rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 0.15rem;
      line-height: 1.5;
    }

    /* Bottom booking block */
    .booking-block {
      background: var(--mid);
      padding: 2rem 2.5rem;
      border-top: 1px solid rgba(122,158,142,0.12);
    }
    .bb-label {
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(232,228,220,0.2);
      margin-bottom: 0.6rem;
    }
    .bb-hours {
      font-family: 'Fraunces', serif;
      font-size: 1rem;
      font-weight: 300;
      color: var(--text);
      line-height: 1.6;
    }
    .bb-price {
      font-size: 0.72rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 0.4rem;
    }
    .bb-price strong {
      font-family: 'Fraunces', serif;
      font-size: 1.1rem;
      font-weight: 300;
      color: var(--cream);
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Kvällen</div>
    <ul class="nav-links">
      <li><a href="#">Saunarium</a></li>
      <li><a href="#">Rituale</a></li>
      <li><a href="#">Preise</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
    <a href="#" class="nav-book">Buchen</a>
  </nav>

  <section class="hero">
    <div class="hero-left">
      <div class="eyebrow">Nordic Spa & Saunarium · Trier</div>

      <h1 class="hero-headline">
        Stille,<br>
        die man<br>
        <em>spürt.</em>
      </h1>

      <div class="sage-line"></div>

      <p class="hero-body">
        Kvällen ist Schwedisch für den Abend — jene Stunde,
        wenn alles ruhig wird. Wir haben daraus einen Ort gemacht:
        Sauna, Aufguss, kaltes Wasser und Schweigen.
      </p>

      <div class="ritual-list">
        <div class="ritual-row">
          <span class="rr-num">01</span>
          <div class="rr-info">
            <div class="rr-name">Klassischer Aufguss</div>
            <div class="rr-detail">Eukalyptus & Birke, geführt</div>
          </div>
          <span class="rr-dur">20 min</span>
        </div>
        <div class="ritual-row">
          <span class="rr-num">02</span>
          <div class="rr-info">
            <div class="rr-name">Eiskaltes Bad</div>
            <div class="rr-detail">Tauchbecken, 8 – 12 °C</div>
          </div>
          <span class="rr-dur">3 min</span>
        </div>
        <div class="ritual-row">
          <span class="rr-num">03</span>
          <div class="rr-info">
            <div class="rr-name">Ruheraum Hvila</div>
            <div class="rr-detail">Liegestühle, Kräutertee, Stille</div>
          </div>
          <span class="rr-dur">offen</span>
        </div>
        <div class="ritual-row">
          <span class="rr-num">04</span>
          <div class="rr-info">
            <div class="rr-name">Dampfbad</div>
            <div class="rr-detail">Lavendel & Fichtennadel</div>
          </div>
          <span class="rr-dur">15 min</span>
        </div>
      </div>

      <div class="cta-row">
        <a href="#" class="cta-btn">Termin buchen →</a>
        <a href="#" class="cta-link">Alle Rituale ansehen</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="temp-block">
        <div class="tb-label">Finnische Sauna</div>
        <div class="tb-temp">90<span class="unit"> °C</span></div>
        <div class="tb-name">Kiuas Traditionsofen</div>
        <div class="tb-note">Trockene Wärme · Aufguss auf Anfrage</div>
      </div>
      <div class="temp-block">
        <div class="tb-label">Dampfbad</div>
        <div class="tb-temp">45<span class="unit"> °C</span></div>
        <div class="tb-name">Hammam-Stil</div>
        <div class="tb-note">100 % Luftfeuchtigkeit · Kräuteressenzen</div>
      </div>
      <div class="temp-block">
        <div class="tb-label">Tauchbecken</div>
        <div class="tb-temp">10<span class="unit"> °C</span></div>
        <div class="tb-name">Kaltbad Isbad</div>
        <div class="tb-note">Durchblutungsfördernd · täglich frisch</div>
      </div>

      <div class="booking-block">
        <div class="bb-label">Öffnungszeiten</div>
        <div class="bb-hours">Di – So<br>14:00 – 22:00 Uhr</div>
        <div class="bb-price">Tageskarte ab <strong>38 €</strong></div>
      </div>
    </div>
  </section>
</body>
</html>
