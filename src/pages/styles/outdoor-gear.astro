      background: var(--ember);
      padding: 6rem 4rem;
      position: relative;
      overflow: hidden;
    }
    .section-cta::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image: repeating-linear-gradient(
        -18deg,
        transparent 0px, transparent 34px,
        rgba(255,255,255,0.045) 34px, rgba(255,255,255,0.045) 35px
      );
    }

    .cta-inner {
      max-width: 1600px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 4rem;
      position: relative;
      z-index: 1;
