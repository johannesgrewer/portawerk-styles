---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Gipfelblick — Outdoor & Bergausrüstung | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --ink:    #0d190d;
      --forest: #1b3318;
      --leaf:   #2d5a20;
      --ember:  #c8531a;
      --gold:   #c48a14;
      --paper:  #f4edd8;
      --fog:    #e5dcca;
      --ash:    #8a8278;
      --snow:   #faf8f4;
    }

    body {
      background: var(--paper);
      color: var(--ink);
      font-family: 'Lora', Georgia, serif;
      overflow-x: hidden;
    }

    /* Grain texture overlay */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9999;
      opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      background-size: 180px 180px;
    }

    /* ========== NAV ========== */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.4rem 4rem;
      transition: background 0.5s, backdrop-filter 0.5s, padding 0.3s;
    }
    nav.scrolled {
      background: rgba(13, 25, 13, 0.93);
      backdrop-filter: blur(14px);
      padding: 1rem 4rem;
    }

    .nav-logo {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1.1rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #fff;
    }
    .nav-logo span { color: var(--ember); }

    .nav-links {
      display: flex;
      gap: 3rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: #fff; }

    .nav-cta {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.64rem;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--ember);
      padding: 0.6rem 1.5rem;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
      clip-path: polygon(0 0, calc(100% - 7px) 0, 100% 7px, 100% 100%, 7px 100%, 0 calc(100% - 7px));
    }
    .nav-cta:hover { background: #fff; }

    /* ========== HERO ========== */
    .hero {
      position: relative;
      height: 100vh;
      min-height: 720px;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
    }
    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      will-change: transform;
    }
    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to right, rgba(13,25,13,0.88) 0%, rgba(13,25,13,0.45) 55%, rgba(13,25,13,0.15) 100%),
        linear-gradient(to top, rgba(13,25,13,0.75) 0%, transparent 45%);
    }
    /* Topographic lines */
    .hero-topo {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background-image:
        repeating-linear-gradient(
          -12deg,
          transparent 0px, transparent 36px,
          rgba(255,255,255,0.028) 36px, rgba(255,255,255,0.028) 37px
        ),
        repeating-linear-gradient(
          78deg,
          transparent 0px, transparent 52px,
          rgba(255,255,255,0.015) 52px, rgba(255,255,255,0.015) 53px
        );
    }

    .hero-content {
      position: relative;
      z-index: 2;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 4rem 5.5rem;
      max-width: 1600px;
      margin: 0 auto;
    }

    .hero-eyebrow {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      margin-bottom: 2rem;
      animation: fadeUp 0.9s 0.1s both;
    }
    .eyebrow-line {
      width: 2.8rem;
      height: 2px;
      background: var(--ember);
    }
    .eyebrow-text {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--ember);
    }

    .hero-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(5.5rem, 12vw, 10.5rem);
      line-height: 0.86;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 3rem;
      animation: fadeUp 0.9s 0.2s both;
    }
    .hero-title .outline {
      -webkit-text-stroke: 2px rgba(255,255,255,0.32);
      color: transparent;
    }
    .hero-title .accent { color: var(--ember); }

    .hero-bottom {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 3rem;
      animation: fadeUp 0.9s 0.35s both;
    }

    .hero-desc {
      max-width: 38ch;
      font-size: 0.9rem;
      font-style: italic;
      color: rgba(255,255,255,0.6);
      line-height: 1.85;
    }

    .hero-stats {
      display: flex;
      gap: 0;
    }
    .hero-stat {
      padding: 0 2.5rem;
      border-left: 1px solid rgba(255,255,255,0.12);
      text-align: right;
    }
    .hero-stat:first-child { border-left: none; padding-left: 0; }
    .stat-val {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 2.6rem;
      color: #fff;
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .stat-val sup { color: var(--ember); font-size: 0.5em; vertical-align: super; }
    .stat-key {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.55rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.38);
      margin-top: 0.2rem;
    }

    /* Scroll indicator */
    .hero-scroll {
      position: absolute;
      right: 4rem;
      bottom: 3.5rem;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.8rem;
    }
    .scroll-word {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.5rem;
      font-weight: 600;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.28);
      writing-mode: vertical-rl;
    }
    .scroll-bar {
      width: 1px;
      height: 4.5rem;
      background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
      animation: scrollPulse 2.2s ease-in-out infinite;
    }
    @keyframes scrollPulse {
      0%, 100% { opacity: 0.4; transform: scaleY(0.9); transform-origin: top; }
      50% { opacity: 1; transform: scaleY(1.1); transform-origin: top; }
    }

    /* ========== SECTION SORTIMENT ========== */
    .section-sortiment {
      background: var(--ink);
      padding: 7rem 4rem;
      position: relative;
      overflow: hidden;
    }
    .section-sortiment::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image: repeating-linear-gradient(
        0deg,
        transparent 0px, transparent 47px,
        rgba(255,255,255,0.018) 47px, rgba(255,255,255,0.018) 48px
      );
    }

    .sortiment-inner {
      max-width: 1600px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    .sec-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 4rem;
    }
    .sec-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--ember);
      margin-bottom: 0.8rem;
    }
    .sec-title-dark {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(2.4rem, 4.5vw, 4rem);
      line-height: 0.88;
      text-transform: uppercase;
      color: #fff;
    }
    .sec-title-dark .g {
      -webkit-text-stroke: 1.5px rgba(255,255,255,0.18);
      color: transparent;
    }
    .sec-title-light {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(2.4rem, 4.5vw, 4rem);
      line-height: 0.88;
      text-transform: uppercase;
      color: var(--ink);
    }
    .sec-title-light .g {
      -webkit-text-stroke: 1.5px rgba(13,25,13,0.15);
      color: transparent;
    }
    .sec-link {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.64rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.38);
      text-decoration: none;
      border-bottom: 1px solid rgba(255,255,255,0.12);
      padding-bottom: 0.25rem;
      transition: color 0.2s, border-color 0.2s;
    }
    .sec-link:hover { color: var(--ember); border-color: var(--ember); }
    .sec-link-light {
      color: rgba(13,25,13,0.35);
      border-color: rgba(13,25,13,0.1);
    }
    .sec-link-light:hover { color: var(--ember); border-color: var(--ember); }

    /* Product grid */
    .products-grid {
      display: grid;
      grid-template-columns: 1.6fr 1fr 1fr;
      grid-template-rows: 320px 280px;
      gap: 2px;
      background: rgba(255,255,255,0.05);
    }

    .pcard {
      position: relative;
      overflow: hidden;
      background: #080f08;
      cursor: pointer;
    }
    /* Tall hero card */
    .pcard:nth-child(1) { grid-row: 1 / 3; }
    /* Wide bottom card */
    .pcard:nth-child(4) { grid-column: 2 / 4; }

    .pcard img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      filter: saturate(0.8);
    }
    .pcard:hover img {
      transform: scale(1.07);
      filter: saturate(1);
    }

    .pcard-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13,25,13,0.9) 0%, rgba(13,25,13,0.2) 45%, transparent 100%);
      transition: background 0.4s;
    }
    .pcard:hover .pcard-overlay {
      background: linear-gradient(to top, rgba(13,25,13,0.95) 0%, rgba(13,25,13,0.4) 55%, rgba(13,25,13,0.1) 100%);
    }

    .pcard-info {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1.75rem 2rem;
    }
    .pcard-cat {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.52rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--ember);
      margin-bottom: 0.45rem;
    }
    .pcard-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1.6rem;
      text-transform: uppercase;
      color: #fff;
      line-height: 0.92;
      margin-bottom: 0.5rem;
      transition: color 0.2s;
    }
    .pcard:nth-child(1) .pcard-name { font-size: 2.6rem; }
    .pcard:hover .pcard-name { color: rgba(255,255,255,0.85); }
    .pcard-brands {
      font-size: 0.68rem;
      font-style: italic;
      color: rgba(255,255,255,0.42);
    }

    .pcard-corner {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255,255,255,0.16);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.35);
      font-size: 0.9rem;
      transition: all 0.25s;
      clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 6px 100%, 0 calc(100% - 6px));
    }
    .pcard:hover .pcard-corner {
      background: var(--ember);
      border-color: var(--ember);
      color: #fff;
    }

    /* ========== SECTION TOUREN ========== */
    .section-touren {
      background: var(--paper);
      padding: 8rem 4rem;
    }

    .touren-inner {
      max-width: 1600px;
      margin: 0 auto;
    }

    .touren-layout {
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      gap: 6rem;
      margin-top: 5rem;
      align-items: start;
    }

    /* Left: photo composition */
    .tour-photos {
      position: relative;
      padding-bottom: 3rem;
    }
    .tour-photo-main {
      position: relative;
      overflow: hidden;
      aspect-ratio: 3 / 4;
    }
    .tour-photo-main img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.8s ease;
    }
    .tour-photo-main:hover img { transform: scale(1.04); }
    .tour-photo-main::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13,25,13,0.55) 0%, transparent 45%);
    }

    .tour-badge {
      position: absolute;
      bottom: 2rem;
      left: 2rem;
      z-index: 2;
      background: var(--ember);
      padding: 0.9rem 1.4rem;
      clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
    }
    .tb-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 2rem;
      color: #fff;
      line-height: 1;
    }
    .tb-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.5rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.72);
    }

    /* Small inset photo */
    .tour-photo-inset {
      position: absolute;
      bottom: 0;
      right: -2rem;
      width: 42%;
      aspect-ratio: 1;
      overflow: hidden;
      border: 4px solid var(--paper);
      box-shadow: 0 8px 32px rgba(13,25,13,0.2);
    }
    .tour-photo-inset img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Right: tour list */
    .tour-list {
      display: flex;
      flex-direction: column;
      padding-top: 0.5rem;
    }

    .tour-item {
      display: grid;
      grid-template-columns: 2.5rem 1fr auto;
      gap: 1.25rem;
      align-items: center;
      padding: 1.75rem 0;
      border-bottom: 1px solid rgba(13,25,13,0.08);
      cursor: default;
      transition: padding 0.2s, background 0.2s;
    }
    .tour-item:first-child { border-top: 1px solid rgba(13,25,13,0.08); }
    .tour-item:hover { padding-left: 0.5rem; padding-right: 0.5rem; background: rgba(13,25,13,0.022); }

    .tour-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 0.68rem;
      color: var(--ember);
      letter-spacing: 0.08em;
    }

    .tour-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 1.25rem;
      text-transform: uppercase;
      color: var(--ink);
      line-height: 1;
      margin-bottom: 0.35rem;
      transition: color 0.2s;
    }
    .tour-item:hover .tour-name { color: var(--ember); }

    .tour-meta {
      font-size: 0.7rem;
      font-style: italic;
      color: var(--ash);
      line-height: 1.6;
    }
    .tour-meta strong { font-style: normal; font-weight: 500; color: var(--ink); }

    .tour-diff {
      display: flex;
      gap: 4px;
      flex-shrink: 0;
    }
    .dd {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: rgba(13,25,13,0.1);
    }
    .dd.on { background: var(--ember); }

    .tour-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.8rem;
      margin-top: 2.5rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--forest);
      text-decoration: none;
      border-bottom: 2px solid var(--forest);
      padding-bottom: 0.3rem;
      transition: color 0.2s, border-color 0.2s;
    }
    .tour-cta:hover { color: var(--ember); border-color: var(--ember); }

    /* ========== SECTION WERKSTATT ========== */
    .section-werkstatt {
      background: var(--forest);
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 640px;
    }

    .wk-photo {
      position: relative;
      overflow: hidden;
    }
    .wk-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: saturate(0.65);
      transition: filter 0.6s, transform 0.8s;
    }
    .section-werkstatt:hover .wk-photo img {
      filter: saturate(0.85);
      transform: scale(1.03);
    }
    .wk-photo::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, transparent 55%, var(--forest) 100%);
    }

    .wk-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 6rem 5rem 6rem 3.5rem;
    }

    .wk-items {
      display: flex;
      flex-direction: column;
      gap: 2.25rem;
      margin-top: 2.75rem;
    }

    .wk-item {
      display: flex;
      gap: 1.5rem;
      align-items: flex-start;
    }

    .wk-icon {
      width: 2.6rem;
      height: 2.6rem;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
      clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 6px 100%, 0 calc(100% - 6px));
      transition: background 0.2s;
    }
    .wk-item:hover .wk-icon { background: rgba(200,83,26,0.2); }

    .wk-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 1.05rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #fff;
      margin-bottom: 0.22rem;
    }
    .wk-desc {
      font-size: 0.74rem;
      font-style: italic;
      color: rgba(255,255,255,0.42);
      line-height: 1.75;
    }

    .sec-title-white {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(2rem, 3.5vw, 3.4rem);
      line-height: 0.88;
      text-transform: uppercase;
      color: #fff;
    }
    .sec-title-white .g {
      -webkit-text-stroke: 1.5px rgba(255,255,255,0.2);
      color: transparent;
    }

    /* ========== SECTION COMMUNITY ========== */
    .section-community {
      background: var(--snow);
      padding: 8rem 4rem;
    }

    .community-inner {
      max-width: 1600px;
      margin: 0 auto;
    }

    .community-layout {
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      gap: 7rem;
      margin-top: 5rem;
      align-items: center;
    }

    .comm-quote {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(2rem, 4vw, 3.8rem);
      line-height: 0.88;
      text-transform: uppercase;
      color: var(--ink);
      margin-bottom: 2rem;
    }
    .comm-quote .accent { color: var(--ember); }
    .comm-quote .g {
      -webkit-text-stroke: 1.5px rgba(13,25,13,0.13);
      color: transparent;
    }

    .comm-body {
      font-size: 0.88rem;
      font-style: italic;
      color: var(--ash);
      line-height: 1.9;
      max-width: 44ch;
      margin-bottom: 2.5rem;
    }

    .comm-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
    }
    .ctag {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 0.38rem 0.95rem;
      border: 1px solid rgba(13,25,13,0.13);
      color: var(--ash);
      transition: border-color 0.2s, color 0.2s;
      cursor: default;
    }
    .ctag:hover { border-color: var(--ember); color: var(--ember); }

    /* Photo mosaic */
    .comm-mosaic {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 260px 200px;
      gap: 0.75rem;
    }
    .cm-photo {
      position: relative;
      overflow: hidden;
    }
    .cm-photo:first-child { grid-column: span 2; }
    .cm-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.65s ease;
    }
    .cm-photo:hover img { transform: scale(1.05); }
    .cm-photo::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13,25,13,0.38) 0%, transparent 55%);
    }

    /* ========== SECTION CTA ========== */
