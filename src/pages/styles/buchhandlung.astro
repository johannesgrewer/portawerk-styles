---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Seitenblick — Buchhandlung &amp; Lesecafé | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Lora:ital,wght@0,400;1,400&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --cream:   #FAF7F2;
      --warm:    #F3E9D8;
      --paper:   #EAD9C0;
      --brown:   #2C1A0E;
      --mid:     #5C3820;
      --sienna:  #9B3A18;
      --rust:    #C04828;
      --gold:    #C8853A;
      --muted:   rgba(44,26,14,0.45);
      --rule:    rgba(44,26,14,0.09);
    }

    body {
      background: var(--cream);
      color: var(--brown);
      font-family: 'Source Sans 3', sans-serif;
      overflow-x: hidden;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      inset: 0 0 auto;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.2rem 3.5rem;
      background: rgba(250,247,242,0.96);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--rule);
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: var(--brown);
    }
    .nav-logo span {
      font-weight: 400;
      font-style: italic;
      color: var(--sienna);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.775rem;
      font-weight: 400;
      letter-spacing: 0.06em;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--brown); }
    .nav-cta {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--sienna);
      border: 1.5px solid var(--sienna);
      padding: 0.55rem 1.4rem;
      text-decoration: none;
      transition: all 0.2s;
    }
    .nav-cta:hover { background: var(--sienna); color: #fff; }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      padding-top: 64px;
      display: grid;
      grid-template-columns: 52% 48%;
    }
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 5rem 4.5rem 5rem 5rem;
      gap: 2rem;
      border-right: 1px solid var(--rule);
    }
    .eyebrow {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--sienna);
    }
    .hero-headline {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: clamp(3rem, 5vw, 4.8rem);
      line-height: 1.1;
      color: var(--brown);
    }
    .hero-headline em {
      font-style: italic;
      font-weight: 400;
      color: var(--sienna);
    }
    .hero-rule {
      width: 2.5rem;
      height: 2px;
      background: var(--gold);
    }
    .hero-body {
      font-family: 'Lora', serif;
      font-size: 0.95rem;
      font-weight: 400;
      line-height: 1.9;
      color: var(--muted);
      max-width: 42ch;
    }

    /* Book widget */
    .book-widget {
      border: 1px solid var(--rule);
      background: #fff;
      overflow: hidden;
    }
    .bw-header {
      background: var(--brown);
      padding: 0.55rem 1.1rem;
      font-size: 0.55rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(250,247,242,0.4);
    }
    .bw-row {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.9rem 1.1rem;
      border-bottom: 1px solid var(--rule);
      transition: background 0.2s;
      cursor: default;
    }
    .bw-row:last-child { border-bottom: none; }
    .bw-row:hover { background: rgba(44,26,14,0.03); }
    .bw-spine {
      width: 5px;
      align-self: stretch;
      border-radius: 1px;
      flex-shrink: 0;
      min-height: 36px;
      transition: transform 0.2s;
    }
    .bw-row:hover .bw-spine { transform: scaleY(1.15); }
    .bw-info { flex: 1; min-width: 0; }
    .bw-title {
      font-family: 'Playfair Display', serif;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--brown);
      transition: color 0.2s;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .bw-row:hover .bw-title { color: var(--sienna); }
    .bw-author {
      font-family: 'Lora', serif;
      font-size: 0.67rem;
      font-style: italic;
      color: var(--muted);
      margin-top: 0.1rem;
    }
    .bw-tag {
      font-size: 0.5rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.22rem 0.55rem;
      background: var(--warm);
      color: var(--muted);
      white-space: nowrap;
      flex-shrink: 0;
    }
    .hero-cta {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .btn-primary {
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #fff;
      background: var(--brown);
      padding: 0.95rem 2.2rem;
      text-decoration: none;
      transition: background 0.2s;
      white-space: nowrap;
    }
    .btn-primary:hover { background: var(--sienna); }
    .btn-ghost {
      font-family: 'Lora', serif;
      font-size: 0.88rem;
      font-style: italic;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 1px;
      transition: color 0.2s, border-color 0.2s;
      white-space: nowrap;
    }
    .btn-ghost:hover { color: var(--sienna); border-color: var(--sienna); }

    /* Hero right: atmospheric photo */
    .hero-right {
      position: relative;
      overflow: hidden;
    }
    .hero-right img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: sepia(14%) brightness(0.9);
      transition: transform 10s ease;
    }
    .hero-right:hover img { transform: scale(1.04); }
    .hero-right-gradient {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to right,
        rgba(250,247,242,0.2) 0%,
        transparent 35%
      ),
      linear-gradient(
        to top,
        rgba(44,26,14,0.65) 0%,
        transparent 55%
      );
    }
    .hero-right-caption {
      position: absolute;
      bottom: 2.5rem;
      left: 2.5rem;
      right: 2.5rem;
    }
    .hrc-quote {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      font-style: italic;
      font-weight: 400;
      color: rgba(250,247,242,0.88);
      line-height: 1.55;
      max-width: 30ch;
      margin-bottom: 0.65rem;
    }
    .hrc-source {
      font-size: 0.6rem;
      font-weight: 400;
      color: rgba(250,247,242,0.45);
      letter-spacing: 0.08em;
    }

    /* ─── SECTION HEADER (shared) ─── */
    .section-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 3.5rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--rule);
    }
    .sh-eyebrow {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--sienna);
      margin-bottom: 0.6rem;
    }
    .sh-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 3.5vw, 3.2rem);
      font-weight: 700;
      color: var(--brown);
      line-height: 1.1;
    }
    .sh-title em { font-style: italic; font-weight: 400; color: var(--sienna); }
    .sh-link {
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid rgba(44,26,14,0.2);
      padding-bottom: 2px;
      white-space: nowrap;
      flex-shrink: 0;
      margin-left: 2rem;
      transition: color 0.2s;
    }
    .sh-link:hover { color: var(--sienna); }

    /* ─── SECTION 2: EMPFEHLUNGEN ─── */
    .empfehlungen {
      padding: 6rem 5rem;
      background: var(--warm);
      border-top: 1px solid var(--rule);
    }
    .book-editorial {
      display: grid;
      grid-template-columns: 5fr 7fr;
      gap: 2px;
      min-height: 500px;
    }
    .book-feature {
      position: relative;
      overflow: hidden;
      min-height: 400px;
    }
    .book-feature img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: sepia(8%);
      transition: transform 0.65s ease, filter 0.65s ease;
    }
    .book-feature:hover img { transform: scale(1.04); filter: sepia(0%); }
    .book-feature-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(44,26,14,0.9) 0%,
        rgba(44,26,14,0.2) 55%,
        transparent 100%
      );
    }
    .book-feature-info {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 2.5rem;
    }
    .bfi-badge {
      display: inline-block;
      font-size: 0.5rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(200,133,58,0.45);
      padding: 0.25rem 0.65rem;
      margin-bottom: 0.85rem;
    }
    .bfi-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.5rem, 2.5vw, 2.2rem);
      font-weight: 700;
      font-style: italic;
      color: #FAF7F2;
      line-height: 1.25;
      margin-bottom: 0.35rem;
    }
    .bfi-author {
      font-family: 'Lora', serif;
      font-size: 0.75rem;
      font-style: italic;
      font-weight: 400;
      color: rgba(250,247,242,0.55);
      margin-bottom: 1rem;
    }
    .bfi-desc {
      font-size: 0.82rem;
      font-weight: 300;
      color: rgba(250,247,242,0.5);
      line-height: 1.75;
      max-width: 36ch;
    }
    .book-side {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .book-small {
      flex: 1;
      position: relative;
      overflow: hidden;
      min-height: 160px;
    }
    .book-small img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: sepia(8%);
      transition: transform 0.55s ease, filter 0.55s ease;
    }
    .book-small:hover img { transform: scale(1.06); filter: sepia(0%); }
    .book-small-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(44,26,14,0.82) 0%, transparent 65%);
    }
    .book-small-info {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 1.25rem 1.5rem;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
    }
    .bsi-title {
      font-family: 'Playfair Display', serif;
      font-size: 0.95rem;
      font-style: italic;
      color: #FAF7F2;
      line-height: 1.3;
    }
    .bsi-tag {
      font-size: 0.48rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      white-space: nowrap;
      margin-left: 0.75rem;
      flex-shrink: 0;
    }

    /* ─── SECTION 3: LESUNGEN ─── */
    .lesungen {
      padding: 6rem 5rem;
      background: var(--brown);
    }
    .lesungen .section-head {
      border-bottom-color: rgba(250,247,242,0.08);
    }
    .lesungen .sh-eyebrow { color: var(--gold); }
    .lesungen .sh-title { color: #FAF7F2; }
    .lesungen .sh-title em { color: var(--gold); }
    .lesungen .sh-link {
      color: rgba(250,247,242,0.3);
      border-color: rgba(250,247,242,0.18);
    }
    .lesungen .sh-link:hover { color: var(--gold); }
    .event-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(250,247,242,0.07);
    }
    .event-card {
      background: var(--brown);
      padding: 2.5rem;
      transition: background 0.25s;
      cursor: default;
    }
    .event-card:hover { background: rgba(200,133,58,0.07); }
    .event-date {
      display: flex;
      align-items: baseline;
      gap: 0.4rem;
      margin-bottom: 1.75rem;
    }
    .ed-day {
      font-family: 'Playfair Display', serif;
      font-size: 3.5rem;
      font-weight: 900;
      color: rgba(250,247,242,0.07);
      line-height: 1;
    }
    .ed-month {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
    }
    .event-label {
      font-size: 0.5rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(250,247,242,0.22);
      margin-bottom: 0.5rem;
    }
    .event-author {
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      font-weight: 700;
      color: rgba(250,247,242,0.9);
      margin-bottom: 0.2rem;
    }
    .event-book {
      font-family: 'Lora', serif;
      font-size: 0.85rem;
      font-style: italic;
      color: var(--gold);
      margin-bottom: 1rem;
    }
    .event-desc {
      font-size: 0.82rem;
      font-weight: 300;
      color: rgba(250,247,242,0.42);
      line-height: 1.8;
    }
    .event-footer {
      margin-top: 1.75rem;
      padding-top: 1.25rem;
      border-top: 1px solid rgba(250,247,242,0.07);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .event-time {
      font-size: 0.6rem;
      font-weight: 400;
      color: rgba(250,247,242,0.28);
      letter-spacing: 0.05em;
    }
    .event-link {
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      border-bottom: 1px solid rgba(200,133,58,0.3);
      padding-bottom: 1px;
      white-space: nowrap;
      flex-shrink: 0;
      transition: border-color 0.2s;
    }
    .event-link:hover { border-color: var(--gold); }

    /* ─── SECTION 4: ÜBER UNS ─── */
    .ueber-uns {
      display: grid;
      grid-template-columns: 42% 58%;
      min-height: 600px;
      border-top: 1px solid var(--rule);
    }
    .uu-text {
      background: var(--cream);
      padding: 6rem 4.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.75rem;
      border-right: 1px solid var(--rule);
    }
    .uu-eyebrow {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--sienna);
    }
    .uu-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 2.8vw, 2.6rem);
      font-weight: 700;
      color: var(--brown);
      line-height: 1.2;
    }
    .uu-title em { font-style: italic; font-weight: 400; color: var(--sienna); }
    .uu-body {
      font-family: 'Lora', serif;
      font-size: 0.9rem;
      font-weight: 400;
      line-height: 1.95;
      color: var(--muted);
      max-width: 46ch;
    }
    .uu-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      padding-top: 1.75rem;
      border-top: 1px solid var(--rule);
    }
    .uu-stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 2.2rem;
      font-weight: 700;
      color: var(--brown);
      line-height: 1;
    }
    .uu-stat-label {
      font-family: 'Lora', serif;
      font-size: 0.62rem;
      font-style: italic;
      font-weight: 400;
      color: var(--muted);
      margin-top: 0.3rem;
    }
    .uu-photo {
      position: relative;
      overflow: hidden;
    }
    .uu-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: sepia(10%) brightness(0.9);
      transition: transform 10s ease;
    }
    .uu-photo:hover img { transform: scale(1.03); }
    .uu-photo::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 1;
      background: linear-gradient(to right, rgba(250,247,242,0.18) 0%, transparent 25%);
    }

    /* ─── SECTION 5: LESECAFÉ ─── */
    .lesecafe {
      display: grid;
      grid-template-columns: 55% 45%;
      min-height: 580px;
      border-top: 1px solid var(--rule);
    }
    .lc-photo-wrap {
      display: flex;
      flex-direction: column;
    }
    .lc-photo-main {
      flex: 2;
      position: relative;
      overflow: hidden;
      min-height: 200px;
    }
    .lc-photo-main img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: sepia(8%);
      transition: transform 0.65s ease;
    }
    .lc-photo-main:hover img { transform: scale(1.04); }
    .lc-photo-sub {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 120px;
    }
    .lc-photo-sub-item {
      position: relative;
      overflow: hidden;
    }
    .lc-photo-sub-item + .lc-photo-sub-item {
      border-left: 2px solid var(--cream);
    }
    .lc-photo-sub-item img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: sepia(8%);
      transition: transform 0.55s ease;
    }
    .lc-photo-sub-item:hover img { transform: scale(1.07); }
    /* thin divider between main and sub */
    .lc-photo-main + .lc-photo-sub {
      border-top: 2px solid var(--cream);
    }
    .lc-content {
      background: var(--warm);
      padding: 5rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.75rem;
    }
    .lc-eyebrow {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--sienna);
    }
    .lc-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.6rem, 2.6vw, 2.4rem);
      font-weight: 700;
      color: var(--brown);
      line-height: 1.2;
    }
    .lc-title em { font-style: italic; font-weight: 400; color: var(--sienna); }
    .lc-body {
      font-family: 'Lora', serif;
      font-size: 0.88rem;
      font-weight: 400;
      line-height: 1.9;
      color: var(--muted);
      max-width: 44ch;
    }
    .lc-menu {
      border-top: 1px solid var(--rule);
      padding-top: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }
    .lc-menu-item {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
    }
    .lci-name {
      font-family: 'Lora', serif;
      font-size: 0.85rem;
      font-style: italic;
      color: var(--brown);
      white-space: nowrap;
    }
    .lci-dots {
      flex: 1;
      border-bottom: 1px dotted rgba(44,26,14,0.18);
    }
    .lci-price {
      font-size: 0.75rem;
      font-weight: 300;
      color: var(--muted);
      white-space: nowrap;
    }
    .lc-hours {
      font-family: 'Lora', serif;
      font-size: 0.72rem;
      font-style: italic;
      font-weight: 400;
      color: var(--muted);
    }
    .lc-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #fff;
      background: var(--brown);
      padding: 0.95rem 2rem;
      text-decoration: none;
      align-self: flex-start;
      transition: background 0.2s;
    }
    .lc-cta:hover { background: var(--sienna); }

    /* ─── FOOTER ─── */
    footer {
      background: var(--brown);
      padding: 2.75rem 5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }
    .footer-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 700;
