---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Seitenblick — Buchhandlung & Lesecafé | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=Nunito:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --brown:  #3D2B1F;
      --rust:   #B5451B;
      --bg:     #FAF6EF;
      --warm:   #F5EFE4;
      --paper:  #EDE4D4;
      --muted:  rgba(61,43,31,0.45);
      --rule:   rgba(61,43,31,0.1);
    }

    body {
      background: var(--bg);
      color: var(--brown);
      font-family: 'Nunito', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Paper grain texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: repeating-linear-gradient(
        90deg,
        transparent 0px,
        transparent 60px,
        rgba(61,43,31,0.008) 60px,
        rgba(61,43,31,0.008) 61px
      );
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 4rem;
      background: rgba(250,246,239,0.97);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--rule);
    }
    .nav-logo {
      font-family: 'Lora', serif;
      font-weight: 600;
      font-size: 1.15rem;
      letter-spacing: 0.04em;
      color: var(--brown);
    }
    .nav-logo span {
      font-weight: 400;
      font-style: italic;
      color: var(--rust);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Lora', serif;
      font-size: 0.8rem;
      font-weight: 400;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--brown); }
    .nav-cafe {
      font-family: 'Nunito', sans-serif;
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--rust);
      border: 1px solid var(--rust);
      padding: 0.5rem 1.25rem;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
      border-radius: 2px;
    }
    .nav-cafe:hover { background: var(--rust); color: #fff; }

    .hero {
      min-height: 100vh;
      padding-top: 68px;
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    /* LEFT */
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 5rem 4rem 5rem 4.5rem;
      gap: 2.5rem;
      border-right: 1px solid var(--rule);
    }

    .eyebrow {
      font-family: 'Lora', serif;
      font-style: italic;
      font-size: 0.82rem;
      color: var(--rust);
    }

    .hero-headline {
      font-family: 'Lora', serif;
      font-weight: 600;
      font-size: clamp(2.8rem, 5vw, 4.2rem);
      line-height: 1.2;
      color: var(--brown);
    }
    .hero-headline em {
      font-weight: 400;
      font-style: italic;
      color: var(--rust);
    }

    .rust-rule {
      width: 3rem;
      height: 1px;
      background: var(--rust);
    }

    .hero-body {
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 2;
      color: var(--muted);
      max-width: 44ch;
    }

    /* Book picks */
    .book-list {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--rule);
      border-radius: 4px;
      overflow: hidden;
      background: #fff;
    }
    .bl-header {
      background: var(--brown);
      padding: 0.45rem 1rem;
      font-family: 'Nunito', sans-serif;
      font-size: 0.52rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(250,246,239,0.5);
    }
    .book-row {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.85rem 1rem;
      border-bottom: 1px solid var(--rule);
    }
    .book-row:last-child { border-bottom: none; }
    .br-spine {
      width: 6px;
      align-self: stretch;
      border-radius: 1px;
      flex-shrink: 0;
    }
    .br-info { flex: 1; }
    .br-title {
      font-family: 'Lora', serif;
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--brown);
    }
    .br-author {
      font-size: 0.62rem;
      font-weight: 300;
      color: var(--muted);
      font-style: italic;
      margin-top: 0.05rem;
    }
    .br-tag {
      font-size: 0.48rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.2rem 0.5rem;
      background: var(--warm);
      color: var(--muted);
      border-radius: 2px;
    }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .cta-btn {
      font-family: 'Nunito', sans-serif;
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #fff;
      background: var(--brown);
      padding: 0.9rem 2rem;
      text-decoration: none;
      border-radius: 2px;
      transition: background 0.2s;
    }
    .cta-btn:hover { background: var(--rust); }
    .cta-link {
      font-family: 'Lora', serif;
      font-size: 0.88rem;
      font-style: italic;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 1px;
    }

    /* RIGHT */
    .hero-right {
      background: var(--warm);
      display: flex;
      flex-direction: column;
      padding: 5rem 4rem;
      gap: 2.5rem;
    }

    .right-label {
      font-family: 'Nunito', sans-serif;
      font-size: 0.52rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* Pull quote */
    .pull-quote {
      border-left: 3px solid var(--rust);
      padding-left: 1.5rem;
    }
    .pq-text {
      font-family: 'Lora', serif;
      font-size: 1.15rem;
      font-weight: 400;
      font-style: italic;
      color: var(--brown);
      line-height: 1.6;
    }
    .pq-source {
      font-size: 0.6rem;
      font-weight: 300;
      color: var(--muted);
      margin-top: 0.6rem;
      letter-spacing: 0.06em;
    }

    /* Genre pills */
    .genre-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .genre-pill {
      font-family: 'Lora', serif;
      font-size: 0.78rem;
      font-style: italic;
      color: var(--brown);
      background: #fff;
      border: 1px solid var(--rule);
      padding: 0.4rem 0.85rem;
      border-radius: 100px;
    }
    .genre-pill.active {
      background: var(--brown);
      color: var(--bg);
      border-color: var(--brown);
    }

    /* Café info */
    .cafe-block {
      background: var(--brown);
      border-radius: 6px;
      padding: 1.5rem;
      margin-top: auto;
    }
    .cb-label {
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(250,246,239,0.3);
      margin-bottom: 0.5rem;
    }
    .cb-title {
      font-family: 'Lora', serif;
      font-size: 1rem;
      font-weight: 600;
      color: rgba(250,246,239,0.9);
      margin-bottom: 0.4rem;
    }
    .cb-text {
      font-size: 0.78rem;
      font-weight: 300;
      color: rgba(250,246,239,0.55);
      line-height: 1.7;
    }
    .cb-hours {
      margin-top: 0.75rem;
      font-size: 0.62rem;
      font-weight: 400;
      color: var(--rust);
      letter-spacing: 0.04em;
    }
    /* === Animations & Micro-interactions === */
    @keyframes quoteGrow {
      from { border-left-width: 0; padding-left: 0; opacity: 0; }
      to   { border-left-width: 3px; padding-left: 1.5rem; opacity: 1; }
    }

    .book-row {
      transition: background 0.2s, padding-left 0.25s;
      cursor: default;
    }
    .book-row:hover {
      background: rgba(61,43,31,0.04);
      padding-left: 0.5rem;
    }
    .br-title { transition: color 0.2s; }
    .book-row:hover .br-title { color: var(--rust); }
    .br-spine {
      transition: transform 0.2s;
    }
    .book-row:hover .br-spine { transform: scaleY(1.15); }

    .genre-pill {
      transition: background 0.2s, color 0.2s, border-color 0.2s;
      cursor: default;
    }
    .genre-pill:not(.active):hover {
      background: var(--brown);
      color: var(--bg);
      border-color: var(--brown);
    }

    .pull-quote {
      animation: quoteGrow 0.6s ease-out both;
      animation-delay: 0.2s;
    }

    .cafe-block {
      transition: box-shadow 0.3s;
      cursor: default;
    }
    .cafe-block:hover {
      box-shadow: inset 0 0 0 1px rgba(181,69,27,0.3);
    }

    .cta-btn {
      position: relative;
      overflow: hidden;
    }
    .cta-btn::after {
      content: '';
      position: absolute;
      top: 0; left: -60%;
      width: 40%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
      transition: left 0.5s;
    }
    .cta-btn:hover::after { left: 150%; }


    /* ===== SECTION 2 — BÜCHER ===== */
    .buecher {
      padding: 6rem 5rem;
      background: var(--warm);
      border-top: 1px solid var(--rule);
    }
    .buecher-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--rule);
    }
    .buecher-eyebrow {
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--rust);
      margin-bottom: 0.6rem;
    }
    .buecher-title {
      font-family: 'Libre Baskerville', serif;
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      font-weight: 700;
      color: var(--brown);
      line-height: 1.1;
    }
    .buecher-title em { font-style: italic; color: var(--rust); }
    .buecher-link {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid rgba(61,43,31,0.2);
      padding-bottom: 2px;
      white-space: nowrap;
      transition: color 0.2s;
    }
    .buecher-link:hover { color: var(--rust); }

    .book-photo-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    .book-photo-card {
      position: relative;
      overflow: hidden;
    }
    .book-photo-card img {
      width: 100%;
      height: 400px;
      object-fit: cover;
      display: block;
      transition: transform 0.55s ease;
      filter: sepia(10%);
    }
    .book-photo-card:hover img { transform: scale(1.05); filter: sepia(0%); }
    .book-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(61,43,31,0.85) 0%, transparent 55%);
    }
    .book-photo-info {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 2rem;
    }
    .book-photo-genre {
      font-size: 0.5rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--rust);
      margin-bottom: 0.4rem;
    }
    .book-photo-title {
      font-family: 'Libre Baskerville', serif;
      font-size: 1.1rem;
      font-style: italic;
      color: #FAF6EF;
      line-height: 1.3;
    }

    /* ===== SECTION 3 — LESECAFÉ ===== */
    .lesecafe {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 560px;
    }
    .lc-photo {
      position: relative;
      overflow: hidden;
    }
    .lc-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: sepia(8%);
    }
    .lc-text {
      background: var(--brown);
      padding: 5rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.75rem;
    }
    .lc-eyebrow {
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--rust);
    }
    .lc-title {
      font-family: 'Libre Baskerville', serif;
      font-size: clamp(1.6rem, 2.8vw, 2.4rem);
      font-weight: 700;
      font-style: italic;
      color: var(--bg);
      line-height: 1.25;
    }
    .lc-body {
      font-size: 0.88rem;
      font-weight: 400;
      line-height: 1.95;
      color: rgba(250,246,239,0.55);
      max-width: 46ch;
    }
    .lc-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--rust);
      padding: 0.9rem 2rem;
      text-decoration: none;
      align-self: flex-start;
      transition: background 0.2s;
    }
    .lc-cta:hover { background: #9a3a14; }

    @media (max-width: 1024px) {
      .book-photo-grid { grid-template-columns: 1fr 1fr; }
      .book-photo-card:last-child { grid-column: 1 / -1; }
      .book-photo-card:last-child img { height: 280px; }
      .lesecafe { grid-template-columns: 1fr; }
      .lc-photo { height: 380px; position: relative; }
      .lc-photo img { position: absolute; }
    }
    @media (max-width: 768px) {
      .buecher { padding: 4rem 2rem; }
      .book-photo-grid { grid-template-columns: 1fr; }
      .book-photo-card:last-child { grid-column: auto; }
      .book-photo-card img, .book-photo-card:last-child img { height: 280px; }
      .lc-text { padding: 3.5rem 2rem; }
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Seiten<span>blick</span></div>
    <ul class="nav-links">
      <li><a href="#">Neu & Empfohlen</a></li>
      <li><a href="#">Genre</a></li>
      <li><a href="#">Lesungen</a></li>
      <li><a href="#">Café</a></li>
    </ul>
    <a href="#" class="nav-cafe">Tisch reservieren</a>
  </nav>

  <section class="hero">
    <div class="hero-left">
      <div class="eyebrow">Buchhandlung & Lesecafé · Trier</div>

      <h1 class="hero-headline">
        Jedes Buch<br>
        ein <em>Anfang.</em>
      </h1>

      <div class="rust-rule"></div>

      <p class="hero-body">
        Hier riecht es nach Papier und Kaffee.
        Wir verkaufen keine Bestseller-Listen,
        sondern Bücher, die wir selbst gelesen
        und für gut befunden haben.
      </p>

      <div class="book-list">
        <div class="bl-header">Unsere Empfehlungen</div>
        <div class="book-row">
          <div class="br-spine" style="background:#B5451B;"></div>
          <div class="br-info">
            <div class="br-title">Der Gesang der Flusskrebse</div>
            <div class="br-author">Delia Owens · Roman</div>
          </div>
          <span class="br-tag">Lesetipp</span>
        </div>
        <div class="book-row">
          <div class="br-spine" style="background:#3D2B1F;"></div>
          <div class="br-info">
            <div class="br-title">Stoner</div>
            <div class="br-author">John Williams · Roman</div>
          </div>
          <span class="br-tag">Klassiker</span>
        </div>
        <div class="book-row">
          <div class="br-spine" style="background:#7A5C3E;"></div>
          <div class="br-info">
            <div class="br-title">Atemschaukel</div>
            <div class="br-author">Herta Müller · Roman</div>
          </div>
          <span class="br-tag">Literatur</span>
        </div>
      </div>

      <div class="cta-row">
        <a href="#" class="cta-btn">Alle Bücher entdecken</a>
        <a href="#" class="cta-link">Lesung anfragen</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="right-label">Aus unserem Herzen</div>

      <div class="pull-quote">
        <div class="pq-text">
          „Ein Buch ist ein Spiegel.
          Wenn ein Affe hineinschaut,
          kann kein Apostel herausschauen."
        </div>
        <div class="pq-source">— Georg Christoph Lichtenberg</div>
      </div>

      <div class="right-label">Genres im Haus</div>

      <div class="genre-grid">
        <span class="genre-pill active">Belletristik</span>
        <span class="genre-pill">Sachbuch</span>
        <span class="genre-pill">Lyrik</span>
        <span class="genre-pill active">Kinder & Jugend</span>
        <span class="genre-pill">Philosophie</span>
        <span class="genre-pill">Geschichte</span>
        <span class="genre-pill">Kriminalroman</span>
        <span class="genre-pill active">Regionales</span>
        <span class="genre-pill">Reise</span>
        <span class="genre-pill">Bildband</span>
      </div>

      <div class="cafe-block">
        <div class="cb-label">Unser Lesecafé</div>
        <div class="cb-title">Kaffee & Kuchen zum Buch</div>
        <div class="cb-text">
          Im hinteren Teil des Ladens gibt es fünf Tische,
          zwei Sofas und einen Ofen. Wer kauft, darf bleiben.
          Espresso, Filterkaffee, selbst gebackener Kuchen.
        </div>
        <div class="cb-hours">Mo – Sa: 9:30 – 19:00 · So: 11:00 – 17:00</div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 2: BÜCHER ===== -->
  <section class="buecher">
    <div class="buecher-head">
      <div>
        <div class="buecher-eyebrow">Handverlesen & empfohlen</div>
        <h2 class="buecher-title">Bücher, die<br><em>bleiben.</em></h2>
      </div>
      <a href="#" class="buecher-link">Alle Empfehlungen →</a>
    </div>
    <div class="book-photo-grid">
      <div class="book-photo-card">
        <img src="https://images.unsplash.com/photo-1512820790803-83ca734da794?auto=format&fit=crop&w=800&h=600&q=80"
             alt="Bücher im Regal" loading="lazy" />
        <div class="book-photo-overlay"></div>
        <div class="book-photo-info">
          <div class="book-photo-genre">Belletristik</div>
          <div class="book-photo-title">Der Gesang<br>der Flusskrebse</div>
        </div>
      </div>
      <div class="book-photo-card">
        <img src="https://images.unsplash.com/photo-1481627834876-b7833e8f5570?auto=format&fit=crop&w=800&h=600&q=80"
             alt="Aufgeschlagenes Buch" loading="lazy" />
        <div class="book-photo-overlay"></div>
        <div class="book-photo-info">
          <div class="book-photo-genre">Klassiker</div>
          <div class="book-photo-title">Stoner</div>
        </div>
      </div>
      <div class="book-photo-card">
        <img src="https://images.unsplash.com/photo-1524995997946-a1c2e315a42f?auto=format&fit=crop&w=800&h=600&q=80"
             alt="Gemütliche Leseecke" loading="lazy" />
        <div class="book-photo-overlay"></div>
        <div class="book-photo-info">
          <div class="book-photo-genre">Literatur</div>
          <div class="book-photo-title">Atemschaukel</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 3: LESECAFÉ ===== -->
  <section class="lesecafe">
    <div class="lc-photo">
      <img src="https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=900&h=700&q=80"
           alt="Buchhandlung Atmosphäre mit Holzregalen" loading="lazy" />
    </div>
    <div class="lc-text">
      <div class="lc-eyebrow">Der Ort</div>
      <h2 class="lc-title">"Wer kauft,<br>darf bleiben."</h2>
      <p class="lc-body">
        Im hinteren Teil des Ladens stehen fünf Tische,
        zwei alte Sofas und ein Kachelofen. Es gibt
        Espresso, Filterkaffee und selbst gebackenen Kuchen —
        jeden Tag eine andere Sorte.
      </p>
      <p class="lc-body">
        Kein WLAN-Passwort auf Kassenbon. Kein Zeitlimit.
        Wer ein Buch kauft, gehört dazu.
      </p>
      <a href="#" class="lc-cta">Tisch reservieren →</a>
    </div>
  </section>

</body>
</html>
