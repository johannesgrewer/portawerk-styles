---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Klinge & Kamm — Barbershop & Herrenpflege | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Pinyon+Script&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --ink:      #1A1410;
      --leather:  #6B3A2A;
      --leather2: #8C4E37;
      --gold:     #C8973A;
      --gold2:    #E5B865;
      --cream:    #F5EFE4;
      --cream2:   #EDE3D2;
      --warm-mid: #3D2B1F;
      --rule:     rgba(200,151,58,0.2);
      --muted:    rgba(26,20,16,0.45);
    }

    body {
      background: var(--cream);
      color: var(--ink);
      font-family: 'Barlow', sans-serif;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ── BARBER STRIPE ── */
    .stripe-top {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 4px;
      background: repeating-linear-gradient(
        90deg,
        var(--leather) 0px, var(--leather) 12px,
        var(--cream) 12px, var(--cream) 20px,
        var(--ink) 20px, var(--ink) 32px,
        var(--cream) 32px, var(--cream) 40px
      );
      background-size: 40px 4px;
      animation: stripemove 0.8s linear infinite;
      z-index: 300;
    }
    @keyframes stripemove {
      from { background-position: 0 0; }
      to   { background-position: -40px 0; }
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 4px; left: 0; right: 0;
      z-index: 200;
      background: var(--ink);
      border-bottom: 1px solid rgba(200,151,58,0.15);
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 3rem;
      height: 64px;
    }
    .nav-logo {
      display: flex;
      flex-direction: column;
      line-height: 1;
    }
    .nav-logo-script {
      font-family: 'Pinyon Script', cursive;
      font-size: 1.5rem;
      color: var(--gold);
      line-height: 1;
    }
    .nav-logo-sub {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.48rem;
      font-weight: 600;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(245,239,228,0.3);
      margin-top: 1px;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(245,239,228,0.4);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--gold); }
    .nav-book {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--gold);
      padding: 0.65rem 1.6rem;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
    }
    .nav-book:hover { background: var(--gold2); }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      padding-top: 68px;
      display: grid;
      grid-template-columns: 1fr 480px;
      max-width: 1400px;
      margin: 0 auto;
    }

    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 5rem 4rem 5rem 3rem;
      gap: 2rem;
    }

    .eyebrow {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.55rem;
      font-weight: 600;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--leather);
    }
    .eyebrow::before {
      content: '';
      display: block;
      width: 28px;
      height: 1px;
      background: var(--leather);
      flex-shrink: 0;
    }

    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 700;
      font-size: clamp(3.5rem, 7vw, 6.5rem);
      line-height: 0.93;
      color: var(--ink);
      letter-spacing: -0.01em;
    }
    .hero-title .script-accent {
      font-family: 'Pinyon Script', cursive;
      font-size: 1.2em;
      font-weight: 400;
      color: var(--leather);
      display: block;
      line-height: 1;
      margin-top: -0.1em;
    }

    .hero-divider {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .hero-divider::before,
    .hero-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--rule);
    }
    .hero-divider-ornament {
      font-family: 'Pinyon Script', cursive;
      font-size: 1.2rem;
      color: var(--gold);
      line-height: 1;
    }

    .hero-body {
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 1.9;
      color: var(--muted);
      max-width: 42ch;
    }

    /* Service tiles */
    .service-tiles {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
    }
    .tile {
      background: var(--cream);
      padding: 1rem 1.1rem 0.9rem;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      transition: background 0.2s;
      cursor: default;
    }
    .tile:hover { background: var(--cream2); }
    .tile-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .tile-price {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--leather);
      line-height: 1;
    }

    .hero-cta-row {
      display: flex;
      align-items: center;
      gap: 1.75rem;
    }
    .btn-primary {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--cream);
      background: var(--ink);
      padding: 0.95rem 2.2rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .btn-primary:hover { background: var(--warm-mid); }
    .btn-ghost {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 2px;
      transition: color 0.2s, border-color 0.2s;
    }
    .btn-ghost:hover { color: var(--leather); border-color: var(--leather); }

    /* Hero Right */
    .hero-right {
      position: relative;
      overflow: hidden;
    }
    .hero-right img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: sepia(20%);
      transition: transform 0.8s ease;
    }
    .hero-right:hover img { transform: scale(1.03); }
    .hero-right-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, rgba(245,239,228,0.3) 0%, transparent 40%),
                  linear-gradient(to top, rgba(26,20,16,0.8) 0%, transparent 50%);
    }
    .hero-right-badge {
      position: absolute;
      bottom: 2.5rem;
      left: 2rem;
      right: 2rem;
    }
    .badge-script {
      font-family: 'Pinyon Script', cursive;
      font-size: 2rem;
      color: var(--gold);
      line-height: 1.2;
      display: block;
    }
    .badge-sub {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.52rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(245,239,228,0.5);
      margin-top: 0.3rem;
    }

    /* ── SECTION: ATMOSPHERE ── */
    .atmosphere {
      background: var(--ink);
      overflow: hidden;
    }
    .atm-inner {
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 520px 1fr;
      min-height: 580px;
    }
    .atm-text {
      padding: 5.5rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.75rem;
    }
    .section-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.55rem;
      font-weight: 600;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--gold);
    }
    .atm-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      font-size: clamp(2.2rem, 3.5vw, 3.2rem);
      line-height: 1.1;
      color: var(--cream);
    }
    .atm-title em {
      font-style: italic;
      color: var(--gold2);
    }
    .atm-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.95;
      color: rgba(245,239,228,0.5);
      max-width: 40ch;
    }
    .atm-facts {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }
    .atm-fact {
      border-left: 2px solid var(--leather);
      padding: 0.6rem 1rem;
    }
    .atm-fact-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--gold);
      line-height: 1;
    }
    .atm-fact-label {
      font-size: 0.58rem;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(245,239,228,0.3);
      margin-top: 0.2rem;
    }
    .atm-photos {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 3px;
    }
    .atm-photo {
      position: relative;
      overflow: hidden;
    }
    .atm-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: sepia(15%) brightness(0.85);
      transition: transform 0.55s ease, filter 0.4s;
    }
    .atm-photo:hover img {
      transform: scale(1.06);
      filter: sepia(5%) brightness(1);
    }
    .atm-photo-label {
      position: absolute;
      bottom: 0.8rem;
      left: 0.9rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.5rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(245,239,228,0.6);
    }

    /* ── SECTION: TEAM ── */
    .team-section {
      padding: 7rem 3rem;
      max-width: 1400px;
      margin: 0 auto;
    }
    .team-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 3.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--rule);
    }
    .team-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 700;
      font-size: clamp(2.2rem, 4vw, 3.5rem);
      color: var(--ink);
      line-height: 1;
    }
    .team-title .script {
      font-family: 'Pinyon Script', cursive;
      font-weight: 400;
      color: var(--leather);
      font-size: 1.05em;
    }
    .team-tagline {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.05rem;
      font-weight: 300;
      font-style: italic;
      color: var(--muted);
      max-width: 28ch;
      text-align: right;
      line-height: 1.5;
    }
    .team-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    .barber-card {
      background: var(--cream2);
      overflow: hidden;
      position: relative;
      transition: transform 0.3s;
    }
    .barber-card:hover { transform: translateY(-4px); }
    .barber-photo {
      position: relative;
      overflow: hidden;
      height: 420px;
    }
    .barber-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
      filter: sepia(15%) grayscale(20%);
      transition: transform 0.6s ease, filter 0.4s;
    }
    .barber-card:hover .barber-photo img {
      transform: scale(1.05);
      filter: sepia(5%) grayscale(0%);
    }
    .barber-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(26,20,16,0.75) 0%, transparent 55%);
    }
    .barber-rank {
      position: absolute;
      top: 1rem;
      right: 1rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.48rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--gold);
      padding: 0.3rem 0.7rem;
    }
    .barber-name-overlay {
      position: absolute;
      bottom: 1.25rem;
      left: 1.5rem;
    }
    .bon-script {
      font-family: 'Pinyon Script', cursive;
      font-size: 1.6rem;
      color: var(--gold);
      line-height: 1;
      display: block;
    }
    .barber-info {
      padding: 1.5rem 1.75rem 2rem;
      border-top: 2px solid var(--leather);
    }
    .barber-spec {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--leather);
      margin-bottom: 0.5rem;
    }
    .barber-desc {
      font-size: 0.84rem;
      font-weight: 300;
      line-height: 1.8;
      color: var(--muted);
    }
    .barber-avail {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 1rem;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.52rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .avail-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .avail-yes .avail-dot { background: #6DC46D; box-shadow: 0 0 6px rgba(109,196,109,0.5); }
    .avail-yes { color: #6DC46D; }
    .avail-no .avail-dot { background: #E07A7A; }
    .avail-no { color: #E07A7A; }

    /* ── SECTION: SERVICES ── */
    .services-section {
      background: var(--ink);
    }
    .services-inner {
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 560px;
      min-height: 600px;
    }
    .services-content {
      padding: 6rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 2.5rem;
    }
    .services-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 700;
      font-size: clamp(2rem, 3.5vw, 3rem);
      color: var(--cream);
      line-height: 1.1;
    }
    .services-title .script {
      font-family: 'Pinyon Script', cursive;
      font-weight: 400;
      color: var(--gold);
      font-size: 1.1em;
    }
    .price-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .price-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.1rem 0;
      border-bottom: 1px solid rgba(200,151,58,0.1);
      cursor: default;
      transition: padding-left 0.2s;
    }
    .price-row:hover { padding-left: 0.5rem; }
    .pr-left { display: flex; align-items: center; gap: 1rem; }
    .pr-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.9rem;
      font-weight: 300;
      color: rgba(200,151,58,0.3);
      width: 1.5ch;
    }
    .pr-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.88rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--cream);
    }
    .pr-dots {
      flex: 1;
      border-bottom: 1px dotted rgba(200,151,58,0.2);
      margin: 0 1rem;
      position: relative;
      top: 1px;
    }
    .pr-price {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--gold);
    }
    .services-photo {
      position: relative;
      overflow: hidden;
    }
    .services-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: sepia(25%) brightness(0.75);
      transition: transform 0.7s ease;
    }
    .services-section:hover .services-photo img { transform: scale(1.04); }
    .services-photo-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, rgba(26,20,16,0.6) 0%, transparent 60%);
    }

    /* ── SECTION: BUCHUNG ── */
    .booking-section {
      padding: 7rem 3rem;
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .booking-left {}
    .booking-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 700;
      font-size: clamp(2.5rem, 4vw, 3.8rem);
      line-height: 1.0;
      color: var(--ink);
      margin-bottom: 1.5rem;
    }
    .booking-title .script {
      font-family: 'Pinyon Script', cursive;
      font-weight: 400;
      color: var(--leather);
      font-size: 1.1em;
    }
    .booking-body {
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 1.9;
      color: var(--muted);
      max-width: 44ch;
      margin-bottom: 2.5rem;
    }
    .booking-cta-group {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .booking-info-grid {
      display: flex;
      flex-direction: column;
      gap: 0;
      background: var(--cream2);
      border: 1px solid var(--rule);
      border-top: 3px solid var(--leather);
    }
    .info-row {
      display: flex;
      padding: 1.25rem 1.75rem;
      gap: 2rem;
      border-bottom: 1px solid var(--rule);
      align-items: flex-start;
    }
    .info-row:last-child { border-bottom: none; }
    .info-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.52rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--leather);
      flex-shrink: 0;
      width: 80px;
      padding-top: 0.15rem;
    }
    .info-val {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.05rem;
      font-weight: 400;
      color: var(--ink);
      line-height: 1.5;
    }

    /* ── FOOTER ── */
    footer {
      background: var(--warm-mid);
      padding: 3rem;
    }
    .footer-inner {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .footer-logo {
      font-family: 'Pinyon Script', cursive;
      font-size: 2rem;
      color: var(--gold);
    }
    .footer-copy {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.52rem;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(245,239,228,0.3);
    }
    .footer-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .footer-links a {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(245,239,228,0.35);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--gold); }

    /* ── RESPONSIVE ── */
    @media (max-width: 1100px) {
      .hero { grid-template-columns: 1fr; }
      .hero-right { height: 440px; }
      .hero-right img { position: absolute; }
      .atm-inner { grid-template-columns: 1fr; }
      .atm-photos { height: 400px; grid-template-rows: 1fr; grid-template-columns: repeat(4, 1fr); }
      .services-inner { grid-template-columns: 1fr; }
      .services-photo { height: 380px; position: relative; }
      .services-photo img { position: absolute; }
      .booking-section { grid-template-columns: 1fr; gap: 3rem; }
    }
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-inner { padding: 0 1.5rem; }
      .hero-left { padding: 3.5rem 1.5rem; }
      .service-tiles { grid-template-columns: 1fr 1fr; }
      .team-grid { grid-template-columns: 1fr; max-width: 380px; margin: 0 auto; }
