---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Klinge & Kamm — Barbershop & Herrenpflege | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Work+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --navy:  #1C2B4A;
      --red:   #CC2936;
      --cream: #F5F2EC;
      --bg:    #F5F2EC;
      --dark:  #111820;
      --muted: rgba(28,43,74,0.45);
      --rule:  rgba(28,43,74,0.1);
    }

    body {
      background: var(--bg);
      color: var(--navy);
      font-family: 'Work Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Barber pole stripe at top */
    .barber-stripe {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 5px;
      background: repeating-linear-gradient(
        90deg,
        var(--red) 0px, var(--red) 10px,
        var(--cream) 10px, var(--cream) 20px,
        var(--navy) 20px, var(--navy) 30px,
        var(--cream) 30px, var(--cream) 40px
      );
      z-index: 200;
    }

    nav {
      position: fixed;
      top: 5px; left: 0; right: 0;
      z-index: 100;
      background: var(--navy);
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.1rem 3.5rem;
      max-width: 1600px;
      margin: 0 auto;
    }
    .nav-logo {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--cream);
    }
    .nav-logo span { color: var(--red); }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(245,242,236,0.35);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--cream); }
    .nav-book {
      font-family: 'Oswald', sans-serif;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--navy);
      background: var(--cream);
      padding: 0.6rem 1.5rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .nav-book:hover { background: var(--red); color: #fff; }

    .hero-wrap {
      background: var(--bg);
    }

    .hero {
      min-height: 100vh;
      padding-top: 62px;
      display: grid;
      grid-template-columns: 1fr 420px;
      max-width: 1600px;
      margin: 0 auto;
      width: 100%;
    }

    /* LEFT */
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 3.5rem 4rem 4.5rem;
      gap: 2.5rem;
      border-right: 3px solid var(--navy);
    }

    .eyebrow {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--red);
    }
    .eyebrow-bar {
      width: 20px;
      height: 2px;
      background: var(--red);
      flex-shrink: 0;
    }

    .hero-headline {
      font-family: 'Oswald', sans-serif;
      font-weight: 700;
      font-size: clamp(3rem, 6.5vw, 5.5rem);
      line-height: 0.95;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      color: var(--navy);
    }
    .hero-headline .red { color: var(--red); }

    .hero-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.9;
      color: var(--muted);
      max-width: 44ch;
    }

    /* Services list */
    .service-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
    }
    .service-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.9rem 1.1rem;
      background: #fff;
      border: 1px solid var(--rule);
      border-top: 3px solid var(--navy);
    }
    .service-item:hover { border-top-color: var(--red); }
    .si-name {
      font-family: 'Oswald', sans-serif;
      font-size: 0.88rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--navy);
    }
    .si-price {
      font-family: 'Oswald', sans-serif;
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--red);
    }

    .cta-row {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .cta-btn {
      font-family: 'Oswald', sans-serif;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--cream);
      background: var(--navy);
      padding: 0.9rem 2rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .cta-btn:hover { background: var(--red); }
    .cta-link {
      font-size: 0.62rem;
      font-weight: 400;
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 1px;
    }

    /* RIGHT — dark panel */
    .hero-right {
      background: var(--dark);
      display: flex;
      flex-direction: column;
    }

    /* Masthead quote */
    .right-masthead {
      padding: 3rem 2.5rem 2rem;
      border-bottom: 1px solid rgba(245,242,236,0.06);
    }
    .rm-label {
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(245,242,236,0.2);
      margin-bottom: 0.75rem;
    }
    .rm-quote {
      font-family: 'Oswald', sans-serif;
      font-size: 1.4rem;
      font-weight: 400;
      letter-spacing: 0.04em;
      color: var(--cream);
      line-height: 1.3;
    }
    .rm-quote .red { color: var(--red); }

    /* Barber cards */
    .barber-list {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .barber-card {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.25rem 2.5rem;
      border-bottom: 1px solid rgba(245,242,236,0.05);
    }
    .bc-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: rgba(245,242,236,0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Oswald', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--red);
      flex-shrink: 0;
    }
    .bc-info { flex: 1; }
    .bc-name {
      font-family: 'Oswald', sans-serif;
      font-size: 0.95rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      color: var(--cream);
    }
    .bc-spec {
      font-size: 0.62rem;
      font-weight: 300;
      color: rgba(245,242,236,0.35);
      margin-top: 0.15rem;
    }
    .bc-free {
      font-size: 0.52rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.2rem 0.55rem;
      border-radius: 100px;
    }
    .free-yes { background: rgba(100,180,100,0.15); color: #6dc46d; }
    .free-no { background: rgba(204,41,54,0.15); color: #e07a7a; }

    /* Hours block */
    .hours-block {
      padding: 1.5rem 2.5rem;
      background: rgba(204,41,54,0.08);
      border-top: 1px solid rgba(204,41,54,0.2);
    }
    .hb-label {
      font-size: 0.5rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(245,242,236,0.2);
      margin-bottom: 0.5rem;
    }
    .hb-hours {
      font-family: 'Oswald', sans-serif;
      font-size: 1rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      color: var(--cream);
      line-height: 1.6;
    }
    .hb-sub {
      font-size: 0.65rem;
      font-weight: 300;
      color: rgba(245,242,236,0.35);
      margin-top: 0.25rem;
    }
    /* === Animations & Micro-interactions === */
    @keyframes barberpole {
      from { background-position: 0 0; }
      to   { background-position: -40px 0; }
    }
    @keyframes freePulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(100,180,100,0.3); }
      50%       { box-shadow: 0 0 0 4px rgba(100,180,100,0); }
    }

    .barber-stripe {
      background-size: 40px 5px;
      animation: barberpole 0.7s linear infinite;
    }

    .free-yes { animation: freePulse 2.5s ease-in-out infinite; }

    .barber-card {
      transition: background 0.2s, transform 0.2s;
      cursor: default;
    }
    .barber-card:hover {
      background: rgba(245,242,236,0.035);
      transform: translateX(4px);
    }
    .bc-name { transition: color 0.2s; }
    .barber-card:hover .bc-name { color: var(--cream); }

    .service-item {
      transition: border-top-color 0.2s, transform 0.15s, box-shadow 0.15s;
      cursor: default;
    }
    .service-item:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(28,43,74,0.1);
    }

    .nav-book {
      position: relative;
      overflow: hidden;
    }
    .nav-book::after {
      content: '';
      position: absolute;
      top: 0; left: -60%;
      width: 40%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transition: left 0.5s;
    }
    .nav-book:hover::after { left: 150%; }


    /* ===== SECTION 2 — CUTS ===== */
    .cuts {
      padding: 6rem 5rem;
      background: var(--dark);
      max-width: 1600px;
      margin: 0 auto;
    }
    .cuts-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 3rem;
      border-bottom: 2px solid var(--red);
      padding-bottom: 1.5rem;
    }
    .cuts-eyebrow {
      font-size: 0.55rem;
      font-weight: 600;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 0.6rem;
    }
    .cuts-title {
      font-family: 'Oswald', sans-serif;
      font-size: clamp(2rem, 3.5vw, 3rem);
      font-weight: 700;
      color: var(--cream);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .cuts-link {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(245,242,236,0.35);
      text-decoration: none;
      border-bottom: 1px solid rgba(245,242,236,0.2);
      padding-bottom: 2px;
      white-space: nowrap;
      transition: color 0.2s;
    }
    .cuts-link:hover { color: var(--red); }

    .cut-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3px;
    }
    .cut-card {
      position: relative;
      overflow: hidden;
    }
    .cut-card img {
      width: 100%;
      height: 420px;
      object-fit: cover;
      display: block;
      transition: transform 0.55s ease;
      filter: grayscale(30%);
    }
    .cut-card:hover img { transform: scale(1.05); filter: grayscale(0%); }
    .cut-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(17,24,32,0.9) 0%, transparent 55%);
    }
    .cut-info {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 1.75rem 2rem;
    }
    .cut-name {
      font-family: 'Oswald', sans-serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--cream);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .cut-price {
      font-size: 0.88rem;
      font-weight: 700;
      color: var(--red);
      margin-top: 0.3rem;
    }

    /* ===== SECTION 3 — SHOP ===== */
    .shop-vibe {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 540px;
      max-width: 1600px;
      margin: 0 auto;
    }
    .shop-photo {
      position: relative;
      overflow: hidden;
    }
    .shop-photo img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: grayscale(20%);
    }
    .shop-text {
      background: var(--navy);
      padding: 5rem 4rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.75rem;
    }
    .shop-eyebrow {
      font-size: 0.55rem;
      font-weight: 600;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--red);
    }
    .shop-title {
      font-family: 'Oswald', sans-serif;
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      font-weight: 700;
      color: var(--cream);
      text-transform: uppercase;
      line-height: 1.1;
    }
    .shop-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.9;
      color: rgba(245,242,236,0.55);
      max-width: 44ch;
    }
    .shop-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--dark);
      background: var(--cream);
      padding: 0.9rem 2rem;
      text-decoration: none;
      align-self: flex-start;
      transition: background 0.2s;
    }
    .shop-cta:hover { background: var(--red); color: var(--cream); }

    @media (max-width: 1024px) {
      .cut-grid { grid-template-columns: 1fr 1fr; }
      .cut-card:last-child { grid-column: 1 / -1; }
      .cut-card:last-child img { height: 280px; }
      .shop-vibe { grid-template-columns: 1fr; }
      .shop-photo { height: 380px; position: relative; }
      .shop-photo img { position: absolute; }
    }
    @media (max-width: 768px) {
      .cuts { padding: 4rem 2rem; }
      .cut-grid { grid-template-columns: 1fr; }
      .cut-card:last-child { grid-column: auto; }
      .cut-card img, .cut-card:last-child img { height: 300px; }
      .shop-text { padding: 3.5rem 2rem; }
    }
  </style>
</head>
<body>
  <div class="barber-stripe"></div>

  <nav>
    <div class="nav-inner">
      <div class="nav-logo">Klinge <span>&</span> Kamm</div>
      <ul class="nav-links">
        <li><a href="#">Leistungen</a></li>
        <li><a href="#">Team</a></li>
        <li><a href="#">Produkte</a></li>
        <li><a href="#">Kontakt</a></li>
      </ul>
      <a href="#" class="nav-book">Termin buchen</a>
    </div>
  </nav>

  <div class="hero-wrap">
  <section class="hero">
    <div class="hero-left">
      <div class="eyebrow">
        <span class="eyebrow-bar"></span>
        Barbershop · Trier
      </div>

      <h1 class="hero-headline">
        Scharf.<br>
        Gepflegt.<br>
        <span class="red">Männlich.</span>
      </h1>

      <p class="hero-body">
        Kein Schnick-Schnack. Nur ein guter Schnitt,
        eine saubere Rasur und ein Barbier, der weiß
        was er tut. Seit 2017 in der Trierer Innenstadt.
      </p>

      <div class="service-grid">
        <div class="service-item">
          <span class="si-name">Haarschnitt</span>
          <span class="si-price">28 €</span>
        </div>
        <div class="service-item">
          <span class="si-name">Rasur</span>
          <span class="si-price">32 €</span>
        </div>
        <div class="service-item">
          <span class="si-name">Bart Trim</span>
          <span class="si-price">18 €</span>
        </div>
        <div class="service-item">
          <span class="si-name">Kombi</span>
          <span class="si-price">50 €</span>
        </div>
      </div>

      <div class="cta-row">
        <a href="#" class="cta-btn">Termin buchen →</a>
        <a href="#" class="cta-link">Alle Leistungen</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="right-masthead">
        <div class="rm-label">Das Motto</div>
        <div class="rm-quote">
          „Komm rein als<br>
          Mann, geh raus als<br>
          <span class="red">Gentleman."</span>
        </div>
      </div>

      <div class="barber-list">
        <div class="barber-card">
          <div class="bc-avatar">MK</div>
          <div class="bc-info">
            <div class="bc-name">Marco Kessler</div>
            <div class="bc-spec">Inhaber · Rasur & klassische Schnitte</div>
          </div>
          <span class="bc-free free-yes">Frei</span>
        </div>
        <div class="barber-card">
          <div class="bc-avatar">AL</div>
          <div class="bc-info">
            <div class="bc-name">Artur Levi</div>
            <div class="bc-spec">Fade & Textured Cuts</div>
          </div>
          <span class="bc-free free-no">Belegt</span>
        </div>
        <div class="barber-card">
          <div class="bc-avatar">FS</div>
          <div class="bc-info">
            <div class="bc-name">Florian Schulz</div>
            <div class="bc-spec">Bartpflege & Skin Fades</div>
          </div>
          <span class="bc-free free-yes">Frei</span>
        </div>
      </div>

      <div class="hours-block">
        <div class="hb-label">Öffnungszeiten</div>
        <div class="hb-hours">Di – Fr: 9:00 – 19:00<br>Sa: 9:00 – 16:00</div>
        <div class="hb-sub">Termine bevorzugt · Walk-ins willkommen</div>
      </div>
    </div>
  </section>
  </div>

  <!-- ===== SECTION 2: CUTS ===== -->
  <section class="cuts">
    <div class="cuts-head">
      <div>
        <div class="cuts-eyebrow">Unser Handwerk</div>
        <h2 class="cuts-title">KLASSIKER & FADES</h2>
      </div>
      <a href="#" class="cuts-link">Alle Leistungen →</a>
    </div>
    <div class="cut-grid">
      <div class="cut-card">
        <img src="https://images.unsplash.com/photo-1503951914875-452162b0f3f1?auto=format&fit=crop&w=800&h=700&q=80"
             alt="Klassischer Herrenhaarschnitt" loading="lazy" />
        <div class="cut-overlay"></div>
        <div class="cut-info">
          <div class="cut-name">Classic Cut</div>
          <div class="cut-price">ab 22 €</div>
        </div>
      </div>
      <div class="cut-card">
        <img src="https://images.unsplash.com/photo-1622286342621-4bd786c2447c?auto=format&fit=crop&w=800&h=700&q=80"
             alt="Skin Fade Haarschnitt" loading="lazy" />
        <div class="cut-overlay"></div>
        <div class="cut-info">
          <div class="cut-name">Skin Fade</div>
          <div class="cut-price">ab 28 €</div>
        </div>
      </div>
      <div class="cut-card">
        <img src="https://images.unsplash.com/photo-1621605815971-fbc98d665033?auto=format&fit=crop&w=800&h=700&q=80"
             alt="Rasur und Bartpflege" loading="lazy" />
        <div class="cut-overlay"></div>
        <div class="cut-info">
          <div class="cut-name">Rasur & Bart</div>
          <div class="cut-price">ab 18 €</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 3: SHOP VIBES ===== -->
  <section class="shop-vibe">
    <div class="shop-photo">
      <img src="https://images.unsplash.com/photo-1585747860715-2ba37e788b70?auto=format&fit=crop&w=900&h=700&q=80"
           alt="Barbershop Interieur mit Stuhl und Spiegel" loading="lazy" />
    </div>
    <div class="shop-text">
      <div class="shop-eyebrow">Der Laden</div>
      <h2 class="shop-title">KEIN SALON.<br>EIN SHOP.</h2>
      <p class="shop-body">
        Klinge & Kamm ist kein Friseursalon mit
        Zeitschriften und Wartemusik. Hier riecht es nach
        Rasiercreme, hier läuft Blues, und hier sagt
        man dir ehrlich, was zum Gesicht passt.
      </p>
      <p class="shop-body">
        Termine online oder einfach reinkommen —
        Walk-ins sind immer willkommen,
        solange der Stuhl frei ist.
      </p>
      <a href="#" class="shop-cta">Termin buchen →</a>
    </div>
  </section>

</body>
</html>
