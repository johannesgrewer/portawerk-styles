---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Presswerk — Risodruck & Buchbinderei | Trier-Nord</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }

    :root {
      --paper: #F2E8D5;
      --navy: #1A2744;
      --red: #C4392D;
      --ink-faint: rgba(26,39,68,0.08);
    }

    body {
      overflow-x: hidden;
      background: var(--paper);
      color: var(--navy);
      font-family: 'Libre Baskerville', Georgia, serif;
      min-height: 100vh;
    }

    /* Paper grain */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 200px 200px;
      pointer-events: none;
      z-index: 0;
      mix-blend-mode: multiply;
    }

    /* Aged edge burn */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse at 0% 0%, rgba(100,70,20,0.12) 0%, transparent 50%),
        radial-gradient(ellipse at 100% 100%, rgba(100,70,20,0.1) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, transparent 60%, rgba(100,70,20,0.06) 100%);
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 3.5rem;
      border-bottom: 2px solid var(--navy);
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: 1.1rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--navy);
    }
    .nav-logo span { color: var(--red); }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Libre Baskerville', serif;
      font-size: 0.65rem;
      font-style: italic;
      color: rgba(26,39,68,0.6);
      text-decoration: none;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: var(--red); }

    .hero {
      min-height: 100vh;
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      padding: 6rem 3.5rem 3.5rem;
    }

    /* Registration marks (riso style) */
    .reg-mark {
      position: absolute;
      width: 20px;
      height: 20px;
    }
    .reg-mark::before, .reg-mark::after {
      content: '';
      position: absolute;
      background: var(--navy);
      opacity: 0.2;
    }
    .reg-mark::before { width: 1px; height: 100%; left: 50%; }
    .reg-mark::after { width: 100%; height: 1px; top: 50%; }
    .reg-mark.tl { top: 2rem; left: 2rem; }
    .reg-mark.tr { top: 2rem; right: 2rem; }
    .reg-mark.bl { bottom: 2rem; left: 2rem; }
    .reg-mark.br { bottom: 2rem; right: 2rem; }

    /* Issue number + date band */
    .issue-band {
      display: flex;
      align-items: center;
      gap: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--navy);
      margin-bottom: 3rem;
    }
    .issue-num {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: 0.65rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--red);
    }
    .issue-line {
      flex: 1;
      height: 1px;
      background: var(--navy);
      opacity: 0.15;
    }
    .issue-date {
      font-size: 0.6rem;
      letter-spacing: 0.16em;
      color: rgba(26,39,68,0.45);
      font-style: italic;
    }

    /* Main headline area */
    .headline-area {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 4rem;
      align-items: start;
      flex: 1;
    }

    .headline-main {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    /* Riso color ghost effect */
    .headline-ghost {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: clamp(4rem, 10vw, 9rem);
      line-height: 0.85;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      color: transparent;
      -webkit-text-stroke: 1px rgba(196,57,45,0.18);
      position: absolute;
      top: 0;
      left: 3px;
      pointer-events: none;
    }
    .headline-wrap {
      position: relative;
    }
    .headline-text {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: clamp(4rem, 10vw, 9rem);
      line-height: 0.85;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      color: var(--navy);
      position: relative;
    }
    .headline-text .accent { color: var(--red); }

    .sub-copy {
      font-size: 0.9rem;
      font-style: italic;
      line-height: 1.75;
      color: rgba(26,39,68,0.65);
      max-width: 38ch;
      border-left: 3px solid var(--red);
      padding-left: 1.25rem;
    }

    /* Right column */
    .side-col {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      padding-top: 0.5rem;
    }

    .stamp-box {
      border: 2px solid var(--navy);
      padding: 1.5rem;
      text-align: center;
      position: relative;
    }
    .stamp-box::before {
      content: '';
      position: absolute;
      inset: 3px;
      border: 1px solid var(--navy);
      opacity: 0.3;
    }
    .stamp-title {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 0.75rem;
    }
    .stamp-name {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: 1.8rem;
      color: var(--navy);
      line-height: 1;
      margin-bottom: 0.5rem;
    }
    .stamp-sub {
      font-size: 0.6rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(26,39,68,0.45);
    }

    .info-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .info-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      border-bottom: 1px dashed rgba(26,39,68,0.2);
      padding-bottom: 0.6rem;
      font-size: 0.7rem;
    }
    .info-key {
      font-style: italic;
      color: rgba(26,39,68,0.5);
    }
    .info-val {
      font-weight: 700;
      color: var(--navy);
    }

    .cta-btn {
      display: block;
      text-align: center;
      background: var(--navy);
      color: var(--paper);
      text-decoration: none;
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-style: italic;
      font-size: 0.85rem;
      padding: 1rem;
      letter-spacing: 0.04em;
      transition: background 0.3s;
    }
    .cta-btn:hover { background: var(--red); }

    /* Bottom colophon */
    .colophon {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 2rem;
      border-top: 2px solid var(--navy);
      margin-top: 3rem;
    }
    .colophon-text {
      font-size: 0.55rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(26,39,68,0.4);
      font-style: italic;
    }
    .colophon-riso {
      display: flex;
      gap: 0.4rem;
    }
    .riso-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      opacity: 0.6;
    }

    /* Photo container */
    .ph { position: relative; overflow: hidden; }
    .ph img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
    .ph:hover img { transform: scale(1.05); }

    /* Produkte section */
    .section-produkte {
      padding: 6rem 3.5rem;
      background: var(--paper);
      position: relative;
      z-index: 1;
      max-width: 1600px;
      margin: 0 auto;
    }
    .prod-issue {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 0.5rem;
    }
    .prod-heading {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: clamp(2rem, 4vw, 3.5rem);
      text-transform: uppercase;
      line-height: 0.9;
      letter-spacing: -0.02em;
      color: var(--navy);
      margin-bottom: 3.5rem;
    }
    .prod-heading .accent { color: var(--red); }

    .produkte-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
    }
    .prod-card {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .prod-photo {
      border: 6px solid #E8DCC8;
      box-shadow: 0 2px 12px rgba(26,39,68,0.1);
    }
    .prod-card-title {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--navy);
    }
    .prod-card-desc {
      font-size: 0.72rem;
      font-style: italic;
      line-height: 1.7;
      color: rgba(26,39,68,0.6);
    }
    .prod-card-price {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--red);
    }

    /* Prozess section */
    .section-prozess {
      padding: 6rem 3.5rem;
      background: var(--navy);
      position: relative;
      z-index: 1;
      max-width: 1600px;
      margin: 0 auto;
    }
    .prozess-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
    }
    .prozess-text {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .prozess-heading {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: clamp(2rem, 3.5vw, 3rem);
      text-transform: uppercase;
      line-height: 0.9;
      letter-spacing: -0.02em;
      color: var(--paper);
    }
    .prozess-heading .accent { color: #F5C842; }
    .prozess-steps {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .pstep {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      border-bottom: 1px dashed rgba(242,232,213,0.12);
      padding-bottom: 1rem;
    }
    .pstep-num {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: 0.7rem;
      color: #F5C842;
      flex-shrink: 0;
      margin-top: 0.1rem;
    }
    .pstep-title {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-size: 0.88rem;
      color: var(--paper);
      margin-bottom: 0.2rem;
    }
    .pstep-desc {
      font-size: 0.65rem;
      font-style: italic;
      color: rgba(242,232,213,0.5);
      line-height: 1.6;
    }
    .prozess-cta {
      display: inline-block;
      background: #F5C842;
      color: var(--navy);
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-style: italic;
      font-size: 0.85rem;
      padding: 0.9rem 2rem;
      text-decoration: none;
      transition: background 0.3s;
    }
    .prozess-cta:hover { background: var(--paper); }
  </style>
</head>
<body>
  <nav>
    <div class="nav-logo">Press<span>werk</span></div>
    <ul class="nav-links">
      <li><a href="#">Risodruck</a></li>
      <li><a href="#">Buchbinderei</a></li>
      <li><a href="#">Auflagen</a></li>
      <li><a href="#">Kontakt</a></li>
    </ul>
  </nav>

  <section class="hero">
    <div class="reg-mark tl"></div>
    <div class="reg-mark tr"></div>
    <div class="reg-mark bl"></div>
    <div class="reg-mark br"></div>

    <div class="issue-band">
      <div class="issue-num">Ausgabe No. 001 — Trier-Nord</div>
      <div class="issue-line"></div>
      <div class="issue-date">Seit 1987 im Druck</div>
    </div>

    <div class="headline-area">
      <div class="headline-main">
        <div class="headline-wrap">
          <div class="headline-ghost">Druck<br>sachen</div>
          <h1 class="headline-text">
            Druck<br>
            <span class="accent">sachen.</span>
          </h1>
        </div>

        <p class="sub-copy">
          Risografiedruck, Buchdruck, Letterpress. Wir drucken, was bleibt —
          auf Papier, das man spürt. Kleine Auflagen, große Wirkung.
          Gedruckt. Handgemacht. Echt.
        </p>
      </div>

      <div class="side-col">
        <div class="stamp-box">
          <div class="stamp-title">Druckerei</div>
          <div class="stamp-name">Presswerk</div>
          <div class="stamp-sub">Trier-Nord · Est. 1987</div>
        </div>

        <div class="info-list">
          <div class="info-row">
            <span class="info-key">Verfahren</span>
            <span class="info-val">Risodruck</span>
          </div>
          <div class="info-row">
            <span class="info-key">Mindestauflage</span>
            <span class="info-val">25 Stück</span>
          </div>
          <div class="info-row">
            <span class="info-key">Papier</span>
            <span class="info-val">Recycling & Munken</span>
          </div>
          <div class="info-row">
            <span class="info-key">Lieferzeit</span>
            <span class="info-val">7–14 Werktage</span>
          </div>
        </div>

        <a href="#" class="cta-btn">Druckauftrag anfragen</a>
      </div>
    </div>

    <div class="colophon">
      <span class="colophon-text">Presswerk GmbH · Trier-Nord · Risodruck & Buchbinderei seit 1987</span>
      <div class="colophon-riso">
        <div class="riso-dot" style="background:#C4392D"></div>
        <div class="riso-dot" style="background:#1A2744"></div>
        <div class="riso-dot" style="background:#F5C842"></div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Produkte -->
  <div style="background:var(--paper); position:relative; z-index:1;">
    <section class="section-produkte">
      <div class="prod-issue">Drucksachen No. 002</div>
      <h2 class="prod-heading">Was wir<br><span class="accent">drucken.</span></h2>
      <div class="produkte-grid">
        <div class="prod-card">
          <div class="ph prod-photo" style="height:280px;">
            <img src="https://images.unsplash.com/photo-1481627834876-b7833e8f5570?auto=format&fit=crop&w=800&h=700&q=80" alt="Risodruck Poster" loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,39,68,0.4) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
          <div class="prod-card-title">Riso-Poster</div>
          <div class="prod-card-desc">Zweifarbiger Risografiedruck auf 120 g Recyclingpapier. Jede Auflage ein kleines Unikat — charakteristische Körnung inklusive.</div>
          <div class="prod-card-price">ab 45 € — 25 Stück</div>
        </div>
        <div class="prod-card">
          <div class="ph prod-photo" style="height:280px;">
            <img src="https://images.unsplash.com/photo-1506277886164-e25aa3f4ef7f?auto=format&fit=crop&w=800&h=700&q=80" alt="Zine Buchbinderei" loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,39,68,0.4) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
          <div class="prod-card-title">Zines & Hefte</div>
          <div class="prod-card-desc">Selbst verlegte Publikationen, Kataloge und Magazine. Risodruck mit handgebundener Fadenheftung oder Klammerheftung.</div>
          <div class="prod-card-price">ab 80 € — 25 Stück</div>
        </div>
        <div class="prod-card">
          <div class="ph prod-photo" style="height:280px;">
            <img src="https://images.unsplash.com/photo-1464349095431-e9a21285b5f3?auto=format&fit=crop&w=800&h=700&q=80" alt="Visitenkarten Letterpress" loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,39,68,0.4) 0%,transparent 60%);pointer-events:none;"></div>
          </div>
          <div class="prod-card-title">Karten & Einladungen</div>
          <div class="prod-card-desc">Visitenkarten, Hochzeitseinladungen, Event-Flyer. Letterpress auf Karton, spürbar geprägt, unvergesslich.</div>
          <div class="prod-card-price">ab 60 € — 50 Stück</div>
        </div>
      </div>
    </section>
  </div>

  <!-- SECTION 3: Prozess & Kontakt -->
  <div style="background:var(--navy); position:relative; z-index:1;">
    <section class="section-prozess">
      <div class="prozess-inner">
        <div class="prozess-text">
          <div style="font-family:'Playfair Display',serif;font-weight:900;font-size:0.6rem;letter-spacing:0.22em;text-transform:uppercase;color:#F5C842;">Druckauftrag</div>
          <h2 class="prozess-heading">So läuft's<br><span class="accent">ab.</span></h2>
          <div class="prozess-steps">
            <div class="pstep">
              <div class="pstep-num">01</div>
              <div>
                <div class="pstep-title">Datei oder Konzept einreichen</div>
                <div class="pstep-desc">Druckfertige PDF, Illustrator-Datei oder Entwurf — wir beraten auch ohne fertige Vorlage.</div>
              </div>
            </div>
            <div class="pstep">
              <div class="pstep-num">02</div>
              <div>
                <div class="pstep-title">Angebot & Andruckproof</div>
                <div class="pstep-desc">Wir schicken ein verbindliches Angebot plus einen Andruck zum Freigeben. Kein Druck ohne dein OK.</div>
              </div>
            </div>
            <div class="pstep">
              <div class="pstep-num">03</div>
              <div>
                <div class="pstep-title">Druck & Lieferung</div>
                <div class="pstep-desc">7–14 Werktage Produktionszeit. Abholung in Trier-Nord oder Versand deutschlandweit.</div>
              </div>
            </div>
          </div>
          <a href="#" class="prozess-cta">Druckauftrag anfragen →</a>
        </div>
        <div class="ph" style="height:500px; border: 8px solid rgba(242,232,213,0.08);">
          <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=800&h=1000&q=80" alt="Druckwerkstatt" loading="lazy" />
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,39,68,0.5) 0%,transparent 60%);pointer-events:none;"></div>
        </div>
      </div>
    </section>
  </div>

</body>
</html>
