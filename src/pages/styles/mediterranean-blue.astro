          />
          <div class="ph-overlay" style="background: linear-gradient(to top, rgba(13,63,110,0.4) 0%, transparent 55%);"></div>
        </div>
        <div class="ph" style="height: 200px; border-radius: 2px;">
          <img
            src="https://images.unsplash.com/photo-1559925393-8be0ec4767c8?auto=format&fit=crop&w=1000&h=600&q=80"
