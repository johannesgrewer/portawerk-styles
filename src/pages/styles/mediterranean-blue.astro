    <div class="hero-content">
      <div class="hero-left">
        <div class="hero-eyebrow">Boutique Hotel & Restaurant · Trier</div>
        <h1 class="hero-headline">
          Das Mittelmeer<br>
          <em>direkt vor Ihrer Tür.</em>
        </h1>
        <div class="hero-rule"></div>
        <p class="hero-tagline">
          Mediterranes Lebensgefühl im Herzen Triers —
          Azurblau, Weißkalk und der Duft nach Thymian
          und warmem Stein.
        </p>
        <div class="hero-cta-group">
          <a href="#" class="btn-primary">Suite reservieren →</a>
          <a href="#" class="btn-ghost">Restaurant entdecken</a>
        </div>
      </div>

      <div class="hero-right">
        <div class="hero-badges">
          <div class="hb-item">
            <strong>18</strong>
            Exklusive Suiten
          </div>
          <div class="hb-item">
            <strong>3★</strong>
            Sterne Küche
