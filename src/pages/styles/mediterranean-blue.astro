        <div class="menu-list">
          <div class="menu-item">
            <div>
              <div class="mi-name">Lubina a la sal</div>
              <div class="mi-desc">Wolfsbarsch im Salzteig, Salsa verde, Fenchel</div>
            </div>
            <div class="mi-price">38 €</div>
          </div>
          <div class="menu-item">
            <div>
              <div class="mi-name">Pulpo a la brasa</div>
              <div class="mi-desc">Gegrillter Oktopus, Paprika-Öl, Kartoffelstampf</div>
            </div>
            <div class="mi-price">29 €</div>
          </div>
          <div class="menu-item">
            <div>
              <div class="mi-name">Arròs negre</div>
