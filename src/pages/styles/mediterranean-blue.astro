---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Casa Azul — Boutique Hotel & Restaurant | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    :root {
      --azure:      #1A6FAB;
      --azure-deep: #0D3F6E;
      --terra:      #C4714A;
      --terra-lt:   #E8A07E;
      --sand:       #F5EFE6;
      --limestone:  #FAF7F2;
      --white:      #FFFFFF;
      --ink:        #1A1510;
      --ink-50:     rgba(26,21,16,0.5);
      --ink-25:     rgba(26,21,16,0.25);
      --ink-10:     rgba(26,21,16,0.1);
      --sea-tint:   rgba(26,111,171,0.08);
    }

    body {
      background: var(--limestone);
      color: var(--ink);
      font-family: 'Jost', sans-serif;
      overflow-x: hidden;
    }

    /* ─── Grain texture overlay ─── */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 999;
      opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-size: 160px 160px;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 3.5rem;
      mix-blend-mode: normal;
    }
    nav.scrolled {
      background: rgba(250,247,242,0.96);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--ink-10);
      padding: 1rem 3.5rem;
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-size: 1.25rem;
      letter-spacing: 0.03em;
      color: var(--white);
      text-decoration: none;
      transition: color 0.3s;
    }
    nav.scrolled .nav-logo { color: var(--azure-deep); }
    .nav-logo span {
      display: block;
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      font-size: 0.5rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      opacity: 0.65;
      margin-top: -2px;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.6rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.75);
      text-decoration: none;
      transition: color 0.2s;
    }
    nav.scrolled .nav-links a { color: var(--ink-50); }
    .nav-links a:hover { color: var(--white); }
    nav.scrolled .nav-links a:hover { color: var(--azure); }
    .nav-book {
      font-size: 0.57rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--white);
      border: 1px solid rgba(255,255,255,0.5);
      padding: 0.6rem 1.4rem;
      text-decoration: none;
      transition: all 0.25s;
    }
    .nav-book:hover {
      background: var(--white);
      color: var(--azure-deep);
      border-color: var(--white);
    }
    nav.scrolled .nav-book {
      color: var(--azure);
      border-color: var(--azure);
    }
    nav.scrolled .nav-book:hover {
      background: var(--azure);
      color: var(--white);
    }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      height: 100vh;
      min-height: 700px;
      display: flex;
      align-items: flex-end;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }
    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
      transform: scale(1.04);
      transition: transform 8s ease-out;
    }
    .hero-bg img.loaded { transform: scale(1); }
    /* Gradient: bottom heavy for text legibility */
    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to top, rgba(10,28,55,0.78) 0%, rgba(10,28,55,0.35) 45%, transparent 70%),
        linear-gradient(to bottom, rgba(0,0,0,0.25) 0%, transparent 30%);
    }

    .hero-content {
      position: relative;
      z-index: 2;
      width: 100%;
      padding: 0 3.5rem 5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: flex-end;
    }

    .hero-left {}
    .hero-eyebrow {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--terra-lt);
      margin-bottom: 1.25rem;
    }
    .hero-eyebrow::before {
      content: '';
      width: 2rem;
      height: 1px;
      background: var(--terra-lt);
    }
    .hero-headline {
      font-family: 'Playfair Display', serif;
      font-weight: 900;
      font-size: clamp(3.5rem, 6vw, 6rem);
      line-height: 1.0;
      color: var(--white);
      letter-spacing: -0.01em;
    }
    .hero-headline em {
      display: block;
      font-style: italic;
      font-weight: 400;
      color: rgba(255,255,255,0.7);
      font-size: 0.75em;
      line-height: 1.3;
      margin-top: 0.1em;
    }
    .hero-rule {
      width: 3.5rem;
      height: 2px;
      background: linear-gradient(90deg, var(--terra), var(--terra-lt));
      margin: 2rem 0;
    }
    .hero-tagline {
      font-size: 0.82rem;
      font-weight: 300;
      line-height: 1.85;
      color: rgba(255,255,255,0.6);
      max-width: 36ch;
    }

    .hero-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 2rem;
      padding-bottom: 0.5rem;
    }
    .hero-badges {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.5rem;
    }
    .hb-item {
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      border-right: 2px solid rgba(255,255,255,0.15);
      padding-right: 1rem;
    }
    .hb-item strong {
      display: block;
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: 0;
      color: var(--white);
      line-height: 1;
      margin-bottom: 0.1rem;
    }
    .hero-cta-group {
      display: flex;
      gap: 1rem;
      align-items: center;
    }
    .btn-primary {
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--white);
      background: var(--terra);
      padding: 0.85rem 2rem;
      text-decoration: none;
      transition: background 0.25s;
      position: relative;
      overflow: hidden;
    }
    .btn-primary::after {
      content: '';
      position: absolute;
      top: 0; left: -60%;
      width: 40%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transition: left 0.5s;
    }
    .btn-primary:hover { background: #b05e3a; }
    .btn-primary:hover::after { left: 150%; }
    .btn-ghost {
      font-family: 'Playfair Display', serif;
      font-size: 0.88rem;
      font-style: italic;
      color: rgba(255,255,255,0.55);
      text-decoration: none;
      border-bottom: 1px solid rgba(255,255,255,0.2);
      padding-bottom: 2px;
      transition: color 0.2s, border-color 0.2s;
    }
    .btn-ghost:hover { color: rgba(255,255,255,0.9); border-color: rgba(255,255,255,0.5); }

    /* Scroll indicator */
    .hero-scroll {
      position: absolute;
      bottom: 2.5rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 3;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .scroll-line {
      width: 1px;
      height: 3rem;
      background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
      animation: scrollPulse 2s ease-in-out infinite;
    }
    @keyframes scrollPulse {
      0%, 100% { opacity: 0.4; transform: scaleY(1); }
      50% { opacity: 1; transform: scaleY(1.1); }
    }
    .scroll-label {
      font-size: 0.48rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      writing-mode: vertical-rl;
      margin-top: 0.25rem;
    }

    /* ─── INTRO / PHILOSOPHY ─── */
    .intro-section {
      background: var(--limestone);
      padding: 7rem 3.5rem;
    }
    .intro-inner {
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 6rem;
      align-items: start;
    }
    .intro-label {
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--terra);
      padding-top: 0.5rem;
    }
    .intro-label::before {
      content: '';
      display: block;
      width: 2rem;
      height: 1px;
      background: var(--terra);
      margin-bottom: 0.75rem;
    }
    .intro-text {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }
    .intro-headline {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 3.5vw, 3.5rem);
      font-weight: 700;
      line-height: 1.15;
      color: var(--ink);
      letter-spacing: -0.01em;
    }
    .intro-headline em {
      font-style: italic;
      font-weight: 400;
      color: var(--azure);
    }
    .intro-body-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem 3rem;
    }
    .intro-body {
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 1.95;
      color: var(--ink-50);
    }
    .intro-numbers {
      display: flex;
      gap: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--ink-10);
    }
    .in-item {}
    .in-value {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--azure);
      line-height: 1;
    }
    .in-label {
      font-size: 0.58rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-50);
      margin-top: 0.3rem;
    }

    /* Photo helper */
    .ph {
      position: relative;
      overflow: hidden;
      flex-shrink: 0;
    }
    .ph img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.65s ease;
    }
    .ph:hover img { transform: scale(1.06); }
    .ph-overlay {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    /* ─── SUITES SECTION ─── */
    .suites-section {
      background: var(--sand);
      padding: 7rem 3.5rem;
    }
    .suites-inner {
      max-width: 1400px;
      margin: 0 auto;
    }
    .section-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 3.5rem;
    }
    .sh-left {}
    .sh-eyebrow {
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--terra);
      margin-bottom: 0.65rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .sh-eyebrow::before {
      content: '';
      width: 1.5rem;
      height: 1px;
      background: var(--terra);
    }
    .sh-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3vw, 3rem);
      font-weight: 700;
      line-height: 1.15;
      color: var(--ink);
      letter-spacing: -0.01em;
    }
    .sh-title em {
      font-style: italic;
      font-weight: 400;
      color: var(--azure);
    }
    .sh-link {
      font-size: 0.58rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-50);
      text-decoration: none;
      border-bottom: 1px solid var(--ink-25);
      padding-bottom: 2px;
      transition: color 0.2s;
      margin-bottom: 0.4rem;
    }
    .sh-link:hover { color: var(--azure); border-color: var(--azure); }

    .suites-grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 1.25rem;
    }
    .suite-card {}
    .suite-photo {
      border-radius: 2px;
    }
    .suite-info {
      padding: 1.25rem 0 0;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }
    .si-left {}
    .si-cat {
      font-size: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--terra);
      margin-bottom: 0.3rem;
    }
    .si-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--ink);
    }
    .si-desc {
      font-size: 0.75rem;
      font-weight: 300;
      color: var(--ink-50);
      margin-top: 0.25rem;
      line-height: 1.6;
    }
    .si-price {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      font-weight: 400;
      color: var(--azure);
      white-space: nowrap;
    }
    .si-price small {
      display: block;
      font-family: 'Jost', sans-serif;
      font-size: 0.48rem;
      font-weight: 300;
      letter-spacing: 0.15em;
      color: var(--ink-50);
      text-align: right;
      margin-top: 0.1rem;
    }

    /* ─── RESTAURANT ─── */
    .restaurant-section {
      background: var(--azure-deep);
      padding: 7rem 0;
      overflow: hidden;
    }
    .restaurant-inner {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 3.5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .rest-text {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }
    .rest-eyebrow {
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--terra-lt);
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .rest-eyebrow::before {
      content: '';
      width: 1.5rem;
      height: 1px;
      background: var(--terra-lt);
    }
    .rest-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.2rem, 3.5vw, 3.5rem);
      font-weight: 700;
      line-height: 1.1;
      color: var(--white);
      letter-spacing: -0.01em;
    }
    .rest-title em {
      font-style: italic;
      font-weight: 400;
      color: rgba(255,255,255,0.55);
    }
    .rest-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.95;
      color: rgba(255,255,255,0.5);
      max-width: 44ch;
    }

    /* Menu items */
    .menu-list {
      display: flex;
      flex-direction: column;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .menu-item {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 1rem;
      padding: 1.1rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      transition: padding-left 0.25s;
      cursor: default;
    }
    .menu-item:hover { padding-left: 0.75rem; }
    .mi-name {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--white);
      transition: color 0.2s;
    }
    .menu-item:hover .mi-name { color: var(--terra-lt); }
    .mi-desc {
      font-size: 0.65rem;
      font-weight: 300;
      color: rgba(255,255,255,0.35);
      font-style: italic;
      margin-top: 0.1rem;
    }
    .mi-price {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 400;
      color: var(--terra-lt);
    }

    .rest-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.6rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--azure-deep);
      background: var(--white);
      padding: 0.85rem 2rem;
      text-decoration: none;
      transition: background 0.25s, color 0.25s;
      width: fit-content;
    }
    .rest-cta:hover { background: var(--terra-lt); color: var(--white); }

    .rest-photos {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    /* ─── EXPERIENCE SECTION ─── */
    .exp-section {
      background: var(--limestone);
      padding: 7rem 3.5rem;
    }
    .exp-inner {
      max-width: 1400px;
      margin: 0 auto;
    }
    .exp-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .exp-photo-mosaic {
      display: grid;
      grid-template-columns: 3fr 2fr;
      grid-template-rows: auto auto;
      gap: 1rem;
    }
    .mosaic-main {
      grid-row: 1 / 3;
    }
    .exp-text {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }
    .exp-eyebrow {
      font-size: 0.55rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--terra);
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .exp-eyebrow::before {
      content: '';
      width: 1.5rem;
      height: 1px;
      background: var(--terra);
    }
    .exp-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 3.5vw, 3.2rem);
      font-weight: 700;
      line-height: 1.15;
      color: var(--ink);
      letter-spacing: -0.01em;
    }
    .exp-title em {
      font-style: italic;
      font-weight: 400;
      color: var(--azure);
    }
    .exp-body {
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.95;
      color: var(--ink-50);
    }
    .features-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .feat-item {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      padding: 1rem 1.25rem;
      background: var(--sea-tint);
      border-left: 2px solid var(--azure);
      transition: background 0.2s;
      cursor: default;
    }
    .feat-item:hover { background: rgba(26,111,171,0.14); }
    .feat-icon {
      font-size: 1.1rem;
      flex-shrink: 0;
      line-height: 1.6;
    }
    .feat-content {}
    .feat-title {
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--ink);
    }
    .feat-desc {
      font-size: 0.72rem;
      font-weight: 300;
      color: var(--ink-50);
      margin-top: 0.15rem;
      line-height: 1.5;
    }
    .exp-info-strip {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--ink-10);
    }
    .eis-item {}
    .eis-label {
      font-size: 0.48rem;
      font-weight: 400;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--ink-25);
      margin-bottom: 0.4rem;
    }
    .eis-value {
      font-family: 'Playfair Display', serif;
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.4;
    }
    .eis-value span {
      display: block;
      font-family: 'Jost', sans-serif;
      font-size: 0.7rem;
      font-weight: 300;
      color: var(--ink-50);
      margin-top: 0.1rem;
    }

    /* ─── FOOTER STRIP ─── */
    .footer-strip {
      background: var(--ink);
      padding: 2.5rem 3.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .fs-brand {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-size: 1.05rem;
      color: var(--white);
      letter-spacing: 0.02em;
    }
    .fs-brand span {
      font-weight: 300;
      font-style: italic;
      color: rgba(255,255,255,0.45);
    }
    .fs-meta {
      font-size: 0.6rem;
      font-weight: 300;
      letter-spacing: 0.12em;
      color: rgba(255,255,255,0.3);
    }
    .fs-cta {
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--terra-lt);
      text-decoration: none;
      border-bottom: 1px solid rgba(196,113,74,0.35);
      padding-bottom: 1px;
      transition: color 0.2s;
    }
    .fs-cta:hover { color: var(--white); }

    /* ─── Animations ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-eyebrow { animation: fadeUp 0.7s 0.2s both ease-out; }
    .hero-headline { animation: fadeUp 0.8s 0.4s both ease-out; }
    .hero-rule { animation: fadeUp 0.6s 0.65s both ease-out; }
    .hero-tagline { animation: fadeUp 0.7s 0.8s both ease-out; }
    .hero-cta-group { animation: fadeUp 0.7s 1s both ease-out; }
    .hero-badges { animation: fadeUp 0.7s 0.6s both ease-out; }

    .suite-card {
      transition: transform 0.35s ease;
    }
    .suite-card:hover { transform: translateY(-4px); }

    .nav {
      transition: background 0.3s, padding 0.3s, border-color 0.3s;
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav id="navbar">
