              />
              <div class="ph-overlay" style="background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 55%);"></div>
            </div>
            <div class="ph" style="height: 252px; border-radius: 2px;">
              <img
                src="https://images.unsplash.com/photo-1555881400-74d7acaacd8b?auto=format&fit=crop&w=600&h=600&q=80"
                alt="Weiße Hausfassade mit blauen Details Santorini"
                loading="lazy"
              />
              <div class="ph-overlay" style="background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 55%);"></div>
            </div>
          </div>
        </div>

        <!-- Text -->
        <div class="exp-text">
          <div class="exp-eyebrow">Lage & Erlebnisse</div>
          <h2 class="exp-title">
            Im Herzen von<br>
            Trier —<em>mit Seele<br>des Südens.</em>
          </h2>
          <p class="exp-body">
            Casa Azul liegt im historischen Kern Triers, zwei Gehminuten
            von der Porta Nigra entfernt. Die Stadt ist eine der ältesten
            Deutschlands — und beides, ihr mediterranes Klima und ihre
            römische Geschichte, machen sie zum perfekten Heimat
            für ein Hotel wie dieses.
          </p>

          <div class="features-list">
            <div class="feat-item">
              <span class="feat-icon">🏺</span>
              <div class="feat-content">
                <div class="feat-title">Innenhof mit Brunnen</div>
                <div class="feat-desc">Maurisch inspirierter Patio mit Orangenbäumen und Ziegelbrunnen</div>
              </div>
            </div>
            <div class="feat-item">
              <span class="feat-icon">🌿</span>
              <div class="feat-content">
                <div class="feat-title">Dachterrasse & Bar</div>
                <div class="feat-desc">Abendausklang mit Blick über die Trierer Altstadt und Weinberge</div>
              </div>
            </div>
            <div class="feat-item">
              <span class="feat-icon">🍋</span>
              <div class="feat-content">
                <div class="feat-title">Frühstück al fresco</div>
                <div class="feat-desc">Täglich von 07:30 bis 11:00 im Innenhof — oder aufs Zimmer</div>
              </div>
            </div>
          </div>

          <div class="exp-info-strip">
            <div class="eis-item">
              <div class="eis-label">Check-in / Check-out</div>
              <div class="eis-value">
                15:00 / 11:00
                <span>Früheres/spätes Check-out anfragen</span>
              </div>
            </div>
            <div class="eis-item">
              <div class="eis-label">Adresse</div>
