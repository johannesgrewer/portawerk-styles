---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Pura — Naturkosmetik & Hautpflege | Trier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,300;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; }
    body {
      overflow-x: hidden;
      background: #FBF8F3;
      color: #2A3528;
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 3rem;
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.75rem;
      letter-spacing: 0.04em;
      color: #2A3528;
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #3D5A47;
      text-decoration: none;
      transition: opacity 0.3s;
    }
    .nav-links a:hover { opacity: 0.55; }

    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    /* LEFT */
    .hero-visual {
      background: #EEE8DE;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 6rem 2.5rem 4rem 4rem;
      position: relative;
      overflow: hidden;
    }

    .blob-wrap {
      position: relative;
      width: 420px;
      max-width: 100%;
    }
    .blob-frame {
      width: 100%;
      aspect-ratio: 4/5;
      border-radius: 62% 38% 50% 50% / 52% 58% 42% 48%;
      overflow: hidden;
      animation: morph 10s ease-in-out infinite;
    }
    @keyframes morph {
      0%, 100% { border-radius: 62% 38% 50% 50% / 52% 58% 42% 48%; }
      33%       { border-radius: 45% 55% 62% 38% / 60% 40% 58% 42%; }
      66%       { border-radius: 55% 45% 38% 62% / 42% 60% 40% 58%; }
    }
    .blob-frame img {
      width: 100%; height: 100%;
      object-fit: cover;
      animation: slowZoom 14s ease-in-out infinite alternate;
    }
    @keyframes slowZoom {
      from { transform: scale(1.04); }
      to   { transform: scale(1.10) translate(-1%, -1%); }
    }

    .stamp {
      position: absolute;
      bottom: 14%;
      left: -16px;
      background: #FBF8F3;
      border: 1px solid rgba(196, 149, 106, 0.6);
      padding: 0.5rem 1rem;
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #3D5A47;
      white-space: nowrap;
      opacity: 0;
      animation: slideStamp 0.8s ease 1.2s forwards;
    }
    @keyframes slideStamp {
      from { opacity: 0; transform: translateX(-16px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    /* botanical SVG corner */
    .leaf-deco {
      position: absolute;
      top: 6%;
      right: 6%;
      width: 90px;
      opacity: 0.28;
      animation: sway 7s ease-in-out infinite;
    }
    @keyframes sway {
      0%, 100% { transform: rotate(-6deg); }
      50%       { transform: rotate(4deg) translateY(-4px); }
    }

    /* RIGHT */
    .hero-text {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 7rem 5rem 5rem 4.5rem;
    }

    .eyebrow {
      font-size: 0.68rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #C4956A;
      margin-bottom: 1.8rem;
      opacity: 0;
      animation: up 0.7s ease 0.15s forwards;
    }

    .headline {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3.2rem, 4.5vw, 5.5rem);
      line-height: 1.05;
      color: #2A3528;
      margin-bottom: 1.6rem;
    }
    .headline em {
      font-style: italic;
      color: #3D5A47;
    }
    .headline .ln {
      display: block;
      opacity: 0;
      animation: up 0.7s ease forwards;
    }
    .headline .ln:nth-child(1) { animation-delay: 0.25s; }
    .headline .ln:nth-child(2) { animation-delay: 0.42s; }
    .headline .ln:nth-child(3) { animation-delay: 0.58s; }

    .divider {
      width: 0;
      height: 1px;
      background: linear-gradient(to right, #C4956A, transparent);
      margin: 1.4rem 0;
      animation: grow 0.8s ease 0.9s forwards;
    }
    @keyframes grow { to { width: 56px; } }

    .tagline {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.15rem;
      color: #5A7055;
      margin-bottom: 1.4rem;
      opacity: 0;
      animation: up 0.7s ease 1s forwards;
    }
    .desc {
      font-size: 0.88rem;
      line-height: 1.85;
      color: #4A5A46;
      max-width: 340px;
      margin-bottom: 2.4rem;
      opacity: 0;
      animation: up 0.7s ease 1.1s forwards;
    }
    .cta-row {
      display: flex;
      align-items: center;
      gap: 2rem;
      margin-bottom: 3rem;
      opacity: 0;
      animation: up 0.7s ease 1.25s forwards;
    }
    .btn-main {
      background: #3D5A47;
      color: #FBF8F3;
      border: none;
      padding: 0.85rem 2rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.3s;
    }
    .btn-main:hover { background: #2A3528; }
    .btn-link {
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #C4956A;
      text-decoration: none;
      padding-bottom: 2px;
      border-bottom: 1px solid transparent;
      transition: border-color 0.3s;
    }
    .btn-link:hover { border-color: #C4956A; }

    .badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      opacity: 0;
      animation: up 0.7s ease 1.4s forwards;
    }
    .badge {
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      color: #5A7055;
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }
    .badge::before {
      content: '';
      width: 4px; height: 4px;
      border-radius: 50%;
      background: #C4956A;
      flex-shrink: 0;
    }

    @keyframes up {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <nav>
    <span class="nav-logo">Pura</span>
    <ul class="nav-links">
      <li><a href="#">Pflege</a></li>
      <li><a href="#">Zutaten</a></li>
      <li><a href="#">Über uns</a></li>
      <li><a href="#">Shop</a></li>
    </ul>
  </nav>

  <section class="hero">
    <div class="hero-visual">
      <svg class="leaf-deco" viewBox="0 0 90 140" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M45 135 C45 90 8 72 5 35 C2 5 25 0 45 0 C65 0 88 5 85 35 C82 72 45 90 45 135Z" stroke="#3D5A47" stroke-width="1.2" fill="none"/>
        <path d="M45 120 L22 85 M45 100 L68 68 M45 78 L18 50 M45 56 L72 38" stroke="#3D5A47" stroke-width="0.7" opacity="0.5"/>
      </svg>

      <div class="blob-wrap">
        <div class="blob-frame">
          <img
            src="https://images.unsplash.com/photo-1501004318641-b39e6451bec6?w=900&q=80&auto=format"
            alt="Botanische Pflanzenstoffe für Pura Naturkosmetik"
            loading="eager"
          />
        </div>
        <div class="stamp">Handgefertigt · Trier · Seit 2019</div>
      </div>
    </div>

    <div class="hero-text">
      <p class="eyebrow">Naturkosmetik · Trier</p>

      <h1 class="headline">
        <span class="ln">Was wächst,</span>
        <span class="ln"><em>heilt.</em></span>
      </h1>

      <div class="divider"></div>

      <p class="tagline">Pflege aus dem, was die Natur gibt.</p>

      <p class="desc">
        Pura vereint botanische Wirkstoffe mit handwerklichem Wissen.
        Jedes Produkt entsteht in kleinen Chargen — in Trier,
        mit Zeit und Sorgfalt.
      </p>

      <div class="cta-row">
        <a href="#" class="btn-main">Zur Pflege</a>
        <a href="#" class="btn-link">Unsere Zutaten →</a>
      </div>

      <div class="badges">
        <span class="badge">Rosehip</span>
        <span class="badge">Calendula</span>
        <span class="badge">Arganöl</span>
        <span class="badge">Wildkräuter</span>
        <span class="badge">Ohne Parabene</span>
        <span class="badge">Vegan</span>
      </div>
    </div>
  </section>
</body>
</html>
